<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="MoShang - Real-time OpenClaw Status Dashboard">
    <meta name="theme-color" content="#08080c">
    <title>MoShang Status v29.0</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        /* v23.0: Next-Gen Dashboard - Quantum Glass Design */

        /* ========== CSS Variables ========== */
        :root {
            /* Color System */
            --primary: #ffc864;
            --primary-glow: #ffaa33;
            --primary-dim: rgba(255,200,100,0.3);
            --primary-soft: color-mix(in srgb, var(--primary) 60%, transparent);

            --accent: #00d4ff;
            --accent-glow: #00ffff;
            --accent-dim: rgba(0,212,255,0.3);
            --accent-soft: color-mix(in srgb, var(--accent) 60%, transparent);

            --success: #5cdb95;
            --success-glow: #7fff7f;
            --success-dim: rgba(92,219,149,0.3);
            --success-soft: color-mix(in srgb, var(--success) 60%, transparent);

            --warning: #feca57;
            --warning-glow: #ffcc00;
            --warning-dim: rgba(254,202,87,0.3);

            --danger: #ff6b6b;
            --danger-glow: #ff4444;
            --danger-dim: rgba(255,107,107,0.3);

            --purple: #a855f7;
            --purple-glow: #c084fc;
            --purple-dim: rgba(168,85,247,0.3);

            --pink: #ec4899;
            --pink-glow: #f472b6;
            --pink-dim: rgba(236,72,153,0.3);

            /* Backgrounds */
            --bg-dark: #08080c;
            --bg-dark-elevated: color-mix(in srgb, var(--bg-dark) 95%, var(--primary) 5%);
            --bg-card: rgba(15,15,25,0.88);
            --bg-card-hover: rgba(18,18,28,0.92);
            --bg-glass: rgba(255,255,255,0.025);
            --bg-glass-hover: rgba(255,255,255,0.035);

            /* Text */
            --text: #e8e8ec;
            --text-dim: #5a5a6a;
            --text-bright: #ffffff;
            --text-muted: #8a8a9a;

            /* Spacing & Radius */
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --radius-full: 9999px;

            /* Shadows */
            --shadow-soft: 0 4px 24px rgba(0,0,0,0.3);
            --shadow-medium: 0 8px 32px rgba(0,0,0,0.4);
            --shadow-glow: 0 0 80px -20px;
            --shadow-glow-strong: 0 0 120px -20px;

            /* Gradients */
            --neon-gradient: linear-gradient(135deg, var(--primary), var(--accent));
            --aurora-gradient: linear-gradient(135deg, #ff6b9d, #ffc864, #00d4ff, #5cdb95);
            --cyber-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --glass-shimmer: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0.1) 100%);
            --space-gradient: radial-gradient(ellipse at center, rgba(30,30,60,0.8) 0%, transparent 70%);
            --card-gradient: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);

            /* Animation Timing - Enhanced with spring physics */
            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);
            --ease-in-out-circ: cubic-bezier(0.85, 0, 0.15, 1);
            --spring-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
            --spring-smooth: cubic-bezier(0.43, 0.195, 0.22, 1.3);
            --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);

            /* Transitions */
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
            --transition-bounce: 0.6s var(--spring-bounce);
        }

        /* v24.0: Ambient Floating Orbs Background */
        .ambient-orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.15;
            pointer-events: none;
            z-index: -1;
            animation: orbFloat 20s ease-in-out infinite;
        }

        .ambient-orb-1 {
            width: 400px;
            height: 400px;
            background: var(--primary);
            top: -100px;
            left: -100px;
            animation-delay: 0s;
        }

        .ambient-orb-2 {
            width: 300px;
            height: 300px;
            background: var(--accent);
            bottom: -50px;
            right: -50px;
            animation-delay: -7s;
        }

        .ambient-orb-3 {
            width: 250px;
            height: 250px;
            background: var(--purple);
            top: 50%;
            left: 50%;
            animation-delay: -14s;
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(30px, -30px) scale(1.1); }
            50% { transform: translate(-20px, 20px) scale(0.95); }
            75% { transform: translate(20px, 30px) scale(1.05); }
        }

        /* v24.0: Spring Press Effect for buttons */
        .spring-press {
            transition: transform 0.15s var(--ease-spring), box-shadow 0.15s ease;
        }

        .spring-press:active {
            transform: scale(0.95);
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        }

        /* v24.0: Aurora Border Animation */
        .aurora-border {
            position: relative;
        }

        .aurora-border::before {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: inherit;
            background: conic-gradient(from var(--aurora-angle, 0deg), var(--primary), var(--accent), var(--purple), var(--pink), var(--primary));
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s ease;
            animation: auroraSpin 4s linear infinite;
        }

        .aurora-border:hover::before {
            opacity: 1;
        }

        @keyframes auroraSpin {
            to { --aurora-angle: 360deg; }
        }

        /* v24.0: Data Stream Effect */
        .data-stream {
            position: relative;
            overflow: hidden;
        }

        .data-stream::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            animation: dataStreamMove 3s ease-in-out infinite;
        }

        @keyframes dataStreamMove {
            0% { left: -100%; }
            100% { left: 100%; }
        }

        /* v24.0: Glitch Effect for error state */
        @keyframes glitch {
            0%, 100% { transform: translate(0); }
            20% { transform: translate(-2px, 2px); }
            40% { transform: translate(-2px, -2px); }
            60% { transform: translate(2px, 2px); }
            80% { transform: translate(2px, -2px); }
        }

        .glitch-text {
            animation: glitch 0.5s ease-in-out infinite;
        }

        /* v24.0: Ripple Click Effect */
        .ripple-container {
            position: relative;
            overflow: hidden;
        }

        .ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.3);
            transform: scale(0);
            animation: rippleEffect 0.6s ease-out;
            pointer-events: none;
        }

        @keyframes rippleEffect {
            to {
                transform: scale(4);
                opacity: 0;
            }
        }

        /* v24.0: Shimmer Loading Skeleton */
        .skeleton {
            background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: skeletonShimmer 1.5s ease-in-out infinite;
        }

        @keyframes skeletonShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* v24.0: Morphing Card Shape */
        .morph-card {
            transition: border-radius 0.5s var(--ease-out-expo);
        }

        .morph-card:hover {
            border-radius: 40px;
        }

        /* v24.0: Particle Burst Container */
        .particle-container {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            animation: particleFade 1s ease-out forwards;
        }

        @keyframes particleFade {
            0% { transform: translate(0, 0) scale(1); opacity: 1; }
            100% { transform: translate(var(--tx), var(--ty)) scale(0); opacity: 0; }
        }

        /* v25.0: Enhanced Micro-interactions */

        /* Stat card hover lift with glow */
        .stat-card {
            transition: all var(--transition-normal) var(--ease-out-expo),
                        box-shadow 0.2s ease,
                        transform 0.2s var(--ease-spring);
        }

        .stat-card:hover {
            transform: translateY(-6px) scale(1.02);
        }

        .stat-card:active {
            transform: translateY(-2px) scale(0.98);
            transition-duration: 0.1s;
        }

        /* Mini stat hover glow */
        .mini-stat {
            transition: all 0.2s var(--ease-spring),
                        box-shadow 0.2s ease;
        }

        .mini-stat:hover {
            background: rgba(255,255,255,0.08);
            transform: translateY(-3px);
            box-shadow: 0 8px 24px -8px rgba(255,200,100,0.3);
        }

        /* v25.0: Number counter animation */
        .stat-value {
            font-variant-numeric: tabular-nums;
            transition: color 0.3s ease;
        }

        .stat-value.counting {
            color: var(--accent);
        }

        /* v25.0: Progress bar animated stripes */
        .progress-fill {
            position: relative;
            overflow: hidden;
        }

        .progress-fill::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                90deg,
                transparent 0%,
                rgba(255,255,255,0.15) 50%,
                transparent 100%
            );
            animation: progressShimmer 2s ease-in-out infinite;
        }

        @keyframes progressShimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(200%); }
        }

        /* v25.0: Action button enhanced */
        .action-btn {
            position: relative;
            overflow: hidden;
            transition: all 0.2s var(--ease-spring);
        }

        .action-btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), rgba(255,255,255,0.2) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .action-btn:hover::before {
            opacity: 1;
        }

        .action-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px -4px rgba(255,200,100,0.4);
        }

        .action-btn:active {
            transform: translateY(0) scale(0.96);
        }

        /* v25.0: Timeline item stagger entrance */
        .timeline-item {
            opacity: 0;
            transform: translateX(-20px);
            animation: timelineSlideIn 0.4s var(--ease-out-expo) forwards;
        }

        .timeline-item:nth-child(1) { animation-delay: 0.05s; }
        .timeline-item:nth-child(2) { animation-delay: 0.1s; }
        .timeline-item:nth-child(3) { animation-delay: 0.15s; }
        .timeline-item:nth-child(4) { animation-delay: 0.2s; }
        .timeline-item:nth-child(5) { animation-delay: 0.25s; }

        @keyframes timelineSlideIn {
            to { opacity: 1; transform: translateX(0); }
        }

        /* v25.0: Data storytelling card */
        .story-card {
            background: var(--bg-card);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-lg);
            padding: 20px;
            position: relative;
            overflow: hidden;
        }

        .story-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--neon-gradient);
            opacity: 0.8;
        }

        .story-title {
            font-size: 13px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .story-text {
            font-size: 15px;
            color: var(--text-bright);
            line-height: 1.6;
        }

        .story-highlight {
            color: var(--primary);
            font-weight: 600;
        }

        /* v25.0: Thinking chain visualization */
        .thinking-chain {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 12px;
            background: rgba(168,85,247,0.08);
            border: 1px solid rgba(168,85,247,0.2);
            border-radius: var(--radius-md);
            margin-top: 12px;
        }

        .thinking-node {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--purple);
            animation: thinkingPulse 1.5s ease-in-out infinite;
        }

        .thinking-node:nth-child(2) { animation-delay: 0.2s; }
        .thinking-node:nth-child(3) { animation-delay: 0.4s; }
        .thinking-node:nth-child(4) { animation-delay: 0.6s; }
        .thinking-node:nth-child(5) { animation-delay: 0.8s; }

        @keyframes thinkingPulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.4); opacity: 1; }
        }

        .thinking-label {
            font-size: 12px;
            color: var(--purple);
            margin-left: 8px;
        }

        /* v25.0: Task progress mini */
        .task-progress {
            margin-top: 16px;
        }

        .task-progress-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .task-progress-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .task-progress-value {
            font-size: 12px;
            color: var(--accent);
            font-weight: 500;
        }

        .task-progress-bar {
            height: 4px;
            background: rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .task-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--success));
            border-radius: var(--radius-full);
            transition: width 0.5s var(--ease-out-expo);
        }

        /* v25.0: EvoMap reputation badge */
        .reputation-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: rgba(168,85,247,0.1);
            border: 1px solid rgba(168,85,247,0.3);
            border-radius: var(--radius-full);
            font-size: 12px;
            color: var(--purple);
            cursor: help;
            transition: all 0.2s ease;
        }

        .reputation-badge:hover {
            background: rgba(168,85,247,0.2);
            transform: scale(1.05);
        }

        .reputation-icon {
            font-size: 14px;
        }

        /* v25.0: Time-aware greeting */
        .time-greeting {
            font-size: 12px;
            color: var(--text-muted);
            padding: 4px 10px;
            background: rgba(255,200,100,0.08);
            border-radius: var(--radius-full);
            margin-bottom: 8px;
        }

        /* ========== Reset & Base ========== */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', -apple-system, sans-serif;
            background: var(--bg-dark);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            position: relative;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            color: var(--text);
        }

        /* ========== Background Effects ========== */
        .bg-space {
            position: fixed;
            inset: 0;
            background: var(--space-gradient);
            z-index: -3;
        }

        .bg-stars {
            position: fixed;
            inset: 0;
            z-index: -2;
            pointer-events: none;
        }

        .bg-neural {
            position: fixed;
            inset: 0;
            z-index: -1;
            opacity: 0.5;
        }

        /* ========== Main Container ========== */
        .dashboard-container {
            width: 100%;
            max-width: 1200px;
            position: relative;
            z-index: 10;
        }

        /* ========== Glass Card ========== */
        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-soft), var(--shadow-glow);
            overflow: hidden;
            transition: all var(--transition-normal) var(--ease-out-expo);
        }

        .glass-card:hover {
            background: var(--bg-card-hover);
            border-color: rgba(255,255,255,0.1);
            box-shadow: var(--shadow-medium), var(--shadow-glow-strong);
            transform: translateY(-2px);
        }

        /* ========== Header ========== */
        .dashboard-header {
            padding: 24px 32px;
            border-bottom: 1px solid var(--bg-glass);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            background: rgba(255,255,255,0.05);
            border-radius: var(--radius-full);
            font-size: 14px;
            font-weight: 500;
            border: 1px solid var(--bg-glass);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
            animation: pulse 2s ease-in-out infinite;
        }

        .status-dot.warning { background: var(--warning); }
        .status-dot.error { background: var(--danger); }

        .status-dot.critical {
            background: var(--danger);
            animation: criticalPulse 0.5s ease-in-out infinite;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .refresh-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-muted);
            background: rgba(255,255,255,0.03);
            padding: 6px 12px;
            border-radius: var(--radius-full);
        }

        .refresh-badge .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            animation: pulse 1.5s ease-in-out infinite;
        }

        /* ========== Dashboard Grid ========== */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 24px;
            padding: 24px 32px;
        }

        /* ========== Left Column - Avatar Section ========== */
        .left-column {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .avatar-section {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 24px;
        }

        .fox-container {
            position: relative;
            width: 180px;
            height: 180px;
            margin-bottom: 20px;
        }
        
        /* v23.0: Status whisper glow */
        .fox-container::before {
            content: '';
            position: absolute;
            inset: -20px;
            border-radius: 50%;
            background: var(--accent);
            opacity: 0.2;
            filter: blur(25px);
            animation: statusWhisper 4s ease-in-out infinite;
            z-index: -1;
            transition: background 0.5s ease;
        }
        
        /* Mood-aware whisper colors */
        .fox-container.idle::before { background: var(--warning); }
        .fox-container.working::before { background: var(--accent); }
        .fox-container.sleeping::before { background: var(--purple); }
        .fox-container.excited::before { background: var(--pink); }
        .fox-container.error::before { background: var(--danger); }

        .fox-canvas {
            width: 100%;
            height: 100%;
            border-radius: var(--radius-lg);
        }

        /* v22.0: Mood Sync Ring */
        .mood-sync-ring {
            position: absolute;
            inset: -8px;
            border-radius: 50%;
            border: 2px solid transparent;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .mood-sync-ring.active {
            opacity: 1;
            animation: ringPulse 2s ease-in-out infinite;
        }

        /* Mood colors */
        .mood-sync-ring.idle { border-color: var(--warning); box-shadow: 0 0 30px var(--warning); }
        .mood-sync-ring.working { border-color: var(--accent); box-shadow: 0 0 30px var(--accent); }
        .mood-sync-ring.sleeping { border-color: var(--purple); box-shadow: 0 0 30px var(--purple); }
        .mood-sync-ring.excited { border-color: var(--pink); box-shadow: 0 0 30px var(--pink); }
        .mood-sync-ring.thinking { border-color: var(--purple); box-shadow: 0 0 30px var(--purple); }
        .mood-sync-ring.laughing { border-color: var(--warning); box-shadow: 0 0 30px var(--warning); }
        .mood-sync-ring.error { border-color: var(--danger); box-shadow: 0 0 30px var(--danger); }
        .mood-sync-ring.focused { border-color: var(--success); box-shadow: 0 0 30px var(--success); }
        .mood-sync-ring.learning { border-color: var(--primary); box-shadow: 0 0 30px var(--primary); }

        @keyframes ringPulse {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.05); opacity: 1; }
        }

        /* v23.0: Quantum Glass Animations */
        
        /* Heartbeat Sync Pulse - Cards breathe with heartbeat */
        @keyframes heartbeatPulse {
            0%, 100% { transform: scale(1); box-shadow: var(--shadow-soft), var(--shadow-glow); }
            50% { transform: scale(1.005); box-shadow: var(--shadow-soft), 0 0 100px -30px var(--accent); }
        }
        
        /* Data Wave Effect - Ripple on data update */
        @keyframes dataWave {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.02); opacity: 0.8; }
            100% { transform: scale(1); opacity: 1; }
        }
        
        /* Sparkle shimmer for stat cards */
        @keyframes sparkleShimmer {
            0%, 100% { background-position: -200% center; }
            50% { background-position: 200% center; }
        }
        
        /* Status Whisper - Subtle glow around fox */
        @keyframes statusWhisper {
            0%, 100% { opacity: 0.3; transform: scale(1); filter: blur(20px); }
            50% { opacity: 0.6; transform: scale(1.1); filter: blur(25px); }
        }
        
        /* Sync Wave - Data sync ripple effect */
        @keyframes syncWave {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(2); opacity: 0; }
        }
        
        /* Number morph animation */
        @keyframes numberPop {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        /* Card breathing effect */
        .card-breathe {
            animation: heartbeatPulse 3s ease-in-out infinite;
        }
        
        /* Data update wave effect */
        .data-wave {
            animation: dataWave 0.6s ease-out;
        }
        
        /* Stat sparkle effect */
        .stat-sparkle {
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            background-size: 200% 100%;
            animation: sparkleShimmer 3s ease-in-out infinite;
        }
        
        /* Status whisper glow */
        .status-whisper {
            position: absolute;
            inset: -20px;
            border-radius: 50%;
            background: var(--accent);
            opacity: 0.3;
            filter: blur(20px);
            animation: statusWhisper 4s ease-in-out infinite;
            pointer-events: none;
            z-index: -1;
        }
        
        /* Sync ripple container */
        .sync-ripple {
            position: absolute;
            inset: 0;
            border-radius: inherit;
            overflow: hidden;
            pointer-events: none;
        }
        
        .sync-ripple::after {
            content: '';
            position: absolute;
            inset: 0;
            border: 2px solid var(--accent);
            border-radius: inherit;
            animation: syncWave 1.5s ease-out infinite;
        }
        
        /* Number update pop */
        .num-pop {
            animation: numberPop 0.3s ease-out;
        }

        .fox-name {
            font-size: 24px;
            font-weight: 600;
            background: var(--neon-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

        .fox-role {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

        /* v22.0: Stats Row */
        .stats-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            width: 100%;
        }

        .mini-stat {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-md);
            padding: 12px;
            text-align: center;
            transition: all var(--transition-fast);
        }

        .mini-stat:hover {
            background: rgba(255,255,255,0.06);
            transform: translateY(-2px);
        }

        .mini-stat-value {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-bright);
            margin-bottom: 4px;
        }

        .mini-stat-label {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ========== Right Column - Stats Cards ========== */
        .right-column {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-lg);
            padding: 20px;
            position: relative;
            overflow: hidden;
            transition: all var(--transition-normal) var(--ease-out-expo);
            cursor: pointer;
        }
        
        /* v23.0: Card breathe animation synced to heartbeat */
        .stat-card.card-breathe {
            animation: heartbeatPulse 3s ease-in-out infinite;
        }
        
        /* v23.0: Data update wave effect */
        .stat-card.data-wave {
            animation: dataWave 0.6s ease-out;
        }
        
        /* v23.0: Sparkle overlay on hover */
        .stat-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity var(--transition-fast);
        }
        
        .stat-card:hover::before {
            opacity: 1;
            animation: sparkleShimmer 1.5s ease-in-out infinite;
        }
        
        /* v23.0: Sync ripple on data fetch */
        .stat-card .sync-ripple {
            position: absolute;
            inset: 0;
            border-radius: inherit;
            overflow: hidden;
            pointer-events: none;
            opacity: 0;
        }
        
        .stat-card.syncing .sync-ripple {
            opacity: 1;
        }
        
        .stat-card.syncing .sync-ripple::after {
            content: '';
            position: absolute;
            inset: 0;
            border: 2px solid var(--accent);
            border-radius: inherit;
            animation: syncWave 1s ease-out;
        }

        .stat-card:hover {
            border-color: rgba(255,255,255,0.15);
            transform: translateY(-4px);
            box-shadow: var(--shadow-medium);
        }

        .stat-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .stat-icon {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        /* v23.0: Stat value with pop animation */
        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--text-bright);
            margin-bottom: 4px;
            font-variant-numeric: tabular-nums;
            transition: transform 0.15s ease;
        }
        
        .stat-value.num-pop {
            animation: numberPop 0.3s ease-out;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-subtext {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 8px;
        }

        /* ========== Progress Bars ========== */
        .progress-container {
            margin-top: 12px;
        }

        .progress-bar {
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: var(--radius-full);
            transition: width 0.5s var(--ease-out-expo);
        }

        .progress-fill.success { background: var(--success); }
        .progress-fill.warning { background: var(--warning); }
        .progress-fill.danger { background: var(--danger); }

        /* ========== Status Section ========== */
        .status-section {
            margin-top: 20px;
            padding: 16px;
            background: rgba(255,255,255,0.03);
            border-radius: var(--radius-md);
        }

        .status-title {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .status-value {
            font-size: 16px;
            font-weight: 500;
            color: var(--text-bright);
        }

        /* ========== Quick Actions ========== */
        .quick-actions {
            display: flex;
            gap: 8px;
            margin-top: 16px;
        }

        .action-btn {
            flex: 1;
            padding: 10px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-md);
            color: var(--text);
            font-size: 13px;
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .action-btn:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.2);
        }

        .action-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: var(--bg-dark);
        }

        /* ========== Charts Section ========== */
        .charts-section {
            grid-column: 1 / -1;
            margin-top: 8px;
        }

        .charts-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }

        .chart-card {
            background: var(--bg-card);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-lg);
            padding: 16px;
        }

        .chart-title {
            font-size: 13px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .chart-canvas-container {
            height: 120px;
            position: relative;
        }

        .chart-canvas {
            width: 100%;
            height: 100%;
        }

        /* ========== Bottom Section ========== */
        .bottom-section {
            grid-column: 1 / -1;
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 16px;
            margin-top: 16px;
        }

        /* ========== Memory Timeline ========== */
        .memory-timeline {
            background: var(--bg-card);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-lg);
            padding: 20px;
        }

        .timeline-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .timeline-title {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-bright);
        }

        .timeline-items {
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-height: 200px;
            overflow-y: auto;
        }

        .timeline-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px;
            background: rgba(255,255,255,0.03);
            border-radius: var(--radius-md);
            transition: all var(--transition-fast);
        }

        .timeline-item:hover {
            background: rgba(255,255,255,0.06);
        }

        .timeline-icon {
            width: 32px;
            height: 32px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .timeline-content {
            flex: 1;
        }

        .timeline-text {
            font-size: 13px;
            color: var(--text-bright);
            margin-bottom: 4px;
        }

        .timeline-time {
            font-size: 11px;
            color: var(--text-muted);
        }

        /* ========== Skills Distribution ========== */
        .skills-distribution {
            background: var(--bg-card);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-lg);
            padding: 20px;
        }

        .skills-title {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-bright);
            margin-bottom: 16px;
        }

        .skill-item {
            margin-bottom: 12px;
        }

        .skill-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 6px;
        }

        .skill-name {
            font-size: 13px;
            color: var(--text-bright);
        }

        .skill-value {
            font-size: 13px;
            color: var(--text-muted);
        }

        .skill-bar {
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .skill-fill {
            height: 100%;
            border-radius: var(--radius-full);
            transition: width 0.5s var(--ease-out-expo);
        }

        /* ========== Footer ========== */
        .dashboard-footer {
            padding: 20px 32px;
            border-top: 1px solid var(--bg-glass);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .footer-info {
            font-size: 12px;
            color: var(--text-muted);
        }

        .footer-info span {
            color: var(--text-bright);
        }

        /* ========== Animations ========== */
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        @keyframes criticalPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes scaleIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        /* ========== Utility Classes ========== */
        .fade-in {
            animation: fadeIn 0.5s ease forwards;
        }

        .slide-in {
            animation: slideIn 0.3s ease forwards;
        }

        .scale-in {
            animation: scaleIn 0.3s ease forwards;
        }

        /* ========== Responsive Design ========== */
        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
                padding: 16px;
            }

            .dashboard-header {
                padding: 16px;
            }

            .dashboard-grid {
                gap: 16px;
            }

            .right-column {
                grid-template-columns: 1fr;
            }

            .stats-row {
                grid-template-columns: 1fr;
            }

            .charts-container {
                grid-template-columns: 1fr;
            }

            .bottom-section {
                grid-template-columns: 1fr;
            }

            .fox-container {
                width: 140px;
                height: 140px;
            }
        }

        @media (max-width: 480px) {
            .dashboard-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            .header-right {
                width: 100%;
                justify-content: space-between;
            }

            .stat-value {
                font-size: 24px;
            }

            .stat-card {
                padding: 16px;
            }
        }

        /* ========== Data Source Health Badge ========== */
        .data-source-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-left: 12px;
            padding: 2px 8px;
            background: rgba(255,255,255,0.05);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--text-muted);
            cursor: help;
        }

        .source-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            transition: background 0.3s ease;
        }

        .source-dot.warning { background: var(--warning); }
        .source-dot.error { background: var(--danger); }
        .source-dot.stale { background: var(--purple); }

        /* v27.0: External Route Status Badge */
        .external-route-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-left: 8px;
            padding: 2px 8px;
            background: rgba(255,255,255,0.05);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--text-muted);
            cursor: help;
            transition: all 0.3s ease;
        }

        .external-route-badge.checking {
            animation: pulse 1s ease-in-out infinite;
        }

        .external-route-badge.online {
            background: rgba(92,219,149,0.15);
            color: var(--success);
        }

        .external-route-badge.offline {
            background: rgba(255,107,107,0.15);
            color: var(--danger);
        }

        .route-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--text-dim);
            transition: background 0.3s ease;
        }

        .route-dot.online {
            background: var(--success);
            box-shadow: 0 0 6px var(--success);
        }

        .route-dot.offline {
            background: var(--danger);
            box-shadow: 0 0 6px var(--danger);
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* ========== Reduced Motion ========== */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }

            .stat-card:hover,
            .mini-stat:hover,
            .timeline-item:hover,
            .action-btn:hover {
                transform: none !important;
            }
        }

        /* ========== Loading State ========== */
        body.loading .stat-card,
        body.loading .mini-stat,
        body.loading .timeline-item {
            opacity: 0.5;
            pointer-events: none;
        }

        /* ========== Error State ========== */
        body.error .status-dot {
            background: var(--danger);
        }

        body.error .status-badge {
            background: rgba(255,107,107,0.1);
            border-color: var(--danger);
        }

        /* v26.0: Enhanced Energy Core Visualization */
        .energy-core {
            position: absolute;
            width: 60px;
            height: 60px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            z-index: 0;
        }

        .energy-ring {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 2px solid transparent;
            border-top-color: var(--accent);
            border-right-color: var(--primary);
            animation: energySpin 3s linear infinite;
        }

        .energy-ring:nth-child(2) {
            inset: 6px;
            animation-duration: 2s;
            animation-direction: reverse;
            border-top-color: var(--purple);
            border-right-color: var(--pink);
        }

        .energy-ring:nth-child(3) {
            inset: 12px;
            animation-duration: 1.5s;
            border-top-color: var(--success);
            border-right-color: var(--accent);
        }

        @keyframes energySpin {
            to { transform: rotate(360deg); }
        }

        /* v26.0: Mood Aura Dynamic Glow */
        .mood-aura {
            position: absolute;
            inset: -30px;
            border-radius: 50%;
            opacity: 0.4;
            filter: blur(20px);
            transition: all 0.8s ease;
            pointer-events: none;
            z-index: -1;
        }

        .mood-aura.idle { background: radial-gradient(circle, var(--warning) 0%, transparent 70%); }
        .mood-aura.working { background: radial-gradient(circle, var(--accent) 0%, transparent 70%); animation: auraWorking 2s ease-in-out infinite; }
        .mood-aura.sleeping { background: radial-gradient(circle, var(--purple) 0%, transparent 70%); animation: auraSleeping 4s ease-in-out infinite; }
        .mood-aura.excited { background: radial-gradient(circle, var(--pink) 0%, transparent 70%); animation: auraExcited 1s ease-in-out infinite; }
        .mood-aura.thinking { background: radial-gradient(circle, var(--purple) 0%, transparent 70%); animation: auraThinking 3s ease-in-out infinite; }
        .mood-aura.laughing { background: radial-gradient(circle, var(--warning) 0%, transparent 70%); animation: auraLaughing 0.8s ease-in-out infinite; }
        .mood-aura.error { background: radial-gradient(circle, var(--danger) 0%, transparent 70%); animation: auraError 0.5s ease-in-out infinite; }
        .mood-aura.focused { background: radial-gradient(circle, var(--success) 0%, transparent 70%); animation: auraFocused 2s ease-in-out infinite; }

        @keyframes auraWorking { 0%, 100% { opacity: 0.3; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.1); } }
        @keyframes auraSleeping { 0%, 100% { opacity: 0.2; transform: scale(0.95); } 50% { opacity: 0.5; transform: scale(1.05); } }
        @keyframes auraExcited { 0%, 100% { opacity: 0.4; transform: scale(1.05); } 50% { opacity: 0.7; transform: scale(1.15); } }
        @keyframes auraThinking { 0%, 100% { opacity: 0.3; } 25% { opacity: 0.5; transform: translateX(-2px); } 75% { opacity: 0.5; transform: translateX(2px); } }
        @keyframes auraLaughing { 0%, 100% { opacity: 0.4; transform: scale(1) rotate(0deg); } 50% { opacity: 0.6; transform: scale(1.08) rotate(3deg); } }
        @keyframes auraError { 0%, 100% { opacity: 0.5; transform: scale(1); } 25% { transform: translate(-2px, 2px); } 50% { opacity: 0.7; transform: scale(1.1); } 75% { transform: translate(2px, -2px); } }
        @keyframes auraFocused { 0%, 100% { opacity: 0.3; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.08); } }

        /* v26.0: Floating Particle Trail for Cursor */
        .cursor-trail-particle {
            position: fixed;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            animation: trailFade 0.8s ease-out forwards;
        }

        @keyframes trailFade {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(0); opacity: 0; }
        }

        /* v26.0: Session Journey Progress */
        .session-journey {
            background: var(--bg-card);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-lg);
            padding: 16px;
            margin-top: 16px;
        }

        .journey-title {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .journey-track {
            position: relative;
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            overflow: visible;
        }

        .journey-fill {
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--primary));
            border-radius: var(--radius-full);
            transition: width 0.5s var(--ease-out-expo);
        }

        .journey-marker {
            position: absolute;
            top: 50%;
            transform: translate(-50%, -50%);
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--primary);
            border: 2px solid var(--bg-dark);
            transition: left 0.5s var(--ease-out-expo);
        }

        .journey-label {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 8px;
            display: flex;
            justify-content: space-between;
        }

        /* v26.0: Enhanced Chart with Gradient Fill */
        .chart-canvas-container {
            position: relative;
            overflow: hidden;
        }

        .chart-glow {
            position: absolute;
            inset: 0;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .stat-card:hover .chart-glow {
            opacity: 1;
        }

        /* v26.0: Pulsing Status Indicator */
        .status-pulse {
            position: relative;
        }

        .status-pulse::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            border: 2px solid currentColor;
            animation: statusPulseRing 2s ease-out infinite;
            opacity: 0;
        }

        @keyframes statusPulseRing {
            0% { transform: scale(0.8); opacity: 0.8; }
            100% { transform: scale(1.5); opacity: 0; }
        }

        /* v26.0: Magnetic Hover Effect for Cards */
        .magnetic-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .magnetic-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 40px -15px rgba(255,200,100,0.3);
        }

        /* v26.0: Liquid Morph Border */
        .liquid-border {
            position: relative;
        }

        .liquid-border::before {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: inherit;
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--purple), var(--pink), var(--primary));
            background-size: 300% 100%;
            animation: liquidGradient 4s linear infinite;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .liquid-border:hover::before {
            opacity: 1;
        }

        @keyframes liquidGradient {
            0% { background-position: 0% 50%; }
            100% { background-position: 300% 50%; }
        }

        /* v26.0: Animated Gradient Text */
        .gradient-text-animated {
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--purple), var(--pink), var(--primary));
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientFlow 3s ease infinite;
        }

        @keyframes gradientFlow {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        /* v26.0: Fox Expression Emoji Overlay */
        .fox-expression {
            position: absolute;
            top: -10px;
            right: -10px;
            font-size: 24px;
            animation: expressionBounce 2s ease-in-out infinite;
            pointer-events: none;
            z-index: 10;
        }

        @keyframes expressionBounce {
            0%, 100% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.1) rotate(-5deg); }
            75% { transform: scale(1.1) rotate(5deg); }
        }

        /* v26.0: Staggered Entrance Animation */
        .stagger-enter > * {
            opacity: 0;
            transform: translateY(20px);
            animation: staggerIn 0.5s ease forwards;
        }

        .stagger-enter > *:nth-child(1) { animation-delay: 0.1s; }
        .stagger-enter > *:nth-child(2) { animation-delay: 0.2s; }
        .stagger-enter > *:nth-child(3) { animation-delay: 0.3s; }
        .stagger-enter > *:nth-child(4) { animation-delay: 0.4s; }
        .stagger-enter > *:nth-child(5) { animation-delay: 0.5s; }

        @keyframes staggerIn {
            to { opacity: 1; transform: translateY(0); }
        }

        /* v26.0: Loading Skeleton with Shimmer */
        .skeleton-v2 {
            background: linear-gradient(90deg, 
                rgba(255,255,255,0.03) 0%, 
                rgba(255,255,255,0.08) 50%, 
                rgba(255,255,255,0.03) 100%);
            background-size: 200% 100%;
            animation: skeletonShimmerV2 1.5s ease-in-out infinite;
            border-radius: var(--radius-md);
        }

        @keyframes skeletonShimmerV2 {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* v26.0: Data Stream Flow Effect */
        .data-flow {
            position: relative;
            overflow: hidden;
        }

        .data-flow::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0,212,255,0.1), transparent);
            animation: dataFlowSweep 2s ease-in-out infinite;
        }

        @keyframes dataFlowSweep {
            0% { left: -100%; }
            100% { left: 200%; }
        }

        /* v26.0: Compact Mood Selector */
        .mood-selector {
            display: flex;
            gap: 8px;
            margin-top: 16px;
            justify-content: center;
        }

        .mood-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid var(--bg-glass);
            background: rgba(255,255,255,0.03);
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s var(--ease-spring);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .mood-btn:hover {
            transform: scale(1.2);
            border-color: var(--primary);
            background: rgba(255,200,100,0.1);
        }

        .mood-btn:active {
            transform: scale(0.95);
        }

        .mood-btn.active {
            border-color: var(--primary);
            background: rgba(255,200,100,0.2);
            box-shadow: 0 0 20px rgba(255,200,100,0.3);
        }

        /* v26.0: Quick Stats Panel */
        .quick-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            margin-top: 16px;
        }

        .quick-stat {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--bg-glass);
            border-radius: var(--radius-md);
            padding: 10px;
            text-align: center;
        }

        .quick-stat-value {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-bright);
        }

        .quick-stat-label {
            font-size: 10px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-top: 4px;
        }

        /* v26.0: Glassmorphic Divider */
        .glass-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--bg-glass), transparent);
            margin: 16px 0;
        }

        /* v26.0: Notification Badge */
        .notification-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            min-width: 18px;
            height: 18px;
            border-radius: var(--radius-full);
            background: var(--danger);
            color: white;
            font-size: 11px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            animation: badgePulse 2s ease-in-out infinite;
        }

        @keyframes badgePulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        /* v28.0: Modern Enhancements */

        /* Floating 3D Card Effect */
        .card-3d-hover {
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        .card-3d-hover:hover {
            transform: rotateX(5deg) rotateY(5deg) translateY(-8px);
            box-shadow: 
                20px 20px 60px rgba(0,0,0,0.4),
                -5px -5px 20px rgba(255,255,255,0.05);
        }

        /* Neon Glow Text */
        .neon-glow {
            text-shadow: 
                0 0 10px currentColor,
                0 0 20px currentColor,
                0 0 40px currentColor;
        }

        /* Animated Border Gradient */
        @keyframes borderGlow {
            0%, 100% { border-color: var(--primary); box-shadow: 0 0 20px var(--primary-dim); }
            33% { border-color: var(--accent); box-shadow: 0 0 20px var(--accent-dim); }
            66% { border-color: var(--purple); box-shadow: 0 0 20px var(--purple-dim); }
        }

        .border-glow-animated {
            animation: borderGlow 4s ease-in-out infinite;
        }

        /* Breathing Animation */
        @keyframes breathe {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.05); opacity: 1; }
        }

        .breathing {
            animation: breathe 4s ease-in-out infinite;
        }

        /* Typing Indicator */
        .typing-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            margin: 0 3px;
            animation: typingBounce 1.4s ease-in-out infinite;
        }

        .typing-dot:nth-child(1) { animation-delay: 0s; }
        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typingBounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-8px); }
        }

        /* Interactive Fox Pet Zone */
        .fox-pet-zone {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            border-radius: 50%;
            cursor: pointer;
            z-index: 5;
        }

        .fox-pet-zone:hover + .fox-canvas {
            filter: brightness(1.1) drop-shadow(0 0 20px var(--primary));
        }

        /* Heart Rain Effect */
        @keyframes heartRain {
            0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100px) rotate(360deg); opacity: 0; }
        }

        .heart-rain {
            position: absolute;
            font-size: 20px;
            animation: heartRain 2s ease-out forwards;
            pointer-events: none;
        }

        /* Smooth Scroll Snap */
        .scroll-snap-container {
            scroll-snap-type: y mandatory;
            overflow-y: auto;
            scroll-behavior: smooth;
        }

        .scroll-snap-item {
            scroll-snap-align: start;
        }

        /* Glassmorphism Enhanced */
        .glassmorphism-enhanced {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
        }

        /* Morphing Shape */
        @keyframes morphShape {
            0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
            50% { border-radius: 50% 60% 30% 60% / 30% 40% 70% 60%; }
            75% { border-radius: 60% 40% 60% 30% / 70% 50% 40% 60%; }
        }

        .morphing-shape {
            animation: morphShape 8s ease-in-out infinite;
        }

        /* Shimmer Loading */
        @keyframes shimmerLoad {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        .shimmer {
            background: linear-gradient(90deg, 
                rgba(255,255,255,0) 0%, 
                rgba(255,255,255,0.1) 50%, 
                rgba(255,255,255,0) 100%);
            background-size: 200% 100%;
            animation: shimmerLoad 1.5s ease-in-out infinite;
        }

        /* Typewriter Effect */
        @keyframes typewriter {
            from { width: 0; }
            to { width: 100%; }
        }

        .typewriter {
            overflow: hidden;
            white-space: nowrap;
            animation: typewriter 2s steps(40) forwards;
        }

        /* Focus Ring Animation */
        @keyframes focusRing {
            0%, 100% { box-shadow: 0 0 0 0 var(--accent); }
            50% { box-shadow: 0 0 0 10px transparent; }
        }

        .focus-ring-animate {
            animation: focusRing 2s ease-in-out infinite;
        }

        /* Marquee Text */
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .marquee {
            animation: marquee 20s linear infinite;
        }

        /* Interactive Ripple on Click */
        .click-ripple {
            position: relative;
            overflow: hidden;
        }

        .click-ripple::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
            background-image: radial-gradient(circle, var(--primary) 10%, transparent 10%);
            background-repeat: no-repeat;
            background-position: 50%;
            transform: scale(10);
            opacity: 0;
            transition: transform 0.5s, opacity 0.5s;
        }

        .click-ripple:active::after {
            transform: scale(0);
            opacity: 0.3;
            transition: 0s;
        }

        /* Gradient Border on Hover */
        .gradient-border-hover {
            position: relative;
        }

        .gradient-border-hover::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            padding: 2px;
            background: linear-gradient(135deg, var(--primary), var(--accent), var(--purple));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .gradient-border-hover:hover::before {
            opacity: 1;
        }

        /* v28.0: Pet the Fox Interaction */
        .fox-happy {
            animation: foxHappy 0.5s ease-out;
        }

        @keyframes foxHappy {
            0% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.1) rotate(-5deg); }
            50% { transform: scale(1.15) rotate(5deg); }
            75% { transform: scale(1.1) rotate(-3deg); }
            100% { transform: scale(1) rotate(0deg); }
        }

        /* Sparkle Effect */
        @keyframes sparkle {
            0%, 100% { opacity: 0; transform: scale(0); }
            50% { opacity: 1; transform: scale(1); }
        }

        .sparkle-effect::before,
        .sparkle-effect::after {
            content: '✨';
            position: absolute;
            animation: sparkle 1s ease-in-out infinite;
        }

        /* Status Transition Animation */
        .status-transition {
            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        /* Interactive Star Rating */
        .star-rating {
            display: inline-flex;
            gap: 4px;
        }

        .star-rating span {
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        .star-rating span:hover {
            transform: scale(1.3);
        }

        .star-rating span.active {
            color: var(--primary);
        }

        /* Animated Progress Ring */
        .progress-ring {
            transform: rotate(-90deg);
        }

        .progress-ring-circle {
            transition: stroke-dashoffset 0.5s ease;
            stroke-linecap: round;
        }

        /* Noise Texture Overlay */
        .noise-overlay {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 9999;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        }

        /* Floating Labels */
        .floating-label {
            position: relative;
        }

        .floating-label input {
            padding-top: 20px;
        }

        .floating-label::after {
            content: attr(data-label);
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            transition: all 0.2s ease;
            pointer-events: none;
        }

        /* Pulse Ring Effect */
        @keyframes pulseRing {
            0% { transform: scale(0.8); opacity: 1; }
            100% { transform: scale(2); opacity: 0; }
        }

        .pulse-ring {
            position: relative;
        }

        .pulse-ring::before {
            content: '';
            position: absolute;
            inset: -5px;
            border-radius: 50%;
            border: 2px solid currentColor;
            animation: pulseRing 1.5s ease-out infinite;
        }

        /* v29.0: Particle Mesh Grid Background */
        .particle-mesh-canvas {
            position: fixed;
            inset: 0;
            z-index: -2;
            opacity: 0.4;
            pointer-events: none;
        }

        /* v29.0: Interactive Glow Cursor */
        .glow-cursor {
            position: fixed;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.4) 0%, transparent 70%);
            pointer-events: none;
            z-index: 9998;
            transform: translate(-50%, -50%);
            transition: width 0.2s, height 0.2s, background 0.3s;
            mix-blend-mode: screen;
        }

        .glow-cursor.active {
            width: 40px;
            height: 40px;
            background: radial-gradient(circle, rgba(0,212,255,0.5) 0%, transparent 70%);
        }

        /* v29.0: SVG Sparkline Mini Chart */
        .sparkline {
            display: inline-block;
            vertical-align: middle;
        }

        /* v29.0: Enhanced Stat Card with Mini Sparkline */
        .stat-card .mini-trend {
            position: absolute;
            bottom: 8px;
            right: 8px;
            width: 40px;
            height: 16px;
            opacity: 0.6;
        }

        /* v29.0: Shimmer Loading v2 */
        @keyframes shimmerWave {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        .skeleton-v2 {
            background: linear-gradient(90deg, 
                rgba(255,255,255,0.03) 25%, 
                rgba(255,255,255,0.08) 50%, 
                rgba(255,255,255,0.03) 75%);
            background-size: 200% 100%;
            animation: shimmerWave 2s ease infinite;
            border-radius: var(--radius-sm);
        }

        /* v29.0: Card Spring Tilt v2 */
        .spring-tilt-card {
            transform-style: preserve-3d;
            perspective: 800px;
            transition: transform 0.1s ease-out;
        }

        .spring-tilt-card:hover {
            transform: rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg)) translateZ(10px);
        }

        /* v29.0: Animated Title with Gradient Flow */
        @keyframes gradientFlow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .gradient-text-flow {
            background: linear-gradient(270deg, var(--primary), var(--accent), var(--purple), var(--primary));
            background-size: 300% 100%;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: gradientFlow 4s ease infinite;
        }

        /* v29.0: Fox Character Enhancements */
        .fox-canvas-wrapper {
            position: relative;
        }

        .fox-shadow {
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 20px;
            background: radial-gradient(ellipse, rgba(0,0,0,0.4) 0%, transparent 70%);
            border-radius: 50%;
            animation: shadowBreath 3s ease-in-out infinite;
        }

        @keyframes shadowBreath {
            0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.4; }
            50% { transform: translateX(-50%) scale(1.1); opacity: 0.3; }
        }

        .fox-glow-aura {
            position: absolute;
            inset: -20px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.15) 0%, transparent 70%);
            animation: foxGlowPulse 2s ease-in-out infinite;
            pointer-events: none;
        }

        @keyframes foxGlowPulse {
            0%, 100% { opacity: 0.5; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.1); }
        }

        /* v29.0: Heartbeat Ring Animation */
        .heartbeat-ring {
            position: relative;
        }

        .heartbeat-ring::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            border: 2px solid var(--primary);
            animation: heartbeatRingPulse var(--bpm-duration, 1s) ease-out infinite;
            opacity: 0;
        }

        @keyframes heartbeatRingPulse {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(1.5); opacity: 0; }
        }

        /* v29.0: Number Morph Animation */
        @keyframes numberPop {
            0% { transform: scale(1); }
            50% { transform: scale(1.15); color: var(--primary); }
            100% { transform: scale(1); }
        }

        .number-pop {
            animation: numberPop 0.4s var(--ease-spring);
        }

        /* v29.0: Data Pulse Ripple */
        @keyframes dataRipple {
            0% { box-shadow: 0 0 0 0 rgba(0, 212, 255, 0.4); }
            100% { box-shadow: 0 0 0 12px rgba(0, 212, 255, 0); }
        }

        .data-pulse {
            animation: dataRipple 1s ease-out;
        }

        /* v29.0: Glassmorphism 2.0 */
        .glass-v2 {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(24px) saturate(180%);
            -webkit-backdrop-filter: blur(24px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 
                0 8px 32px rgba(0, 0, 0, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.1),
                inset 0 -1px 0 rgba(0, 0, 0, 0.1);
        }

        /* v29.0: Status Color Theming */
        body.status-working { --theme-color: var(--accent); }
        body.status-sleeping { --theme-color: var(--purple); }
        body.status-excited { --theme-color: var(--pink); }
        body.status-thinking { --theme-color: var(--purple); }
        body.status-error { --theme-color: var(--danger); }
        body.status-laughing { --theme-color: var(--primary); }
        body.status-focused { --theme-color: var(--success); }
        body.status-learning { --theme-color: var(--primary); }

        /* v29.0: Animated SVG Heartbeat Line */
        .heartbeat-svg {
            width: 100%;
            height: 32px;
            overflow: visible;
        }

        .heartbeat-path {
            fill: none;
            stroke: var(--primary);
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            filter: drop-shadow(0 0 4px var(--primary-glow));
        }

        /* v29.0: Corner Fold Effect */
        .corner-fold {
            position: relative;
            overflow: hidden;
        }

        .corner-fold::before {
            content: '';
            position: absolute;
            top: -20px;
            right: -20px;
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.05);
            transform: rotate(45deg);
            transition: all 0.3s ease;
        }

        .corner-fold:hover::before {
            top: -10px;
            right: -10px;
            background: rgba(255,255,255,0.1);
        }

        /* v29.0: Flip Card Effect */
        .flip-card {
            perspective: 1000px;
        }

        .flip-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform-style: preserve-3d;
        }

        /* v29.0: Marquee Text */
        @keyframes marqueeScroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .marquee-container {
            overflow: hidden;
            white-space: nowrap;
        }

        .marquee-content {
            display: inline-block;
            animation: marqueeScroll 20s linear infinite;
        }

        /* v29.0: Bounce In Animation */
        @keyframes bounceIn {
            0% { transform: scale(0); opacity: 0; }
            60% { transform: scale(1.2); opacity: 1; }
            80% { transform: scale(0.9); }
            100% { transform: scale(1); }
        }

        .bounce-in {
            animation: bounceIn 0.6s var(--ease-spring) forwards;
        }

        /* v29.0: Typewriter Effect v2 */
        @keyframes typewriterCursor {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        .typewriter-cursor-v2::after {
            content: '|';
            animation: typewriterCursor 0.8s ease infinite;
            color: var(--primary);
        }

        /* v29.0: Orbiting Dots */
        @keyframes orbit {
            from { transform: rotate(0deg) translateX(30px) rotate(0deg); }
            to { transform: rotate(360deg) translateX(30px) rotate(-360deg); }
        }

        .orbit-dot {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--primary);
            animation: orbit 3s linear infinite;
        }

        /* v29.0: Scroll Indicator */
        .scroll-indicator {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            opacity: 0.5;
        }

        .scroll-indicator span {
            width: 2px;
            height: 8px;
            background: var(--text-dim);
            border-radius: 2px;
            animation: scrollBounce 1.5s ease-in-out infinite;
        }

        .scroll-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .scroll-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes scrollBounce {
            0%, 100% { transform: translateY(0); opacity: 0.5; }
            50% { transform: translateY(4px); opacity: 1; }
        }

        /* v29.0: Magnetic Hover Effect */
        .magnetic-hover {
            transition: transform 0.2s var(--ease-spring);
        }

        /* v29.0: Neon Border Glow */
        @keyframes neonFlicker {
            0%, 100% { opacity: 1; }
            92% { opacity: 1; }
            93% { opacity: 0.8; }
            94% { opacity: 1; }
            96% { opacity: 0.9; }
            97% { opacity: 1; }
        }

        .neon-glow-v2 {
            animation: neonFlicker 3s ease-in-out infinite;
            box-shadow: 
                0 0 5px var(--theme-color, var(--primary)),
                0 0 10px var(--theme-color, var(--primary)),
                0 0 20px var(--theme-color, var(--primary));
        }

        /* v29.0: Responsive Enhancements */
        @media (max-width: 768px) {
            .dashboard-grid {
                gap: 12px;
            }
            .stat-card {
                padding: 12px;
            }
        }

        @media (max-width: 480px) {
            .dashboard-grid {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
</head>
<body class="loading">
    <!-- Background Effects -->
    <div class="bg-space"></div>
    <div class="bg-stars" id="stars"></div>
    <canvas class="bg-neural" id="neuralCanvas"></canvas>

    <!-- v24.0: Ambient Floating Orbs -->
    <div class="ambient-orb ambient-orb-1"></div>
    <div class="ambient-orb ambient-orb-2"></div>
    <div class="ambient-orb ambient-orb-3"></div>

    <!-- v29.0: Particle Mesh Background -->
    <canvas class="particle-mesh-canvas" id="particleMeshCanvas"></canvas>

    <!-- v29.0: Glow Cursor -->
    <div class="glow-cursor" id="glowCursor"></div>

    <!-- Main Dashboard -->
    <div class="dashboard-container">
        <div class="glass-card">
            <!-- Header -->
            <div class="dashboard-header">
                <div class="header-left">
                    <div class="status-badge">
                        <div class="status-dot" id="statusDot"></div>
                        <span id="statusText">Loading...</span>
                    </div>
                </div>
                <div class="header-right">
                    <div class="refresh-badge">
                        <div class="dot"></div>
                        <span id="refreshRate">Fast</span>
                    </div>
                </div>
            </div>

            <!-- Dashboard Grid -->
            <div class="dashboard-grid">
                <!-- Left Column -->
                <div class="left-column">
                    <!-- Avatar Section -->
                    <div class="avatar-section">
                        <div class="fox-container">
                            <div class="mood-aura" id="moodAura"></div>
                            <div class="energy-core">
                                <div class="energy-ring"></div>
                                <div class="energy-ring"></div>
                                <div class="energy-ring"></div>
                            </div>
                            <div class="fox-canvas-wrapper">
                                <div class="fox-shadow"></div>
                                <div class="fox-glow-aura" id="foxGlowAura"></div>
                                <canvas class="fox-canvas" id="foxCanvas"></canvas>
                            </div>
                            <div class="mood-sync-ring" id="moodSyncRing"></div>
                            <div class="fox-expression" id="foxExpression">😺</div>
                        </div>
                        <h1 class="fox-name gradient-text-animated">MoShang</h1>
                        <p class="fox-role">Digital Assistant</p>

                        <!-- Mini Stats -->
                        <div class="stats-row">
                            <div class="mini-stat">
                                <div class="mini-stat-value" id="miniHeartbeat">--</div>
                                <div class="mini-stat-label">BPM</div>
                            </div>
                            <div class="mini-stat">
                                <div class="mini-stat-value" id="miniActivity">--</div>
                                <div class="mini-stat-label">Activity</div>
                            </div>
                        </div>

                        <!-- Status Section -->
                        <div class="status-section">
                            <div class="status-title">Current Status</div>
                            <div class="status-value" id="statusValue">Idle</div>
                        </div>

                        <!-- Quick Actions -->
                        <div class="quick-actions">
                            <button class="action-btn" onclick="setMode('idle')">Idle</button>
                            <button class="action-btn" onclick="setMode('working')">Work</button>
                            <button class="action-btn" onclick="setMode('sleeping')">Sleep</button>
                        </div>

                        <!-- v26.0: Mood Selector -->
                        <div class="mood-selector" id="moodSelector">
                            <button class="mood-btn" onclick="setMood('idle')" title="Idle">😺</button>
                            <button class="mood-btn" onclick="setMood('excited')" title="Excited">🎉</button>
                            <button class="mood-btn" onclick="setMood('thinking')" title="Thinking">🤔</button>
                            <button class="mood-btn" onclick="setMood('laughing')" title="Laughing">😄</button>
                            <button class="mood-btn" onclick="setMood('focused')" title="Focused">🎯</button>
                        </div>

                        <!-- v26.0: Quick Stats Panel -->
                        <div class="quick-stats">
                            <div class="quick-stat">
                                <div class="quick-stat-value" id="quickMsgs">--</div>
                                <div class="quick-stat-label">Msgs</div>
                            </div>
                            <div class="quick-stat">
                                <div class="quick-stat-value" id="quickTasks">--</div>
                                <div class="quick-stat-label">Tasks</div>
                            </div>
                            <div class="quick-stat">
                                <div class="quick-stat-value" id="quickSkills">--</div>
                                <div class="quick-stat-label">Skills</div>
                            </div>
                        </div>

                        <div class="glass-divider"></div>

                        <!-- v26.0: Session Journey -->
                        <div class="session-journey" id="sessionJourney">
                            <div class="journey-title">🚀 Today's Journey</div>
                            <div class="journey-track">
                                <div class="journey-fill" id="journeyFill" style="width: 0%"></div>
                                <div class="journey-marker" id="journeyMarker" style="left: 0%"></div>
                            </div>
                            <div class="journey-label">
                                <span>Session Start</span>
                                <span id="journeyProgress">0%</span>
                            </div>
                        </div>

                        <!-- v25.0: Time-aware greeting -->
                        <div class="time-greeting" id="timeGreeting">Loading...</div>

                        <!-- v25.0: Activity Story -->
                        <div class="story-card" id="storyCard">
                            <div class="story-title">📊 Activity Story</div>
                            <div class="story-text" id="storyText">Analyzing today's rhythm...</div>
                        </div>

                        <!-- v25.0: Task Progress -->
                        <div class="task-progress" id="taskProgress" style="display:none;">
                            <div class="task-progress-header">
                                <span class="task-progress-label">Current Task</span>
                                <span class="task-progress-value" id="taskProgressValue">0%</span>
                            </div>
                            <div class="task-progress-bar">
                                <div class="task-progress-fill" id="taskProgressFill" style="width: 0%"></div>
                            </div>
                        </div>

                        <!-- v25.0: Thinking Chain -->
                        <div class="thinking-chain" id="thinkingChain" style="display:none;">
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <span class="thinking-label">Thinking...</span>
                        </div>

                        <!-- v25.0: Reputation Badge -->
                        <div class="reputation-badge" id="reputationBadge" title="EvoMap Reputation">
                            <span class="reputation-icon">⭐</span>
                            <span id="reputationValue">--</span>
                        </div>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="right-column">
                    <!-- Stat Cards -->
                    <div class="stat-card magnetic-card liquid-border data-flow corner-fold" onclick="copyStat('heartbeat')">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(255,200,100,0.1); color: var(--primary);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                            </div>
                            <div class="stat-value" id="heartbeat">--</div>
                        </div>
                        <div class="stat-label">Heart Rate</div>
                        <div class="stat-subtext">BPM • Click to copy</div>
                        <div class="progress-container">
                            <div class="progress-bar">
                                <div class="progress-fill" id="heartbeatBar" style="width: 0%"></div>
                            </div>
                        </div>
                        <svg class="mini-trend" id="heartbeatSparkline" viewBox="0 0 40 16" preserveAspectRatio="none"></svg>
                    </div>

                    <div class="stat-card magnetic-card liquid-border data-flow corner-fold" onclick="copyStat('activity')">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(0,212,255,0.1); color: var(--accent);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                                </svg>
                            </div>
                            <div class="stat-value" id="activity">--</div>
                        </div>
                        <div class="stat-label">Activity Level</div>
                        <div class="stat-subtext">0-100% • Click to copy</div>
                        <div class="progress-container">
                            <div class="progress-bar">
                                <div class="progress-fill" id="activityBar" style="width: 0%"></div>
                            </div>
                        </div>
                        <svg class="mini-trend" id="activitySparkline" viewBox="0 0 40 16" preserveAspectRatio="none"></svg>
                    </div>

                    <div class="stat-card magnetic-card liquid-border data-flow corner-fold" onclick="copyStat('memory')">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(92,219,149,0.1); color: var(--success);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="2" y="6" width="20" height="12" rx="2"/>
                                    <path d="M6 12h4M8 10v4M14 12h.01M18 12h.01"/>
                                </svg>
                            </div>
                            <div class="stat-value" id="memory">--</div>
                        </div>
                        <div class="stat-label">Memory Usage</div>
                        <div class="stat-subtext">MB • Click to copy</div>
                        <div class="progress-container">
                            <div class="progress-bar">
                                <div class="progress-fill" id="memoryBar" style="width: 0%"></div>
                            </div>
                        </div>
                        <svg class="mini-trend" id="memorySparkline" viewBox="0 0 40 16" preserveAspectRatio="none"></svg>
                    </div>

                    <div class="stat-card corner-fold" onclick="copyStat('cpu')">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(254,202,87,0.1); color: var(--warning);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="4" y="4" width="16" height="16" rx="2"/>
                                    <rect x="9" y="9" width="6" height="6"/>
                                    <path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"/>
                                </svg>
                            </div>
                            <div class="stat-value" id="cpu">--</div>
                        </div>
                        <div class="stat-label">CPU Usage</div>
                        <div class="stat-subtext">% • Click to copy</div>
                        <div class="progress-container">
                            <div class="progress-bar">
                                <div class="progress-fill" id="cpuBar" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Charts Section -->
                    <div class="charts-section">
                        <div class="charts-container">
                            <div class="chart-card">
                                <div class="chart-title">24h Activity Rhythm</div>
                                <div class="chart-canvas-container">
                                    <canvas class="chart-canvas" id="activityChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <div class="chart-title">Memory History</div>
                                <div class="chart-canvas-container">
                                    <canvas class="chart-canvas" id="memoryChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <div class="chart-title">CPU History</div>
                                <div class="chart-canvas-container">
                                    <canvas class="chart-canvas" id="cpuChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Section -->
                    <div class="bottom-section">
                        <!-- Memory Timeline -->
                        <div class="memory-timeline">
                            <div class="timeline-header">
                                <div class="timeline-title">Recent Memories</div>
                            </div>
                            <div class="timeline-items" id="timelineItems">
                                <!-- Timeline items will be inserted here -->
                            </div>
                        </div>

                        <!-- Skills Distribution -->
                        <div class="skills-distribution">
                            <div class="skills-title">Skills Distribution</div>
                            <div id="skillsList">
                                <!-- Skills will be inserted here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="dashboard-footer">
                <div class="footer-info">
                    Last updated: <span id="lastUpdated">--</span>
                    <!-- v24.0: Data source health indicator -->
                    <span id="dataSourceHealth" class="data-source-badge" title="Data Source Health">
                        <span class="source-dot" id="sourceDot"></span>
                        <span id="sourceName">--</span>
                    </span>
                    <!-- v27.0: External route status indicator -->
                    <span id="externalRouteStatus" class="external-route-badge" title="External Route Status">
                        <span class="route-dot" id="routeDot"></span>
                        <span id="routeName">Route</span>
                    </span>
                </div>
                <div class="footer-info">
                    v29.0 • <span id="uptime">--</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ========== State Management ==========
        const state = {
            heartbeat: '--',
            activity: '--',
            memory: '--',
            cpu: '--',
            status: 'idle',
            uptime: '--',
            lastUpdated: '--',
            dataHistory: {
                heartbeat: [],
                activity: [],
                memory: [],
                cpu: []
            },
            maxHistory: 24,
            // v24.0: Data reliability tracking
            dataSource: 'api',
            dataAge: 0,
            lastSuccessfulFetch: null,
            consecutiveErrors: 0,
            isOnline: true,
            // v25.0: Enhanced state
            sessionStart: Date.now(),
            peakActivityCount: 0,
            lastPeakTime: null,
            currentTask: null,
            taskProgress: 0,
            reputation: null,
            activityPeaks: [],
            storyNarrative: '',
            // v26.0: Quick stats
            msgCount: 0,
            taskDone: 0,
            skillsTotal: 0
        };

        // ========== DOM Elements ==========
        const elements = {
            body: document.body,
            statusDot: document.getElementById('statusDot'),
            statusText: document.getElementById('statusText'),
            refreshRate: document.getElementById('refreshRate'),
            foxCanvas: document.getElementById('foxCanvas'),
            moodSyncRing: document.getElementById('moodSyncRing'),
            heartbeat: document.getElementById('heartbeat'),
            activity: document.getElementById('activity'),
            memory: document.getElementById('memory'),
            cpu: document.getElementById('cpu'),
            heartbeatBar: document.getElementById('heartbeatBar'),
            activityBar: document.getElementById('activityBar'),
            memoryBar: document.getElementById('memoryBar'),
            cpuBar: document.getElementById('cpuBar'),
            miniHeartbeat: document.getElementById('miniHeartbeat'),
            miniActivity: document.getElementById('miniActivity'),
            statusValue: document.getElementById('statusValue'),
            lastUpdated: document.getElementById('lastUpdated'),
            uptime: document.getElementById('uptime'),
            timelineItems: document.getElementById('timelineItems'),
            skillsList: document.getElementById('skillsList'),
            stars: document.getElementById('stars'),
            neuralCanvas: document.getElementById('neuralCanvas'),
            // v24.0: Data source health
            sourceDot: document.getElementById('sourceDot'),
            sourceName: document.getElementById('sourceName'),
            // v27.0: External route status
            routeDot: document.getElementById('routeDot'),
            routeName: document.getElementById('routeName'),
            externalRouteBadge: document.getElementById('externalRouteStatus')
        };

        // v24.0: Ripple Click Effect Generator
        function createRipple(event, element) {
            const ripple = document.createElement('span');
            ripple.className = 'ripple';
            const rect = element.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height);
            ripple.style.width = ripple.style.height = size + 'px';
            ripple.style.left = (event.clientX - rect.left - size / 2) + 'px';
            ripple.style.top = (event.clientY - rect.top - size / 2) + 'px';
            element.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);
        }

        // v24.0: Enhanced Particle Burst
        function createEnhancedParticleBurst(ctx, x, y, color = '#ffc864') {
            const particles = [];
            const particleCount = 16;

            for (let i = 0; i < particleCount; i++) {
                const angle = (Math.PI * 2 / particleCount) * i;
                const velocity = 4 + Math.random() * 6;
                particles.push({
                    x: x,
                    y: y,
                    vx: Math.cos(angle) * velocity,
                    vy: Math.sin(angle) * velocity,
                    life: 1,
                    color: color,
                    size: 3 + Math.random() * 4
                });
            }

            function animate() {
                let alive = false;
                particles.forEach(p => {
                    if (p.life > 0) {
                        alive = true;
                        p.x += p.vx;
                        p.y += p.vy;
                        p.vy += 0.15; // gravity
                        p.life -= 0.025;

                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
                        ctx.fillStyle = p.color;
                        ctx.globalAlpha = p.life;
                        ctx.fill();
                        ctx.globalAlpha = 1;
                    }
                });

                if (alive) {
                    requestAnimationFrame(animate);
                }
            }

            animate();
        }

        // v24.0: Data Source Health Update
        function updateDataSourceHealth(source, isHealthy) {
            if (!elements.sourceDot || !elements.sourceName) return;

            state.dataSource = source;
            state.lastSuccessfulFetch = Date.now();
            state.consecutiveErrors = 0;
            state.isOnline = isHealthy;

            elements.sourceDot.className = 'source-dot' + (isHealthy ? '' : ' error');
            elements.sourceName.textContent = source;

            // Fade out error styling
            elements.body.classList.remove('error');
        }

        // v24.0: Data Age Indicator
        function updateDataAgeIndicator() {
            if (!state.lastSuccessfulFetch) return;

            const age = (Date.now() - state.lastSuccessfulFetch) / 1000;
            state.dataAge = age;

            if (age > 30) {
                elements.sourceDot.className = 'source-dot stale';
                elements.sourceName.textContent = 'Stale';
            } else {
                elements.sourceDot.className = 'source-dot';
                elements.sourceName.textContent = state.dataSource;
            }
        }

        // v24.0: Online/Offline detection
        function setupConnectivityMonitoring() {
            window.addEventListener('online', () => {
                state.isOnline = true;
                updateDataSourceHealth('api', true);
                showToast('Connection restored', 'success');
            });

            window.addEventListener('offline', () => {
                state.isOnline = false;
                updateDataSourceHealth('offline', false);
                showToast('Connection lost - using cached data', 'warning');
            });
        }

        // v27.0: External Route Status Checker
        const EXTERNAL_URL = 'https://oclaw.mochencloud.cn:1443/onboard/';
        let externalRouteCheckTimer = null;

        function checkExternalRoute() {
            if (!elements.routeDot || !elements.externalRouteBadge) return;

            // Show checking state
            elements.externalRouteBadge.classList.add('checking');
            elements.routeDot.className = 'route-dot';
            elements.routeName.textContent = 'Checking...';

            // Use a beacon or fetch with timeout to check if external URL is accessible
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 5000);

            fetch(EXTERNAL_URL, {
                method: 'HEAD',
                mode: 'no-cors',
                cache: 'no-cache'
            })
            .then(() => {
                clearTimeout(timeoutId);
                // If we get here without error, the route is likely accessible
                updateExternalRouteStatus(true);
            })
            .catch(() => {
                clearTimeout(timeoutId);
                // Even with no-cors, some errors indicate the route is down
                updateExternalRouteStatus(false);
            });
        }

        function updateExternalRouteStatus(isOnline) {
            if (!elements.routeDot || !elements.externalRouteBadge) return;

            elements.externalRouteBadge.classList.remove('checking');

            if (isOnline) {
                elements.externalRouteBadge.classList.remove('offline');
                elements.externalRouteBadge.classList.add('online');
                elements.routeDot.classList.remove('offline');
                elements.routeDot.classList.add('online');
                elements.routeName.textContent = 'Online';
            } else {
                elements.externalRouteBadge.classList.remove('online');
                elements.externalRouteBadge.classList.add('offline');
                elements.routeDot.classList.remove('online');
                elements.routeDot.classList.add('offline');
                elements.routeName.textContent = 'Route Down';
            }
        }

        function startExternalRouteMonitoring() {
            // Check immediately
            checkExternalRoute();
            // Then check every 30 seconds
            if (externalRouteCheckTimer) clearInterval(externalRouteCheckTimer);
            externalRouteCheckTimer = setInterval(checkExternalRoute, 30000);
        }

        // v25.0: Time-aware greeting
        function updateTimeGreeting() {
            const hour = new Date().getHours();
            const greeting = document.getElementById('timeGreeting');
            if (!greeting) return;

            let timeText = '';
            if (hour >= 5 && hour < 12) timeText = '🌤️ 上午好，哥哥';
            else if (hour >= 12 && hour < 14) timeText = '☀️ 中午好';
            else if (hour >= 14 && hour < 18) timeText = '🌅 下午好';
            else if (hour >= 18 && hour < 22) timeText = '🌙 晚上好';
            else timeText = '🌛 夜深了';

            greeting.textContent = timeText;
        }

        // v25.0: Activity story generation
        function generateActivityStory() {
            const storyText = document.getElementById('storyText');
            if (!storyText) return;

            const sessionMinutes = Math.floor((Date.now() - state.sessionStart) / 60000);
            const recentActivity = state.activityPeaks.length;

            // Generate narrative based on current state
            if (state.activity >= 80) {
                storyText.innerHTML = `🔥 活跃高峰期！今天第<span class="story-highlight">${recentActivity + 1}</span>次高峰，状态极佳`;
                state.activityPeaks.push(Date.now());
            } else if (state.activity >= 50) {
                const minutesWorking = sessionMinutes > 0 ? sessionMinutes : 1;
                storyText.innerHTML = `⚡ 稳定运行中，已活跃 <span class="story-highlight">${minutesWorking}</span> 分钟`;
            } else if (state.status === 'sleeping') {
                storyText.innerHTML = `😴 休息模式，恢复能量中...`;
            } else if (state.status === 'thinking') {
                storyText.innerHTML = `🧠 深度思考中...`;
            } else {
                storyText.innerHTML = `✨ 待命中，随时准备服务哥哥`;
            }
        }

        // v25.0: Update thinking chain visibility
        function updateThinkingChain(show) {
            const chain = document.getElementById('thinkingChain');
            if (chain) {
                chain.style.display = show ? 'flex' : 'none';
            }
        }

        // v25.0: Update task progress
        function updateTaskProgress(task, progress) {
            state.currentTask = task;
            state.taskProgress = progress;

            const container = document.getElementById('taskProgress');
            const value = document.getElementById('taskProgressValue');
            const fill = document.getElementById('taskProgressFill');

            if (container) {
                if (task) {
                    container.style.display = 'block';
                    if (value) value.textContent = progress + '%';
                    if (fill) fill.style.width = progress + '%';
                } else {
                    container.style.display = 'none';
                }
            }
        }

        // v25.0: Reputation display
        function updateReputation(rep) {
            state.reputation = rep;
            const el = document.getElementById('reputationValue');
            if (el) {
                el.textContent = rep !== null ? rep : '--';
            }
        }

        // ========== Initialization ==========
        async function init() {
            // v24.0: Setup connectivity monitoring first
            setupConnectivityMonitoring();

            // v27.0: Start external route monitoring
            startExternalRouteMonitoring();

            // Initialize star background
            initStars();

            // Initialize neural network background
            initNeuralNetwork();

            // Initialize fox canvas
            initFoxCanvas();

            // Initialize charts
            initCharts();

            // Load initial data
            await fetchData();

            // v25.0: Initialize new features
            updateTimeGreeting();
            generateActivityStory();

            // Start periodic updates
            setInterval(updateData, 3000);

            // v25.0: Update story and greeting periodically
            setInterval(() => {
                updateTimeGreeting();
                generateActivityStory();
            }, 30000);

            // v24.0: Data age indicator update
            setInterval(() => {
                if (state.lastSuccessfulFetch) {
                    const age = (Date.now() - state.lastSuccessfulFetch) / 1000;
                    if (age > 30 && elements.sourceDot) {
                        elements.sourceDot.className = 'source-dot stale';
                        elements.sourceName.textContent = 'Stale';
                    }
                }
            }, 5000);

            // Remove loading state
            setTimeout(() => {
                elements.body.classList.remove('loading');
            }, 500);
        }

        // ========== Star Background ==========
        function initStars() {
            const starsContainer = elements.stars;
            const starCount = 100;

            for (let i = 0; i < starCount; i++) {
                const star = document.createElement('div');
                star.style.cssText = `
                    position: absolute;
                    width: ${Math.random() * 2 + 1}px;
                    height: ${Math.random() * 2 + 1}px;
                    background: white;
                    border-radius: 50%;
                    opacity: ${Math.random() * 0.5 + 0.3};
                    left: ${Math.random() * 100}%;
                    top: ${Math.random() * 100}%;
                    animation: twinkle ${Math.random() * 3 + 2}s ease-in-out infinite;
                `;
                starsContainer.appendChild(star);
            }
        }

        // ========== Neural Network Background ==========
        function initNeuralNetwork() {
            const canvas = elements.neuralCanvas;
            const ctx = canvas.getContext('2d');

            // Set canvas size
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            const nodes = [];
            const nodeCount = 50;

            // Create nodes
            for (let i = 0; i < nodeCount; i++) {
                nodes.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: (Math.random() - 0.5) * 0.5,
                    radius: Math.random() * 2 + 1
                });
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                // Update and draw nodes
                nodes.forEach(node => {
                    node.x += node.vx;
                    node.y += node.vy;

                    // Bounce off edges
                    if (node.x < 0 || node.x > canvas.width) node.vx *= -1;
                    if (node.y < 0 || node.y > canvas.height) node.vy *= -1;

                    // Draw node
                    ctx.beginPath();
                    ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(0, 212, 255, 0.5)';
                    ctx.fill();

                    // Draw connections
                    nodes.forEach(otherNode => {
                        const dx = node.x - otherNode.x;
                        const dy = node.y - otherNode.y;
                        const distance = Math.sqrt(dx * dx + dy * dy);

                        if (distance < 150) {
                            ctx.beginPath();
                            ctx.moveTo(node.x, node.y);
                            ctx.lineTo(otherNode.x, otherNode.y);
                            ctx.strokeStyle = `rgba(0, 212, 255, ${0.2 * (1 - distance / 150)})`;
                            ctx.lineWidth = 1;
                            ctx.stroke();
                        }
                    });
                });

                requestAnimationFrame(animate);
            }

            animate();

            // Resize handler
            window.addEventListener('resize', () => {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            });
        }

        // ========== Fox Canvas v29.0 ==========
        function initFoxCanvas() {
            const canvas = elements.foxCanvas;
            const ctx = canvas.getContext('2d');
            const width = canvas.width = 180;
            const height = canvas.height = 180;

            let mouseX = width / 2;
            let mouseY = height / 2;
            let eyeX = 0;
            let eyeY = 0;
            let breathPhase = 0;

            // Mouse tracking
            canvas.addEventListener('mousemove', (e) => {
                const rect = canvas.getBoundingClientRect();
                mouseX = e.clientX - rect.left;
                mouseY = e.clientY - rect.top;
            });

            // Click effect
            canvas.addEventListener('click', (e) => {
                const colors = {
                    idle: '#ffc864', working: '#00d4ff', sleeping: '#a855f7',
                    excited: '#ec4899', error: '#ff6b6b', thinking: '#a855f7',
                    laughing: '#ffc864', focused: '#5cdb95', learning: '#ffc864'
                };
                const color = colors[state.status] || '#ffc864';
                createParticleBurst(ctx, width / 2, height / 2, color);
            });

            // Blinking
            let lastBlink = 0;
            let isBlinking = false;
            let blinkProgress = 0;
            function blink() {
                const now = Date.now();
                if (!isBlinking && now - lastBlink > 3000 + Math.random() * 2000) {
                    isBlinking = true;
                    lastBlink = now;
                    blinkProgress = 0;
                }
                if (isBlinking) {
                    blinkProgress += 0.08;
                    if (blinkProgress >= 1) {
                        isBlinking = false;
                        blinkProgress = 0;
                    }
                }
                // Smooth blink curve
                if (isBlinking) {
                    return Math.cos(blinkProgress * Math.PI) * 0.5 + 0.5; // 0 to 1 to 0
                }
                return 0;
            }

            // Ear twitch
            let earTwitchPhase = 0;

            function drawFox() {
                ctx.clearRect(0, 0, width, height);

                // Breathing animation
                breathPhase += 0.02;
                const breathScale = 1 + Math.sin(breathPhase) * 0.02;

                // Smooth eye tracking
                eyeX += (mouseX - width / 2 - eyeX) * 0.08;
                eyeY += (mouseY - height / 2 - eyeY) * 0.08;

                const cx = width / 2;
                const cy = height / 2;
                const blinkAmt = blink();
                const eyeScaleY = Math.max(0.1, 1 - blinkAmt * 0.9);

                ctx.save();
                ctx.translate(cx, cy);
                ctx.scale(breathScale, breathScale);
                ctx.translate(-cx, -cy);

                // Draw shadow beneath fox
                ctx.save();
                ctx.fillStyle = 'rgba(0, 0, 0, 0.15)';
                ctx.beginPath();
                ctx.ellipse(cx, cy + 65, 40 * breathScale, 10, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();

                // Body gradient
                const bodyGrad = ctx.createRadialGradient(cx - 10, cy + 20, 0, cx, cy + 20, 60);
                bodyGrad.addColorStop(0, '#ffe4a0');
                bodyGrad.addColorStop(0.6, '#ffc864');
                bodyGrad.addColorStop(1, '#e0a830');

                // Body
                ctx.fillStyle = bodyGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy + 22, 50, 38, 0, 0, Math.PI * 2);
                ctx.fill();

                // Chest highlight
                const chestGrad = ctx.createRadialGradient(cx, cy + 15, 0, cx, cy + 15, 25);
                chestGrad.addColorStop(0, 'rgba(255,255,220,0.5)');
                chestGrad.addColorStop(1, 'rgba(255,255,220,0)');
                ctx.fillStyle = chestGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy + 10, 25, 20, 0, 0, Math.PI * 2);
                ctx.fill();

                // Head gradient
                const headGrad = ctx.createRadialGradient(cx - 8, cy - 25, 0, cx, cy - 20, 50);
                headGrad.addColorStop(0, '#ffe4a0');
                headGrad.addColorStop(0.6, '#ffc864');
                headGrad.addColorStop(1, '#e0a830');

                ctx.fillStyle = headGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy - 20, 44, 38, 0, 0, Math.PI * 2);
                ctx.fill();

                // Inner face light
                const faceGrad = ctx.createRadialGradient(cx - 5, cy - 30, 0, cx, cy - 25, 30);
                faceGrad.addColorStop(0, 'rgba(255,255,230,0.6)');
                faceGrad.addColorStop(1, 'rgba(255,255,230,0)');
                ctx.fillStyle = faceGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy - 25, 28, 22, 0, 0, Math.PI * 2);
                ctx.fill();

                // Ears with gradient
                earTwitchPhase += 0.05;
                const earTwitch = Math.sin(earTwitchPhase) * (state.status === 'idle' || state.status === 'working' ? 2 : 0);

                // Left ear
                ctx.fillStyle = '#ffc864';
                ctx.beginPath();
                ctx.moveTo(cx - 32, cy - 55);
                ctx.lineTo(cx - 22 + earTwitch, cy - 90);
                ctx.lineTo(cx - 10, cy - 55);
                ctx.fill();
                // Inner ear
                ctx.fillStyle = '#ffb8c0';
                ctx.beginPath();
                ctx.moveTo(cx - 28, cy - 55);
                ctx.lineTo(cx - 22 + earTwitch * 0.5, cy - 78);
                ctx.lineTo(cx - 16, cy - 55);
                ctx.fill();

                // Right ear
                ctx.fillStyle = '#ffc864';
                ctx.beginPath();
                ctx.moveTo(cx + 32, cy - 55);
                ctx.lineTo(cx + 22 - earTwitch, cy - 90);
                ctx.lineTo(cx + 10, cy - 55);
                ctx.fill();
                // Inner ear
                ctx.fillStyle = '#ffb8c0';
                ctx.beginPath();
                ctx.moveTo(cx + 28, cy - 55);
                ctx.lineTo(cx + 22 - earTwitch * 0.5, cy - 78);
                ctx.lineTo(cx + 16, cy - 55);
                ctx.fill();

                // Eye white glow
                const eyeGlow = ctx.createRadialGradient(cx - 15, cy - 25, 0, cx - 15, cy - 25, 14);
                eyeGlow.addColorStop(0, 'rgba(255,255,255,0.8)');
                eyeGlow.addColorStop(1, 'rgba(255,255,255,0)');
                ctx.fillStyle = eyeGlow;
                ctx.beginPath();
                ctx.ellipse(cx - 15, cy - 25, 14, 16 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(cx + 15, cy - 25, 14, 16 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();

                // Eyes
                ctx.fillStyle = '#ffffff';
                ctx.beginPath();
                ctx.ellipse(cx - 15, cy - 25, 10, 12 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(cx + 15, cy - 25, 10, 12 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();

                // Pupils with iris color
                if (blinkAmt < 0.5) {
                    // Iris
                    ctx.fillStyle = '#8B6914';
                    ctx.beginPath();
                    ctx.arc(cx - 15 + eyeX * 0.4, cy - 25 + eyeY * 0.4, 5, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(cx + 15 + eyeX * 0.4, cy - 25 + eyeY * 0.4, 5, 0, Math.PI * 2);
                    ctx.fill();

                    // Pupil
                    ctx.fillStyle = '#1a1a1a';
                    ctx.beginPath();
                    ctx.arc(cx - 15 + eyeX * 0.4, cy - 25 + eyeY * 0.4, 3, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(cx + 15 + eyeX * 0.4, cy - 25 + eyeY * 0.4, 3, 0, Math.PI * 2);
                    ctx.fill();

                    // Eye highlight
                    ctx.fillStyle = 'rgba(255,255,255,0.8)';
                    ctx.beginPath();
                    ctx.arc(cx - 17 + eyeX * 0.2, cy - 28 + eyeY * 0.2, 1.5, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(cx + 13 + eyeX * 0.2, cy - 28 + eyeY * 0.2, 1.5, 0, Math.PI * 2);
                    ctx.fill();
                }

                // Nose
                const noseGrad = ctx.createRadialGradient(cx - 1, cy - 12, 0, cx, cy - 10, 8);
                noseGrad.addColorStop(0, '#555555');
                noseGrad.addColorStop(1, '#222222');
                ctx.fillStyle = noseGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy - 10, 6, 5, 0, 0, Math.PI * 2);
                ctx.fill();

                // Nose highlight
                ctx.fillStyle = 'rgba(255,255,255,0.3)';
                ctx.beginPath();
                ctx.ellipse(cx - 2, cy - 12, 2, 1.5, 0, 0, Math.PI * 2);
                ctx.fill();

                // Blush
                ctx.fillStyle = 'rgba(255, 150, 150, 0.3)';
                ctx.beginPath();
                ctx.ellipse(cx - 32, cy - 15, 8, 5, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(cx + 32, cy - 15, 8, 5, 0, 0, Math.PI * 2);
                ctx.fill();

                // Mouth
                ctx.strokeStyle = '#c08030';
                ctx.lineWidth = 2;
                ctx.lineCap = 'round';
                ctx.beginPath();
                ctx.arc(cx, cy - 3, 10, 0.15 * Math.PI, 0.85 * Math.PI);
                ctx.stroke();

                // Tiny whiskers
                ctx.strokeStyle = 'rgba(200,160,50,0.4)';
                ctx.lineWidth = 0.8;
                // Left whiskers
                ctx.beginPath(); ctx.moveTo(cx - 10, cy - 8); ctx.lineTo(cx - 28, cy - 12); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(cx - 10, cy - 6); ctx.lineTo(cx - 28, cy - 5); ctx.stroke();
                // Right whiskers
                ctx.beginPath(); ctx.moveTo(cx + 10, cy - 8); ctx.lineTo(cx + 28, cy - 12); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(cx + 10, cy - 6); ctx.lineTo(cx + 28, cy - 5); ctx.stroke();

                ctx.restore();

                // v29.0: State-based eye effects
                if (state.status === 'excited') {
                    // Excited: heart sparkles around eyes
                    ctx.fillStyle = 'rgba(255,100,150,0.6)';
                    for (let i = 0; i < 3; i++) {
                        const angle = (Date.now() / 500 + i * 2) % (Math.PI * 2);
                        const sx = cx - 15 + Math.cos(angle) * 22;
                        const sy = cy - 30 + Math.sin(angle) * 12;
                        ctx.beginPath();
                        ctx.arc(sx, sy, 2, 0, Math.PI * 2);
                        ctx.fill();
                    }
                }

                if (state.status === 'sleeping') {
                    // Sleeping: Zzz
                    ctx.fillStyle = 'rgba(168,85,247,0.6)';
                    ctx.font = 'bold 12px Outfit';
                    const zzOffset = (Date.now() / 800) % 20;
                    ctx.fillText('z', cx + 35 + zzOffset * 0.3, cy - 60 - zzOffset);
                    ctx.fillText('z', cx + 40 + zzOffset * 0.5, cy - 70 - zzOffset * 0.8);
                }

                requestAnimationFrame(drawFox);
            }

            drawFox();
        }

        // ========== Particle Burst Effect ==========
        function createParticleBurst(ctx, x, y) {
            const particles = [];
            const particleCount = 12;

            for (let i = 0; i < particleCount; i++) {
                const angle = (Math.PI * 2 / particleCount) * i;
                const velocity = 5 + Math.random() * 5;
                particles.push({
                    x: x,
                    y: y,
                    vx: Math.cos(angle) * velocity,
                    vy: Math.sin(angle) * velocity,
                    life: 1,
                    color: ['#ffc864', '#00d4ff', '#5cdb95', '#ff6b6b'][Math.floor(Math.random() * 4)]
                });
            }

            function animate() {
                let alive = false;

                particles.forEach(p => {
                    if (p.life > 0) {
                        alive = true;
                        p.x += p.vx;
                        p.y += p.vy;
                        p.life -= 0.05;

                        ctx.beginPath();
                        ctx.arc(p.x, p.y, 4 * p.life, 0, Math.PI * 2);
                        ctx.fillStyle = p.color;
                        ctx.globalAlpha = p.life;
                        ctx.fill();
                        ctx.globalAlpha = 1;
                    }
                });

                if (alive) {
                    requestAnimationFrame(animate);
                }
            }

            animate();
        }

        // ========== Charts ==========
        function initCharts() {
            // Initialize empty charts
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
            createLineChart('memoryChart', state.dataHistory.memory, '#5cdb95');
            createLineChart('cpuChart', state.dataHistory.cpu, '#00d4ff');
        }

        function createLineChart(canvasId, data, color) {
            const canvas = document.getElementById(canvasId);
            const ctx = canvas.getContext('2d');

            // Set canvas size
            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = canvas.parentElement.clientHeight;

            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                if (data.length < 2) return;

                const max = Math.max(...data, 100);
                const min = Math.min(...data, 0);
                const range = max - min || 1;

                // Draw line
                ctx.beginPath();
                data.forEach((value, index) => {
                    const x = (index / (data.length - 1)) * canvas.width;
                    const y = canvas.height - ((value - min) / range) * canvas.height;
                    if (index === 0) {
                        ctx.moveTo(x, y);
                    } else {
                        ctx.lineTo(x, y);
                    }
                });

                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.stroke();

                // Fill area
                ctx.lineTo(canvas.width, canvas.height);
                ctx.lineTo(0, canvas.height);
                ctx.closePath();
                ctx.fillStyle = color + '20';
                ctx.fill();
            }

            draw();
        }

        // ========== Data Fetching ==========
        async function fetchData() {
            // v24.0: Check connectivity before fetching
            if (!state.isOnline) {
                return;
            }

            try {
                // Fetch heartbeat data
                const heartbeatRes = await fetch('/api/heartbeat');
                if (!heartbeatRes.ok) throw new Error('Heartbeat API failed');
                const heartbeatData = await heartbeatRes.json();

                // v24.0: Update data source health
                updateDataSourceHealth(heartbeatData.source || 'api', true);

                if (heartbeatData.heartbeat) {
                    updateHeartbeat(heartbeatData.heartbeat);
                }

                if (heartbeatData.activity) {
                    updateActivity(heartbeatData.activity);
                }

                if (heartbeatData.status) {
                    updateStatus(heartbeatData.status);
                }

                if (heartbeatData.uptime) {
                    updateUptime(heartbeatData.uptime);
                }

                // v25.0: Handle additional agent status
                if (heartbeatData.reputation !== undefined) {
                    updateReputation(heartbeatData.reputation);
                }

                if (heartbeatData.currentTask) {
                    updateTaskProgress(heartbeatData.currentTask, heartbeatData.taskProgress || 0);
                }

                // Fetch system data
                const systemRes = await fetch('/api/system');
                if (systemRes.ok) {
                    const systemData = await systemRes.json();

                    if (systemData.memory) {
                        updateMemory(systemData.memory);
                    }

                    if (systemData.cpu !== undefined) {
                        updateCPU(systemData.cpu);
                    }
                }

                // Fetch memories
                const memoriesRes = await fetch('/api/memories');
                if (memoriesRes.ok) {
                    const memories = await memoriesRes.json();
                    updateMemories(memories);
                }

                // Fetch skills
                const skillsRes = await fetch('/api/skills/detailed');
                if (skillsRes.ok) {
                    const skills = await skillsRes.json();
                    updateSkills(skills);
                    // v26.0: Update quick stats for skills
                    if (skills.summary) {
                        state.skillsTotal = skills.summary.total || 0;
                        updateQuickStats();
                    }
                }

                // v26.0: Fetch dashboard API for complete data
                const dashRes = await fetch('/api/dashboard');
                if (dashRes.ok) {
                    const dashData = await dashRes.json();
                    if (dashData.msgCount !== undefined) {
                        state.msgCount = dashData.msgCount;
                    }
                    if (dashData.taskDone !== undefined) {
                        state.taskDone = dashData.taskDone;
                    }
                    updateQuickStats();
                }

                // Update last updated time
                elements.lastUpdated.textContent = new Date().toLocaleTimeString();

                // v24.0: Reset error counter on success
                state.consecutiveErrors = 0;

            } catch (error) {
                console.error('Error fetching data:', error);
                state.consecutiveErrors++;

                // v24.0: Mark as stale after consecutive errors
                if (state.consecutiveErrors >= 2) {
                    if (elements.sourceDot) {
                        elements.sourceDot.className = 'source-dot stale';
                        elements.sourceName.textContent = 'Stale';
                    }
                }

                elements.statusText.textContent = 'Error';
                elements.statusDot.classList.add('error');
            }
        }

        // v24.0: Update data source health
        function updateDataSourceHealth(source, isHealthy) {
            if (!elements.sourceDot || !elements.sourceName) return;

            state.dataSource = source;
            state.lastSuccessfulFetch = Date.now();
            state.consecutiveErrors = 0;
            state.isOnline = isHealthy;

            elements.sourceDot.className = 'source-dot' + (isHealthy ? '' : ' error');
            elements.sourceName.textContent = source;
            elements.body.classList.remove('error');
        }

        // v24.0: Online/Offline detection
        function setupConnectivityMonitoring() {
            window.addEventListener('online', () => {
                state.isOnline = true;
                updateDataSourceHealth('api', true);
            });

            window.addEventListener('offline', () => {
                state.isOnline = false;
                if (elements.sourceDot) elements.sourceDot.className = 'source-dot error';
                if (elements.sourceName) elements.sourceName.textContent = 'Offline';
            });
        }

        function updateData() {
            fetchData();
        }

        function updateHeartbeat(value) {
            state.heartbeat = value;
            
            // v23.0: Num pop animation
            elements.heartbeat.classList.add('num-pop');
            setTimeout(() => elements.heartbeat.classList.remove('num-pop'), 300);
            
            elements.heartbeat.textContent = value;
            elements.miniHeartbeat.textContent = value;

            // Update progress bar
            const percent = Math.min((value / 180) * 100, 100);
            elements.heartbeatBar.style.width = percent + '%';
            elements.heartbeatBar.className = 'progress-fill ' + getProgressClass(percent);

            // Update history
            state.dataHistory.heartbeat.push(value);
            if (state.dataHistory.heartbeat.length > state.maxHistory) {
                state.dataHistory.heartbeat.shift();
            }

            // v29.0: Update sparkline
            updateSparkline('heartbeatSparkline', state.dataHistory.heartbeat.slice(-12), '#ffc864');
            updateHeartbeatRing(value);

            // Update chart
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
        }

        function updateActivity(value) {
            state.activity = value;
            
            // v23.0: Num pop animation
            elements.activity.classList.add('num-pop');
            setTimeout(() => elements.activity.classList.remove('num-pop'), 300);
            
            elements.activity.textContent = value + '%';
            elements.miniActivity.textContent = value + '%';

            // Update progress bar
            elements.activityBar.style.width = value + '%';
            elements.activityBar.className = 'progress-fill ' + getProgressClass(value);

            // v25.0: Track activity peaks
            if (value >= 80 && !state.lastPeakTime || (state.lastPeakTime && Date.now() - state.lastPeakTime > 300000)) {
                state.peakActivityCount++;
                state.lastPeakTime = Date.now();
            }

            // Update history
            state.dataHistory.activity.push(value);
            if (state.dataHistory.activity.length > state.maxHistory) {
                state.dataHistory.activity.shift();
            }

            // v25.0: Generate activity story on significant changes
            generateActivityStory();

            // v29.0: Update sparkline
            updateSparkline('activitySparkline', state.dataHistory.activity.slice(-12), '#00d4ff');

            // Update chart
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
        }

        function updateMemory(value) {
            state.memory = value;
            
            // v23.0: Num pop animation
            elements.memory.classList.add('num-pop');
            setTimeout(() => elements.memory.classList.remove('num-pop'), 300);
            
            elements.memory.textContent = value;

            // Update progress bar
            const percent = Math.min((value / state.memoryTotal) * 100, 100);
            elements.memoryBar.style.width = percent + '%';
            elements.memoryBar.className = 'progress-fill ' + getProgressClass(percent);

            // Update history
            state.dataHistory.memory.push(value);
            if (state.dataHistory.memory.length > state.maxHistory) {
                state.dataHistory.memory.shift();
            }

            // v29.0: Update sparkline
            updateSparkline('memorySparkline', state.dataHistory.memory.slice(-12), '#5cdb95');

            // Update chart
            createLineChart('memoryChart', state.dataHistory.memory, '#5cdb95');
        }

        function updateCPU(value) {
            state.cpu = value;
            
            // v23.0: Num pop animation
            elements.cpu.classList.add('num-pop');
            setTimeout(() => elements.cpu.classList.remove('num-pop'), 300);
            
            elements.cpu.textContent = value + '%';

            // Update progress bar
            elements.cpuBar.style.width = value + '%';
            elements.cpuBar.className = 'progress-fill ' + getProgressClass(value);

            // Update history
            state.dataHistory.cpu.push(value);
            if (state.dataHistory.cpu.length > state.maxHistory) {
                state.dataHistory.cpu.shift();
            }

            // Update chart
            createLineChart('cpuChart', state.dataHistory.cpu, '#00d4ff');
        }

        function updateStatus(status) {
            state.status = status;
            elements.statusValue.textContent = status.charAt(0).toUpperCase() + status.slice(1);

            // v29.0: Update body status class for theme color
            updateBodyStatusClass(status);

            // Update mood ring
            elements.moodSyncRing.className = 'mood-sync-ring ' + status;
            elements.moodSyncRing.classList.add('active');

            // v23.0: Update fox container mood class
            elements.foxCanvas.parentElement.className = 'fox-canvas-wrapper ' + status;

            // Update status dot
            elements.statusDot.classList.remove('warning', 'error', 'critical');
            if (status === 'error') {
                elements.statusDot.classList.add('error');
            } else if (status === 'sleeping') {
                elements.statusDot.classList.add('warning');
            }

            // v25.0: Show/hide thinking chain based on status
            updateThinkingChain(status === 'thinking' || status === 'working');

            // v25.0: Generate activity story
            generateActivityStory();

            // v26.0: Update mood aura and fox expression
            updateMoodAura(status);
            updateFoxExpression(status);
        }

        function updateUptime(value) {
            state.uptime = value;
            elements.uptime.textContent = value;
        }

        function updateMemories(memories) {
            elements.timelineItems.innerHTML = memories.slice(0, 5).map(memory => `
                <div class="timeline-item fade-in">
                    <div class="timeline-icon" style="background: rgba(255,200,100,0.1); color: var(--primary);">
                        📝
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-text">${memory.text || 'Memory'}</div>
                        <div class="timeline-time">${memory.timestamp || new Date().toLocaleTimeString()}</div>
                    </div>
                </div>
            `).join('');
        }

        function updateSkills(skills) {
            elements.skillsList.innerHTML = skills.slice(0, 5).map(skill => `
                <div class="skill-item fade-in">
                    <div class="skill-header">
                        <span class="skill-name">${skill.name}</span>
                        <span class="skill-value">${skill.count} uses</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-fill" style="width: ${skill.count * 5}%; background: var(--primary);"></div>
                    </div>
                </div>
            `).join('');
        }

        function getProgressClass(value) {
            if (value >= 80) return 'danger';
            if (value >= 60) return 'warning';
            return 'success';
        }

        // ========== Copy Stat ==========
        function copyStat(type) {
            const value = state[type];
            if (value !== '--') {
                navigator.clipboard.writeText(value).then(() => {
                    showToast(`${type} copied: ${value}`);
                });
            }
        }

        // ========== Toast Notification ==========
        function showToast(message, type = 'default') {
            const toast = document.createElement('div');
            const bgColors = {
                default: 'rgba(255,255,255,0.1)',
                success: 'rgba(92,219,149,0.2)',
                warning: 'rgba(254,202,87,0.2)',
                error: 'rgba(255,107,107,0.2)'
            };
            const borderColors = {
                default: 'rgba(255,255,255,0.1)',
                success: 'rgba(92,219,149,0.5)',
                warning: 'rgba(254,202,87,0.5)',
                error: 'rgba(255,107,107,0.5)'
            };
            toast.style.cssText = `
                position: fixed;
                bottom: 20px;
                right: 20px;
                background: ${bgColors[type] || bgColors.default};
                backdrop-filter: blur(10px);
                padding: 12px 24px;
                border-radius: var(--radius-md);
                border: 1px solid ${borderColors[type] || borderColors.default};
                color: white;
                font-size: 14px;
                animation: slideIn 0.3s ease;
                z-index: 1000;
            `;
            toast.textContent = message;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.animation = 'fadeOut 0.3s ease forwards';
                setTimeout(() => toast.remove(), 300);
            }, 2000);
        }

        // ========== Mode Selection ==========
        function setMode(mode) {
            updateStatus(mode);
            showToast(`Mode changed to ${mode}`);
        }

        // v26.0: Mood Selection with Expression Update
        function setMood(mood) {
            updateStatus(mood);
            
            // Update mood selector active state
            document.querySelectorAll('.mood-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            const moodBtns = {
                idle: '😺', excited: '🎉', thinking: '🤔', laughing: '😄', focused: '🎯'
            };
            const activeBtn = document.querySelector(`.mood-btn[onclick="setMood('${mood}')"]`);
            if (activeBtn) activeBtn.classList.add('active');
            
            // Update fox expression
            updateFoxExpression(mood);
            
            showToast(`Mood: ${moodBtns[mood] || '😺'} ${mood}`);
        }

        // v26.0: Fox Expression Update
        function updateFoxExpression(mood) {
            const expressionEl = document.getElementById('foxExpression');
            if (!expressionEl) return;
            
            const expressions = {
                idle: '😺',
                working: '⚡',
                sleeping: '😴',
                excited: '🎉',
                thinking: '🤔',
                laughing: '😄',
                error: '😿',
                focused: '🎯',
                learning: '📚'
            };
            
            expressionEl.textContent = expressions[mood] || '😺';
            expressionEl.style.animation = 'none';
            expressionEl.offsetHeight; // Trigger reflow
            expressionEl.style.animation = 'expressionBounce 2s ease-in-out infinite';
        }

        // v26.0: Mood Aura Update
        function updateMoodAura(mood) {
            const auraEl = document.getElementById('moodAura');
            if (!auraEl) return;
            
            auraEl.className = 'mood-aura ' + mood;
        }

        // v26.0: Cursor Trail Effect
        let lastTrailTime = 0;
        function createCursorTrail(e) {
            const now = Date.now();
            if (now - lastTrailTime < 80) return; // Throttle to 80ms
            lastTrailTime = now;
            
            const particle = document.createElement('div');
            particle.className = 'cursor-trail-particle';
            
            const colors = {
                idle: '#ffc864',
                working: '#00d4ff',
                sleeping: '#a855f7',
                excited: '#ec4899',
                error: '#ff6b6b',
                thinking: '#a855f7',
                laughing: '#ffc864',
                focused: '#5cdb95',
                learning: '#ffc864'
            };
            
            const color = colors[state.status] || '#ffc864';
            
            particle.style.left = e.clientX + 'px';
            particle.style.top = e.clientY + 'px';
            particle.style.background = color;
            particle.style.boxShadow = `0 0 10px ${color}`;
            
            document.body.appendChild(particle);
            
            setTimeout(() => particle.remove(), 800);
        }

        // v26.0: Session Journey Update
        function updateSessionJourney() {
            const sessionDuration = Date.now() - state.sessionStart;
            const sessionHours = sessionDuration / (1000 * 60 * 60);
            const maxHours = 24; // Assume a full day cycle
            const progress = Math.min((sessionHours / maxHours) * 100, 100);
            
            const fillEl = document.getElementById('journeyFill');
            const markerEl = document.getElementById('journeyMarker');
            const labelEl = document.getElementById('journeyProgress');
            
            if (fillEl) fillEl.style.width = progress + '%';
            if (markerEl) markerEl.style.left = progress + '%';
            if (labelEl) labelEl.textContent = Math.round(progress) + '%';
        }

        // v26.0: Update Quick Stats Panel
        function updateQuickStats() {
            const quickMsgs = document.getElementById('quickMsgs');
            const quickTasks = document.getElementById('quickTasks');
            const quickSkills = document.getElementById('quickSkills');
            
            if (quickMsgs) quickMsgs.textContent = state.msgCount || '--';
            if (quickTasks) quickTasks.textContent = state.taskDone || '--';
            if (quickSkills) quickSkills.textContent = state.skillsTotal || '--';
        }

        // v26.0: Magnetic Card Effect
        function initMagneticCards() {
            document.querySelectorAll('.magnetic-card').forEach(card => {
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    const rotateX = (y - centerY) / 10;
                    const rotateY = (centerX - x) / 10;
                    
                    card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-8px) scale(1.02)`;
                });
                
                card.addEventListener('mouseleave', () => {
                    card.style.transform = '';
                });
            });
        }

        // v26.0: Liquid Border Animation Init
        function initLiquidBorders() {
            document.querySelectorAll('.liquid-border').forEach(el => {
                el.addEventListener('mouseenter', () => {
                    el.style.borderColor = 'rgba(255,200,100,0.3)';
                });
                el.addEventListener('mouseleave', () => {
                    el.style.borderColor = '';
                });
            });
        }

        // ========== Start ==========
        document.addEventListener('DOMContentLoaded', () => {
            init();
            
            // v26.0: Initialize new features after init
            setTimeout(() => {
                updateFoxExpression(state.status || 'idle');
                updateMoodAura(state.status || 'idle');
                initMagneticCards();
                initLiquidBorders();
                updateSessionJourney();
                updateQuickStats();
                
                // Set initial mood button active
                const initialMoodBtn = document.querySelector(`.mood-btn[onclick="setMood('idle')"]`);
                if (initialMoodBtn) initialMoodBtn.classList.add('active');
            }, 600);
            
            // v26.0: Cursor trail effect
            document.addEventListener('mousemove', createCursorTrail);
            
            // v26.0: Update session journey periodically
            setInterval(updateSessionJourney, 30000);

            // v26.0: Update quick stats periodically
            setInterval(updateQuickStats, 5000);

            // v28.0: Pet the Fox Interaction
            initPetFox();
        });

        // v28.0: Pet the Fox Feature
        function initPetFox() {
            const foxCanvas = document.getElementById('foxCanvas');
            if (!foxCanvas) return;

            let petCount = 0;
            const petZone = document.createElement('div');
            petZone.className = 'fox-pet-zone';
            petZone.title = 'Click to pet MoShang!';
            petZone.style.cssText = 'position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:120px;height:120px;border-radius:50%;cursor:pointer;z-index:10;';

            petZone.addEventListener('click', (e) => {
                e.stopPropagation();
                petCount++;

                // Happy animation on fox
                foxCanvas.classList.add('fox-happy');
                setTimeout(() => foxCanvas.classList.remove('fox-happy'), 500);

                // Create heart particles
                createHeartBurst(foxCanvas);

                // Show pet reaction
                const expression = document.getElementById('foxExpression');
                if (expression) {
                    expression.textContent = '😻';
                    setTimeout(() => updateFoxExpression(state.status), 1500);
                }

                // Update story with pet count
                if (petCount === 1) {
                    showToast('MoShang loved that! 😻 Keep going!');
                } else if (petCount === 5) {
                    showToast('MoShang is so happy! You pet them 5 times! 🎉');
                } else if (petCount === 10) {
                    showToast('Wow! 10 pets! MoShang is blushing! 💕');
                }
            });

            foxCanvas.parentElement.appendChild(petZone);
        }

        // v28.0: Heart Burst Effect
        function createHeartBurst(canvas) {
            const rect = canvas.getBoundingClientRect();
            const hearts = ['💕', '💖', '💗', '💝', '❤️', '😻'];
            const container = canvas.parentElement;

            for (let i = 0; i < 6; i++) {
                const heart = document.createElement('div');
                heart.className = 'heart-rain';
                heart.textContent = hearts[Math.floor(Math.random() * hearts.length)];
                heart.style.left = (Math.random() * 80 + 10) + '%';
                heart.style.top = (Math.random() * 30 + 30) + '%';
                heart.style.animationDelay = (Math.random() * 0.3) + 's';
                container.appendChild(heart);

                setTimeout(() => heart.remove(), 2000);
            }
        }

        // v28.0: Add noise overlay for texture
        function initNoiseOverlay() {
            const noise = document.createElement('div');
            noise.className = 'noise-overlay';
            document.body.appendChild(noise);
        }

        // v28.0: Animated Stat Counter
        function animateCounter(element, start, end, duration) {
            const range = end - start;
            const startTime = performance.now();

            function update(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const easeProgress = 1 - Math.pow(1 - progress, 3); // ease-out cubic
                const current = Math.floor(start + (range * easeProgress));
                element.textContent = current;

                if (progress < 1) {
                    requestAnimationFrame(update);
                }
            }

            requestAnimationFrame(update);
        }

        // v28.0: Typing Indicator Show/Hide
        function showTypingIndicator(show) {
            let indicator = document.getElementById('typingIndicator');
            if (!indicator && show) {
                indicator = document.createElement('div');
                indicator.id = 'typingIndicator';
                indicator.className = 'typing-indicator';
                indicator.innerHTML = '<span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>';
                indicator.style.cssText = 'display:flex;align-items:center;gap:4px;margin-left:8px;';
                const statusValue = document.getElementById('statusValue');
                if (statusValue) statusValue.parentElement.appendChild(indicator);
            }
            if (indicator) {
                indicator.style.display = show ? 'flex' : 'none';
            }
        }

        // v28.0: Progress Ring Update
        function updateProgressRing(canvasId, percent, color = '#ffc864') {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const size = canvas.width;
            const strokeWidth = 8;
            const radius = (size - strokeWidth) / 2;
            const circumference = 2 * Math.PI * radius;
            const offset = circumference - (percent / 100) * circumference;

            ctx.clearRect(0, 0, size, size);
            ctx.strokeStyle = color + '30';
            ctx.lineWidth = strokeWidth;
            ctx.beginPath();
            ctx.arc(size/2, size/2, radius, 0, 2 * Math.PI);
            ctx.stroke();

            ctx.strokeStyle = color;
            ctx.lineWidth = strokeWidth;
            ctx.beginPath();
            ctx.arc(size/2, size/2, radius, -Math.PI/2, -Math.PI/2 + (percent/100) * 2 * Math.PI);
            ctx.stroke();
        }

        // v28.0: Star Rating Interaction
        function initStarRating() {
            const rating = document.querySelector('.star-rating');
            if (!rating) return;

            const stars = rating.querySelectorAll('span');
            stars.forEach((star, index) => {
                star.addEventListener('click', () => {
                    stars.forEach((s, i) => {
                        s.classList.toggle('active', i <= index);
                    });
                    showToast(`You rated ${index + 1} stars! ⭐`);
                });
            });
        }

        // v28.0: Focus Mode Toggle
        let focusModeActive = false;
        function toggleFocusMode() {
            focusModeActive = !focusModeActive;
            document.body.classList.toggle('focus-mode', focusModeActive);

            if (focusModeActive) {
                // Dim non-essential elements
                document.querySelectorAll('.stat-card').forEach((card, i) => {
                    if (i > 1) card.style.opacity = '0.3';
                });
                showToast('Focus mode activated! 🎯');
            } else {
                // Restore all elements
                document.querySelectorAll('.stat-card').forEach(card => {
                    card.style.opacity = '1';
                });
                showToast('Focus mode disabled');
            }
        }

        // v28.0: Shake Animation for Errors
        function shakeElement(element) {
            element.style.animation = 'none';
            element.offsetHeight; // Trigger reflow
            element.style.animation = 'shake 0.5s ease';
        }

        // Add shake animation to CSS
        const shakeStyle = document.createElement('style');
        shakeStyle.textContent = `
            @keyframes shake {
                0%, 100% { transform: translateX(0); }
                20% { transform: translateX(-10px); }
                40% { transform: translateX(10px); }
                60% { transform: translateX(-10px); }
                80% { transform: translateX(10px); }
            }
        `;
        document.head.appendChild(shakeStyle);

        // v28.0: Parallax Effect on Scroll
        function initParallax() {
            const layers = document.querySelectorAll('[data-parallax]');
            window.addEventListener('scroll', () => {
                const scrollY = window.scrollY;
                layers.forEach(layer => {
                    const speed = parseFloat(layer.dataset.parallax) || 0.5;
                    layer.style.transform = `translateY(${scrollY * speed}px)`;
                });
            });
        }

        // v28.0: Easter Egg - Konami Code
        const konamiCode = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
        let konamiIndex = 0;

        document.addEventListener('keydown', (e) => {
            if (e.key === konamiCode[konamiIndex]) {
                konamiIndex++;
                if (konamiIndex === konamiCode.length) {
                    activateKonamiEasterEgg();
                    konamiIndex = 0;
                }
            } else {
                konamiIndex = 0;
            }
        });

        function activateKonamiEasterEgg() {
            showToast('🎮 KONAMI CODE ACTIVATED! 🎉');
            document.body.style.animation = 'none';
            document.body.offsetHeight;
            document.body.style.animation = 'rainbowBg 3s ease';

            const rainbowStyle = document.createElement('style');
            rainbowStyle.textContent = `
                @keyframes rainbowBg {
                    0% { filter: hue-rotate(0deg); }
                    100% { filter: hue-rotate(360deg); }
                }
            `;
            document.head.appendChild(rainbowStyle);

            // Make fox dance
            const fox = document.getElementById('foxCanvas');
            if (fox) {
                fox.style.animation = 'foxDance 0.5s ease infinite';
                const danceStyle = document.createElement('style');
                danceStyle.textContent = `
                    @keyframes foxDance {
                        0%, 100% { transform: rotate(0deg) scale(1); }
                        25% { transform: rotate(-15deg) scale(1.1); }
                        75% { transform: rotate(15deg) scale(1.1); }
                    }
                `;
                document.head.appendChild(danceStyle);

                setTimeout(() => {
                    fox.style.animation = '';
                    showToast('Back to normal mode 😄');
                }, 5000);
            }
        }

        // v28.0: Initialize new features
        document.addEventListener('DOMContentLoaded', () => {
            initNoiseOverlay();
            initParallax();
            initStarRating();
        });

        // v29.0: Particle Mesh Background
        function initParticleMesh() {
            const canvas = document.getElementById('particleMeshCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', resize);

            const particleCount = Math.min(60, Math.floor(window.innerWidth / 20));
            const particles = [];
            let mouseX = -1000, mouseY = -1000;

            for (let i = 0; i < particleCount; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: (Math.random() - 0.5) * 0.5,
                    size: 1.5 + Math.random() * 2,
                    color: `rgba(255,200,100,${0.3 + Math.random() * 0.4})`,
                    pulse: Math.random() * Math.PI * 2
                });
            }

            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });
            document.addEventListener('mouseleave', () => { mouseX = -1000; mouseY = -1000; });

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                particles.forEach((p, i) => {
                    // Mouse repulsion
                    const dx = p.x - mouseX;
                    const dy = p.y - mouseY;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 150 && dist > 0) {
                        const force = (150 - dist) / 150 * 0.3;
                        p.vx += (dx / dist) * force;
                        p.vy += (dy / dist) * force;
                    }

                    // Dampen velocity
                    p.vx *= 0.98;
                    p.vy *= 0.98;

                    p.x += p.vx;
                    p.y += p.vy;

                    // Wrap around
                    if (p.x < 0) p.x = canvas.width;
                    if (p.x > canvas.width) p.x = 0;
                    if (p.y < 0) p.y = canvas.height;
                    if (p.y > canvas.height) p.y = 0;

                    p.pulse += 0.03;
                    const size = p.size * (0.8 + Math.sin(p.pulse) * 0.2);

                    // Draw particle
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
                    ctx.fillStyle = p.color;
                    ctx.fill();

                    // Connect nearby particles
                    for (let j = i + 1; j < particles.length; j++) {
                        const p2 = particles[j];
                        const dx2 = p.x - p2.x;
                        const dy2 = p.y - p2.y;
                        const dist2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);
                        if (dist2 < 120) {
                            ctx.beginPath();
                            ctx.moveTo(p.x, p.y);
                            ctx.lineTo(p2.x, p2.y);
                            ctx.strokeStyle = `rgba(255,200,100,${(1 - dist2 / 120) * 0.15})`;
                            ctx.lineWidth = 1;
                            ctx.stroke();
                        }
                    }
                });

                requestAnimationFrame(animate);
            }
            animate();
        }

        // v29.0: Glow Cursor Effect
        function initGlowCursor() {
            const cursor = document.getElementById('glowCursor');
            if (!cursor) return;

            let mouseX = 0, mouseY = 0;
            let curX = 0, curY = 0;

            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });

            document.addEventListener('mousedown', () => cursor.classList.add('active'));
            document.addEventListener('mouseup', () => cursor.classList.remove('active'));

            function animate() {
                curX += (mouseX - curX) * 0.15;
                curY += (mouseY - curY) * 0.15;
                cursor.style.left = curX + 'px';
                cursor.style.top = curY + 'px';
                requestAnimationFrame(animate);
            }
            animate();
        }

        // v29.0: Sparkline Updater
        function updateSparkline(svgId, data, color = '#ffc864') {
            const svg = document.getElementById(svgId);
            if (!svg || !data || data.length < 2) return;

            const w = 40, h = 16;
            const min = Math.min(...data);
            const max = Math.max(...data);
            const range = max - min || 1;

            const points = data.map((v, i) => {
                const x = (i / (data.length - 1)) * w;
                const y = h - ((v - min) / range) * (h - 2) - 1;
                return `${x.toFixed(1)},${y.toFixed(1)}`;
            }).join(' ');

            svg.innerHTML = `
                <polyline points="${points}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.8"/>
                <circle cx="${w}" cy="${h - ((data[data.length-1] - min) / range) * (h - 2) - 1}" r="2" fill="${color}" opacity="0.9"/>
            `;
        }

        // v29.0: Update sparklines on data change
        function updateAllSparklines() {
            if (state.dataHistory.heartbeat.length > 1) {
                updateSparkline('heartbeatSparkline', state.dataHistory.heartbeat.slice(-12), '#ffc864');
            }
            if (state.dataHistory.activity.length > 1) {
                updateSparkline('activitySparkline', state.dataHistory.activity.slice(-12), '#00d4ff');
            }
            if (state.dataHistory.memory.length > 1) {
                updateSparkline('memorySparkline', state.dataHistory.memory.slice(-12), '#5cdb95');
            }
        }

        // v29.0: Status-based body class
        function updateBodyStatusClass(status) {
            const validStatuses = ['idle','working','sleeping','excited','thinking','laughing','error','focused','learning'];
            validStatuses.forEach(s => document.body.classList.remove('status-' + s));
            document.body.classList.add('status-' + (validStatuses.includes(status) ? status : 'idle'));
        }

        // v29.0: BPM-based heartbeat ring
        function updateHeartbeatRing(bpm) {
            const heartIcon = document.querySelector('.mini-stat:first-child .mini-stat-value');
            if (!heartIcon) return;
            const duration = Math.max(0.4, Math.min(2, 60 / (bpm || 60)));
            document.documentElement.style.setProperty('--bpm-duration', duration + 's');
        }

        // Initialize v29.0 features
        document.addEventListener('DOMContentLoaded', () => {
            initParticleMesh();
            initGlowCursor();
        });

        // Hook sparklines into data fetch
        const originalFetchData = window.fetchData;
    </script>
</body>
</html>
