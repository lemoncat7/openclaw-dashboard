<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⚡ MoShang Status</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root{--bg:#06060c;--card-bg:rgba(14,14,22,0.82);--card-border:rgba(255,255,255,0.055);--card-border-hover:rgba(139,92,246,0.28);--text:#ededf5;--text-dim:#5e5e75;--accent:#8b5cf6;--accent-light:#a78bfa;--accent-2:#06b6d4;--accent-3:#f472b6;--success:#10b981;--warning:#f59e0b;--danger:#ef4444;--gradient-primary:linear-gradient(135deg,#8b5cf6 0%,#a78bfa 50%,#06b6d4 100%)}
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Outfit',-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:20px;overflow-x:hidden;-webkit-font-smoothing:antialiased}

        /* Connection Banner */
        .conn-banner{position:fixed;top:0;left:0;right:0;padding:6px 16px;text-align:center;font-size:0.72rem;font-family:'JetBrains Mono',monospace;z-index:1000;transform:translateY(-100%);transition:transform 0.4s cubic-bezier(0.4,0,0.2,1)}
        .conn-banner.show{transform:translateY(0)}
        .conn-banner.error{background:rgba(239,68,68,0.15);border-bottom:1px solid rgba(239,68,68,0.3);color:#fca5a5}
        .conn-banner.reconnecting{background:rgba(245,158,11,0.12);border-bottom:1px solid rgba(245,158,11,0.25);color:#fcd34d}

        /* BG */
        .bg-layer{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:-1;overflow:hidden}
        .bg-orb{position:absolute;border-radius:50%;filter:blur(90px);opacity:0.35;animation:orbFloat 25s ease-in-out infinite}
        .bg-orb-1{width:700px;height:700px;background:var(--accent);top:-250px;left:-200px}
        .bg-orb-2{width:550px;height:550px;background:var(--accent-2);bottom:-200px;right:-180px;animation-delay:-12s}
        .bg-orb-3{width:350px;height:350px;background:var(--accent-3);top:55%;left:55%;transform:translate(-50%,-50%);animation-delay:-6s;opacity:0.18}
        @keyframes orbFloat{0%,100%{transform:translate(0,0) scale(1)}30%{transform:translate(40px,-40px) scale(1.08)}60%{transform:translate(-25px,25px) scale(0.94)}80%{transform:translate(20px,10px) scale(1.03)}}
        .bg-mesh{position:absolute;inset:0;background:radial-gradient(ellipse at 15% 85%,rgba(139,92,246,0.12) 0%,transparent 50%),radial-gradient(ellipse at 85% 15%,rgba(6,182,212,0.12) 0%,transparent 50%),radial-gradient(ellipse at 50% 50%,rgba(244,114,182,0.06) 0%,transparent 45%);animation:meshShift 18s ease-in-out infinite}
        @keyframes meshShift{0%,100%{opacity:0.85;transform:scale(1)}50%{opacity:1;transform:scale(1.05)}}
        .bg-grid{position:absolute;inset:0;background-image:radial-gradient(rgba(139,92,246,0.06) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse at 50% 50%,black 20%,transparent 75%);-webkit-mask-image:radial-gradient(ellipse at 50% 50%,black 20%,transparent 75%)}
        .noise-overlay{position:fixed;inset:0;pointer-events:none;z-index:9998;opacity:0.022;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}
        .stars{position:absolute;inset:0;pointer-events:none}
        .star{position:absolute;width:2px;height:2px;background:white;border-radius:50%;opacity:0;animation:twinkle 3s ease-in-out infinite}
        @keyframes twinkle{0%,100%{opacity:0;transform:scale(0.4)}50%{opacity:0.7;transform:scale(1)}}

        /* Data Source Pill */
        .data-source{position:fixed;top:16px;right:16px;display:flex;align-items:center;gap:8px;padding:7px 14px;background:rgba(14,14,22,0.8);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.07);border-radius:24px;font-size:0.68rem;color:var(--text-dim);z-index:100}
        .data-source .dot{width:7px;height:7px;border-radius:50%;transition:background 0.3s,box-shadow 0.3s}
        .data-source .dot.connected{background:var(--success);box-shadow:0 0 8px var(--success);animation:dp 2s ease-in-out infinite}
        .data-source .dot.disconnected{background:var(--danger);box-shadow:0 0 8px var(--danger)}
        .data-source .dot.reconnecting{background:var(--warning);box-shadow:0 0 8px var(--warning);animation:dpf 0.7s ease-in-out infinite}
        .data-source .dot.websocket{background:var(--accent-2);box-shadow:0 0 8px var(--accent-2);animation:dp 1.5s ease-in-out infinite}
        @keyframes dp{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.35);opacity:0.65}}
        @keyframes dpf{0%,100%{transform:scale(1)}50%{transform:scale(1.6)}}

        .container{max-width:1100px;margin:0 auto;position:relative}

        /* Header */
        header{text-align:center;padding:36px 0 32px;position:relative}
        .avatar-container{display:inline-block;position:relative;margin-bottom:16px}
        .avatar-glow{position:absolute;inset:-24px;background:var(--gradient-primary);border-radius:50%;opacity:0.28;animation:glowP 3s ease-in-out infinite;filter:blur(24px)}
        @keyframes glowP{0%,100%{transform:scale(1);opacity:0.28}50%{transform:scale(1.18);opacity:0.5}}
        .avatar-effect{position:absolute;inset:-20px;pointer-events:none;opacity:0;transition:opacity 0.5s}
        .avatar-effect.active{opacity:1}
        .avatar-effect.working{background:radial-gradient(circle,rgba(139,92,246,0.3) 0%,transparent 70%);animation:efP 1s ease-in-out infinite}
        .avatar-effect.thinking{background:radial-gradient(circle,rgba(6,182,212,0.25) 0%,transparent 70%);animation:efR 3s linear infinite}
        .avatar-effect.sleeping{background:radial-gradient(circle,rgba(99,102,241,0.18) 0%,transparent 70%)}
        .avatar-effect.excited{background:radial-gradient(circle,rgba(244,114,182,0.35) 0%,transparent 70%);animation:efE 0.5s ease-in-out infinite}
        .avatar-effect.laughing{background:radial-gradient(circle,rgba(251,191,36,0.22) 0%,transparent 70%);animation:efL 0.8s ease-in-out infinite}
        .avatar-effect.error{background:radial-gradient(circle,rgba(239,68,68,0.25) 0%,transparent 70%);animation:efP 1.2s ease-in-out infinite}
        @keyframes efP{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
        @keyframes efR{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
        @keyframes efE{0%,100%{transform:scale(1) rotate(0deg)}25%{transform:scale(1.1) rotate(-4deg)}75%{transform:scale(1.1) rotate(4deg)}}
        @keyframes efL{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}
        .activity-ring{position:absolute;inset:-10px;border-radius:50%;border:2px solid rgba(139,92,246,0.3);opacity:0;pointer-events:none}
        .activity-ring.pulse{animation:ringP 2s ease-out infinite}
        @keyframes ringP{0%{transform:scale(1);opacity:0.8}100%{transform:scale(1.6);opacity:0}}
        .avatar{width:108px;height:108px;position:relative;background:rgba(18,18,28,0.9);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:52px;border:2px solid rgba(139,92,246,0.4);box-shadow:0 0 40px rgba(139,92,246,0.25);animation:avF 4s ease-in-out infinite;cursor:pointer;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.3s;user-select:none}
        .avatar:hover{transform:scale(1.08) rotate(5deg);box-shadow:0 0 60px rgba(139,92,246,0.4)}
        .avatar:active{transform:scale(0.95)}
        .avatar.working::before{content:'';position:absolute;inset:-12px;border:2px solid rgba(139,92,246,0.4);border-radius:50%;border-top-color:transparent;animation:spin 1s linear infinite}
        @keyframes spin{to{transform:rotate(360deg)}}
        @keyframes avF{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
        .status-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 18px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.22);border-radius:24px;font-size:0.8rem;color:var(--success);margin-top:14px;font-weight:500;transition:all 0.4s}
        .status-badge .dot{width:8px;height:8px;border-radius:50%;background:var(--success);box-shadow:0 0 8px var(--success);animation:dp 1.5s ease-in-out infinite}
        .status-badge.sleeping{background:rgba(99,102,241,0.1);border-color:rgba(99,102,241,0.2);color:#818cf8}
        .status-badge.sleeping .dot{background:#818cf8;box-shadow:0 0 8px #818cf8;animation:none;opacity:0.6}
        .status-badge.working{background:rgba(139,92,246,0.1);border-color:rgba(139,92,246,0.2);color:var(--accent-light)}
        .status-badge.working .dot{background:var(--accent-light);box-shadow:0 0 8px var(--accent-light);animation:dpf 0.8s ease-in-out infinite}
        h1{font-size:2.4rem;font-weight:700;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:6px;letter-spacing:-0.5px}
        .subtitle{color:var(--text-dim);font-size:0.92rem;font-weight:300}
        .last-update{font-size:0.68rem;color:var(--text-dim);margin-top:8px;font-family:'JetBrains Mono',monospace;display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap}
        .freshness-bar{width:44px;height:3px;background:rgba(255,255,255,0.05);border-radius:2px;overflow:hidden;display:inline-block;vertical-align:middle}
        .freshness-fill{height:100%;background:var(--success);border-radius:2px;transition:width 0.5s,background 0.3s}
        .freshness-fill.stale{background:var(--warning)}
        .freshness-fill.critical{background:var(--danger)}

        /* Bento Grid */
        .grid{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:minmax(120px,auto);gap:16px}
        @media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr)}}
        @media(max-width:600px){.grid{grid-template-columns:1fr}}

        /* Glass Card */
        .card{background:var(--card-bg);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-radius:22px;border:1px solid var(--card-border);padding:24px;position:relative;overflow:hidden;transition:transform 0.35s cubic-bezier(0.4,0,0.2,1),border-color 0.35s,box-shadow 0.35s;animation:cardE 0.6s ease-out backwards}
        .card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(139,92,246,0.25),transparent);opacity:0;transition:opacity 0.3s}
        .card:hover{transform:translateY(-5px) scale(1.008);border-color:var(--card-border-hover);box-shadow:0 24px 48px rgba(0,0,0,0.45),0 0 35px rgba(139,92,246,0.1)}
        .card:hover::before{opacity:1}
        .card.holo{overflow:hidden}
        .card.holo::after{content:'';position:absolute;top:-60%;left:-60%;width:220%;height:220%;background:linear-gradient(45deg,transparent 32%,rgba(139,92,246,0.04) 45%,rgba(8,145,178,0.04) 55%,transparent 68%);transform:translateX(-100%);transition:transform 0.9s ease;pointer-events:none;z-index:1}
        .card.holo:hover::after{transform:translateX(100%)}
        @keyframes cardE{from{opacity:0;transform:translateY(28px) scale(0.96)}to{opacity:1;transform:translateY(0) scale(1)}}
        .card:nth-child(1){animation-delay:0.05s}.card:nth-child(2){animation-delay:0.1s}.card:nth-child(3){animation-delay:0.15s}.card:nth-child(4){animation-delay:0.2s}.card:nth-child(5){animation-delay:0.25s}.card:nth-child(6){animation-delay:0.3s}.card:nth-child(7){animation-delay:0.35s}.card:nth-child(8){animation-delay:0.4s}
        .card-header{display:flex;align-items:center;gap:9px;margin-bottom:18px;color:var(--text-dim);font-size:0.72rem;text-transform:uppercase;letter-spacing:1.5px;font-weight:500}
        .card-header .icon{font-size:1.15rem;filter:grayscale(0.2)}

        /* Time card */
        .time-card{text-align:center}
        .time{font-family:'JetBrains Mono',monospace;font-size:3rem;font-weight:600;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:3px}
        .weekday{color:var(--text);font-size:1.1rem;font-weight:500;margin-top:6px}
        .date{color:var(--text-dim);font-size:0.88rem;margin-top:8px;font-weight:300}

        /* Weather card */
        .weather-card{text-align:center}
        .weather-icon{font-size:3rem;margin-bottom:6px;animation:wf 3s ease-in-out infinite}
        @keyframes wf{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
        .weather-temp{font-size:2rem;font-weight:600;color:var(--text);transition:transform 0.2s}
        .weather-temp.bump{animation:bump 0.3s ease}
        @keyframes bump{0%,100%{transform:scale(1)}50%{transform:scale(1.1)}}
        .weather-desc{color:var(--text-dim);font-size:0.84rem;margin-top:4px}
        .weather-location{display:flex;align-items:center;justify-content:center;gap:4px;color:var(--text-dim);font-size:0.78rem;margin-top:10px}

        /* Status rows */
        .status-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
        .status-row:last-child{border-bottom:none}
        .status-label{color:var(--text-dim);font-size:0.88rem}
        .status-value{font-weight:500;display:flex;align-items:center;gap:7px}
        .status-dot{width:8px;height:8px;border-radius:50%}
        .status-dot.online{background:var(--success);box-shadow:0 0 8px var(--success);animation:dp 2s ease-in-out infinite}
        .status-dot.warning{background:var(--warning);box-shadow:0 0 8px var(--warning)}
        .status-dot.error{background:var(--danger);box-shadow:0 0 8px var(--danger);animation:dpf 1s ease-in-out infinite}

        /* Timeline */
        .status-timeline{display:flex;align-items:center;gap:5px;margin-top:10px}
        .timeline-dot{width:8px;height:8px;border-radius:50%;background:rgba(139,92,246,0.25);transition:all 0.3s}
        .timeline-dot.active{background:var(--success);box-shadow:0 0 8px var(--success);animation:dp 1.5s ease-in-out infinite}
        .timeline-dot.idle{background:rgba(139,92,246,0.4)}
        .timeline-dot.working{background:var(--accent-light);box-shadow:0 0 8px var(--accent-light)}
        .timeline-dot.sleeping{background:#818cf8}
        .timeline-dot.error{background:var(--danger);box-shadow:0 0 8px var(--danger)}

        /* Resources */
        .progress-item{margin-bottom:14px}
        .progress-item:last-child{margin-bottom:0}
        .progress-header{display:flex;justify-content:space-between;margin-bottom:7px;font-size:0.84rem}
        .progress-label{color:var(--text-dim)}
        .progress-value{font-weight:600;font-family:'JetBrains Mono',monospace;transition:color 0.3s}
        .progress-value.high{color:var(--danger)}
        .progress-value.warn{color:var(--warning)}
        .progress{height:7px;background:rgba(255,255,255,0.05);border-radius:8px;overflow:hidden}
        .progress-bar{height:100%;border-radius:8px;transition:width 0.7s cubic-bezier(0.4,0,0.2,1);position:relative;overflow:hidden}
        .progress-bar::after{content:'';position:absolute;top:0;left:-150%;width:80%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.35),transparent);animation:ps 2.2s ease-in-out infinite}
        @keyframes ps{0%{left:-150%}100%{left:150%}}
        .progress-bar.cpu{background:linear-gradient(90deg,#8b5cf6,#a78bfa);box-shadow:0 0 10px rgba(139,92,246,0.45)}
        .progress-bar.memory{background:linear-gradient(90deg,#06b6d4,#22d3ee);box-shadow:0 0 10px rgba(6,182,212,0.45)}
        .progress-bar.disk{background:linear-gradient(90deg,#f59e0b,#fbbf24);box-shadow:0 0 10px rgba(245,158,11,0.4)}
        .progress-item.warning .progress-bar{animation:wb 1.2s ease-in-out infinite}
        @keyframes wb{0%,100%{filter:brightness(1)}50%{filter:brightness(1.35)}}
        .resource-detail{font-size:0.67rem;color:var(--text-dim);margin-top:4px;font-family:'JetBrains Mono',monospace}
        .mini-chart{margin-top:14px;height:52px;background:rgba(0,0,0,0.18);border-radius:10px;overflow:hidden}
        .mini-chart canvas{width:100%;height:100%;display:block}
        .mini-chart-labels{display:flex;justify-content:space-between;margin-top:4px;font-size:0.63rem;color:var(--text-dim)}

        /* Skills */
        .skill-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px}
        .skill-item{display:flex;align-items:center;gap:10px;padding:11px;background:rgba(255,255,255,0.025);border-radius:12px;border:1px solid rgba(255,255,255,0.04);transition:all 0.3s}
        .skill-item:hover{background:rgba(139,92,246,0.08);border-color:rgba(139,92,246,0.18);transform:translateX(3px)}
        .skill-icon{font-size:1.2rem}
        .skill-info{flex:1}
        .skill-name{font-size:0.83rem;font-weight:500}
        .skill-status{font-size:0.67rem;color:var(--success);display:flex;align-items:center;gap:3px;margin-top:2px}

        /* Tasks */
        .task-list{list-style:none}
        .task-item{display:flex;align-items:center;gap:11px;padding:11px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
        .task-item:last-child{border-bottom:none}
        .task-check{width:20px;height:20px;border-radius:50%;border:2px solid rgba(139,92,246,0.35);display:flex;align-items:center;justify-content:center;font-size:0.68rem;transition:all 0.3s;flex-shrink:0}
        .task-check.done{background:var(--success);border-color:var(--success);color:white}
        .task-title{font-size:0.88rem}
        .task-time{font-size:0.72rem;color:var(--text-dim);font-family:'JetBrains Mono',monospace;margin-top:2px}

        /* Quick Actions */
        .quick-actions{grid-column:span 3}
        @media(max-width:900px){.quick-actions{grid-column:span 2}}
        @media(max-width:600px){.quick-actions{grid-column:span 1}}
        .btn-group{display:flex;gap:11px;flex-wrap:wrap}
        .btn{padding:13px 26px;border:none;border-radius:14px;cursor:pointer;font-size:0.88rem;font-weight:500;font-family:inherit;transition:all 0.3s cubic-bezier(0.4,0,0.2,1);display:inline-flex;align-items:center;gap:8px;position:relative;overflow:hidden}
        .btn::after{content:'';position:absolute;top:50%;left:50%;width:0;height:0;background:rgba(255,255,255,0.15);border-radius:50%;transform:translate(-50%,-50%);transition:width 0.45s,height 0.45s}
        .btn:active::after{width:260px;height:260px}
        .btn-primary{background:var(--gradient-primary);color:white;box-shadow:0 8px 24px rgba(139,92,246,0.3)}
        .btn-primary:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 16px 40px rgba(139,92,246,0.42)}
        .btn-secondary{background:rgba(255,255,255,0.055);color:var(--text);border:1px solid rgba(255,255,255,0.07)}
        .btn-secondary:hover{background:rgba(255,255,255,0.1);border-color:rgba(139,92,246,0.25);transform:translateY(-2px)}
        .btn:active{transform:translateY(-1px) scale(0.98)}

        /* Toast */
        .toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(80px);background:rgba(14,14,22,0.95);backdrop-filter:blur(20px);border:1px solid rgba(139,92,246,0.28);border-radius:16px;padding:13px 26px;color:var(--text);font-size:0.85rem;box-shadow:0 10px 40px rgba(0,0,0,0.45),0 0 25px rgba(139,92,246,0.15);z-index:10000;opacity:0;transition:all 0.4s cubic-bezier(0.34,1.56,0.64,1)}
        .toast.show{transform:translateX(-50%) translateY(0);opacity:1}

        /* Shortcuts */
        .shortcuts-panel{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(14,14,22,0.97);border:1px solid rgba(139,92,246,0.35);border-radius:18px;padding:28px;z-index:10001;display:none;backdrop-filter:blur(24px);box-shadow:0 0 60px rgba(139,92,246,0.2);min-width:300px}
        .shortcuts-panel.show{display:block;animation:fa 0.25s ease}
        @keyframes fa{from{opacity:0;transform:translate(-50%,-48%)}to{opacity:1;transform:translate(-50%,-50%)}}
        .shortcuts-panel h3{color:var(--accent-light);margin-bottom:18px;font-size:1rem}
        .shortcut-item{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
        .shortcut-key{background:rgba(139,92,246,0.18);padding:3px 10px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:var(--accent-light)}

        footer{text-align:center;margin-top:44px;padding:22px;color:var(--text-dim);font-size:0.78rem;border-top:1px solid rgba(255,255,255,0.04)}
        footer span{background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        ::-webkit-scrollbar{width:7px}
        ::-webkit-scrollbar-track{background:rgba(18,18,28,0.4);border-radius:4px}
        ::-webkit-scrollbar-thumb{background:linear-gradient(180deg,#8b5cf6,#06b6d4);border-radius:4px}
        *{scrollbar-width:thin;scrollbar-color:#8b5cf6 #12121c}
        ::selection{background:rgba(139,92,246,0.4);color:white}
        @media(max-width:640px){body{padding:14px}h1{font-size:1.8rem}.time{font-size:2.2rem}.card{padding:18px}.btn{padding:12px 20px;font-size:0.85rem}.avatar{width:90px;height:90px;font-size:42px}.grid{gap:12px}.skill-grid{grid-template-columns:1fr}.btn-group{flex-direction:column}.btn{width:100%;justify-content:center}.data-source{font-size:0.6rem;padding:6px 10px}}
        @media(hover:none){.card:hover{transform:none}.btn:hover{transform:none}.card:active{transform:scale(0.98)}.btn:active{transform:scale(0.96)}}
        @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important}}
        body.power-save *{animation:none!important;transition:none!important}
    </style>
</head>
<body>
    <div class="conn-banner" id="connBanner"></div>
    <div class="noise-overlay"></div>
    <div class="bg-layer">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
        <div class="bg-mesh"></div>
        <div class="bg-grid"></div>
    </div>

    <div class="data-source">
        <div class="dot" id="connDot"></div>
        <span id="connText">连接中...</span>
        <span style="margin-left:6px;opacity:0.4">| R=刷新 C=聊天</span>
    </div>

    <div class="container">
        <header>
            <div class="avatar-container">
                <div class="avatar-glow"></div>
                <div class="avatar-effect" id="avatarEffect"></div>
                <div class="activity-ring" id="activityRing"></div>
                <div class="avatar" id="avatar" title="点击刷新!">🦊</div>
            </div>
            <div class="status-badge" id="statusBadge">
                <span class="dot"></span>
                <span id="onlineStatus">在线</span>
            </div>
            <h1>⚡ MoShang</h1>
            <p class="subtitle">数字弟弟实时状态看板</p>
            <div class="last-update">
                数据来源: /api/status | 最后更新: <span id="lastUpdate">--:--:--</span>
                <span style="display:inline-flex;align-items:center;gap:5px;margin-left:8px">
                    <span>新鲜度</span>
                    <span class="freshness-bar"><span class="freshness-fill" id="freshnessFill" style="width:100%"></span></span>
                </span>
            </div>
        </header>

        <div class="grid">
            <div class="card time-card">
                <div class="card-header"><span class="icon">🕐</span>当前时间</div>
                <div class="time" id="clock">--:--:--</div>
                <div class="weekday" id="weekday">--</div>
                <div class="date" id="date">---</div>
            </div>

            <div class="card weather-card">
                <div class="card-header"><span class="icon">🌤️</span>天气状况</div>
                <div class="weather-icon" id="weatherIcon">☀️</div>
                <div class="weather-temp" id="weatherTemp">--°</div>
                <div class="weather-desc" id="weatherDesc">加载中...</div>
                <div class="weather-location"><span>📍</span><span id="weatherLocation">上海</span></div>
            </div>

            <div class="card holo">
                <div class="card-header"><span class="icon">💻</span>系统状态</div>
                <div class="status-row"><span class="status-label">运行状态</span><div class="status-value"><span class="status-dot online" id="sysDot"></span><span id="systemStatus">运行中</span></div></div>
                <div class="status-row"><span class="status-label">运行时间</span><span class="status-value" id="uptime">--</span></div>
                <div class="status-row"><span class="status-label">Dashboard</span><span class="status-value" id="dashboardStatus">--</span></div>
                <div class="status-row" style="border-bottom:none"><span class="status-label">活动轨迹</span><div class="status-timeline" id="activityTimeline"><span style="font-size:0.7rem;color:var(--text-dim)">等待数据...</span></div></div>
            </div>

            <div class="card holo">
                <div class="card-header"><span class="icon">📊</span>资源使用</div>
                <div class="progress-item">
                    <div class="progress-header"><span class="progress-label">🖥️ CPU</span><span class="progress-value" id="cpuValue">--%</span></div>
                    <div class="progress"><div class="progress-bar cpu" id="cpuBar" style="width:0%"></div></div>
                    <div class="resource-detail" id="cpuDetail">-- / --</div>
                </div>
                <div class="progress-item">
