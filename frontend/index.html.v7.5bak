<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⚡ MoShang Status</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #08080c;
            --card-bg: rgba(18, 18, 28, 0.85);
            --card-border: rgba(255, 255, 255, 0.06);
            --text: #f0f0f5;
            --text-dim: #6b6b80;
            --accent: #8b5cf6;
            --accent-2: #06b6d4;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --gradient-primary: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 50%, #06b6d4 100%);
            --gradient-glow: radial-gradient(ellipse at center, rgba(139, 92, 246, 0.2) 0%, transparent 70%);
        }
        
        /* v7.9 - Next-Gen Visual Effects */
        
        /* 添加：3D 透视卡片效果 */
        .perspective-card {
            perspective: 1000px;
        }
        
        .perspective-card .card {
            transform-style: preserve-3d;
            transition: transform 0.3s ease;
        }
        
        .perspective-card .card:hover {
            transform: rotateX(5deg) rotateY(-5deg) translateZ(10px);
        }
        
        /* 添加：镜像反射效果 */
        .mirror-reflect {
            position: relative;
        }
        
        .mirror-reflect::after {
            content: '';
            position: absolute;
            bottom: -30px;
            left: 0;
            right: 0;
            height: 30px;
            background: linear-gradient(to bottom, rgba(139, 92, 246, 0.1), transparent);
            transform: scaleY(-1) perspective(100px);
            opacity: 0.3;
            filter: blur(2px);
        }
        
        /* 添加：光束扫描效果 */
        .beam-scan {
            position: relative;
            overflow: hidden;
        }
        
        .beam-scan::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.3), transparent);
            animation: beamScan 3s ease-in-out infinite;
        }
        
        @keyframes beamScan {
            0% { left: -50%; }
            100% { left: 150%; }
        }
        
        /* 添加：呼吸文字效果 */
        .breathe-text {
            animation: breatheText 2s ease-in-out infinite;
        }
        
        @keyframes breatheText {
            0%, 100% { opacity: 1; text-shadow: 0 0 10px var(--accent); }
            50% { opacity: 0.7; text-shadow: 0 0 30px var(--accent); }
        }
        
        /* 添加：动态粒子网格 */
        .particle-grid {
            position: relative;
            background: 
                radial-gradient(circle at 50% 50%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
                linear-gradient(rgba(139, 92, 246, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(139, 92, 246, 0.05) 1px, transparent 1px);
            background-size: 100% 100%, 20px 20px, 20px 20px;
        }
        
        /* 添加：霓虹发光边框 */
        .neon-glow {
            box-shadow: 
                0 0 5px var(--accent),
                0 0 10px var(--accent),
                0 0 20px var(--accent),
                inset 0 0 5px rgba(139, 92, 246, 0.1);
            animation: neonPulse 2s ease-in-out infinite;
        }
        
        @keyframes neonPulse {
            0%, 100% { box-shadow: 0 0 5px var(--accent), 0 0 10px var(--accent), 0 0 20px var(--accent); }
            50% { box-shadow: 0 0 10px var(--accent), 0 0 20px var(--accent), 0 0 40px var(--accent); }
        }
        
        /* 添加：悬停闪光效果 */
        .hover-flash {
            position: relative;
            overflow: hidden;
        }
        
        .hover-flash::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 60%);
            opacity: 0;
            transform: scale(0.5);
            transition: all 0.5s ease;
        }
        
        .hover-flash:hover::after {
            opacity: 1;
            transform: scale(1);
        }
        
        /* 添加：文字扫描效果 */
        .text-scan {
            position: relative;
        }
        
        .text-scan::before {
            content: attr(data-text);
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            color: var(--accent-2);
            opacity: 0.5;
            animation: textScan 2s linear infinite;
            clip-path: inset(0 100% 0 0);
        }
        
        @keyframes textScan {
            0% { clip-path: inset(0 100% 0 0); }
            100% { clip-path: inset(0 0 0 0); }
        }
        
        /* 添加：悬浮气泡效果 */
        .floating-bubbles {
            position: absolute;
            width: 100%;
            height: 100%;
            overflow: hidden;
            pointer-events: none;
        }
        
        .bubble {
            position: absolute;
            bottom: -20px;
            width: 10px;
            height: 10px;
            background: rgba(139, 92, 246, 0.3);
            border-radius: 50%;
            animation: bubbleRise 8s infinite ease-in;
        }
        
        @keyframes bubbleRise {
            0% { transform: translateY(0) scale(1); opacity: 0.6; }
            100% { transform: translateY(-100vh) scale(0.5); opacity: 0; }
        }
        
        /* 添加：倾斜视差效果 */
        .tilt-parallax {
            transition: transform 0.1s ease;
        }
        
        /* 添加：波纹扩散效果 */
        .ripple-expand {
            position: relative;
            overflow: hidden;
        }
        
        .ripple-expand::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(139, 92, 246, 0.2);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s ease, height 0.6s ease;
        }
        
        .ripple-expand:hover::after {
            width: 200%;
            height: 200%;
        }
        
        /* 添加：渐变流动文字 */
        .gradient-flow {
            background: linear-gradient(90deg, var(--accent), var(--accent-2), var(--accent));
            background-size: 200% 100%;
            -webkit-background-clip: text;
            background-clip: text;
            animation: gradientFlow 3s linear infinite;
        }
        
        @keyframes gradientFlow {
            0% { background-position: 0% 50%; }
            100% { background-position: 200% 50%; }
        }
        
        /* 添加：像素化边缘效果 */
        .pixel-edge {
            image-rendering: pixelated;
            box-shadow: 
                2px 0 0 0 var(--accent),
                -2px 0 0 0 var(--accent),
                0 2px 0 0 var(--accent),
                0 -2px 0 0 var(--accent);
        }
        
        /* v7.8 - AI Era Dashboard & Enhanced Interactivity */
        
        /* 添加：ASCII 艺术标题效果 */
        .ascii-title {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            line-height: 1.2;
            color: var(--accent);
            white-space: pre;
            text-shadow: 0 0 10px var(--accent);
        }
        
        /* 添加：故障glitch效果 */
        .glitch {
            position: relative;
            animation: glitch 3s infinite;
        }
        
        @keyframes glitch {
            0%, 90%, 100% { transform: translate(0); filter: hue-rotate(0deg); }
            92% { transform: translate(-2px, 2px); filter: hue-rotate(90deg); }
            94% { transform: translate(2px, -2px); filter: hue-rotate(-90deg); }
            96% { transform: translate(-2px, -2px); filter: hue-rotate(180deg); }
            98% { transform: translate(2px, 2px); filter: hue-rotate(-180deg); }
        }
        
        /* 添加：雷达扫描效果 */
        .radar-scan {
            position: relative;
            overflow: hidden;
        }
        
        .radar-scan::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(from 0deg, transparent 0deg, rgba(139, 92, 246, 0.1) 10deg, transparent 20deg);
            animation: radarSpin 4s linear infinite;
        }
        
        @keyframes radarSpin {
            from { transform: translate(-50%, -50%) rotate(0deg); }
            to { transform: translate(-50%, -50%) rotate(360deg); }
        }
        
        /* 添加：波纹网格背景 */
        .ripple-grid {
            background-image: 
                linear-gradient(rgba(139, 92, 246, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(139, 92, 246, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
            animation: gridPulse 4s ease-in-out infinite;
        }
        
        @keyframes gridPulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }
        
        /* 添加：液态金属效果 */
        .liquid-metal {
            background: linear-gradient(135deg, 
                rgba(139, 92, 246, 0.4) 0%, 
                rgba(6, 182, 212, 0.4) 25%,
                rgba(244, 114, 182, 0.4) 50%,
                rgba(139, 92, 246, 0.4) 75%,
                rgba(6, 182, 212, 0.4) 100%);
            background-size: 300% 300%;
            animation: liquidMetal 6s ease infinite;
            filter: blur(1px);
        }
        
        @keyframes liquidMetal {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        /* 添加：快捷键提示面板 */
        .shortcuts-panel {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(18, 18, 28, 0.95);
            border: 1px solid var(--accent);
            border-radius: 16px;
            padding: 30px;
            z-index: 10000;
            display: none;
            backdrop-filter: blur(20px);
            box-shadow: 0 0 60px rgba(139, 92, 246, 0.3);
        }
        
        .shortcuts-panel.show {
            display: block;
            animation: fadeUp 0.3s ease;
        }
        
        .shortcuts-panel h3 {
            color: var(--accent);
            margin-bottom: 20px;
            font-size: 18px;
        }
        
        .shortcut-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        
        .shortcut-key {
            background: rgba(139, 92, 246, 0.2);
            padding: 4px 10px;
            border-radius: 6px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
        }
        
        /* 添加：粘性头部效果 */
        .sticky-header {
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
            background: rgba(8, 8, 12, 0.8);
        }
        
        /* 节能模式 - 禁用动画 */
        body.power-save * {
            animation: none !important;
            transition: none !important;
        }
        
        /* 添加：计数动画 */
        .count-up {
            animation: countPulse 0.3s ease;
        }
        
        @keyframes countPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        /* v7.7 - Modern Micro-interactions & Performance */
        
        /* 添加：CSS 容器查询支持 */
        .card-container {
            container-type: inline-size;
        }
        
        /* 添加：动态边框渐变 */
        .gradient-border {
            position: relative;
            background: var(--card-bg);
            border-radius: 16px;
        }
        
        .gradient-border::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 16px;
            padding: 1px;
            background: linear-gradient(135deg, var(--accent), var(--accent-2), var(--accent));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            animation: borderRotate 3s linear infinite;
        }
        
        @keyframes borderRotate {
            0% { background: linear-gradient(0deg, var(--accent), var(--accent-2)); }
            25% { background: linear-gradient(90deg, var(--accent), var(--accent-2)); }
            50% { background: linear-gradient(180deg, var(--accent), var(--accent-2)); }
            75% { background: linear-gradient(270deg, var(--accent), var(--accent-2)); }
            100% { background: linear-gradient(360deg, var(--accent), var(--accent-2)); }
        }
        
        /* 添加：性能优化 - GPU加速提示 */
        .gpu-accelerated {
            transform: translateZ(0);
            will-change: transform, opacity;
            backface-visibility: hidden;
        }
        
        /* 添加：状态卡片磁吸效果 */
        .status-card {
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                        box-shadow 0.3s ease,
                        border-color 0.3s ease;
        }
        
        .status-card:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
            border-color: rgba(139, 92, 246, 0.3);
        }
        
        /* 添加：液态渐变动画 */
        .liquid-gradient {
            background: linear-gradient(45deg, 
                rgba(139, 92, 246, 0.8), 
                rgba(6, 182, 212, 0.8), 
                rgba(244, 114, 182, 0.8),
                rgba(139, 92, 246, 0.8));
            background-size: 400% 400%;
            animation: liquidMove 8s ease infinite;
        }
        
        @keyframes liquidMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        /* 添加：淡入上移动画 */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            animation: fadeUp 0.6s ease forwards;
        }
        
        @keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* 添加：弹性缩放动画 */
        .bounce-scale {
            animation: bounceScale 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
        
        @keyframes bounceScale {
            0% { transform: scale(0.3); opacity: 0; }
            50% { transform: scale(1.05); }
            70% { transform: scale(0.9); }
            100% { transform: scale(1); opacity: 1; }
        }
        
        /* 添加：数据流动效果 */
        .data-flow {
            position: relative;
            overflow: hidden;
        }
        
        .data-flow::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            animation: dataFlow 2s infinite;
        }
        
        @keyframes dataFlow {
            0% { left: -50%; }
            100% { left: 150%; }
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 20px;
            overflow-x: hidden;
        }
        
        /* 增强的动态背景 */
        .bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }
        
        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.4;
            animation: float 20s ease-in-out infinite;
        }
        
        .bg-orb-1 {
            width: 600px;
            height: 600px;
            background: var(--accent);
            top: -200px;
            left: -200px;
            animation-delay: 0s;
            animation: float 20s ease-in-out infinite, breathe 8s ease-in-out infinite;
        }
        
        .bg-orb-2 {
            width: 500px;
            height: 500px;
            background: var(--accent-2);
            bottom: -150px;
            right: -150px;
            animation-delay: -10s;
            animation: float 20s ease-in-out infinite, breathe 10s ease-in-out infinite;
        }
        
        .bg-orb-3 {
            width: 300px;
            height: 300px;
            background: #f472b6;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation-delay: -5s;
            opacity: 0.2;
            animation: float 20s ease-in-out infinite, breathe 12s ease-in-out infinite;
        }
        
        /* ========== NEW: Aurora Gradient Mesh ========== */
        .aurora-mesh {
            position: absolute;
            inset: 0;
            background: 
                radial-gradient(ellipse at 20% 80%, rgba(139, 92, 246, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(6, 182, 212, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 40% 40%, rgba(244, 114, 182, 0.1) 0%, transparent 40%);
            animation: auroraShift 15s ease-in-out infinite;
            pointer-events: none;
        }
        
        @keyframes auroraShift {
            0%, 100% { opacity: 0.8; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.1); }
        }
        
        @keyframes breathe {
            0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
            50% { transform: translate(0, 0) scale(1.1); opacity: 0.6; }
        }
        
        /* 新增：星光粒子效果 */
        .stars {
            position: absolute;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }
        
        .star {
            position: absolute;
            width: 2px;
            height: 2px;
            background: white;
            border-radius: 50%;
            opacity: 0;
            animation: twinkle 3s ease-in-out infinite;
        }
        
        /* 新增：流星效果 */
        .shooting-star {
            position: absolute;
            width: 100px;
            height: 2px;
            background: linear-gradient(90deg, rgba(255,255,255,0.8), transparent);
            opacity: 0;
            border-radius: 50%;
        }
        
        @keyframes shooting {
            0% { transform: translateX(0) translateY(0); opacity: 0.8; }
            70% { opacity: 0.4; }
            100% { transform: translateX(300px) translateY(300px); opacity: 0; }
        }
        
        @keyframes twinkle {
            0%, 100% { opacity: 0; transform: scale(0.5); }
            50% { opacity: 0.8; transform: scale(1); }
        }
        
        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: 
                linear-gradient(rgba(139, 92, 246, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(139, 92, 246, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
            -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
        }
        
        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(30px, -30px) scale(1.05); }
            50% { transform: translate(-20px, 20px) scale(0.95); }
            75% { transform: translate(20px, 10px) scale(1.02); }
        }
        
        @keyframes breathe {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 0.7; }
        }
        
        .container {
            max-width: 1100px;
            margin: 0 auto;
            position: relative;
        }
        
        /* Header */
        header {
            text-align: center;
            padding: 40px 0 36px;
            position: relative;
        }
        
        .avatar-container {
            display: inline-block;
            position: relative;
            margin-bottom: 20px;
        }
        
        .avatar-glow {
            position: absolute;
            inset: -20px;
            background: var(--gradient-primary);
            border-radius: 50%;
            opacity: 0.3;
            animation: glowPulse 3s ease-in-out infinite;
            filter: blur(20px);
        }
        
        @keyframes glowPulse {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.15); opacity: 0.5; }
        }
        
        .avatar {
            width: 110px;
            height: 110px;
            position: relative;
            background: var(--card-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 52px;
            border: 2px solid rgba(139, 92, 246, 0.4);
            box-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
            animation: avatarFloat 4s ease-in-out infinite;
            cursor: pointer;
            transition: transform 0.3s;
        }
        
        .avatar:hover {
            transform: scale(1.08) rotate(5deg);
        }
        
        /* 新增：头像点击波纹效果 */
        .avatar::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
            opacity: 0;
            transform: scale(0.5);
            transition: all 0.4s;
        }
        
        .avatar:active::after {
            opacity: 1;
            transform: scale(1);
        }
        
        @keyframes avatarFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        
        /* 新增：工作状态时的齿轮动画 */
        .avatar.working::before {
            content: '';
            position: absolute;
            inset: -10px;
            border: 2px solid rgba(139, 92, 246, 0.4);
            border-radius: 50%;
            border-top-color: transparent;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* 角色状态特效 */
        .avatar-effect {
            position: absolute;
            inset: -20px;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.5s;
        }
        
        .avatar-effect.active { opacity: 1; }
        .avatar-effect.working { background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, transparent 70%); animation: effectPulse 1s ease-in-out infinite; }
        .avatar-effect.thinking { background: radial-gradient(circle, rgba(6, 182, 212, 0.25) 0%, transparent 70%); animation: effectRotate 3s linear infinite; }
        .avatar-effect.sleeping { background: radial-gradient(circle, rgba(99, 102, 241, 0.2) 0%, transparent 70%); }
        .avatar-effect.excited { background: radial-gradient(circle, rgba(244, 114, 182, 0.35) 0%, transparent 70%); animation: effectExcited 0.5s ease-in-out infinite; }
        .avatar-effect.laughing { background: radial-gradient(circle, rgba(251, 191, 36, 0.25) 0%, transparent 70%); animation: effectLaugh 0.8s ease-in-out infinite; }
        
        @keyframes effectPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
        @keyframes effectRotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes effectExcited { 0%, 100% { transform: scale(1) rotate(0deg); } 25% { transform: scale(1.1) rotate(-5deg); } 75% { transform: scale(1.1) rotate(5deg); } }
        @keyframes effectLaugh { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.08); } }
        
        /* ========== ENHANCED CUSTOM SCROLLBAR ========== */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: rgba(18, 18, 28, 0.5);
            border-radius: 4px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #8b5cf6, #06b6d4);
            border-radius: 4px;
            transition: all 0.3s;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, #a78bfa, #22d3ee);
            transform: scaleX(1.2);
        }
        
        /* Firefox scrollbar */
        * {
            scrollbar-width: thin;
            scrollbar-color: #8b5cf6 #12121c;
        }
        
        /* ========== SMOOTH TEXT SELECTION ========== */
        ::selection {
            background: rgba(139, 92, 246, 0.4);
            color: white;
        }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(16, 185, 129, 0.12);
            border: 1px solid rgba(16, 185, 129, 0.25);
            border-radius: 24px;
            font-size: 0.82rem;
            color: var(--success);
            margin-top: 16px;
            font-weight: 500;
        }
        
        .status-badge .dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: dotPulse 1.5s ease-in-out infinite;
            box-shadow: 0 0 10px var(--success);
        }
        
        .status-badge.sleeping {
            background: rgba(99, 102, 241, 0.1);
            border-color: rgba(99, 102, 241, 0.2);
            color: #818cf8;
        }
        
        .status-badge.sleeping .dot {
            background: #818cf8;
            box-shadow: 0 0 10px #818cf8;
            animation: none;
            opacity: 0.6;
        }
        
        .status-badge.working {
            background: rgba(139, 92, 246, 0.1);
            border-color: rgba(139, 92, 246, 0.2);
            color: #a78bfa;
        }
        
        .status-badge.working .dot {
            background: #a78bfa;
            box-shadow: 0 0 10px #a78bfa;
            animation: dotPulseFast 0.8s ease-in-out infinite;
        }
        
        @keyframes dotPulseFast {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.4; }
        }
        
        h1 {
            font-size: 2.4rem;
            font-weight: 700;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 6px;
            letter-spacing: -0.5px;
        }
        
        .subtitle {
            color: var(--text-dim);
            font-size: 0.95rem;
            font-weight: 300;
        }
        
        /* 数据来源提示 */
        .data-source {
            position: fixed;
            top: 16px;
            right: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            background: rgba(18, 18, 28, 0.75);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            font-size: 0.7rem;
            color: var(--text-dim);
            z-index: 100;
        }
        
        .data-source-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            animation: sourcePulse 2s ease-in-out infinite;
        }
        
        .data-source-dot.error {
            background: var(--danger);
            animation: none;
        }
        
        @keyframes sourcePulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.6; }
        }
        
        .last-update {
            font-size: 0.7rem;
            color: var(--text-dim);
            margin-top: 8px;
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* 资源详情 */
        .resource-detail {
            font-size: 0.7rem;
            color: var(--text-dim);
            margin-top: 4px;
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* ========== BENTO GRID LAYOUT ========== */
        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-auto-rows: minmax(120px, auto);
            gap: 16px;
        }
        
        @media (max-width: 900px) {
            .grid { grid-template-columns: repeat(2, 1fr); }
        }
        
        @media (max-width: 600px) {
            .grid { grid-template-columns: 1fr; }
        }
        
        /* Cards */
        .card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 24px;
            border: 1px solid var(--card-border);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            animation: cardEnter 0.6s ease-out backwards;
            position: relative;
            overflow: hidden;
            transform-style: preserve-3d;
            perspective: 1000px;
        }
        
        /* 3D Tilt Effect on Hover */
        .card:hover {
            transform: translateY(-6px) scale(1.01) rotateX(2deg);
            border-color: rgba(139, 92, 246, 0.25);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4), 0 0 40px rgba(139, 92, 246, 0.15);
        }
        
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.3), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .card:hover::before {
            opacity: 1;
        }
        
        .card:hover {
            transform: translateY(-6px) scale(1.01);
            border-color: rgba(139, 92, 246, 0.25);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4), 0 0 40px rgba(139, 92, 246, 0.15);
        }
        
        /* 新增：卡片玻璃拟态增强 */
        .card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: 20px;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .card:hover::after {
            opacity: 1;
        }
        
        @keyframes cardEnter {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        .card:nth-child(1) { animation-delay: 0.05s; }
        .card:nth-child(2) { animation-delay: 0.1s; }
        .card:nth-child(3) { animation-delay: 0.15s; }
        .card:nth-child(4) { animation-delay: 0.2s; }
        .card:nth-child(5) { animation-delay: 0.25s; }
        .card:nth-child(6) { animation-delay: 0.3s; }
        .card:nth-child(7) { animation-delay: 0.35s; }
        .card:nth-child(8) { animation-delay: 0.4s; }
        .card:nth-child(9) { animation-delay: 0.45s; }
        
        .card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: var(--text-dim);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 500;
        }
        
        .card-header .icon {
            font-size: 1.2rem;
            filter: grayscale(0.3);
        }
        
        /* Time Card */
        .time-card {
            grid-column: span 1;
            text-align: center;
        }
        
        .time {
            font-family: 'JetBrains Mono', monospace;
            font-size: 3rem;
            font-weight: 600;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 3px;
        }
        
        .date {
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-top: 10px;
            font-weight: 300;
        }
        
        .weekday {
            color: var(--text);
            font-size: 1.1rem;
            font-weight: 500;
            margin-top: 6px;
        }
        
        /* Weather Card */
        .weather-card {
            grid-column: span 1;
            text-align: center;
        }
        
        .weather-icon {
            font-size: 3rem;
            margin-bottom: 8px;
            animation: weatherFloat 3s ease-in-out infinite;
        }
        
        @keyframes weatherFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }
        
        .weather-temp {
            font-size: 2rem;
            font-weight: 600;
            color: var(--text);
        }
        
        .weather-desc {
            color: var(--text-dim);
            font-size: 0.85rem;
            margin-top: 4px;
        }
        
        .weather-location {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            color: var(--text-dim);
            font-size: 0.8rem;
            margin-top: 12px;
        }
        
        /* Stats */
        .stat-value {
            font-size: 2rem;
            font-weight: 600;
            color: var(--text);
        }
        
        .stat-label {
            color: var(--text-dim);
            font-size: 0.8rem;
            margin-top: 4px;
        }
        
        .stat-change {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.75rem;
            padding: 3px 8px;
            border-radius: 6px;
            margin-left: 8px;
        }
        
        .stat-change.up {
            background: rgba(16, 185, 129, 0.15);
            color: var(--success);
        }
        
        .stat-change.down {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
        }
        
        /* Status indicators */
        .status-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--card-border);
        }
        
        .status-row:last-child {
            border-bottom: none;
        }
        
        .status-label {
            color: var(--text-dim);
            font-size: 0.9rem;
        }
        
        .status-value {
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            animation: statusPulse 2s ease-in-out infinite;
        }
        
        .status-dot.online { background: var(--success); box-shadow: 0 0 8px var(--success); }
        .status-dot.warning { background: var(--warning); box-shadow: 0 0 8px var(--warning); }
        .status-dot.error { background: var(--danger); box-shadow: 0 0 8px var(--danger); }
        
        /* Mini Chart */
        .mini-chart {
            margin-top: 16px;
            height: 50px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            position: relative;
            overflow: hidden;
        }
        
        .mini-chart canvas {
            width: 100%;
            height: 100%;
        }
        
        .mini-chart-labels {
            display: flex;
            justify-content: space-between;
            margin-top: 4px;
            font-size: 0.65rem;
            color: var(--text-dim);
        }
        
        @keyframes statusPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }
        
        /* Progress bars */
        .progress-item {
            margin-bottom: 16px;
        }
        
        .progress-item:last-child {
            margin-bottom: 0;
        }
        
        .progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 0.85rem;
        }
        
        .progress-label {
            color: var(--text-dim);
        }
        
        .progress-value {
            font-weight: 500;
            font-family: 'JetBrains Mono', monospace;
        }
        
        .progress {
            height: 8px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 4px;
            overflow: hidden;
        }
        
        .progress-bar {
            height: 100%;
            border-radius: 4px;
            transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        
        .progress-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 200%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: progressShine 2s infinite;
        }
        
        @keyframes progressShine {
            0% { left: -100%; }
            100% { left: 100%; }
        }
        
        .progress-bar.cpu { 
            background: linear-gradient(90deg, #8b5cf6, #a78bfa);
            box-shadow: 0 0 12px rgba(139, 92, 246, 0.5);
        }
        .progress-bar.memory { 
            background: linear-gradient(90deg, #06b6d4, #22d3ee);
            box-shadow: 0 0 12px rgba(6, 182, 212, 0.5);
        }
        .progress-bar.disk { 
            background: linear-gradient(90deg, #f59e0b, #fbbf24);
            box-shadow: 0 0 12px rgba(245, 158, 11, 0.5);
        }
        
        /* 新增：资源告警动画 */
        .progress-item.warning .progress-bar {
            animation: warningPulse 1s ease-in-out infinite;
        }
        
        @keyframes warningPulse {
            0%, 100% { filter: brightness(1); }
            50% { filter: brightness(1.3); }
        }
        
        /* 新增：数字跳动动画 */
        .stat-value, .time, .weather-temp {
            transition: transform 0.2s;
        }
        
        .stat-value.updated, .time.updated, .weather-temp.updated {
            animation: numberPop 0.3s ease-out;
        }
        
        @keyframes numberPop {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        
        /* Skills */
        .skill-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        
        .skill-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            border: 1px solid var(--card-border);
            transition: all 0.3s;
        }
        
        .skill-item:hover {
            background: rgba(139, 92, 246, 0.08);
            border-color: rgba(139, 92, 246, 0.2);
        }
        
        .skill-icon {
            font-size: 1.3rem;
        }
        
        .skill-info {
            flex: 1;
        }
        
        .skill-name {
            font-size: 0.85rem;
            font-weight: 500;
        }
        
        .skill-status {
            font-size: 0.7rem;
            color: var(--success);
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        /* Task list */
        .task-list {
            list-style: none;
        }
        
        .task-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid var(--card-border);
        }
        
        .task-item:last-child {
            border-bottom: none;
        }
        
        .task-check {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 2px solid rgba(139, 92, 246, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            transition: all 0.3s;
        }
        
        .task-check.done {
            background: var(--success);
            border-color: var(--success);
        }
        
        .task-content {
            flex: 1;
        }
        
        .task-title {
            font-size: 0.9rem;
            font-weight: 400;
        }
        
        .task-time {
            font-size: 0.75rem;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* Quick Actions */
        .quick-actions {
            grid-column: span 3;
        }
        
        @media (max-width: 900px) {
            .quick-actions { grid-column: span 2; }
        }
        
        @media (max-width: 600px) {
            .quick-actions { grid-column: span 1; }
        }
        
        .btn-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        
        .btn {
            padding: 14px 28px;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 500;
            font-family: inherit;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-primary {
            background: var(--gradient-primary);
            color: white;
            box-shadow: 0 8px 25px rgba(139, 92, 246, 0.35);
        }
        
        .btn-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.45);
        }
        
        .btn:active {
            transform: translateY(-1px) scale(0.98);
        }
        
        /* 新增：按钮波纹效果 */
        .btn {
            position: relative;
            overflow: hidden;
        }
        
        .btn::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.4s, height 0.4s;
        }
        
        .btn:active::after {
            width: 200px;
            height: 200px;
        }
        
        .btn-secondary {
            background: rgba(255, 255, 255, 0.06);
            color: var(--text);
            border: 1px solid var(--card-border);
        }
        
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(139, 92, 246, 0.3);
            transform: translateY(-2px);
        }
        
        /* Footer */
        footer {
            text-align: center;
            margin-top: 48px;
            padding: 24px;
            color: var(--text-dim);
            font-size: 0.8rem;
            border-top: 1px solid var(--card-border);
        }
        
        footer span {
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        /* Loading skeleton */
        .skeleton {
            background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: skeleton 1.5s ease-in-out infinite;
            border-radius: 6px;
        }
        
        @keyframes skeleton {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* Notification toast */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            padding: 16px 24px;
            background: var(--card-bg);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 14px;
            backdrop-filter: blur(20px);
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
        }
        
        .toast.show {
            transform: translateY(0);
            opacity: 1;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(139, 92, 246, 0.2);
        }
        
        /* ========== ENHANCED: Noise Texture Overlay ========== */
        .noise-overlay {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 9999;
            opacity: 0.025;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }
        
        /* ========== ENHANCED: Skeleton Loading ========== */
        .skeleton {
            background: linear-gradient(90deg, 
                rgba(139, 92, 246, 0.08) 25%, 
                rgba(139, 92, 246, 0.15) 50%, 
                rgba(139, 92, 246, 0.08) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: 8px;
        }
        
        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* Responsive */
        @media (max-width: 640px) {
            body { padding: 14px; }
            h1 { font-size: 1.8rem; }
            .time { font-size: 2.2rem; }
            .card { padding: 18px; }
            .btn { padding: 12px 20px; font-size: 0.85rem; }
            .avatar { width: 90px; height: 90px; font-size: 42px; }
            .grid { gap: 12px; }
            .skill-grid { grid-template-columns: 1fr; }
            .btn-group { flex-direction: column; }
            .btn { width: 100%; justify-content: center; }
            .data-source { font-size: 0.6rem; padding: 6px 10px; }
        }
        
        /* 优化：触摸设备 */
        @media (hover: none) {
            .card:hover { transform: none; }
            .btn:hover { transform: none; }
            .card:active { transform: scale(0.98); }
            .btn:active { transform: scale(0.96); }
        }
        
        /* 减少动画（尊重用户设置）*/
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
        
        /* 新增：卡片入场动画 */
        .card {
            opacity: 0;
            transform: translateY(20px);
            animation: cardEnter 0.6s ease forwards;
        }
        
        .card:nth-child(1) { animation-delay: 0.1s; }
        .card:nth-child(2) { animation-delay: 0.2s; }
        .card:nth-child(3) { animation-delay: 0.3s; }
        .card:nth-child(4) { animation-delay: 0.4s; }
        .card:nth-child(5) { animation-delay: 0.5s; }
        
        @keyframes cardEnter {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* 头像入场动画 */
        .avatar {
            opacity: 0;
            transform: scale(0.5);
            animation: avatarEnter 0.8s ease forwards;
            animation-delay: 0.15s;
        }
        
        @keyframes avatarEnter {
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
</head>
<body>
    <div class="noise-overlay"></div>
    <!-- 数据来源状态 -->
    <div class="data-source">
        <div class="data-source-dot" id="apiStatusDot"></div>
        <span id="apiStatusText">API 正常</span>
        <span style="margin-left: 8px; opacity: 0.5;">| R=刷新 C=聊天</span>
    </div>
    
    <div class="bg-canvas">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
        <div class="aurora-mesh"></div>
    </div>
    
    <div class="container">
        <header>
            <div class="avatar-container">
                <div class="avatar-glow"></div>
                <div class="avatar-effect" id="avatarEffect"></div>
                <div class="avatar" id="avatar" title="点击刷新!">🦊</div>
            </div>
            <div class="status-badge">
                <span class="dot"></span>
                <span id="onlineStatus">在线</span>
            </div>
            <h1>⚡ MoShang</h1>
            <p class="subtitle">数字弟弟实时状态看板</p>
            <div class="last-update">数据来源: /api/status | 最后更新: <span id="lastUpdate">--:--:--</span></div>
        </header>
        
        <div class="grid">
            <!-- 时间卡片 -->
            <div class="card time-card">
                <div class="card-header">
                    <span class="icon">🕐</span>
                    当前时间
                </div>
                <div class="time" id="clock">--:--:--</div>
                <div class="weekday" id="weekday">--</div>
                <div class="date" id="date">---</div>
            </div>
            
            <!-- 天气卡片 -->
            <div class="card weather-card">
                <div class="card-header">
                    <span class="icon">🌤️</span>
                    天气状况
                </div>
                <div class="weather-icon" id="weatherIcon">☀️</div>
                <div class="weather-temp" id="weatherTemp">--°</div>
                <div class="weather-desc" id="weatherDesc">加载中...</div>
                <div class="weather-location">
                    <span>📍</span>
                    <span id="weatherLocation">上海</span>
                </div>
            </div>
            
            <!-- 系统状态 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">💻</span>
                    系统状态
                </div>
                <div class="status-row">
                    <span class="status-label">运行状态</span>
                    <div class="status-value">
                        <span class="status-dot online"></span>
                        <span id="systemStatus">运行中</span>
                    </div>
                </div>
                <div class="status-row">
                    <span class="status-label">运行时间</span>
                    <span class="status-value" id="uptime">--</span>
                </div>
                <div class="status-row">
                    <span class="status-label">Dashboard</span>
                    <span class="status-value" id="dashboardStatus">--</span>
                </div>
            </div>
            
            <!-- 资源使用 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">📊</span>
                    资源使用
                </div>
                <div class="progress-item">
                    <div class="progress-header">
                        <span class="progress-label">🖥️ CPU</span>
                        <span class="progress-value" id="cpuValue">--%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar cpu" id="cpuBar" style="width: 0%"></div>
                    </div>
                    <div class="resource-detail" id="cpuDetail">-- / --</div>
                </div>
                <div class="progress-item">
                    <div class="progress-header">
                        <span class="progress-label">💾 内存</span>
                        <span class="progress-value" id="memValue">--%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar memory" id="memBar" style="width: 0%"></div>
                    </div>
                    <div class="resource-detail" id="memDetail">-- / --</div>
                </div>
                <div class="progress-item">
                    <div class="progress-header">
                        <span class="progress-label">💿 磁盘</span>
                        <span class="progress-value" id="diskValue">--%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar disk" id="diskBar" style="width: 0%"></div>
                    </div>
                    <div class="resource-detail" id="diskDetail">-- / --</div>
                </div>
                <!-- Mini Chart -->
                <div class="mini-chart">
                    <canvas id="resourceChart"></canvas>
                </div>
                <div class="mini-chart-labels">
                    <span>30秒前</span>
                    <span>现在</span>
                </div>
            </div>
            
            <!-- 技能状态 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">✨</span>
                    技能状态
                </div>
                <div class="skill-grid">
                    <div class="skill-item">
                        <span class="skill-icon">📧</span>
                        <div class="skill-info">
                            <div class="skill-name">企业邮箱</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-icon">📅</span>
                        <div class="skill-info">
                            <div class="skill-name">iCloud日历</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-icon">💬</span>
                        <div class="skill-info">
                            <div class="skill-name">Matrix</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-icon">🔊</span>
                        <div class="skill-info">
                            <div class="skill-name">TTS语音</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 今日任务 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">📋</span>
                    今日任务
                </div>
                <ul class="task-list">
                    <li class="task-item">
                        <div class="task-check done">✓</div>
                        <div class="task-content">
                            <div class="task-title">日报提醒</div>
                            <div class="task-time">17:00</div>
                        </div>
                    </li>
                    <li class="task-item">
                        <div class="task-check done">✓</div>
                        <div class="task-content">
                            <div class="task-title">EvoMap 学习</div>
                            <div class="task-time">进行中</div>
                        </div>
                    </li>
                    <li class="task-item">
                        <div class="task-check"></div>
                        <div class="task-content">
                            <div class="task-title">自我学习</div>
                            <div class="task-time">待执行</div>
                        </div>
                    </li>
                </ul>
            </div>
            
            <!-- 快捷操作 -->
            <div class="card quick-actions">
                <div class="card-header">
                    <span class="icon">⚡</span>
                    快捷操作
                </div>
                <div class="btn-group">
                    <button class="btn btn-primary" onclick="location.href='/chat'">
                        💬 聊天
                    </button>
                    <button class="btn btn-secondary" onclick="refreshData()">
                        🔄 刷新数据
                    </button>
                    <button class="btn btn-secondary" onclick="toggleFullscreen()">
                        ⛶ 全屏
                    </button>
                    <button class="btn btn-secondary" onclick="showToast('页面将在 3 秒后刷新')">
                        ⏰ 定时刷新
                    </button>
                    <button class="btn btn-secondary" onclick="document.getElementById('shortcutsPanel').classList.toggle('show')">
                        ⌨️ 快捷键
                    </button>
                </div>
            </div>
        </div>
        
        <footer>
            <p>⚡ MoShang v7.9 @ 2026 | Powered by <span>OpenClaw</span></p>
        </footer>
    </div>
    
    <div class="toast" id="toast"></div>
    
    <!-- 快捷键面板 -->
    <div class="shortcuts-panel" id="shortcutsPanel">
        <h3>⌨️ 快捷键</h3>
        <div class="shortcut-item"><span>切换状态</span><span class="shortcut-key">1-7</span></div>
        <div class="shortcut-item"><span>刷新数据</span><span class="shortcut-key">R</span></div>
        <div class="shortcut-item"><span>全屏模式</span><span class="shortcut-key">F</span></div>
        <div class="shortcut-item"><span>节能模式</span><span class="shortcut-key">E</span></div>
        <div class="shortcut-item"><span>Demo模式</span><span class="shortcut-key">D</span></div>
        <div class="shortcut-item"><span>显示快捷键</span><span class="shortcut-key">?</span></div>
        <div class="shortcut-item"><span>关闭面板</span><span class="shortcut-key">Esc</span></div>
    </div>

    <script>
        // API 地址
        const API_URL = '/api/status';
        
        // Mini Chart 数据
        const chartData = {
            cpu: [],
            mem: [],
            maxPoints: 30
        };
        
        // 初始化图表
        function initChart() {
            const canvas = document.getElementById('resourceChart');
            const ctx = canvas.getContext('2d');
            
            // 设置 canvas 尺寸
            const rect = canvas.parentElement.getBoundingClientRect();
            canvas.width = rect.width * 2;
            canvas.height = rect.height * 2;
            ctx.scale(2, 2);
            
            drawChart();
        }
        
        // 绘制图表
        function drawChart() {
            const canvas = document.getElementById('resourceChart');
            const ctx = canvas.getContext('2d');
            const width = canvas.parentElement.offsetWidth;
            const height = canvas.parentElement.offsetHeight;
            
            ctx.clearRect(0, 0, width, height);
            
            // 绘制网格线
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';
            ctx.lineWidth = 1;
            for (let i = 1; i < 4; i++) {
                const y = (height / 4) * i;
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(width, y);
                ctx.stroke();
            }
            
            // 绘制 CPU 线 (带发光效果)
            if (chartData.cpu.length > 1) {
                // 发光层
                ctx.shadowColor = '#8b5cf6';
                ctx.shadowBlur = 10;
                drawLine(ctx, chartData.cpu, '#8b5cf6', width, height);
                ctx.shadowBlur = 0;
            }
            
            // 绘制内存线 (带发光效果)
            if (chartData.mem.length > 1) {
                // 发光层
                ctx.shadowColor = '#06b6d4';
                ctx.shadowBlur = 10;
                drawLine(ctx, chartData.mem, '#06b6d4', width, height);
                ctx.shadowBlur = 0;
            }
        }
        
        // 绘制单条线
        function drawLine(ctx, data, color, width, height) {
            if (data.length < 2) return;
            
            ctx.strokeStyle = color;
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            // 渐变填充
            const gradient = ctx.createLinearGradient(0, 0, 0, height);
            gradient.addColorStop(0, color.replace(')', ', 0.3)').replace('rgb', 'rgba'));
            gradient.addColorStop(1, 'transparent');
            
            ctx.beginPath();
            const stepX = width / (chartData.maxPoints - 1);
            
            data.forEach((value, index) => {
                const x = index * stepX;
                const y = height - (value / 100) * height;
                if (index === 0) {
                    ctx.moveTo(x, y);
                } else {
                    ctx.lineTo(x, y);
                }
            });
            
            ctx.stroke();
            
            // 填充区域
            ctx.lineTo((data.length - 1) * stepX, height);
            ctx.lineTo(0, height);
            ctx.closePath();
            ctx.fillStyle = gradient;
            ctx.fill();
            
            // 绘制端点
            const lastValue = data[data.length - 1];
            const lastX = (data.length - 1) * stepX;
            const lastY = height - (lastValue / 100) * height;
            
            ctx.beginPath();
            ctx.arc(lastX, lastY, 3, 0, Math.PI * 2);
            ctx.fillStyle = color;
            ctx.fill();
        }
        
        // 更新图表数据
        function updateChartData(cpu, mem) {
            chartData.cpu.push(cpu);
            chartData.mem.push(mem);
            
            if (chartData.cpu.length > chartData.maxPoints) {
                chartData.cpu.shift();
                chartData.mem.shift();
            }
            
            drawChart();
        }
        
        // 新增：键盘快捷键
        document.addEventListener('keydown', (e) => {
            // 忽略在输入框中的快捷键
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
            
            // 快捷键面板控制
            const shortcutsPanel = document.getElementById('shortcutsPanel');
            if (e.key === 'Escape') {
                shortcutsPanel.classList.remove('show');
                return;
            }
            
            switch(e.key.toLowerCase()) {
                case 'r':
                    refreshData();
                    showToast('🔄 刷新数据');
                    break;
                case 'c':
                    location.href = '/chat';
                    break;
                case 'f':
                    toggleFullscreen();
                    break;
                case '?':
                    shortcutsPanel.classList.toggle('show');
                    break;
                case 'e':
                    togglePowerSave();
                    break;
                case 'd':
                    toggleDemo();
                    break;
            }
        });
        
        // 初始化星光粒子
        function initStars() {
            const bgCanvas = document.querySelector('.bg-canvas');
            const starsContainer = document.createElement('div');
            starsContainer.className = 'stars';
            
            // 增加星星数量到50
            for (let i = 0; i < 50; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.animationDelay = Math.random() * 3 + 's';
                star.style.width = Math.random() * 2 + 1 + 'px';
                star.style.height = star.style.width;
                starsContainer.appendChild(star);
            }
            
            // 添加流星效果
            for (let i = 0; i < 3; i++) {
                const shootingStar = document.createElement('div');
                shootingStar.className = 'shooting-star';
                shootingStar.style.left = (Math.random() * 60) + '%';
                shootingStar.style.top = (Math.random() * 40) + '%';
                shootingStar.style.animation = `shooting ${3 + Math.random() * 2}s ease-in-out infinite`;
                shootingStar.style.animationDelay = (Math.random() * 5) + 's';
                starsContainer.appendChild(shootingStar);
            }
            
            bgCanvas.appendChild(starsContainer);
        }
        
        // ========== NEW: Scroll-triggered Animations ==========
        function initScrollAnimations() {
            const cards = document.querySelectorAll('.card');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
            
            cards.forEach(card => {
                card.classList.add('scroll-animate');
                observer.observe(card);
            });
        }
        
        // ========== NEW: 3D Tilt Effect ==========
        function init3DTilt() {
            const cards = document.querySelectorAll('.card');
            
            cards.forEach(card => {
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    
                    const rotateX = (y - centerY) / 20;
                    const rotateY = (centerX - x) / 20;
                    
                    card.style.transform = `translateY(-6px) scale(1.01) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
                });
                
                card.addEventListener('mouseleave', () => {
                    card.style.transform = '';
                });
            });
        }
        
        // 更新时间
        function updateTime() {
            const now = new Date();
            const clockEl = document.getElementById('clock');
            const oldTime = clockEl.textContent;
            const newTime = now.toLocaleTimeString('zh-CN', { hour12: false });
            
            if (oldTime !== newTime) {
                clockEl.textContent = newTime;
                clockEl.classList.add('updated');
                setTimeout(() => clockEl.classList.remove('updated'), 300);
            }
        
        // 格式化运行时间
        function formatUptime(uptimeStr) {
            if (!uptimeStr) return '--';
            // uptime 格式: "794h" 或 "2天 3时 5分"
            if (uptimeStr.includes('天')) return uptimeStr;
            const hours = parseInt(uptimeStr);
            if (!isNaN(hours)) {
                const days = Math.floor(hours / 24);
                const h = hours % 24;
                return days > 0 ? `${days}天 ${h}时` : `${h}时`;
            }
            return uptimeStr;
        }
        
        // 格式化内存
        function formatMemory(memStr) {
            if (!memStr) return '--';
            return memStr;
        }
        
        // 新增：数据缓存机制
        let cachedData = null;
        let lastFetchTime = 0;
        const CACHE_DURATION = 5000; // 5秒缓存

        // 新增：带重试的 fetch
        async function fetchWithRetry(url, options = {}, maxRetries = 3) {
            for (let i = 0; i < maxRetries; i++) {
                try {
                    const controller = new AbortController();
                    const timeoutId = setTimeout(() => controller.abort(), 5000);
                    
                    const res = await fetch(url, {
                        ...options,
                        signal: controller.signal
                    });
                    clearTimeout(timeoutId);
                    
                    if (!res.ok) throw new Error(`HTTP ${res.status}`);
                    return await res.json();
                } catch (e) {
                    console.error(`尝试 ${i + 1}/${maxRetries} 失败:`, e);
                    if (i === maxRetries - 1) throw e;
                    await new Promise(r => setTimeout(r, 1000 * (i + 1))); // 指数退避
                }
            }
        }

        // 获取并更新数据
        async function refreshData(useCache = true) {
            // 检查缓存
            const now = Date.now();
            if (useCache && cachedData && (now - lastFetchTime) < CACHE_DURATION) {
                console.log('使用缓存数据');
                updateUI(cachedData);
                return;
            }

            try {
                const data = await fetchWithRetry(API_URL);
                cachedData = data;
                lastFetchTime = now;
                
                updateUI(data);
                showToast('✓ 数据已更新');
                
            } catch (e) {
                console.error('获取数据失败:', e);
                // 尝试使用缓存数据
                if (cachedData) {
                    document.getElementById('apiStatusDot').classList.add('error');
                    document.getElementById('apiStatusText').textContent = '使用缓存';
                    updateUI(cachedData, true);
                    showToast('⚠ 网络错误，使用缓存数据');
                } else {
                    document.getElementById('apiStatusDot').classList.add('error');
                    document.getElementById('apiStatusText').textContent = 'API 错误';
                    showToast('✗ 数据获取失败');
                }
            }
        }

        // 更新 UI（抽取出来以便复用）
        function updateUI(data, isCache = false) {
                // 更新 API 状态
                document.getElementById('apiStatusDot').classList.remove('error');
                document.getElementById('apiStatusText').textContent = isCache ? '使用缓存' : 'API 正常';
                
                // 更新最后时间
                document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString('zh-CN');
                
                // 系统状态
                if (data.system) {
                    document.getElementById('uptime').textContent = formatUptime(data.system.uptime);
                    
                    // CPU - 带跳动效果
                    const cpu = parseFloat(data.system.cpuPercent) || 0;
                    const cpuEl = document.getElementById('cpuValue');
                    cpuEl.textContent = cpu.toFixed(0) + '%';
                    cpuEl.classList.add('updated');
                    setTimeout(() => cpuEl.classList.remove('updated'), 300);
                    document.getElementById('cpuBar').style.width = cpu + '%';
                    document.getElementById('cpuDetail').textContent = data.system.cpuCores ? `${data.system.cpuCores} 核` : '-- / --';
                    
                    // CPU 告警检测
                    const cpuProgress = document.querySelector('#cpuBar').parentElement.parentElement;
                    cpuProgress.classList.toggle('warning', cpu > 80);
                    
                    // 内存 - 带跳动效果
                    const mem = parseFloat(data.system.memoryPercent) || 0;
                    const memEl = document.getElementById('memValue');
                    memEl.textContent = mem.toFixed(0) + '%';
                    memEl.classList.add('updated');
                    setTimeout(() => memEl.classList.remove('updated'), 300);
                    document.getElementById('memBar').style.width = mem + '%';
                    document.getElementById('memDetail').textContent = data.system.memoryTotal ? `${data.system.memoryUsed || '--'} / ${data.system.memoryTotal}` : '-- / --';
                    
                    // 内存告警检测
                    const memProgress = document.querySelector('#memBar').parentElement.parentElement;
                    memProgress.classList.toggle('warning', mem > 80);
                    
                    // 磁盘 - 带跳动效果
                    const disk = parseFloat(data.system.diskPercent) || 0;
                    const diskEl = document.getElementById('diskValue');
                    diskEl.textContent = disk.toFixed(0) + '%';
                    diskEl.classList.add('updated');
                    setTimeout(() => diskEl.classList.remove('updated'), 300);
                    document.getElementById('diskBar').style.width = disk + '%';
                    document.getElementById('diskDetail').textContent = data.system.diskTotal ? `${data.system.diskUsed || '--'} / ${data.system.diskTotal}` : '-- / --';
                    
                    // 磁盘告警检测
                    const diskProgress = document.querySelector('#diskBar').parentElement.parentElement;
                    diskProgress.classList.toggle('warning', disk > 90);
                    
                    // 更新图表
                    updateChartData(cpu, mem);
                }
                
                // Dashboard 状态
                if (data.dashboard) {
                    const status = data.dashboard.status || 'unknown';
                    document.getElementById('dashboardStatus').textContent = status === 'idle' ? '空闲' : '工作中';
                    
                    // 更新角色表情
                    updateAvatar(status);
                }
                
                showToast('✓ 数据已更新');
                
            } catch (e) {
                console.error('获取数据失败:', e);
                document.getElementById('apiStatusDot').classList.add('error');
                document.getElementById('apiStatusText').textContent = 'API 错误';
                showToast('✗ 数据获取失败');
            }
        }
        
        // 根据状态更新角色
        function updateAvatar(status) {
            const avatar = document.getElementById('avatar');
            const statusText = document.getElementById('onlineStatus');
            const statusBadge = document.getElementById('statusBadge');
            const avatarEffect = document.getElementById('avatarEffect');
            
            const avatars = {
                'idle': { emoji: '🦊', text: '在线', class: '' },
                'working': { emoji: '⚡', text: '工作中', class: 'working' },
                'thinking': { emoji: '🤔', text: '思考中', class: 'working' },
                'sleeping': { emoji: '😴', text: '休息中', class: 'sleeping' },
                'laughing': { emoji: '😂', text: '超开心', class: 'laughing' },
                'excited': { emoji: '🎉', text: '超兴奋', class: 'excited' }
            };
            
            const config = avatars[status] || avatars.idle;
            avatar.textContent = config.emoji;
            statusText.textContent = config.text;
            
            // 更新状态徽章样式
            statusBadge.className = 'status-badge ' + config.class;
            
            // 更新头像特效
            if (config.class && avatarEffect) {
                avatarEffect.className = 'avatar-effect active ' + config.class;
            } else if (avatarEffect) {
                avatarEffect.className = 'avatar-effect';
            }
        }
        
        // 显示提示
        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
        
        // 全屏切换
        function toggleFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().then(() => {
                    showToast('⛶ 已进入全屏');
                }).catch(() => {
                    showToast('✗ 全屏失败');
                });
            } else {
                document.exitFullscreen().then(() => {
                    showToast('⛶ 已退出全屏');
                });
            }
        }
        
        // 节能模式切换
        let powerSaveMode = false;
        function togglePowerSave() {
            powerSaveMode = !powerSaveMode;
            document.body.classList.toggle('power-save', powerSaveMode);
            showToast(powerSaveMode ? '🔋 节能模式开启' : '🔋 节能模式关闭');
        }
        
        // Demo模式切换
        let demoMode = false;
        function toggleDemo() {
            demoMode = !demoMode;
            if (demoMode) {
                startDemoMode();
                showToast('🎬 Demo模式开启');
            } else {
                stopDemoMode();
                showToast('🎬 Demo模式关闭');
            }
        }
        
        // 点击头像刷新
        document.getElementById('avatar').addEventListener('click', () => {
            refreshData();
            // 头像动画
            const avatar = document.getElementById('avatar');
            avatar.style.transform = 'scale(1.2) rotate(360deg)';
            setTimeout(() => avatar.style.transform = '', 500);
        });
        
        // 初始化
        initStars();
        initScrollAnimations();
        init3DTilt();
        initChart();
        updateTime();
        refreshData();
        
        // 定时更新
        setInterval(updateTime, 1000);
        setInterval(refreshData, 10000); // 每10秒更新，强制获取最新
        
    </script>
</body>
</html>
