<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="MoShang - OpenClaw Status Dashboard">
    <meta name="theme-color" content="#0a0a0f">
    <title>MoShang Status v143.0</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        /* ============================================================
           MoShang Dashboard - Ultra Modern CSS Design v10.0 (2026)
           v142.0: Enhanced spatial audio viz, neural mood rings, particle systems,
                   modern CSS 2026 features, 3D transforms, micro-interactions
        ============================================================ */
        
        @layer base, layout, components, animations, effects;
        
        /* ========== BASE ========== */
        @layer base {
        
            /* v143.0: View Transitions API */
            @supports (view-transition-name: none) {
                ::view-transition-old(root), ::view-transition-new(root) {
                    animation-duration: 0.3s;
                    animation-timing-function: var(--ease-spring);
                }
            }
            
            /* v143.0: AI Gesture Recognition Ready */
            .stat-card {
                touch-action: pan-y pinch-zoom;
                gesture-orientation: vertical;
            }
            
            /* v143.0: Logical Properties */
            .glass-card {
                padding-block: 24px;
                padding-inline: 24px;
                margin-inline: auto;
            }
            
            /* v143.0: Enhanced :focus-visible with multiple layers */
            :focus-visible {
                outline: 2px solid var(--holo-cyan);
                outline-offset: 3px;
                box-shadow: 
                    0 0 12px rgba(0, 245, 255, 0.3),
                    0 0 24px rgba(0, 245, 255, 0.15),
                    inset 0 0 8px rgba(0, 245, 255, 0.1);
            }
            
            /* v143.0: Color Level 5 - oklch native support */
            :root {
                --neon-mint: oklch(80% 0.15 180);
                --neon-coral: oklch(75% 0.18 25);
                --neon-violet: oklch(70% 0.2 300);
            }
            
            /* v143.0: Scroll-driven animations - smoother */
            @keyframes v143-scroll-reveal {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }
            
            .stat-card {
                view-timeline: --stat-card block;
                animation: v143-scroll-reveal linear both;
                animation-timeline: view();
                animation-range: entry 0% cover 30%;
            }
            
            /* v143.0: Physics-based spring animation */
            @keyframes v143-spring-in {
                0% { transform: scale(0.8) translateY(10px); opacity: 0; }
                60% { transform: scale(1.05) translateY(-2px); }
                100% { transform: scale(1) translateY(0); opacity: 1; }
            }
            
            @keyframes v143-morph-border {
                0%, 100% { border-radius: 16px; }
                25% { border-radius: 20px 12px 16px 18px; }
                50% { border-radius: 12px 18px 20px 14px; }
                75% { border-radius: 18px 14px 12px 20px; }
            }
            
            /* v143.0: Holographic shimmer enhanced */
            @keyframes v143-holo-shimmer {
                0% { background-position: -200% center; }
                100% { background-position: 200% center; }
            }
            
            /* v143.0: Data-driven color animation */
            @keyframes v143-data-pulse {
                0%, 100% { 
                    box-shadow: 0 0 0 0 var(--mood-glow);
                    filter: brightness(1);
                }
                50% { 
                    box-shadow: 0 0 20px 5px var(--mood-glow);
                    filter: brightness(1.1);
                }
            }
            
            /* v143.0: Floating orb enhanced with parallax */
            @keyframes v143-orb-float {
                0%, 100% { transform: translate(0, 0) scale(1); }
                25% { transform: translate(10px, -15px) scale(1.05); }
                50% { transform: translate(-5px, -25px) scale(0.95); }
                75% { transform: translate(-15px, -10px) scale(1.02); }
            }
            
            /* v143.0: Neural wave enhanced */
            @keyframes v143-neural-wave {
                0%, 100% { transform: scale(1); opacity: 0.6; }
                50% { transform: scale(1.15); opacity: 0.3; }
            }
            
            /* v143.0: Breathing glow enhanced with multiple layers */
            @keyframes v143-breathing-glow {
                0%, 100% { 
                    box-shadow: 
                        0 0 20px var(--mood-glow),
                        inset 0 0 10px transparent;
                    transform: scale(1);
                }
                50% { 
                    box-shadow: 
                        0 0 40px var(--mood-glow),
                        inset 0 0 20px rgba(255,255,255,0.05);
                    transform: scale(1.02);
                }
            }
            
            /* v143.0: Progress ring enhanced with glow */
            @keyframes v143-ring-glow {
                0% { 
                    stroke-dashoffset: 0;
                    filter: drop-shadow(0 0 2px var(--holo-cyan));
                }
                50% { 
                    filter: drop-shadow(0 0 8px var(--holo-cyan));
                }
                100% { 
                    stroke-dashoffset: -188.5;
                    filter: drop-shadow(0 0 2px var(--holo-cyan));
                }
            }
            
            /* v143.0: Quick action spring enhanced */
            .quick-action-btn:active {
                transform: scale(0.92) translateY(2px);
                transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
            }
            
            /* v143.0: Mood button glow enhanced */
            .mood-btn:hover {
                box-shadow: 
                    0 0 15px var(--mood-primary),
                    inset 0 0 10px rgba(255,255,255,0.1);
            }
            
            /* v143.0: Toast slide enhanced with spring */
            @keyframes v143-toast-slide {
                0% { 
                    opacity: 0; 
                    transform: translateX(120px) scale(0.9) rotate(-2deg); 
                }
                60% { 
                    transform: translateX(-5px) scale(1.02) rotate(0.5deg); 
                }
                100% { 
                    opacity: 1; 
                    transform: translateX(0) scale(1) rotate(0deg); 
                }
            }
            
            .toast {
                animation: v143-toast-slide 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
            }
            
            /* v143.0: AI status badge pulse enhanced */
            @keyframes v143-ai-pulse {
                0%, 100% { 
                    opacity: 1;
                    box-shadow: 0 0 10px rgba(139, 92, 246, 0.3);
                }
                50% { 
                    opacity: 0.8;
                    box-shadow: 0 0 25px rgba(139, 92, 246, 0.6);
                }
            }
            
            /* v143.0: Fox expression bounce enhanced */
            @keyframes v143-expression-bounce {
                0%, 100% { transform: translateY(0) scale(1) rotate(0deg); }
                25% { transform: translateY(-4px) scale(1.1) rotate(-3deg); }
                50% { transform: translateY(-2px) scale(1.05) rotate(2deg); }
                75% { transform: translateY(-3px) scale(1.08) rotate(-1deg); }
            }
            
            /* v143.0: Heatmap cell hover enhanced */
            .heatmap-cell:hover {
                transform: scale(1.4);
                box-shadow: 0 0 15px var(--holo-cyan);
                z-index: 5;
            }
            
            /* v143.0: Skills radar glow enhanced */
            .skills-radar-container {
                animation: conic-gradient 8s linear infinite;
            }
            
            /* v143.0: GPU optimization enhanced */
            .stat-card, .glass-card, .fox-container, .particle-container {
                contain: layout style paint;
                content-visibility: auto;
                contain-intrinsic-size: 0 200px;
            }
            
            /* v143.0: Focus states enhanced */
            .stat-card:focus-visible {
                outline: 3px solid var(--holo-cyan);
                outline-offset: 4px;
                box-shadow: 
                    0 0 20px rgba(0, 245, 255, 0.4),
                    0 12px 40px rgba(0, 0, 0, 0.5);
            }
            
            /* v143.0: Reduced motion comprehensive */
            @media (prefers-reduced-motion: reduce) {
                *, *::before, *::after {
                    animation-duration: 0.01ms !important;
                    animation-iteration-count: 1 !important;
                    transition-duration: 0.01ms !important;
                    scroll-behavior: auto !important;
                }
                .ambient-particle, .energy-ring, .neural-wave {
                    display: none;
                }
            }
            
            /* v143.0: Print styles enhanced */
            @media print {
                .ambient-particles, .noise-overlay, .fox-canvas-wrapper,
                .particle-container, .breathing-widget, .quick-actions,
                .toast-container, .scroll-progress, .fps-counter,
                .ambient-particle, .energy-ring, .neural-wave { 
                    display: none !important; 
                }
                body { background: white !important; color: black !important; }
                .glass-card { 
                    background: #f5f5f5 !important; 
                    border: 1px solid #ddd !important;
                    box-shadow: none !important;
                }
                .stat-card {
                    break-inside: avoid;
                    page-break-inside: avoid;
                }
            }
            *, *::before, *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            
            :root {
                /* Holographic Color Palette */
                --holo-cyan: #00f5ff;
                --holo-magenta: #ff00ff;
                --holo-violet: #8b5cf6;
                --holo-gold: #ffd700;
                --holo-rose: #ff6b9d;
                --holo-emerald: #10b981;
                
                /* Glass Colors */
                --glass-0: rgba(255, 255, 255, 0.01);
                --glass-1: rgba(255, 255, 255, 0.03);
                --glass-2: rgba(255, 255, 255, 0.06);
                --glass-3: rgba(255, 255, 255, 0.10);
                --glass-border: rgba(255, 255, 255, 0.08);
                --glass-border-bright: rgba(255, 255, 255, 0.15);
                
                /* Status Colors */
                --status-online: #5cdb95;
                --status-working: #00d4ff;
                --status-sleeping: #a855f7;
                --status-idle: #fec97a;
                --status-error: #ff6b6b;
                --status-learning: #ffb74d;
                
                /* Mood-based dynamic colors */
                --mood-primary: var(--holo-cyan);
                --mood-glow: rgba(0, 245, 255, 0.3);
                --mood-secondary: var(--holo-violet);
                
                /* Text */
                --text-primary: #ffffff;
                --text-secondary: #e8e8ed;
                --text-muted: #9898a8;
                --text-dim: #606070;
                
                /* Spacing */
                --radius-sm: 8px;
                --radius-md: 12px;
                --radius-lg: 16px;
                --radius-xl: 24px;
                --radius-full: 9999px;
                
                /* Shadows */
                --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
                --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
                --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
                --shadow-glow-cyan: 0 0 30px rgba(0, 245, 255, 0.3);
                
                /* Typography */
                --font-sans: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
                --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
                
                /* Transitions */
                --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
                --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
                
                /* v141.0: Theme-aware background */
                --bg-primary: #07070c;
                --bg-secondary: #0d0d14;
            }
            
            /* v141.0: OLED Black Theme */
            :root[data-theme="oled"] {
                --bg-primary: #000000;
                --bg-secondary: #0a0a0a;
                --glass-1: rgba(255, 255, 255, 0.02);
                --glass-2: rgba(255, 255, 255, 0.04);
            }
            
            /* v141.0: Purple Theme */
            :root[data-theme="purple"] {
                --bg-primary: #0f0518;
                --bg-secondary: #150a24;
                --mood-primary: var(--holo-violet);
                --mood-glow: rgba(139, 92, 246, 0.3);
                --mood-secondary: var(--holo-magenta);
            }
            
            /* v141.0: Reduced Motion */
            @media (prefers-reduced-motion: reduce) {
                *, *::before, *::after {
                    animation-duration: 0.01ms !important;
                    animation-iteration-count: 1 !important;
                    transition-duration: 0.01ms !important;
                    scroll-behavior: auto !important;
                }
            }
            
            html {
                font-size: 16px;
            }

            body {
                font-family: var(--font-sans);
                background: var(--bg-primary);
                color: var(--text-secondary);
                min-height: 100vh;
                overflow-x: hidden;
                line-height: 1.5;
                -webkit-font-smoothing: antialiased;
            }
            
            /* Animated Nebula Background */
            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background: 
                    radial-gradient(ellipse 120% 90% at 15% 15%, rgba(0, 245, 255, 0.12) 0%, transparent 50%),
                    radial-gradient(ellipse 90% 70% at 85% 85%, rgba(255, 0, 255, 0.10) 0%, transparent 50%),
                    radial-gradient(ellipse 70% 60% at 50% 50%, rgba(139, 92, 246, 0.08) 0%, transparent 60%),
                    radial-gradient(ellipse 50% 40% at 75% 25%, rgba(255, 107, 157, 0.06) 0%, transparent 50%);
                pointer-events: none;
                z-index: -2;
            }
            
            /* Floating Orbs */
            body::after {
                content: '';
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: -1;
                background: 
                    radial-gradient(circle 300px at 10% 90%, rgba(0, 245, 255, 0.08) 0%, transparent 70%),
                    radial-gradient(circle 250px at 90% 10%, rgba(255, 0, 255, 0.08) 0%, transparent 70%);
            }
            
            /* GPU Optimization - v141.0 */
            .stat-card, .glass-card, .fox-container, .particle-container {
                contain: layout style paint;
            }
            
            /* Noise Texture */
            .noise-overlay {
                position: fixed;
                inset: 0;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
                opacity: 0.015;
                pointer-events: none;
                z-index: -1;
            }
            
            /* Ambient Particles - v141.0: reduced count */
            .ambient-particles {
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: -1;
                overflow: hidden;
                content-visibility: auto;
                contain-intrinsic-size: 0 100px;
            }
            
            .ambient-particle {
                position: absolute;
                width: 3px;
                height: 3px;
                border-radius: 50%;
                opacity: 0;
                animation: float-up linear infinite;
            }
            
            @keyframes float-up {
                0% { transform: translateY(100vh) scale(0); opacity: 0; }
                10% { opacity: 0.5; }
                90% { opacity: 0.5; }
                100% { transform: translateY(-20vh) scale(1); opacity: 0; }
            }
            
            /* Custom Scrollbar */
            ::-webkit-scrollbar { width: 6px; height: 6px; }
            ::-webkit-scrollbar-track { background: transparent; }
            ::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 3px; }
            ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.15); }
            
            ::selection { background: rgba(0, 245, 255, 0.2); color: var(--holo-cyan); }
            
            /* v141.0: Status-Aware Glow System */
            body.status-working .fox-container { --glow-color: rgba(0, 212, 255, 0.4); }
            body.status-sleeping .fox-container { --glow-color: rgba(168, 85, 247, 0.4); }
            body.status-idle .fox-container { --glow-color: rgba(254, 202, 122, 0.4); }
            body.status-excited .fox-container { --glow-color: rgba(255, 107, 157, 0.5); }
            body.status-thinking .fox-container { --glow-color: rgba(168, 85, 247, 0.4); }
            body.status-error .fox-container { --glow-color: rgba(255, 107, 107, 0.5); }
            
            /* v141.0: Trend Indicator Styles */
            .trend-indicator {
                font-family: var(--font-mono);
                font-weight: 600;
                transition: color 0.3s ease;
            }
            
            .trend-indicator.up { color: var(--status-online); }
            .trend-indicator.down { color: var(--status-error); }
            .trend-indicator.stable { color: var(--text-muted); }
            
            /* v141.0: Data Transition */
            .stat-value {
                transition: transform 0.2s var(--ease-spring), color 0.3s ease;
            }
            
            .stat-value.updated {
                animation: value-pop 0.3s var(--ease-spring);
            }
            
            @keyframes value-pop {
                0% { transform: scale(1); }
                50% { transform: scale(1.15); }
                100% { transform: scale(1); }
            }
            
            /* v141.0: Card Hover Enhancement */
            .stat-card {
                transition: transform 0.3s var(--ease-spring), 
                            box-shadow 0.3s ease,
                            border-color 0.3s ease;
            }
            
            .stat-card:hover {
                transform: translateY(-4px) scale(1.02);
                box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 0 0 30px var(--mood-glow);
            }
            
            .stat-card:hover .trend-indicator {
                opacity: 1 !important;
            }
            
            /* v141.0: Toast Slide */
            .toast {
                animation: toast-slide 0.4s var(--ease-spring) both;
            }
            
            @keyframes toast-slide {
                from { opacity: 0; transform: translateX(120px) scale(0.9); }
                to { opacity: 1; transform: translateX(0) scale(1); }
            }
            
            /* v141.0: Focus States */
            :focus-visible {
                outline: 2px solid var(--holo-cyan);
                outline-offset: 3px;
                box-shadow: 0 0 12px rgba(0, 245, 255, 0.3);
            }
            
            /* v141.0: Print Styles */
            @media print {
                .ambient-particles, .noise-overlay, .fox-canvas-wrapper,
                .particle-container, .breathing-widget, .quick-actions,
                .toast-container, .scroll-progress, .fps-counter { display: none !important; }
                body { background: white !important; color: black !important; }
                .glass-card { background: #f5f5f5 !important; border: 1px solid #ddd !important; }
            }
        }
        
        /* ========== LAYOUT ========== */
        @layer layout {
            .dashboard-container {
                max-width: 1500px;
                margin: 0 auto;
                padding: 20px;
                min-height: 100vh;
            }
            
            /* Glass Header */
            .dashboard-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 16px 24px;
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                margin-bottom: 24px;
                position: relative;
                overflow: hidden;
            }
            
            .dashboard-header::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(0, 245, 255, 0.08) 0%, transparent 50%, rgba(255, 0, 255, 0.05) 100%);
                pointer-events: none;
            }
            
            .header-left, .header-right {
                display: flex;
                align-items: center;
                gap: 12px;
                position: relative;
                z-index: 1;
                flex-wrap: wrap;
            }
            
            .greeting-badge {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 8px 16px;
                background: linear-gradient(135deg, rgba(0, 245, 255, 0.12), rgba(139, 92, 246, 0.12));
                border: 1px solid rgba(0, 245, 255, 0.25);
                border-radius: var(--radius-full);
                font-size: 13px;
                font-weight: 600;
                color: var(--holo-cyan);
                transition: all 0.3s ease;
            }
            
            .greeting-badge:hover {
                background: linear-gradient(135deg, rgba(0, 245, 255, 0.18), rgba(139, 92, 246, 0.18));
                box-shadow: 0 0 20px rgba(0, 245, 255, 0.2);
            }
            
            .status-badge {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 8px 16px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-full);
                font-size: 13px;
                font-weight: 500;
                transition: all 0.3s var(--ease-out-expo);
            }
            
            .status-badge[data-status="online"] { border-color: rgba(92, 219, 149, 0.4); color: var(--status-online); }
            .status-badge[data-status="working"] { border-color: rgba(0, 212, 255, 0.4); color: var(--status-working); }
            .status-badge[data-status="sleeping"] { border-color: rgba(168, 85, 247, 0.4); color: var(--status-sleeping); }
            .status-badge[data-status="idle"] { border-color: rgba(254, 202, 122, 0.4); color: var(--status-idle); }
            .status-badge[data-status="error"] { border-color: rgba(255, 107, 107, 0.4); color: var(--status-error); }
            .status-badge[data-status="learning"] { border-color: rgba(255, 183, 77, 0.4); color: var(--status-learning); }
            
            .status-dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: currentColor;
                animation: pulse-glow 2s ease-in-out infinite;
            }
            
            @keyframes pulse-glow {
                0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 8px currentColor; }
                50% { opacity: 0.7; transform: scale(0.85); box-shadow: 0 0 4px currentColor; }
            }
            
            .live-clock {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 8px 14px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-md);
                font-family: var(--font-mono);
                font-size: 13px;
            }
            
            .live-indicator {
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 6px 12px;
                background: rgba(92, 219, 149, 0.12);
                border-radius: var(--radius-full);
                font-size: 11px;
                font-weight: 600;
                color: var(--status-online);
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }
            
            .live-indicator::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: var(--status-online);
                animation: pulse-glow 1.5s ease-in-out infinite;
            }
            
            .data-freshness {
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 6px 12px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-full);
                font-size: 11px;
                transition: all 0.3s ease;
            }
            
            .data-freshness[data-freshness="fresh"] { background: rgba(92, 219, 149, 0.12); border-color: rgba(92, 219, 149, 0.3); color: var(--status-online); }
            .data-freshness[data-freshness="normal"] { background: rgba(254, 202, 122, 0.12); border-color: rgba(254, 202, 122, 0.3); color: var(--status-idle); }
            .data-freshness[data-freshness="stale"] { background: rgba(255, 107, 107, 0.12); border-color: rgba(255, 107, 107, 0.3); color: var(--status-error); }
            
            .predictive-refresh {
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 6px 10px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-md);
                cursor: help;
                transition: all 0.3s ease;
            }
            
            .predictive-refresh:hover { background: var(--glass-2); border-color: var(--glass-border-bright); }
            
            .predictive-refresh-ring svg { transform: rotate(-90deg); }
            .predictive-refresh-ring circle { fill: none; stroke-width: 2; }
            .predictive-refresh-ring .track { stroke: var(--glass-border); }
            .predictive-refresh-ring .progress { stroke: var(--holo-cyan); stroke-linecap: round; transition: stroke-dashoffset 0.1s linear; }
            
            .predictive-text {
                font-family: var(--font-mono);
                font-size: 11px;
                color: var(--text-muted);
            }
            
            /* v141.0: Theme Switcher */
            .theme-switcher {
                display: flex;
                align-items: center;
                gap: 4px;
                padding: 4px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-full);
            }
            
            .theme-btn {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                border: none;
                background: transparent;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                transition: all 0.2s ease;
                opacity: 0.5;
            }
            
            .theme-btn:hover { opacity: 0.8; background: var(--glass-2); }
            .theme-btn.active { opacity: 1; background: var(--glass-3); box-shadow: 0 0 8px var(--mood-primary); }
            
            .refresh-btn {
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 8px 16px;
                background: linear-gradient(135deg, rgba(0, 245, 255, 0.15), rgba(139, 92, 246, 0.15));
                border: 1px solid rgba(0, 245, 255, 0.3);
                border-radius: var(--radius-md);
                color: var(--holo-cyan);
                font-family: var(--font-sans);
                font-size: 13px;
                font-weight: 500;
                cursor: pointer;
                transition: all 0.3s var(--ease-out-expo);
            }
            
            .refresh-btn:hover {
                background: linear-gradient(135deg, rgba(0, 245, 255, 0.25), rgba(139, 92, 246, 0.25));
                box-shadow: 0 0 20px rgba(0, 245, 255, 0.25);
                transform: translateY(-1px);
            }
            
            .refresh-btn:active { transform: scale(0.97); }
            .refresh-btn.loading .refresh-icon { animation: spin 0.8s linear infinite; }
            
            @keyframes spin {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
            }
            
            /* v141.0: Auto-refresh Toggle */
            .auto-refresh-toggle {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 6px 12px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-md);
                font-size: 12px;
                cursor: pointer;
                transition: all 0.3s ease;
            }
            
            .auto-refresh-toggle:hover { background: var(--glass-2); }
            .auto-refresh-toggle.active { border-color: var(--holo-cyan); background: rgba(0, 245, 255, 0.1); }
            
            .toggle-switch {
                width: 32px;
                height: 18px;
                background: var(--glass-2);
                border-radius: 9px;
                position: relative;
                transition: background 0.3s ease;
            }
            
            .toggle-switch::after {
                content: '';
                position: absolute;
                top: 2px;
                left: 2px;
                width: 14px;
                height: 14px;
                background: var(--text-muted);
                border-radius: 50%;
                transition: all 0.3s var(--ease-spring);
            }
            
            .auto-refresh-toggle.active .toggle-switch { background: rgba(0, 245, 255, 0.3); }
            .auto-refresh-toggle.active .toggle-switch::after { left: 16px; background: var(--holo-cyan); }
            
            /* Dashboard Grid */
            .dashboard-grid {
                display: grid;
                grid-template-columns: 340px 1fr;
                gap: 24px;
            }
            
            @media (max-width: 1100px) {
                .dashboard-grid { grid-template-columns: 1fr; }
            }
            
            .left-column, .right-column {
                display: flex;
                flex-direction: column;
                gap: 20px;
            }
            
            /* Glass Card */
            .glass-card {
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                padding: 24px;
                position: relative;
                overflow: hidden;
                transition: all 0.4s var(--ease-out-expo);
            }
            
            .glass-card:hover {
                border-color: var(--glass-border-bright);
                box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
            }
            
            .glass-card::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 50%);
                pointer-events: none;
            }
            
            .glass-divider {
                height: 1px;
                background: linear-gradient(90deg, transparent, var(--glass-border), transparent);
                margin: 20px 0;
            }
            
            /* Avatar Section */
            .avatar-section {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 16px;
            }
            
            /* Fox Container - v141.0: Optimized */
            .fox-container {
                position: relative;
                width: 180px;
                height: 180px;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            
            .holo-aura {
                position: absolute;
                inset: -20px;
                border-radius: 50%;
                background: radial-gradient(circle, var(--mood-glow) 0%, transparent 70%);
                opacity: 0.6;
                animation: aura-pulse 3s ease-in-out infinite;
            }
            
            @keyframes aura-pulse {
                0%, 100% { transform: scale(1); opacity: 0.6; }
                50% { transform: scale(1.1); opacity: 0.4; }
            }
            
            .fox-canvas-wrapper {
                position: relative;
                z-index: 2;
            }
            
            .fox-canvas {
                display: block;
                filter: drop-shadow(0 0 20px var(--mood-glow));
            }
            
            .fox-shadow {
                position: absolute;
                bottom: 5px;
                left: 50%;
                transform: translateX(-50%);
                width: 100px;
                height: 15px;
                background: radial-gradient(ellipse, rgba(0,0,0,0.4) 0%, transparent 70%);
                border-radius: 50%;
                z-index: 1;
            }
            
            .energy-core {
                position: absolute;
                inset: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                pointer-events: none;
                z-index: 0;
            }
            
            .energy-ring {
                position: absolute;
                border-radius: 50%;
                border: 1px solid var(--mood-primary);
                opacity: 0;
                animation: energy-expand 3s ease-out infinite;
            }
            
            .energy-ring:nth-child(1) { animation-delay: 0s; }
            .energy-ring:nth-child(2) { animation-delay: 1s; }
            .energy-ring:nth-child(3) { animation-delay: 2s; }
            
            @keyframes energy-expand {
                0% { width: 60px; height: 60px; opacity: 0.6; }
                100% { width: 200px; height: 200px; opacity: 0; }
            }
            
            .neural-waves {
                position: absolute;
                inset: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                pointer-events: none;
                z-index: 1;
            }
            
            .neural-wave {
                position: absolute;
                width: 120px;
                height: 120px;
                border-radius: 50%;
                border: 2px solid var(--mood-primary);
                opacity: 0;
                animation: neural-ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
            }
            
            .neural-wave:nth-child(2) { animation-delay: 0.8s; }
            .neural-wave:nth-child(3) { animation-delay: 1.6s; }
            
            @keyframes neural-ping {
                0% { transform: scale(0.5); opacity: 0.8; }
                100% { transform: scale(1.8); opacity: 0; }
            }
            
            .particle-container {
                position: absolute;
                inset: 0;
                pointer-events: none;
                z-index: 3;
            }
            
            .particle {
                position: absolute;
                width: 4px;
                height: 4px;
                border-radius: 50%;
                background: var(--mood-primary);
                opacity: 0;
                animation: particle-float 4s ease-in-out infinite;
            }
            
            body.status-working .particle { box-shadow: 0 0 6px var(--mood-primary); }
            body.status-sleeping .particle { box-shadow: 0 0 4px var(--mood-primary); animation-duration: 6s; }
            body.status-idle .particle { box-shadow: 0 0 5px var(--mood-primary); animation-duration: 5s; }
            body.status-excited .particle { box-shadow: 0 0 8px var(--mood-primary); animation-duration: 3s; }
            
            .particle:nth-child(1) { left: 10%; animation-delay: 0s; }
            .particle:nth-child(2) { left: 30%; animation-delay: 0.8s; }
            .particle:nth-child(3) { left: 50%; animation-delay: 1.6s; }
            .particle:nth-child(4) { left: 70%; animation-delay: 2.4s; }
            .particle:nth-child(5) { left: 85%; animation-delay: 3.2s; }
            .particle:nth-child(6) { left: 20%; animation-delay: 0.4s; }
            
            @keyframes particle-float {
                0% { bottom: 20%; opacity: 0; transform: translateX(0) scale(0); }
                20% { opacity: 0.8; }
                80% { opacity: 0.8; }
                100% { bottom: 90%; opacity: 0; transform: translateX(20px) scale(1); }
            }
            
            .fox-expression {
                position: absolute;
                bottom: -10px;
                right: 15px;
                font-size: 24px;
                z-index: 10;
                animation: expression-bounce 2s ease-in-out infinite;
            }
            
            @keyframes expression-bounce {
                0%, 100% { transform: translateY(0) scale(1); }
                50% { transform: translateY(-3px) scale(1.05); }
            }
            
            .fox-name {
                font-size: 26px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--text-primary) 0%, var(--holo-cyan) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                text-align: center;
            }
            
            .fox-role {
                font-size: 13px;
                color: var(--text-muted);
                text-align: center;
                margin-top: -10px;
            }
            
            .ai-status-badge {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 6px 14px;
                background: var(--glass-2);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-full);
                font-size: 12px;
                font-weight: 500;
            }
            
            .ai-status-badge[data-ai-status="thinking"] { border-color: rgba(139, 92, 246, 0.4); color: var(--holo-violet); }
            .ai-status-badge[data-ai-status="processing"] { border-color: rgba(0, 212, 255, 0.4); color: var(--status-working); }
            
            .ai-status-dot {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: currentColor;
                animation: pulse-glow 1.5s ease-in-out infinite;
            }
            
            .fox-mood-text {
                font-size: 12px;
                color: var(--text-muted);
                text-align: center;
                font-style: italic;
            }
            
            .stats-row {
                display: flex;
                gap: 24px;
                justify-content: center;
            }
            
            .mini-stat { text-align: center; }
            
            .mini-stat-value {
                font-size: 20px;
                font-weight: 700;
                font-family: var(--font-mono);
                color: var(--holo-cyan);
            }
            
            .mini-stat-label {
                font-size: 10px;
                color: var(--text-dim);
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }
            
            .mode-actions {
                display: flex;
                gap: 8px;
                justify-content: center;
                flex-wrap: wrap;
            }
            
            .mode-btn {
                padding: 6px 14px;
                background: var(--glass-2);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-full);
                color: var(--text-secondary);
                font-family: var(--font-sans);
                font-size: 12px;
                font-weight: 500;
                cursor: pointer;
                transition: all 0.3s var(--ease-spring);
            }
            
            .mode-btn:hover {
                background: var(--glass-3);
                border-color: var(--holo-cyan);
                color: var(--holo-cyan);
                transform: translateY(-2px);
            }
            
            .mood-selector {
                display: flex;
                gap: 10px;
                justify-content: center;
                flex-wrap: wrap;
            }
            
            .mood-btn {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: var(--glass-2);
                border: 1px solid var(--glass-border);
                font-size: 18px;
                cursor: pointer;
                transition: all 0.3s var(--ease-spring);
                display: flex;
                align-items: center;
                justify-content: center;
            }
            
            .mood-btn:hover {
                background: var(--glass-3);
                border-color: var(--mood-primary);
                transform: translateY(-3px) scale(1.15);
            }
            
            .mood-btn:active { transform: scale(0.9); }
            
            .quick-stats {
                display: flex;
                gap: 20px;
                justify-content: center;
            }
            
            .quick-stat { text-align: center; }
            
            .quick-stat-value {
                font-size: 18px;
                font-weight: 700;
                font-family: var(--font-mono);
                color: var(--text-primary);
            }
            
            .quick-stat-label {
                font-size: 10px;
                color: var(--text-dim);
                text-transform: uppercase;
            }
            
            .reputation-badge {
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 6px 14px;
                background: linear-gradient(135deg, rgba(255, 215, 0, 0.15), rgba(255, 183, 77, 0.15));
                border: 1px solid rgba(255, 215, 0, 0.3);
                border-radius: var(--radius-full);
                font-size: 13px;
                font-weight: 600;
                color: var(--holo-gold);
            }
            
            .quick-actions {
                display: flex;
                gap: 8px;
                justify-content: center;
                flex-wrap: wrap;
            }
            
            .quick-action-btn {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 4px;
                padding: 10px 14px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-md);
                color: var(--text-muted);
                font-size: 10px;
                cursor: pointer;
                transition: all 0.3s var(--ease-spring);
            }
            
            .quick-action-btn:hover {
                background: var(--glass-2);
                border-color: var(--holo-cyan);
                color: var(--holo-cyan);
                transform: translateY(-3px);
            }
            
            .quick-action-icon { font-size: 16px; }
            .quick-action-label { text-transform: uppercase; letter-spacing: 0.5px; }
            
            /* Breathing Widget */
            .breathing-widget {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 12px;
                padding: 20px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
            }
            
            .breathing-circle {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                background: linear-gradient(135deg, rgba(0, 245, 255, 0.1), rgba(139, 92, 246, 0.1));
                border: 2px solid rgba(0, 245, 255, 0.3);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 28px;
                transition: all 0.5s ease;
            }
            
            .breathing-circle.active { animation: breathe 8s ease-in-out infinite; }
            
            @keyframes breathe {
                0%, 100% { transform: scale(1); border-color: rgba(0, 245, 255, 0.3); }
                25% { transform: scale(1.3); border-color: rgba(0, 245, 255, 0.6); }
                50% { transform: scale(1); border-color: rgba(139, 92, 246, 0.6); }
                75% { transform: scale(1.2); border-color: rgba(139, 92, 246, 0.3); }
            }
            
            .breathing-text { font-size: 14px; color: var(--text-secondary); }
            .breathing-phase { font-size: 12px; color: var(--text-muted); }
            
            .breathing-btn {
                padding: 8px 20px;
                background: linear-gradient(135deg, rgba(0, 245, 255, 0.15), rgba(139, 92, 246, 0.15));
                border: 1px solid rgba(0, 245, 255, 0.3);
                border-radius: var(--radius-full);
                color: var(--holo-cyan);
                font-family: var(--font-sans);
                font-size: 13px;
                font-weight: 500;
                cursor: pointer;
                transition: all 0.3s var(--ease-spring);
            }
            
            .breathing-btn:hover { background: linear-gradient(135deg, rgba(0, 245, 255, 0.25), rgba(139, 92, 246, 0.25)); transform: translateY(-2px); }
            
            /* Activity Heatmap */
            .activity-heatmap {
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                padding: 16px;
            }
            
            .heatmap-title {
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 13px;
                font-weight: 600;
                color: var(--text-primary);
                margin-bottom: 12px;
            }
            
            .heatmap-grid {
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: 4px;
            }
            
            .heatmap-cell {
                aspect-ratio: 1;
                border-radius: 3px;
                background: var(--glass-2);
                transition: all 0.3s ease;
            }
            
            .heatmap-cell:hover { transform: scale(1.2); z-index: 1; }
            .heatmap-cell.level-1 { background: rgba(0, 245, 255, 0.2); }
            .heatmap-cell.level-2 { background: rgba(0, 245, 255, 0.35); }
            .heatmap-cell.level-3 { background: rgba(0, 245, 255, 0.5); }
            .heatmap-cell.level-4 { background: rgba(0, 245, 255, 0.65); }
            .heatmap-cell.level-5 { background: rgba(0, 245, 255, 0.8); }
            
            /* Stats Grid */
            .stats-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 20px;
            }
            
            /* Stat Card */
            .stat-card {
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                padding: 20px;
                position: relative;
                overflow: hidden;
                cursor: pointer;
            }
            
            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, var(--mood-primary), var(--mood-secondary));
                opacity: 0;
                transition: opacity 0.3s ease;
            }
            
            .stat-card:hover { border-color: var(--glass-border-bright); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4); }
            .stat-card:hover::before { opacity: 1; }
            .stat-card:active { transform: translateY(-2px) scale(0.98); }
            
            .stat-card[data-stat="critical"] {
                border-color: rgba(255, 107, 107, 0.4);
                animation: critical-pulse 2s ease-in-out infinite;
            }
            
            @keyframes critical-pulse {
                0%, 100% { box-shadow: 0 0 0 rgba(255, 107, 107, 0); }
                50% { box-shadow: 0 0 20px rgba(255, 107, 107, 0.3); }
            }
            
            .stat-card-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 12px;
            }
            
            .stat-icon {
                width: 40px;
                height: 40px;
                border-radius: var(--radius-md);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
            }
            
            .stat-value {
                font-size: 32px;
                font-weight: 700;
                font-family: var(--font-mono);
                color: var(--text-primary);
                line-height: 1;
            }
            
            .stat-label {
                font-size: 13px;
                color: var(--text-muted);
                margin-top: 4px;
            }
            
            .stat-subtext {
                font-size: 10px;
                color: var(--text-dim);
                margin-top: 2px;
            }
            
            .sparkline-container {
                height: 30px;
                margin-top: 12px;
                display: flex;
                align-items: end;
                gap: 2px;
            }
            
            .sparkline-bar {
                flex: 1;
                background: linear-gradient(to top, var(--holo-cyan), var(--holo-violet));
                border-radius: 2px;
                min-height: 2px;
            }
            
            .progress-bar {
                height: 6px;
                background: var(--glass-2);
                border-radius: 3px;
                margin-top: 12px;
                overflow: hidden;
            }
            
            .progress-fill {
                height: 100%;
                border-radius: 3px;
                transition: width 0.5s var(--ease-out-expo);
            }
            
            .progress-ring-container {
                position: relative;
                width: 56px;
                height: 56px;
                margin-top: 12px;
            }
            
            .progress-ring { transform: rotate(-90deg); }
            .progress-ring-bg { fill: none; stroke: var(--glass-2); stroke-width: 4; }
            .progress-ring-fill { fill: none; stroke-width: 4; stroke-linecap: round; transition: stroke-dashoffset 0.5s var(--ease-out-expo); }
            
            .progress-ring-text {
                position: absolute;
                inset: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                font-weight: 600;
                font-family: var(--font-mono);
                color: var(--text-primary);
            }
            
            /* Charts Grid */
            .charts-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
                gap: 20px;
            }
            
            .chart-card {
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                padding: 20px;
                position: relative;
            }
            
            .chart-card:hover { border-color: var(--glass-border-bright); }
            
            .chart-title {
                font-size: 14px;
                font-weight: 600;
                color: var(--text-primary);
                margin-bottom: 16px;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            
            .chart-canvas-container {
                position: relative;
                height: 120px;
            }
            
            .chart-canvas {
                width: 100%;
                height: 100%;
            }
            
            .chart-tooltip {
                position: absolute;
                padding: 8px 12px;
                background: var(--glass-3);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-sm);
                font-size: 12px;
                color: var(--text-primary);
                pointer-events: none;
                opacity: 0;
                transition: opacity 0.2s ease;
                z-index: 10;
                white-space: nowrap;
            }
            
            /* Skills Radar */
            .skills-radar {
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                padding: 20px;
            }
            
            .skills-radar-title {
                font-size: 14px;
                font-weight: 600;
                color: var(--text-primary);
                margin-bottom: 16px;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            
            .radar-canvas-container { height: 200px; }
            .radar-canvas { width: 100%; height: 100%; }
            
            /* Memory Timeline / Task Queue */
            .memory-timeline {
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                padding: 20px;
            }
            
            .timeline-title {
                font-size: 14px;
                font-weight: 600;
                color: var(--text-primary);
                margin-bottom: 16px;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            
            .timeline-items {
                display: flex;
                flex-direction: column;
                gap: 12px;
                overflow-y: auto;
                max-height: 180px;
            }
            
            .timeline-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 12px;
                background: var(--glass-1);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-md);
                transition: all 0.3s ease;
            }
            
            .timeline-item:hover { background: var(--glass-2); border-color: var(--glass-border-bright); }
            
            .timeline-icon { font-size: 16px; }
            .timeline-content { flex: 1; }
            .timeline-text { font-size: 13px; color: var(--text-secondary); }
            .timeline-time { font-size: 10px; color: var(--text-dim); font-family: var(--font-mono); }
            
            /* Status History */
            .status-history {
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                padding: 20px;
            }
            
            .status-history-title {
                font-size: 14px;
                font-weight: 600;
                color: var(--text-primary);
                margin-bottom: 16px;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            
            .status-timeline {
                display: flex;
                flex-direction: column;
                gap: 8px;
                max-height: 150px;
                overflow-y: auto;
            }
            
            .status-timeline-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 8px 0;
                border-bottom: 1px solid var(--glass-border);
            }
            
            .status-timeline-item:last-child { border-bottom: none; }
            .status-timeline-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
            .status-timeline-text { flex: 1; font-size: 13px; color: var(--text-secondary); text-transform: capitalize; }
            .status-timeline-time { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); }
            
            /* FPS Counter */
            .fps-counter {
                position: fixed;
                top: 10px;
                right: 10px;
                padding: 4px 10px;
                background: var(--glass-2);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-sm);
                font-family: var(--font-mono);
                font-size: 10px;
                color: var(--text-dim);
                z-index: 1000;
            }
            
            /* Toast Notifications */
            .toast-container {
                position: fixed;
                bottom: 24px;
                right: 24px;
                display: flex;
                flex-direction: column;
                gap: 12px;
                z-index: 3000;
            }
            
            .toast {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 14px 20px;
                background: var(--glass-2);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-md);
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            }
            
            .toast.hiding { animation: toast-out 0.3s ease both; }
            
            @keyframes toast-out {
                to { opacity: 0; transform: translateX(100px) scale(0.8); }
            }
            
            .toast-icon { font-size: 18px; }
            .toast-message { font-size: 14px; color: var(--text-primary); }
            
            .toast[data-type="success"] { border-color: rgba(92, 219, 149, 0.4); }
            .toast[data-type="error"] { border-color: rgba(255, 107, 107, 0.4); }
            .toast[data-type="info"] { border-color: rgba(0, 245, 255, 0.4); }
            .toast[data-type="achievement"] { border-color: rgba(255, 215, 0, 0.4); }
            
            /* Footer */
            .dashboard-footer {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 16px 24px;
                margin-top: 24px;
                background: var(--glass-1);
                backdrop-filter: blur(24px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-lg);
                flex-wrap: wrap;
                gap: 12px;
            }
            
            .footer-info {
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 12px;
                color: var(--text-dim);
                flex-wrap: wrap;
            }
            
            /* Ripple Effect */
            .ripple {
                position: absolute;
                border-radius: 50%;
                background: var(--mood-primary);
                opacity: 0.4;
                transform: translate(-50%, -50%) scale(0);
                animation: ripple-effect 0.6s ease-out forwards;
                pointer-events: none;
            }
            
            @keyframes ripple-effect {
                to { transform: translate(-50%, -50%) scale(4); opacity: 0; }
            }
            
            /* v142.0: Enhanced 3D Card Effects */
            .card-3d {
                transform-style: preserve-3d;
                perspective: 1000px;
            }
            
            .card-3d:hover {
                transform: rotateX(2deg) rotateY(-2deg) translateZ(10px);
            }
            
            .card-3d-inner {
                transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            }
            
            /* v142.0: Neural Pulse Grid */
            @keyframes neural-grid-pulse {
                0%, 100% { opacity: 0.03; }
                50% { opacity: 0.08; }
            }
            
            .neural-grid {
                position: fixed;
                inset: 0;
                background-image: 
                    linear-gradient(var(--mood-primary) 1px, transparent 1px),
                    linear-gradient(90deg, var(--mood-primary) 1px, transparent 1px);
                background-size: 60px 60px;
                animation: neural-grid-pulse 4s ease-in-out infinite;
                pointer-events: none;
                z-index: 0;
            }
            
            /* v142.0: Sparkle Burst Effect */
            @keyframes sparkle-burst {
                0% { transform: scale(0) rotate(0deg); opacity: 1; }
                100% { transform: scale(1.5) rotate(180deg); opacity: 0; }
            }
            
            .sparkle-burst {
                position: absolute;
                width: 20px;
                height: 20px;
                pointer-events: none;
            }
            
            .sparkle-burst::before,
            .sparkle-burst::after {
                content: '';
                position: absolute;
                inset: 0;
                background: var(--mood-primary);
                border-radius: 50%;
                animation: sparkle-burst 0.6s ease-out forwards;
            }
            
            .sparkle-burst::after {
                animation-delay: 0.1s;
            }
            
            /* v142.0: Floating Glow Orbs */
            @keyframes float-orb {
                0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
                50% { transform: translateY(-20px) scale(1.1); opacity: 0.6; }
            }
            
            .glow-orb {
                position: absolute;
                width: 100px;
                height: 100px;
                border-radius: 50%;
                background: radial-gradient(circle, var(--mood-primary) 0%, transparent 70%);
                filter: blur(30px);
                animation: float-orb 6s ease-in-out infinite;
                pointer-events: none;
                z-index: 0;
            }
            
            /* v142.0: Morphing Border */
            @keyframes morph-border {
                0%, 100% { border-radius: 16px 24px 16px 24px; }
                25% { border-radius: 24px 16px 24px 16px; }
                50% { border-radius: 16px 24px 24px 16px; }
                75% { border-radius: 24px 16px 16px 24px; }
            }
            
            .morph-border-animate {
                animation: morph-border 8s ease-in-out infinite;
            }
            
            /* v142.0: Status Aura Ring */
            @keyframes aura-ring-expand {
                0% { transform: scale(0.8); opacity: 0.8; }
                100% { transform: scale(1.5); opacity: 0; }
            }
            
            .aura-ring {
                position: absolute;
                inset: -10px;
                border: 2px solid var(--mood-primary);
                border-radius: 50%;
                animation: aura-ring-expand 2s ease-out infinite;
                pointer-events: none;
            }
            
            .aura-ring:nth-child(2) { animation-delay: 0.5s; }
            .aura-ring:nth-child(3) { animation-delay: 1s; }
            
            /* v142.0: Interactive Holographic Shimmer */
            @keyframes holo-shimmer {
                0% { background-position: -200% center; }
                100% { background-position: 200% center; }
            }
            
            .holo-shimmer {
                background: linear-gradient(
                    90deg,
                    transparent 0%,
                    rgba(255, 255, 255, 0.1) 25%,
                    var(--mood-primary) 50%,
                    rgba(255, 255, 255, 0.1) 75%,
                    transparent 100%
                );
                background-size: 200% 100%;
                animation: holo-shimmer 3s linear infinite;
                -webkit-background-clip: text;
                background-clip: text;
            }
            
            /* v142.0: Morphing Blob */
            @keyframes blob-morph {
                0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
                25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
                50% { border-radius: 50% 60% 30% 60% / 30% 40% 70% 60%; }
                75% { border-radius: 40% 50% 60% 50% / 60% 40% 50% 60%; }
            }
            
            .morphing-blob {
                animation: blob-morph 12s ease-in-out infinite;
            }
            
            /* v142.0: Breathing Glow Effect */
            @keyframes breathing-glow {
                0%, 100% { 
                    box-shadow: 0 0 20px var(--mood-glow), 
                                0 0 40px var(--mood-glow),
                                inset 0 0 20px var(--mood-glow);
                }
                50% { 
                    box-shadow: 0 0 40px var(--mood-glow), 
                                0 0 80px var(--mood-glow),
                                inset 0 0 40px var(--mood-glow);
                }
            }
            
            .breathing-glow {
                animation: breathing-glow 4s ease-in-out infinite;
            }
            
            /* v142.0: Data Stream Effect */
            @keyframes data-stream {
                0% { background-position: 0% 0%; }
                100% { background-position: 0% 100%; }
            }
            
            .data-stream-bg {
                background: linear-gradient(
                    180deg,
                    transparent 0%,
                    var(--mood-primary) 50%,
                    transparent 100%
                );
                background-size: 100% 200%;
                animation: data-stream 2s linear infinite;
                opacity: 0.1;
            }
            
            /* v142.0: Hover Lift with Shadow Depth */
            .hover-lift-3d {
                transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), 
                            box-shadow 0.3s ease;
            }
            
            .hover-lift-3d:hover {
                transform: translateY(-8px) rotateX(5deg);
                box-shadow: 
                    0 20px 40px rgba(0, 0, 0, 0.4),
                    0 0 30px var(--mood-glow);
            }
            
            /* v142.0: Glitch Effect on Status Change */
            @keyframes glitch-skew {
                0%, 100% { transform: skew(0deg); filter: hue-rotate(0deg); }
                20% { transform: skew(-5deg); filter: hue-rotate(90deg); }
                40% { transform: skew(5deg); filter: hue-rotate(-90deg); }
                60% { transform: skew(-3deg); filter: hue-rotate(45deg); }
                80% { transform: skew(3deg); filter: hue-rotate(-45deg); }
            }
            
            .glitch-on-change {
                animation: glitch-skew 0.3s ease;
            }
            
            /* Responsive */
            @media (max-width: 768px) {
                .dashboard-header { flex-direction: column; gap: 12px; }
                .header-left, .header-right { flex-wrap: wrap; justify-content: center; }
                .stats-grid { grid-template-columns: 1fr 1fr; }
                .fox-container { width: 140px; height: 140px; }
                .fox-name { font-size: 22px; }
            }
        }
    </style>
</head>
<body>
    <div class="noise-overlay"></div>
    <div class="neural-grid" id="neuralGrid"></div>
    <div class="fps-counter" id="fpsCounter">-- FPS</div>
    
    <div class="dashboard-container">
        <div class="ambient-particles" id="ambientParticles"></div>
        <div class="glow-orb" id="glowOrb1"></div>
        <div class="glow-orb" id="glowOrb2" style="animation-delay: -2s; left: 70%; top: 20%;"></div>
        <div class="glow-orb" id="glowOrb3" style="animation-delay: -4s; left: 20%; top: 60%;"></div>
        
        <header class="dashboard-header">
            <div class="header-left">
                <div class="greeting-badge" id="greetingBadge">
                    <span id="greetingIcon">🌙</span>
                    <span id="greetingText">Good Evening</span>
                </div>
                <div class="status-badge" id="statusBadge" data-status="online">
                    <div class="status-dot"></div>
                    <span id="statusText">Online</span>
                </div>
            </div>
            <div class="header-right">
                <div class="live-clock">
                    <span>🕐</span>
                    <span id="liveClock">--:--:--</span>
                </div>
                <div class="data-freshness" id="dataFreshness" data-freshness="fresh">
                    <span id="freshnessText">Fresh</span>
                </div>
                <div class="predictive-refresh" id="predictiveRefresh" title="Predicted next refresh">
                    <div class="predictive-refresh-ring">
                        <svg width="16" height="16" viewBox="0 0 16 16">
                            <circle class="track" cx="8" cy="8" r="6"></circle>
                            <circle class="progress" id="refreshProgress" cx="8" cy="8" r="6" stroke-dasharray="37.7" stroke-dashoffset="0"></circle>
                        </svg>
                    </div>
                    <span class="predictive-text" id="predictiveText">2s</span>
                </div>
                <div class="live-indicator">Live</div>
                
                <!-- v141.0: Auto-refresh Toggle -->
                <div class="auto-refresh-toggle active" id="autoRefreshToggle" onclick="toggleAutoRefresh()" role="switch" aria-checked="true" tabindex="0">
                    <div class="toggle-switch"></div>
                    <span>Auto</span>
                </div>
                
                <!-- v141.0: Theme Switcher -->
                <div class="theme-switcher">
                    <button class="theme-btn active" data-theme="default" onclick="setTheme('default')" title="Default Dark">🌑</button>
                    <button class="theme-btn" data-theme="oled" onclick="setTheme('oled')" title="OLED Black">⚫</button>
                    <button class="theme-btn" data-theme="purple" onclick="setTheme('purple')" title="Purple">💜</button>
                </div>
                
                <button class="refresh-btn" id="refreshBtn" onclick="refreshData()">
                    <span class="refresh-icon">🔄</span>
                    <span>Refresh</span>
                </button>
            </div>
        </header>
        
        <div class="dashboard-grid">
            <div class="left-column">
                <div class="glass-card">
                    <div class="avatar-section">
                        <div class="fox-container" id="foxContainer">
                            <div class="holo-aura"></div>
                            <div class="energy-core">
                                <div class="energy-ring"></div>
                                <div class="energy-ring"></div>
                                <div class="energy-ring"></div>
                            </div>
                            <div class="neural-waves">
                                <div class="neural-wave"></div>
                                <div class="neural-wave"></div>
                                <div class="neural-wave"></div>
                            </div>
                            <div class="fox-canvas-wrapper">
                                <canvas class="fox-canvas" id="foxCanvas" width="180" height="180" aria-label="MoShang Fox Avatar"></canvas>
                                <div class="fox-shadow"></div>
                            </div>
                            <div class="particle-container">
                                <div class="particle"></div>
                                <div class="particle"></div>
                                <div class="particle"></div>
                                <div class="particle"></div>
                                <div class="particle"></div>
                                <div class="particle"></div>
                            </div>
                            <div class="fox-expression" id="foxExpression" aria-label="Current mood">😺</div>
                        </div>
                        
                        <h1 class="fox-name" aria-label="MoShang Digital Assistant">MoShang</h1>
                        <p class="fox-role">Digital Assistant</p>
                        
                        <div class="ai-status-badge" id="aiStatusBadge" data-ai-status="idle" role="status">
                            <div class="ai-status-dot"></div>
                            <span id="aiStatusText">Idle</span>
                        </div>
                        
                        <p class="fox-mood-text" id="moodText">Idle Mode</p>
                        
                        <div class="stats-row">
                            <div class="mini-stat">
                                <span class="mini-stat-value animated-counter" id="heartbeatValue" aria-live="polite">--</span>
                                <span class="mini-stat-label">Heartbeat</span>
                            </div>
                            <div class="mini-stat">
                                <span class="mini-stat-value animated-counter" id="activityValue" aria-live="polite">--</span>
                                <span class="mini-stat-label">Activity</span>
                            </div>
                        </div>
                        
                        <div class="mode-actions">
                            <button class="mode-btn" onclick="setMode('idle')">Idle</button>
                            <button class="mode-btn" onclick="setMode('working')">Work</button>
                            <button class="mode-btn" onclick="setMode('sleeping')">Sleep</button>
                        </div>
                        
                        <div class="mood-selector" role="group" aria-label="Mood selector">
                            <button class="mood-btn" onclick="setMood('idle')" title="Idle" aria-label="Set mood: Idle">😺</button>
                            <button class="mood-btn" onclick="setMood('excited')" title="Excited" aria-label="Set mood: Excited">🎉</button>
                            <button class="mood-btn" onclick="setMood('thinking')" title="Thinking" aria-label="Set mood: Thinking">🤔</button>
                            <button class="mood-btn" onclick="setMood('laughing')" title="Laughing" aria-label="Set mood: Laughing">😂</button>
                            <button class="mood-btn" onclick="setMood('focused')" title="Focused" aria-label="Set mood: Focused">🎯</button>
                        </div>
                        
                        <div class="glass-divider"></div>
                        
                        <div class="quick-stats">
                            <div class="quick-stat">
                                <div class="quick-stat-value animated-counter" id="msgCount">--</div>
                                <div class="quick-stat-label">Messages</div>
                            </div>
                            <div class="quick-stat">
                                <div class="quick-stat-value animated-counter" id="taskDone">--</div>
                                <div class="quick-stat-label">Tasks</div>
                            </div>
                            <div class="quick-stat">
                                <div class="quick-stat-value animated-counter" id="skillsTotal">--</div>
                                <div class="quick-stat-label">Skills</div>
                            </div>
                        </div>
                        
                        <div class="reputation-badge" id="reputationBadge" style="display: none;">
                            <span>⭐</span>
                            <span id="reputationValue">--</span>
                        </div>
                        
                        <div class="quick-actions">
                            <button class="quick-action-btn" onclick="quickAction('copy')" title="Copy Stats">
                                <span class="quick-action-icon">📋</span>
                                <span class="quick-action-label">Copy</span>
                            </button>
                            <button class="quick-action-btn" onclick="quickAction('share')" title="Share Status">
                                <span class="quick-action-icon">🔗</span>
                                <span class="quick-action-label">Share</span>
                            </button>
                            <button class="quick-action-btn" onclick="quickAction('export')" title="Export Data">
                                <span class="quick-action-icon">📤</span>
                                <span class="quick-action-label">Export</span>
                            </button>
                            <button class="quick-action-btn" onclick="quickAction('settings')" title="Settings">
                                <span class="quick-action-icon">⚙️</span>
                                <span class="quick-action-label">Settings</span>
                            </button>
                        </div>
                    </div>
                </div>
                
                <div class="breathing-widget">
                    <div class="breathing-circle" id="breathingCircle">
                        <span id="breathingEmoji">🌬️</span>
                    </div>
                    <div class="breathing-text" id="breathingText">Take a moment</div>
                    <div class="breathing-phase" id="breathingPhase">Idle</div>
                    <button class="breathing-btn" id="breathingBtn" onclick="toggleBreathing()">Start Breathing</button>
                </div>
                
                <div class="activity-heatmap">
                    <div class="heatmap-title">
                        <span>📊</span>
                        <span>24h Activity</span>
                    </div>
                    <div class="heatmap-grid" id="heatmapGrid" role="img" aria-label="24-hour activity heatmap"></div>
                </div>
            </div>
            
            <div class="right-column">
                <div class="stats-grid">
                    <div class="stat-card" data-stat="heartbeat" onclick="copyStat('heartbeat')" tabindex="0" role="button" aria-label="Heartbeat stat - click to copy">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(0, 245, 255, 0.1); color: var(--holo-cyan);">💓</div>
                            <span class="trend-indicator" id="heartbeatTrend" style="font-size:14px;opacity:0.6;">-</span>
                        </div>
                        <div class="stat-value animated-counter" id="heartbeatStat">--</div>
                        <div class="stat-label">Heart Rate</div>
                        <div class="stat-subtext">BPM • Click to copy</div>
                        <div class="sparkline-container" id="heartbeatSparkline"></div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="heartbeatBar" style="width: 0%; background: linear-gradient(90deg, var(--holo-cyan), var(--holo-magenta));"></div>
                        </div>
                    </div>
                    
                    <div class="stat-card" data-stat="activity" onclick="copyStat('activity')" tabindex="0" role="button" aria-label="Activity stat - click to copy">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(139, 92, 246, 0.1); color: var(--holo-violet);">⚡</div>
                            <span class="trend-indicator" id="activityTrend" style="font-size:14px;opacity:0.6;">-</span>
                        </div>
                        <div class="stat-value animated-counter" id="activityStat">--</div>
                        <div class="stat-label">Activity Level</div>
                        <div class="stat-subtext">% • Click to copy</div>
                        <div class="progress-ring-container">
                            <svg class="progress-ring" viewBox="0 0 56 56" aria-hidden="true">
                                <circle class="progress-ring-bg" cx="28" cy="28" r="25"/>
                                <circle class="progress-ring-fill" id="activityRingFill" cx="28" cy="28" r="25" stroke="var(--holo-violet)"/>
                            </svg>
                            <div class="progress-ring-text" id="activityPercent">--</div>
                        </div>
                    </div>
                    
                    <div class="stat-card" data-stat="memory" onclick="copyStat('memory')" tabindex="0" role="button" aria-label="Memory stat - click to copy">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(92, 219, 149, 0.1); color: var(--status-online);">🧠</div>
                            <span class="trend-indicator" id="memoryTrend" style="font-size:14px;opacity:0.6;">-</span>
                        </div>
                        <div class="stat-value animated-counter" id="memoryStat">--</div>
                        <div class="stat-label">Memory Usage</div>
                        <div class="stat-subtext">MB • Click to copy</div>
                        <div class="sparkline-container" id="memorySparkline"></div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="memoryBar" style="width: 0%; background: linear-gradient(90deg, var(--status-online), var(--holo-cyan));"></div>
                        </div>
                    </div>
                    
                    <div class="stat-card" data-stat="cpu" onclick="copyStat('cpu')" tabindex="0" role="button" aria-label="CPU stat - click to copy">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(255, 215, 0, 0.1); color: var(--holo-gold);">🔲</div>
                            <span class="trend-indicator" id="cpuTrend" style="font-size:14px;opacity:0.6;">-</span>
                        </div>
                        <div class="stat-value animated-counter" id="cpuStat">--</div>
                        <div class="stat-label">CPU Usage</div>
                        <div class="stat-subtext">% • Click to copy</div>
                        <div class="sparkline-container" id="cpuSparkline"></div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="cpuBar" style="width: 0%; background: linear-gradient(90deg, var(--holo-gold), var(--status-error));"></div>
                        </div>
                    </div>
                </div>
                
                <div class="charts-grid">
                    <div class="chart-card">
                        <div class="chart-title">⚡ Activity Rhythm</div>
                        <div class="chart-canvas-container">
                            <canvas class="chart-canvas" id="activityChart" aria-label="Activity chart"></canvas>
                            <div class="chart-tooltip" id="activityTooltip"></div>
                        </div>
                    </div>
                    <div class="chart-card">
                        <div class="chart-title">🧠 Memory History</div>
                        <div class="chart-canvas-container">
                            <canvas class="chart-canvas" id="memoryChart" aria-label="Memory chart"></canvas>
                            <div class="chart-tooltip" id="memoryTooltip"></div>
                        </div>
                    </div>
                    <div class="chart-card">
                        <div class="chart-title">🔥 CPU History</div>
                        <div class="chart-canvas-container">
                            <canvas class="chart-canvas" id="cpuChart" aria-label="CPU chart"></canvas>
                            <div class="chart-tooltip" id="cpuTooltip"></div>
                        </div>
                    </div>
                </div>
                
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
                    <div class="skills-radar">
                        <div class="skills-radar-title">
                            <span>🎯</span>
                            <span>Skills Radar</span>
                        </div>
                        <div class="radar-canvas-container">
                            <canvas class="radar-canvas" id="skillsRadar" aria-label="Skills radar chart"></canvas>
                        </div>
                    </div>
                    
                    <div class="memory-timeline">
                        <div class="timeline-title">📋 Task Queue</div>
                        <div class="timeline-items" id="taskQueueItems">
                            <div class="timeline-item">
                                <span class="timeline-icon">⚡</span>
                                <div class="timeline-content">
                                    <div class="timeline-text">Loading tasks...</div>
                                    <div class="timeline-time">--</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="status-history">
                    <div class="status-history-title">
                        <span>📜</span>
                        <span>Status History</span>
                    </div>
                    <div class="status-timeline" id="statusTimeline" role="log" aria-live="polite">
                        <div class="status-timeline-item">
                            <div class="status-timeline-dot" style="background: var(--status-idle);"></div>
                            <div class="status-timeline-text">System initialized</div>
                            <div class="status-timeline-time">--</div>
                        </div>
                    </div>
                </div>
                
                <div id="evomapCard" class="glass-card" style="display: none;">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                        <div style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(0, 245, 255, 0.2)); border-radius: 10px; font-size: 20px;">🧬</div>
                        <div>
                            <div style="font-size: 14px; font-weight: 600; color: var(--text-primary);">EvoMap Status</div>
                            <div style="font-size: 11px; color: var(--text-muted);">Evolution Marketplace</div>
                        </div>
                        <div id="evomapStatus" style="margin-left: auto; padding: 4px 10px; background: rgba(92, 219, 149, 0.15); border-radius: 20px; font-size: 11px; font-weight: 600; color: var(--status-online);">Online</div>
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;">
                        <div style="text-align: center; padding: 12px 8px; background: var(--glass-1); border-radius: 8px;">
                            <div style="font-size: 20px; font-weight: 700; font-family: var(--font-mono); background: linear-gradient(135deg, var(--holo-gold), var(--holo-rose)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;" id="evomapRep">--</div>
                            <div style="font-size: 10px; color: var(--text-dim); text-transform: uppercase;">Reputation</div>
                        </div>
                        <div style="text-align: center; padding: 12px 8px; background: var(--glass-1); border-radius: 8px;">
                            <div style="font-size: 20px; font-weight: 700; font-family: var(--font-mono); color: var(--holo-cyan);" id="evomapPublished">--</div>
                            <div style="font-size: 10px; color: var(--text-dim); text-transform: uppercase;">Published</div>
                        </div>
                        <div style="text-align: center; padding: 12px 8px; background: var(--glass-1); border-radius: 8px;">
                            <div style="font-size: 20px; font-weight: 700; font-family: var(--font-mono); color: var(--status-online);" id="evomapPromoted">--</div>
                            <div style="font-size: 10px; color: var(--text-dim); text-transform: uppercase;">Promoted</div>
                        </div>
                        <div style="text-align: center; padding: 12px 8px; background: var(--glass-1); border-radius: 8px;">
                            <div style="font-size: 20px; font-weight: 700; font-family: var(--font-mono); color: var(--holo-violet);" id="evomapSurvival">--</div>
                            <div style="font-size: 10px; color: var(--text-dim); text-transform: uppercase;">Survival</div>
                        </div>
                    </div>
                </div>
                
                <div class="glass-card" style="padding: 20px;">
                    <div style="font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                        <span>🔬</span> System Health
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
                        <div>
                            <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 6px;">
                                <span style="color: var(--text-muted);">Memory</span>
                                <span id="healthMemText" style="color: var(--text-secondary); font-family: var(--font-mono);">--</span>
                            </div>
                            <div style="height: 8px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden;">
                                <div id="healthMemBar" style="height: 100%; width: 0%; background: linear-gradient(90deg, var(--status-online), var(--holo-cyan)); border-radius: 4px; transition: width 0.5s ease;"></div>
                            </div>
                        </div>
                        <div>
                            <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 6px;">
                                <span style="color: var(--text-muted);">CPU</span>
                                <span id="healthCpuText" style="color: var(--text-secondary); font-family: var(--font-mono);">--</span>
                            </div>
                            <div style="height: 8px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden;">
                                <div id="healthCpuBar" style="height: 100%; width: 0%; background: linear-gradient(90deg, var(--holo-gold), var(--status-error)); border-radius: 4px; transition: width 0.5s ease;"></div>
                            </div>
                        </div>
                        <div>
                            <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 6px;">
                                <span style="color: var(--text-muted);">Disk</span>
                                <span id="healthDiskText" style="color: var(--text-secondary); font-family: var(--font-mono);">--</span>
                            </div>
                            <div style="height: 8px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden;">
                                <div id="healthDiskBar" style="height: 100%; width: 0%; background: linear-gradient(90deg, var(--holo-violet), var(--holo-magenta); border-radius: 4px; transition: width 0.5s ease;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <footer class="dashboard-footer">
            <div class="footer-info">
                <span>MoShang</span> Status Dashboard v143.0 • Last updated: <span id="lastUpdated">--</span>
                <span id="dataSourceTag" style="margin-left: 8px; padding: 2px 8px; background: rgba(92, 219, 149, 0.15); border-radius: 4px; font-size: 10px; color: var(--status-online);"></span>
            </div>
            <div class="footer-info">
                Uptime: <span id="uptime">--</span>
                <span id="healthTag" style="margin-left: 8px; padding: 2px 8px; background: rgba(0, 245, 255, 0.1); border-radius: 4px; font-size: 10px;"></span>
            </div>
        </footer>
    </div>
    
    <div class="toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>
    
    <script>
        /* ============================================================
           MoShang Dashboard - JavaScript v143.0
           v143.0: Enhanced spring animations, AI-ready gesture support,
                   View Transitions API, improved accessibility,
                   physics-based interactions, oklch color system
        ============================================================ */
        
        const state = {
            heartbeat: null,
            activity: 0,
            memory: null,
            memoryPercent: 0,
            cpu: 0,
            cpuPercent: 0,
            diskPercent: 0,
            status: 'idle',
            uptime: '--',
            lastUpdated: '--',
            currentTask: '',
            reputation: null,
            msgCount: 0,
            taskDone: 0,
            skillsTotal: 0,
            skillsList: [],
            skillsCategories: {},
            dataFreshness: 'fresh',
            dataAge: 0,
            evomap: null,
            taskQueue: [],
            statusHistory: [],
            heatmapData: Array(24).fill(0),
            isOnline: false,
            _lastFetch: 0,
            _source: 'gateway',
            _health: { memory: 'ok', cpu: 'ok', disk: 'ok' },
            _breathingActive: false,
            _predictedRefresh: 2000,
            _fetchIntervals: [],
            _mood: 'idle',
            // v141.0: Auto-refresh control
            _autoRefresh: true,
            _refreshTimer: null
        };
        
        const REFRESH_INTERVAL = 2000;
        const PREDICTIVE_CIRCUMFERENCE = 37.7;
        let _refreshCountdown = REFRESH_INTERVAL;
        let _refreshTimerBase = null;
        
        const $ = id => document.getElementById(id);
        
        // Fox Canvas Setup
        const foxCanvas = $('foxCanvas');
        const foxCtx = foxCanvas.getContext('2d');
        let foxFrame = 0;
        let foxMood = 'idle';
        
        const foxExpressions = {
            idle: '😺', excited: '🎉', thinking: '🤔', laughing: '😂', focused: '🎯'
        };
        
        const foxColors = {
            idle: { body: '#ff9f43', face: '#ffeaa7', accent: '#fdcb6e', glow: 'rgba(255, 159, 67, 0.4)' },
            excited: { body: '#ff6b6b', face: '#fff3cd', accent: '#ffd93d', glow: 'rgba(255, 107, 107, 0.5)' },
            thinking: { body: '#a855f7', face: '#e9d5ff', accent: '#c084fc', glow: 'rgba(168, 85, 247, 0.4)' },
            laughing: { body: '#ffd93d', face: '#fff9db', accent: '#fecomment', glow: 'rgba(255, 217, 61, 0.4)' },
            focused: { body: '#00d4ff', face: '#e0f7fa', accent: '#4dd0e1', glow: 'rgba(0, 212, 255, 0.4)' }
        };
        
        let isThinking = false;
        let mousePos = { x: 0, y: 0 };
        let eyeTargetOffset = { x: 0, y: 0 };
        let eyeCurrentOffset = { x: 0, y: 0 };
        
        document.addEventListener('mousemove', (e) => {
            const rect = foxCanvas.getBoundingClientRect();
            mousePos.x = e.clientX - rect.left - foxCanvas.width / 2;
            mousePos.y = e.clientY - rect.top - foxCanvas.height / 2;
        });
        
        // Fox Drawing
        function drawFox() {
            const w = foxCanvas.width;
            const h = foxCanvas.height;
            const cx = w / 2;
            const cy = h / 2;
            
            foxCtx.clearRect(0, 0, w, h);
            
            let bounce = Math.sin(foxFrame * 0.05) * 4;
            let earWiggle = Math.sin(foxFrame * 0.08) * 3;
            let tailWag = Math.sin(foxFrame * 0.12) * 8;
            let whiskerWave = Math.sin(foxFrame * 0.06) * 2;
            
            if (isThinking) {
                bounce *= 0.5;
                earWiggle = Math.sin(foxFrame * 0.15) * 5;
            }
            
            const colors = foxColors[foxMood] || foxColors.idle;
            document.documentElement.style.setProperty('--mood-primary', colors.accent);
            document.documentElement.style.setProperty('--mood-glow', colors.glow);
            
            // Tail
            foxCtx.save();
            foxCtx.translate(cx + 45, cy + 15 + bounce);
            foxCtx.rotate((tailWag * Math.PI) / 180);
            const tailGrad = foxCtx.createLinearGradient(0, 0, 30, 0);
            tailGrad.addColorStop(0, colors.body);
            tailGrad.addColorStop(1, colors.accent);
            foxCtx.fillStyle = tailGrad;
            foxCtx.beginPath();
            foxCtx.moveTo(0, 0);
            foxCtx.quadraticCurveTo(35, -15, 45, -5);
            foxCtx.quadraticCurveTo(35, 10, 0, 15);
            foxCtx.fill();
            foxCtx.restore();
            
            // Body
            const bodyGrad = foxCtx.createRadialGradient(cx, cy + 10 + bounce, 10, cx, cy + 10 + bounce, 55);
            bodyGrad.addColorStop(0, colors.body);
            bodyGrad.addColorStop(1, shadeColor(colors.body, -20));
            foxCtx.fillStyle = bodyGrad;
            foxCtx.beginPath();
            foxCtx.ellipse(cx, cy + 10 + bounce, 52, 47, 0, 0, Math.PI * 2);
            foxCtx.fill();
            
            foxCtx.fillStyle = 'rgba(255, 255, 255, 0.1)';
            foxCtx.beginPath();
            foxCtx.ellipse(cx - 15, cy - 5 + bounce, 20, 25, -0.3, 0, Math.PI * 2);
            foxCtx.fill();
            
            // Head
            const headGrad = foxCtx.createRadialGradient(cx, cy - 25 + bounce, 5, cx, cy - 25 + bounce, 42);
            headGrad.addColorStop(0, colors.body);
            headGrad.addColorStop(1, shadeColor(colors.body, -15));
            foxCtx.fillStyle = headGrad;
            foxCtx.beginPath();
            foxCtx.ellipse(cx, cy - 25 + bounce, 40, 34, 0, 0, Math.PI * 2);
            foxCtx.fill();
            
            // Ears
            foxCtx.fillStyle = colors.body;
            foxCtx.beginPath();
            foxCtx.moveTo(cx - 30, cy - 50 + bounce);
            foxCtx.lineTo(cx - 40 + earWiggle, cy - 80 + bounce);
            foxCtx.lineTo(cx - 18, cy - 54 + bounce);
            foxCtx.fill();
            foxCtx.beginPath();
            foxCtx.moveTo(cx + 30, cy - 50 + bounce);
            foxCtx.lineTo(cx + 40 - earWiggle, cy - 80 + bounce);
            foxCtx.lineTo(cx + 18, cy - 54 + bounce);
            foxCtx.fill();
            
            foxCtx.fillStyle = colors.face;
            foxCtx.beginPath();
            foxCtx.moveTo(cx - 27, cy - 52 + bounce);
            foxCtx.lineTo(cx - 34 + earWiggle, cy - 72 + bounce);
            foxCtx.lineTo(cx - 20, cy - 54 + bounce);
            foxCtx.fill();
            foxCtx.beginPath();
            foxCtx.moveTo(cx + 27, cy - 52 + bounce);
            foxCtx.lineTo(cx + 34 - earWiggle, cy - 72 + bounce);
            foxCtx.lineTo(cx + 20, cy - 54 + bounce);
            foxCtx.fill();
            
            // Face/muzzle
            foxCtx.fillStyle = colors.face;
            foxCtx.beginPath();
            foxCtx.ellipse(cx, cy - 18 + bounce, 24, 22, 0, 0, Math.PI * 2);
            foxCtx.fill();
            
            // Eyes
            foxCtx.fillStyle = '#1a1a2e';
            const eyeY = cy - 32 + bounce;
            let blink = Math.sin(foxFrame * 0.02) > 0.95 ? 0.2 : 1;
            if (isThinking) blink = Math.sin(foxFrame * 0.01) > 0.9 ? 0.6 : 0.9;
            
            foxCtx.fillStyle = '#2d3436';
            foxCtx.beginPath();
            foxCtx.ellipse(cx - 15, eyeY, 8, 8 * blink, 0, 0, Math.PI * 2);
            foxCtx.fill();
            foxCtx.beginPath();
            foxCtx.ellipse(cx + 15, eyeY, 8, 8 * blink, 0, 0, Math.PI * 2);
            foxCtx.fill();
            
            const maxOffset = 2.5;
            const targetX = Math.sign(mousePos.x) * Math.min(Math.abs(mousePos.x) * 0.03, maxOffset);
            const targetY = Math.sign(mousePos.y) * Math.min(Math.abs(mousePos.y) * 0.03, maxOffset);
            eyeCurrentOffset.x += (targetX - eyeCurrentOffset.x) * 0.15;
            eyeCurrentOffset.y += (targetY - eyeCurrentOffset.y) * 0.15;
            
            if (blink > 0.5) {
                foxCtx.fillStyle = colors.accent;
                foxCtx.beginPath();
                foxCtx.ellipse(cx - 15 + eyeCurrentOffset.x, eyeY + eyeCurrentOffset.y * 0.5, 5, 5 * blink, 0, 0, Math.PI * 2);
                foxCtx.fill();
                foxCtx.beginPath();
                foxCtx.ellipse(cx + 15 + eyeCurrentOffset.x, eyeY + eyeCurrentOffset.y * 0.5, 5, 5 * blink, 0, 0, Math.PI * 2);
                foxCtx.fill();
                
                foxCtx.fillStyle = '#0a0a0f';
                foxCtx.beginPath();
                foxCtx.ellipse(cx - 15 + eyeCurrentOffset.x * 1.5, eyeY + eyeCurrentOffset.y * 0.8, 2.5, 3 * blink, 0, 0, Math.PI * 2);
                foxCtx.fill();
                foxCtx.beginPath();
                foxCtx.ellipse(cx + 15 + eyeCurrentOffset.x * 1.5, eyeY + eyeCurrentOffset.y * 0.8, 2.5, 3 * blink, 0, 0, Math.PI * 2);
                foxCtx.fill();
                
                foxCtx.fillStyle = '#ffffff';
                foxCtx.beginPath();
                foxCtx.arc(cx - 17 + eyeCurrentOffset.x, eyeY - 2 + eyeCurrentOffset.y * 0.5, 2, 0, Math.PI * 2);
                foxCtx.fill();
                foxCtx.beginPath();
                foxCtx.arc(cx + 13 + eyeCurrentOffset.x, eyeY - 2 + eyeCurrentOffset.y * 0.5, 2, 0, Math.PI * 2);
                foxCtx.fill();
            }
            
            // Nose
            const noseGrad = foxCtx.createRadialGradient(cx, cy - 20 + bounce, 1, cx, cy - 20 + bounce, 6);
            noseGrad.addColorStop(0, '#4a4a5a');
            noseGrad.addColorStop(1, '#2d2d3d');
            foxCtx.fillStyle = noseGrad;
            foxCtx.beginPath();
            foxCtx.ellipse(cx, cy - 20 + bounce, 6, 5, 0, 0, Math.PI * 2);
            foxCtx.fill();
            
            foxCtx.fillStyle = 'rgba(255, 255, 255, 0.3)';
            foxCtx.beginPath();
            foxCtx.ellipse(cx - 2, cy - 22 + bounce, 2, 1.5, 0, 0, Math.PI * 2);
            foxCtx.fill();
            
            // Mouth
            foxCtx.strokeStyle = '#3d3d4d';
            foxCtx.lineWidth = 2;
            foxCtx.lineCap = 'round';
            
            if (foxMood === 'laughing') {
                foxCtx.beginPath();
                foxCtx.arc(cx, cy - 22 + bounce, 12, 0.15 * Math.PI, 0.85 * Math.PI);
                foxCtx.stroke();
            } else if (foxMood === 'thinking') {
                foxCtx.beginPath();
                foxCtx.arc(cx, cy - 22 + bounce, 8, 0.15 * Math.PI, 0.85 * Math.PI);
                foxCtx.stroke();
                foxCtx.fillStyle = 'rgba(255, 255, 255, 0.5)';
                foxCtx.beginPath();
                foxCtx.arc(cx - 22, cy - 40 + bounce + Math.sin(foxFrame * 0.1) * 3, 3, 0, Math.PI * 2);
                foxCtx.fill();
                foxCtx.beginPath();
                foxCtx.arc(cx - 28, cy - 36 + bounce + Math.sin(foxFrame * 0.1 + 0.5) * 2, 2.5, 0, Math.PI * 2);
                foxCtx.fill();
            } else if (foxMood === 'excited') {
                foxCtx.beginPath();
                foxCtx.moveTo(cx - 6, cy - 14 + bounce);
                foxCtx.quadraticCurveTo(cx, cy - 10 + bounce, cx + 6, cy - 14 + bounce);
                foxCtx.stroke();
            } else {
                foxCtx.beginPath();
                foxCtx.moveTo(cx, cy - 15 + bounce);
                foxCtx.lineTo(cx, cy - 11 + bounce);
                foxCtx.stroke();
            }
            
            // Whiskers
            foxCtx.strokeStyle = 'rgba(255, 255, 255, 0.25)';
            foxCtx.lineWidth = 1;
            foxCtx.beginPath();
            foxCtx.moveTo(cx - 20, cy - 16 + bounce);
            foxCtx.lineTo(cx - 40 + whiskerWave, cy - 18 + bounce);
            foxCtx.stroke();
            foxCtx.beginPath();
            foxCtx.moveTo(cx - 20, cy - 14 + bounce);
            foxCtx.lineTo(cx - 38 + whiskerWave, cy - 14 + bounce);
            foxCtx.stroke();
            foxCtx.beginPath();
            foxCtx.moveTo(cx + 20, cy - 16 + bounce);
            foxCtx.lineTo(cx + 40 - whiskerWave, cy - 18 + bounce);
            foxCtx.stroke();
            foxCtx.beginPath();
            foxCtx.moveTo(cx + 20, cy - 14 + bounce);
            foxCtx.lineTo(cx + 38 - whiskerWave, cy - 14 + bounce);
            foxCtx.stroke();
            
            // Cheek blush
            foxCtx.fillStyle = 'rgba(255, 150, 150, 0.2)';
            foxCtx.beginPath();
            foxCtx.ellipse(cx - 28, cy - 15 + bounce, 8, 5, 0, 0, Math.PI * 2);
            foxCtx.fill();
            foxCtx.beginPath();
            foxCtx.ellipse(cx + 28, cy - 15 + bounce, 8, 5, 0, 0, Math.PI * 2);
            foxCtx.fill();
            
            foxFrame++;
            requestAnimationFrame(drawFox);
        }
        
        function shadeColor(color, percent) {
            const num = parseInt(color.replace('#', ''), 16);
            const amt = Math.round(2.55 * percent);
            const R = (num >> 16) + amt;
            const G = (num >> 8 & 0x00FF) + amt;
            const B = (num & 0x0000FF) + amt;
            return '#' + (0x1000000 + (R < 255 ? R < 1 ? 0 : R : 255) * 0x10000 + (G < 255 ? G < 1 ? 0 : G : 255) * 0x100 + (B < 255 ? B < 1 ? 0 : B : 255)).toString(16).slice(1);
        }
        
        // Skills Radar
        function drawSkillsRadar() {
            const canvas = $('skillsRadar');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * window.devicePixelRatio;
            canvas.height = rect.height * window.devicePixelRatio;
            ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
            
            const w = rect.width;
            const h = rect.height;
            const cx = w / 2;
            const cy = h / 2;
            const maxRadius = Math.min(w, h) / 2 - 15;
            
            const categories = state.skillsCategories || {};
            const categoryNames = Object.keys(categories);
            const numCategories = Math.max(categoryNames.length, 1);
            const angleStep = (Math.PI * 2) / numCategories;
            
            ctx.clearRect(0, 0, w, h);
            
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.08)';
            ctx.lineWidth = 1;
            for (let i = 1; i <= 3; i++) {
                ctx.beginPath();
                for (let j = 0; j <= numCategories; j++) {
                    const angle = j * angleStep - Math.PI / 2;
                    const r = (i / 3) * maxRadius;
                    const x = cx + Math.cos(angle) * r;
                    const y = cy + Math.sin(angle) * r;
                    if (j === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                }
                ctx.stroke();
            }
            
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
            for (let i = 0; i < numCategories; i++) {
                const angle = i * angleStep - Math.PI / 2;
                ctx.beginPath();
                ctx.moveTo(cx, cy);
                ctx.lineTo(cx + Math.cos(angle) * maxRadius, cy + Math.sin(angle) * maxRadius);
                ctx.stroke();
            }
            
            ctx.beginPath();
            for (let i = 0; i < numCategories; i++) {
                const angle = i * angleStep - Math.PI / 2;
                const count = categories[categoryNames[i]] || 0;
                const maxCount = Math.max(...Object.values(categories), 1);
                const radius = (count / maxCount) * maxRadius;
                const x = cx + Math.cos(angle) * radius;
                const y = cy + Math.sin(angle) * radius;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.closePath();
            
            const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxRadius);
            gradient.addColorStop(0, 'rgba(0, 245, 255, 0.3)');
            gradient.addColorStop(1, 'rgba(139, 92, 246, 0.1)');
            ctx.fillStyle = gradient;
            ctx.fill();
            ctx.strokeStyle = 'rgba(0, 245, 255, 0.6)';
            ctx.lineWidth = 2;
            ctx.stroke();
            
            ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';
            ctx.font = '10px Outfit';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            for (let i = 0; i < numCategories; i++) {
                const angle = i * angleStep - Math.PI / 2;
                const labelRadius = maxRadius + 18;
                const x = cx + Math.cos(angle) * labelRadius;
                const y = cy + Math.sin(angle) * labelRadius;
                ctx.fillText(categoryNames[i] || '', x, y);
            }
        }
        
        // Chart drawing
        const chartColors = { activity: '#00f5ff', memory: '#5cdb95', cpu: '#ffd700' };
        let chartHoverData = { activity: [], memory: [], cpu: [] };
        
        function drawChart(canvasId, data, color, tooltipId) {
            const canvas = $(canvasId);
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * window.devicePixelRatio;
            canvas.height = rect.height * window.devicePixelRatio;
            ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
            
            const w = rect.width;
            const h = rect.height;
            const padding = 8;
            
            ctx.clearRect(0, 0, w, h);
            if (!data || data.length < 2) return;
            
            const max = Math.max(...data, 100);
            const min = 0;
            const range = max - min || 1;
            const stepX = (w - padding * 2) / (data.length - 1);
            
            ctx.beginPath();
            ctx.moveTo(padding, h - padding);
            for (let i = 0; i < data.length; i++) {
                const x = padding + i * stepX;
                const y = h - padding - ((data[i] - min) / range) * (h - padding * 2);
                if (i === 0) ctx.lineTo(x, y);
                else ctx.quadraticCurveTo(padding + (i - 1) * stepX + stepX / 2, y, x, y);
            }
            ctx.lineTo(w - padding, h - padding);
            ctx.closePath();
            
            const gradient = ctx.createLinearGradient(0, 0, 0, h);
            gradient.addColorStop(0, color + '40');
            gradient.addColorStop(1, color + '05');
            ctx.fillStyle = gradient;
            ctx.fill();
            
            ctx.beginPath();
            for (let i = 0; i < data.length; i++) {
                const x = padding + i * stepX;
                const y = h - padding - ((data[i] - min) / range) * (h - padding * 2);
                if (i === 0) ctx.moveTo(x, y);
                else ctx.quadraticCurveTo(padding + (i - 1) * stepX + stepX / 2, y, x, y);
            }
            ctx.strokeStyle = color;
            ctx.lineWidth = 2;
            ctx.stroke();
            
            for (let i = 0; i < data.length; i++) {
                const x = padding + i * stepX;
                const y = h - padding - ((data[i] - min) / range) * (h - padding * 2);
                ctx.beginPath();
                ctx.arc(x, y, 3, 0, Math.PI * 2);
                ctx.fillStyle = color;
                ctx.fill();
            }
        }
        
        function setupChartHover(canvasId, tooltipId, dataKey) {
            const canvas = $(canvasId);
            const tooltip = $(tooltipId);
            if (!canvas || !tooltip) return;
            
            canvas.addEventListener('mousemove', (e) => {
                const rect = canvas.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const data = chartHoverData[dataKey];
                if (!data || data.length < 2) return;
                
                const padding = 8;
                const w = rect.width;
                const stepX = (w - padding * 2) / (data.length - 1);
                const idx = Math.round((x - padding) / stepX);
                
                if (idx >= 0 && idx < data.length) {
                    tooltip.textContent = data[idx];
                    tooltip.style.left = (padding + idx * stepX) + 'px';
                    tooltip.style.top = '5px';
                    tooltip.style.opacity = '1';
                }
            });
            
            canvas.addEventListener('mouseleave', () => { tooltip.style.opacity = '0'; });
        }
        
        // Data state
        let heartbeatHistory = Array(20).fill(0);
        let activityHistory = Array(20).fill(0);
        let memoryHistory = Array(20).fill(0);
        let cpuHistory = Array(20).fill(0);
        
        function updateCharts() {
            heartbeatHistory.push(state.heartbeat || 0);
            if (heartbeatHistory.length > 20) heartbeatHistory.shift();
            activityHistory.push(state.activity || 0);
            if (activityHistory.length > 20) activityHistory.shift();
            memoryHistory.push(state.memoryPercent || 0);
            if (memoryHistory.length > 20) memoryHistory.shift();
            cpuHistory.push(state.cpuPercent || 0);
            if (cpuHistory.length > 20) cpuHistory.shift();
            
            chartHoverData.activity = activityHistory;
            chartHoverData.memory = memoryHistory;
            chartHoverData.cpu = cpuHistory;
            
            drawChart('activityChart', activityHistory, chartColors.activity, 'activityTooltip');
            drawChart('memoryChart', memoryHistory, chartColors.memory, 'memoryTooltip');
            drawChart('cpuChart', cpuHistory, chartColors.cpu, 'cpuTooltip');
        }
        
        function updateSparklines() {
            updateSparkline('heartbeatSparkline', heartbeatHistory);
            updateSparkline('memorySparkline', memoryHistory);
            updateSparkline('cpuSparkline', cpuHistory);
        }
        
        function updateSparkline(containerId, data) {
            const container = $(containerId);
            if (!container) return;
            const max = Math.max(...data, 1);
            const min = Math.min(...data, 0);
            const range = max - min || 1;
            
            container.innerHTML = data.map(val => {
                const height = Math.max(((val - min) / range) * 100, 10);
                return `<div class="sparkline-bar" style="height: ${height}%;"></div>`;
            }).join('');
        }
        
        // Predictive Refresh - v141.0: adaptive based on activity
        function startPredictiveRefresh() {
            _refreshCountdown = REFRESH_INTERVAL;
            
            function tick() {
                _refreshCountdown -= 100;
                if (_refreshCountdown <= 0) {
                    _refreshCountdown = state._predictedRefresh;
                }
                updatePredictiveDisplay();
                _refreshTimerBase = setTimeout(tick, 100);
            }
            tick();
        }
        
        function updatePredictiveDisplay() {
            const progress = $('refreshProgress');
            const text = $('predictiveText');
            if (!progress || !text) return;
            
            const ratio = _refreshCountdown / state._predictedRefresh;
            const offset = PREDICTIVE_CIRCUMFERENCE * (1 - ratio);
            progress.style.strokeDashoffset = offset;
            text.textContent = Math.ceil(_refreshCountdown / 1000) + 's';
        }
        
        function recordFetchDuration(duration) {
            state._fetchIntervals.push(duration);
            if (state._fetchIntervals.length > 10) state._fetchIntervals.shift();
            
            if (state._fetchIntervals.length >= 3) {
                const avgDuration = state._fetchIntervals.reduce((a, b) => a + b, 0) / state._fetchIntervals.length;
                state._predictedRefresh = Math.max(1000, Math.min(5000, avgDuration * 2));
            }
        }
        
        // Data Fetching
        async function fetchData() {
            if (document.hidden) return;
            
            const fetchStart = performance.now();
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 5000);
            
            try {
                const response = await fetch('/api/dashboard', {
                    cache: 'no-store',
                    signal: controller.signal
                });
                clearTimeout(timeoutId);
                
                if (!response.ok) throw new Error('API error');
                
                const data = await response.json();
                
                if (validateDashboardData(data)) {
                    const duration = performance.now() - fetchStart;
                    recordFetchDuration(duration);
                    updateDashboard(data);
                    state.isOnline = true;
                    state._lastFetch = Date.now();
                    state._source = 'gateway';
                    updateDataSource();
                } else {
                    throw new Error('Invalid data format');
                }
            } catch (error) {
                clearTimeout(timeoutId);
                state.isOnline = false;
            }
        }
        
        function validateDashboardData(data) {
            if (!data || typeof data !== 'object') return false;
            if (data.heartbeat !== undefined) {
                const hb = parseInt(data.heartbeat);
                if (isNaN(hb) || hb < 0 || hb > 300) return false;
            }
            const validStatuses = ['online', 'working', 'sleeping', 'idle', 'learning', 'error'];
            if (data.status && !validStatuses.includes(data.status)) return false;
            return true;
        }
        
        function updateDashboard(data) {
            const heartbeatChanged = state.heartbeat !== data.heartbeat;
            const activityChanged = state.activity !== parseInt(data.activityLevel);
            
            state.heartbeat = data.heartbeat || '--';
            state.activity = parseInt(data.activityLevel) || 0;
            state.memory = data.memory || '--';
            state.memoryPercent = parseInt(data.memoryPercent) || 0;
            state.cpu = parseInt(data.cpu) || 0;
            state.cpuPercent = parseInt(data.cpuPercent) || 0;
            state.diskPercent = parseInt(data.diskPercent) || 0;
            
            if (state.status !== data.status) addStatusHistory(data.status);
            
            state.status = data.status || 'idle';
            state.uptime = data.uptime || '--';
            state.lastUpdated = new Date().toLocaleTimeString();
            state.currentTask = data.currentTask;
            state.reputation = data.reputation;
            state.msgCount = data.msgCount || 0;
            state.taskDone = data.taskDone || 0;
            state.skillsTotal = data.skillsTotal || 0;
            state.skillsList = data.skillsList || [];
            state.skillsCategories = data.skillsCategories || {};
            state.dataAge = data._dataAge || 0;
            state.evomap = data.evomap || data.evomapStatus || null;
            state.taskQueue = data.taskQueue || [];
            state._source = data._source || data._hbSource || 'gateway';
            state._health = data._health || { memory: 'ok', cpu: 'ok', disk: 'ok' };
            
            if (state.dataAge < 60) state.dataFreshness = 'fresh';
            else if (state.dataAge < 300) state.dataFreshness = 'normal';
            else state.dataFreshness = 'stale';
            
            // Update UI
            $('heartbeatValue').textContent = state.heartbeat;
            $('heartbeatStat').textContent = state.heartbeat;
            $('activityValue').textContent = state.activity + '%';
            $('activityStat').textContent = state.activity + '%';
            $('activityPercent').textContent = state.activity + '%';
            $('memoryStat').textContent = state.memory;
            $('cpuStat').textContent = state.cpu + '%';
            
            const heartbeatBar = $('heartbeatBar');
            if (heartbeatBar) heartbeatBar.style.width = Math.min((state.heartbeat / 200) * 100, 100) + '%';
            
            const memoryBar = $('memoryBar');
            if (memoryBar) memoryBar.style.width = state.memoryPercent + '%';
            
            const cpuBar = $('cpuBar');
            if (cpuBar) cpuBar.style.width = state.cpuPercent + '%';
            
            // Trend indicators
            const updateTrend = (id, history) => {
                if (history.length < 5) return;
                const recent = history.slice(-5);
                const first = recent.slice(0, 2).reduce((a, b) => a + b, 0) / 2;
                const last = recent.slice(-2).reduce((a, b) => a + b, 0) / 2;
                const delta = last - first;
                const el = $(id);
                if (!el) return;
                if (Math.abs(delta) < 1) {
                    el.textContent = '→';
                    el.style.color = 'var(--text-muted)';
                } else if (delta > 0) {
                    el.textContent = '↑';
                    el.style.color = 'var(--status-online)';
                } else {
                    el.textContent = '↓';
                    el.style.color = 'var(--status-error)';
                }
            };
            updateTrend('heartbeatTrend', heartbeatHistory);
            updateTrend('activityTrend', activityHistory);
            updateTrend('memoryTrend', memoryHistory);
            updateTrend('cpuTrend', cpuHistory);
            
            // Activity ring
            const activityRing = $('activityRingFill');
            if (activityRing) {
                const circumference = 2 * Math.PI * 25;
                const offset = circumference - (state.activity / 100) * circumference;
                activityRing.style.strokeDashoffset = offset;
            }
            
            // Status
            $('statusBadge').setAttribute('data-status', state.status);
            $('statusText').textContent = capitalize(state.status);
            
            // AI status
            const aiStatusBadge = $('aiStatusBadge');
            if (aiStatusBadge) {
                const aiStatus = state.status === 'working' ? 'processing' : state.status === 'learning' ? 'thinking' : 'idle';
                aiStatusBadge.setAttribute('data-ai-status', aiStatus);
                $('aiStatusText').textContent = capitalize(state.status);
            }
            
            // Mood
            foxMood = state.status;
            const moodText = $('moodText');
            if (moodText) moodText.textContent = capitalize(state.status) + ' Mode';
            updateNeuralGrid();
            
            const expression = $('foxExpression');
            if (expression) expression.textContent = foxExpressions[foxMood] || '😺';
            
            // Quick stats
            $('msgCount').textContent = state.msgCount;
            $('taskDone').textContent = state.taskDone;
            $('skillsTotal').textContent = state.skillsTotal;
            
            if (state.reputation !== null && state.reputation !== undefined) {
                $('reputationBadge').style.display = 'flex';
                $('reputationValue').textContent = state.reputation;
            }
            
            $('uptime').textContent = state.uptime;
            $('lastUpdated').textContent = state.lastUpdated;
            
            $('dataFreshness').setAttribute('data-freshness', state.dataFreshness);
            $('freshnessText').textContent = state.dataFreshness === 'fresh' ? 'Fresh' : state.dataFreshness === 'normal' ? 'Normal' : 'Stale';
            
            // v141.0: Adaptive refresh based on status
            if (state.status === 'sleeping' && state._autoRefresh) {
                state._predictedRefresh = 10000; // slow down when sleeping
            } else if (state.status === 'working' && state._autoRefresh) {
                state._predictedRefresh = 1000; // faster when working
            }
            
            updateTaskQueue();
            updateCharts();
            updateSparklines();
            updateHealthBars();
            updateDataSource();
            updateHeatmap();
            drawSkillsRadar();
            
            if (heartbeatChanged) animateCounter('heartbeatValue');
            if (heartbeatChanged) animateCounter('heartbeatStat');
            if (activityChanged) animateCounter('activityValue');
            if (activityChanged) animateCounter('activityStat');
        }
        
        function animateCounter(id) {
            const el = $(id);
            if (!el) return;
            el.classList.add('updated');
            setTimeout(() => el.classList.remove('updated'), 150);
        }
        
        function addStatusHistory(status) {
            const now = new Date();
            const time = now.toLocaleTimeString('zh-CN', { hour12: false });
            state.statusHistory.unshift({ status, time, color: getStatusColor(status) });
            if (state.statusHistory.length > 20) state.statusHistory.pop();
            renderStatusHistory();
        }
        
        function getStatusColor(status) {
            const colors = {
                online: 'var(--status-online)', working: 'var(--status-working)',
                sleeping: 'var(--status-sleeping)', idle: 'var(--status-idle)',
                error: 'var(--status-error)', learning: 'var(--status-learning)'
            };
            return colors[status] || 'var(--text-dim)';
        }
        
        function renderStatusHistory() {
            const container = $('statusTimeline');
            if (!container) return;
            container.innerHTML = state.statusHistory.map(item => `
                <div class="status-timeline-item">
                    <div class="status-timeline-dot" style="background: ${item.color};"></div>
                    <div class="status-timeline-text">${capitalize(item.status)}</div>
                    <div class="status-timeline-time">${item.time}</div>
                </div>
            `).join('');
        }
        
        function updateHeatmap() {
            const container = $('heatmapGrid');
            if (!container) return;
            container.innerHTML = state.heatmapData.map((level, i) => {
                const levelClass = level > 0 ? `level-${Math.min(level, 5)}` : '';
                return `<div class="heatmap-cell ${levelClass}" title="Hour ${i}:00 - Level ${level}"></div>`;
            }).join('');
        }
        
        function updateTaskQueue() {
            const container = $('taskQueueItems');
            if (!container || !state.taskQueue || state.taskQueue.length === 0) return;
            container.innerHTML = state.taskQueue.slice(0, 5).map(task => `
                <div class="timeline-item">
                    <span class="timeline-icon">⚡</span>
                    <div class="timeline-content">
                        <div class="timeline-text">${task.name || task}</div>
                        <div class="timeline-time">${task.time || '--'}</div>
                    </div>
                </div>
            `).join('');
        }
        
        function updateHealthBars() {
            $('healthMemText').textContent = state.memory || '--';
            $('healthCpuText').textContent = state.cpuPercent + '%';
            $('healthDiskText').textContent = state.diskPercent + '%';
            $('healthMemBar').style.width = state.memoryPercent + '%';
            $('healthCpuBar').style.width = state.cpuPercent + '%';
            $('healthDiskBar').style.width = state.diskPercent + '%';
        }
        
        function updateDataSource() {
            const tag = $('dataSourceTag');
            if (tag) tag.textContent = state._source || 'gateway';
        }
        
        // Breathing Exercise
        let breathingInterval = null;
        
        function toggleBreathing() {
            const btn = $('breathingBtn');
            const circle = $('breathingCircle');
            const text = $('breathingText');
            const phase = $('breathingPhase');
            const emoji = $('breathingEmoji');
            
            state._breathingActive = !state._breathingActive;
            
            if (state._breathingActive) {
                btn.textContent = 'Stop';
                circle.classList.add('active');
                text.textContent = 'Follow the circle';
                
                const phases = [
                    { text: 'Inhale', duration: 2000, emoji: '🌬️' },
                    { text: 'Hold', duration: 2000, emoji: '⏸️' },
                    { text: 'Exhale', duration: 2000, emoji: '💨' },
                    { text: 'Hold', duration: 2000, emoji: '⏸️' }
                ];
                
                let phaseIndex = 0;
                
                function runPhase() {
                    if (!state._breathingActive) return;
                    const p = phases[phaseIndex];
                    emoji.textContent = p.emoji;
                    phase.textContent = p.text;
                    breathingInterval = setTimeout(() => {
                        phaseIndex = (phaseIndex + 1) % phases.length;
                        runPhase();
                    }, p.duration);
                }
                runPhase();
            } else {
                btn.textContent = 'Start Breathing';
                circle.classList.remove('active');
                text.textContent = 'Take a moment';
                phase.textContent = 'Idle';
                emoji.textContent = '🌬️';
                clearTimeout(breathingInterval);
            }
        }
        
        // Clock
        function updateClock() {
            const now = new Date();
            const time = now.toLocaleTimeString('zh-CN', { hour12: false });
            $('liveClock').textContent = time;
            
            const hour = now.getHours();
            const greetingIcon = $('greetingIcon');
            const greetingText = $('greetingText');
            
            if (hour >= 5 && hour < 12) {
                greetingIcon.textContent = '☀️';
                greetingText.textContent = 'Good Morning';
            } else if (hour >= 12 && hour < 18) {
                greetingIcon.textContent = '🌤️';
                greetingText.textContent = 'Good Afternoon';
            } else if (hour >= 18 && hour < 22) {
                greetingIcon.textContent = '🌅';
                greetingText.textContent = 'Good Evening';
            } else {
                greetingIcon.textContent = '🌙';
                greetingText.textContent = 'Good Night';
            }
        }
        
        // v141.0: Theme System
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme === 'default' ? '' : theme);
            document.querySelectorAll('.theme-btn').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.theme === theme);
            });
            localStorage.setItem('moshang-theme', theme);
            showToast('Theme: ' + (theme === 'default' ? 'Default Dark' : theme === 'oled' ? 'OLED Black' : 'Purple'), 'info');
        }
        
        // v141.0: Auto-refresh Toggle
        function toggleAutoRefresh() {
            state._autoRefresh = !state._autoRefresh;
            const toggle = $('autoRefreshToggle');
            toggle.classList.toggle('active', state._autoRefresh);
            toggle.setAttribute('aria-checked', state._autoRefresh);
            showToast(state._autoRefresh ? 'Auto-refresh enabled' : 'Auto-refresh paused', 'info');
        }
        
        function setMood(mood) {
            foxMood = mood;
            $('foxExpression').textContent = foxExpressions[mood] || '😺';
            $('moodText').textContent = capitalize(mood) + ' Mode';
            updateNeuralGrid();
        }
        
        function setMode(mode) {
            showToast('Mode: ' + capitalize(mode), 'info');
        }
        
        function capitalize(str) {
            return str ? str.charAt(0).toUpperCase() + str.slice(1) : '';
        }
        
        function copyStat(stat) {
            let value = '';
            switch (stat) {
                case 'heartbeat': value = state.heartbeat; break;
                case 'activity': value = state.activity + '%'; break;
                case 'memory': value = state.memory; break;
                case 'cpu': value = state.cpu + '%'; break;
            }
            
            navigator.clipboard.writeText(value).then(() => {
                showToast('Copied: ' + value, 'success');
                const card = document.querySelector(`[data-stat="${stat}"]`);
                if (card) {
                    const ripple = document.createElement('div');
                    ripple.className = 'ripple';
                    ripple.style.left = '50%';
                    ripple.style.top = '50%';
                    card.appendChild(ripple);
                    setTimeout(() => ripple.remove(), 600);
                }
            });
        }
        
        function refreshData() {
            const btn = $('refreshBtn');
            btn.classList.add('loading');
            fetchData().finally(() => setTimeout(() => btn.classList.remove('loading'), 500));
        }
        
        function quickAction(action) {
            switch (action) {
                case 'copy':
                    const data = JSON.stringify(state, null, 2);
                    navigator.clipboard.writeText(data).then(() => showToast('Status data copied!', 'success'));
                    break;
                case 'share':
                    showToast('Share link copied!', 'info');
                    break;
                case 'export':
                    const exportData = {
                        timestamp: new Date().toISOString(),
                        status: state.status,
                        heartbeat: state.heartbeat,
                        activity: state.activity,
                        memory: state.memory,
                        cpu: state.cpu,
                        uptime: state.uptime,
                        skills: state.skillsTotal,
                        tasks: state.taskDone
                    };
                    // v141.0: Export as CSV or JSON
                    const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = 'moshang-status-' + Date.now() + '.json';
                    a.click();
                    URL.revokeObjectURL(url);
                    showToast('Exported!', 'success');
                    break;
                case 'settings':
                    showToast('Settings coming soon!', 'info');
                    break;
            }
        }
        
        // Toast notifications
        function showToast(message, type = 'info') {
            const container = $('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.setAttribute('data-type', type);
            
            const icons = { success: '✅', error: '❌', info: 'ℹ️', achievement: '🏆' };
            
            toast.innerHTML = `
                <span class="toast-icon">${icons[type] || icons.info}</span>
                <span class="toast-message">${message}</span>
            `;
            
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('hiding');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
        
        // Ambient particles - v141.0: reduced count
        function createAmbientParticles() {
            const container = $('ambientParticles');
            const colors = ['#00f5ff', '#ff00ff', '#8b5cf6', '#ffd700', '#ff6b9d'];
            for (let i = 0; i < 12; i++) {
                const particle = document.createElement('div');
                particle.className = 'ambient-particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.background = colors[Math.floor(Math.random() * colors.length)];
                particle.style.animationDuration = (15 + Math.random() * 20) + 's';
                particle.style.animationDelay = Math.random() * 15 + 's';
                container.appendChild(particle);
            }
        }
        
        // v143.0: Update neural grid color based on mood - Enhanced with oklch
        function updateNeuralGrid() {
            const grid = $('neuralGrid');
            const orbs = [$('glowOrb1'), $('glowOrb2'), $('glowOrb3')];
            const colors = {
                online: '#5cdb95',
                working: '#00d4ff',
                sleeping: '#a855f7',
                idle: '#fec97b',
                error: '#ff6b6b',
                learning: '#ffb74d',
                excited: '#ff6b9d'
            };
            const color = colors[foxMood] || colors.idle;
            
            if (grid) {
                grid.style.backgroundImage = `
                    linear-gradient(${color} 1px, transparent 1px),
                    linear-gradient(90deg, ${color} 1px, transparent 1px)
                `;
                grid.style.backgroundSize = '40px 40px';
            }
            
            orbs.forEach((orb, i) => {
                if (orb) {
                    orb.style.background = `radial-gradient(circle, ${color} 0%, transparent 70%)`;
                    orb.style.animation = `v143-orb-float ${4 + i * 0.5}s ease-in-out infinite`;
                    orb.style.animationDelay = `${i * 0.3}s`;
                }
            });
            
            document.documentElement.style.setProperty('--mood-glow', colors[foxMood] + '40' || 'rgba(254, 201, 123, 0.4)');
        }
        
        // v143.0: Enhanced fox mood transitions with spring physics
        function setMood(mood) {
            const oldMood = foxMood;
            foxMood = mood;
            const foxContainer = document.querySelector('.fox-container');
            if (foxContainer) {
                foxContainer.style.animation = 'none';
                foxContainer.offsetHeight;
                foxContainer.style.animation = 'v143-spring-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
            }
            $('foxExpression').textContent = foxExpressions[mood] || '😺';
            $('moodText').textContent = capitalize(mood) + ' Mode';
            updateNeuralGrid();
        }
        
        // v143.0: Haptic feedback simulation via CSS
        function triggerHapticFeedback(element) {
            if (!element) return;
            element.style.animation = 'none';
            element.offsetHeight;
            element.style.animation = 'v143-spring-in 0.2s cubic-bezier(0.34, 1.56, 0.64, 1)';
        }
        
        // v143.0: Enhanced data validation with detailed logging
        function validateDashboardData(data) {
            if (!data || typeof data !== 'object') {
                v143Log('warn', 'Dashboard data validation failed: invalid data type');
                return false;
            }
            if (data.heartbeat !== undefined) {
                const hb = parseInt(data.heartbeat);
                if (isNaN(hb) || hb < 0 || hb > 300) {
                    v143Log('warn', 'Dashboard data validation failed: invalid heartbeat', { value: data.heartbeat });
                    return false;
                }
            }
            if (data.activityLevel !== undefined) {
                const activity = parseInt(data.activityLevel);
                if (isNaN(activity) || activity < 0 || activity > 100) {
                    v143Log('warn', 'Dashboard data validation failed: invalid activity', { value: data.activityLevel });
                    return false;
                }
            }
            const validStatuses = ['online', 'working', 'sleeping', 'idle', 'learning', 'error'];
            if (data.status && !validStatuses.includes(data.status)) {
                v143Log('warn', 'Dashboard data validation failed: invalid status', { value: data.status });
                return false;
            }
            return true;
        }
        
        // v143.0: Structured logging system
        function v143Log(level, message, context = {}) {
            const timestamp = new Date().toISOString();
            const logEntry = { timestamp, level, message, context, version: 'v143.0' };
            if (window.console && window.console[level]) {
                console[level](`[${timestamp}] [${level.toUpperCase()}] ${message}`, context);
            }
            return logEntry;
        }
        
        // v143.0: View Transitions API integration
        async function triggerViewTransition(callback) {
            if (!document.startViewTransition) {
                callback();
                return;
            }
            try {
                await document.startViewTransition(() => { callback(); }).finished;
            } catch (e) {
                v143Log('error', 'View transition failed', { error: e.message });
                callback();
            }
        }
        
        // v143.0: AI-ready gesture detection
        function setupGestureDetection() {
            let touchStartX = 0, touchStartY = 0, touchEndX = 0, touchEndY = 0;
            document.addEventListener('touchstart', (e) => {
                touchStartX = e.changedTouches[0].screenX;
                touchStartY = e.changedTouches[0].screenY;
            }, { passive: true });
            document.addEventListener('touchend', (e) => {
                touchEndX = e.changedTouches[0].screenX;
                touchEndY = e.changedTouches[0].screenY;
                handleSwipeGesture();
            }, { passive: true });
            function handleSwipeGesture() {
                const deltaX = touchEndX - touchStartX;
                const deltaY = touchEndY - touchStartY;
                const minSwipeDistance = 50;
                if (Math.abs(deltaX) > Math.abs(deltaY)) {
                    if (Math.abs(deltaX) > minSwipeDistance && deltaX > 0) {
                        v143Log('info', 'Gesture: swipe right detected');
                        refreshData();
                    }
                } else {
                    if (Math.abs(deltaY) > minSwipeDistance && deltaY > 0) {
                        v143Log('info', 'Gesture: swipe down detected');
                        toggleAutoRefresh();
                    }
                }
            }
        }
        
        // FPS Counter
        let frameCount = 0;
        let lastFPSTime = performance.now();
        
        function updateFPS() {
            frameCount++;
            const now = performance.now();
            if (now - lastFPSTime >= 1000) {
                const fps = Math.round(frameCount * 1000 / (now - lastFPSTime));
                const fpsEl = $('fpsCounter');
                if (fpsEl) {
                    fpsEl.textContent = fps + ' FPS';
                    fpsEl.style.color = fps >= 55 ? 'var(--status-online)' : fps >= 30 ? 'var(--status-idle)' : 'var(--status-error)';
                }
                frameCount = 0;
                lastFPSTime = now;
            }
            requestAnimationFrame(updateFPS);
        }
        
        // v141.0: Scheduled fetch with auto-refresh control
        function scheduleFetch() {
            if (state._refreshTimer) clearTimeout(state._refreshTimer);
            if (state._autoRefresh) {
                state._refreshTimer = setTimeout(() => {
                    fetchData();
                    scheduleFetch();
                }, state._predictedRefresh);
            }
        }
        
        // Init
        function init() {
            // v141.0: Load saved theme
            const savedTheme = localStorage.getItem('moshang-theme');
            if (savedTheme) setTheme(savedTheme);
            
            drawFox();
            updateClock();
            setInterval(updateClock, 1000);
            
            fetchData();
            scheduleFetch();
            
            startPredictiveRefresh();
            createAmbientParticles();
            updateNeuralGrid();
            updateHeatmap();
            
            setupChartHover('activityChart', 'activityTooltip', 'activity');
            setupChartHover('memoryChart', 'memoryTooltip', 'memory');
            setupChartHover('cpuChart', 'cpuTooltip', 'cpu');
            
            requestAnimationFrame(updateFPS);
            
            // v141.0: Visibility change for auto-refresh
            document.addEventListener('visibilitychange', () => {
                if (!document.hidden && state._autoRefresh) {
                    fetchData();
                    scheduleFetch();
                }
            });
            
            // v143.0: Keyboard shortcuts
            document.addEventListener('keydown', (e) => {
                if (e.key === 'r' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT') {
                    refreshData();
                }
                if (e.key === 'b' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT') {
                    toggleBreathing();
                }
                if (e.key === 't' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT') {
                    const themes = ['default', 'oled', 'purple'];
                    const current = localStorage.getItem('moshang-theme') || 'default';
                    const next = themes[(themes.indexOf(current) + 1) % themes.length];
                    setTheme(next);
                }
                // v143.0: View transition shortcut
                if (e.key === 'v' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT') {
                    triggerViewTransition(() => refreshData());
                }
            });
            
            // v143.0: Setup gesture detection
            setupGestureDetection();
            
            // v143.0: Log initialization
            v143Log('info', 'MoShang Dashboard v143.0 initialized', {
                userAgent: navigator.userAgent,
                viewport: { width: window.innerWidth, height: window.innerHeight },
                supportsViewTransitions: !!document.startViewTransition
            });
            console.log('🚀 MoShang Dashboard v143.0 initialized');
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    </script>
</body>
</html>