<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="MoShang - Real-time OpenClaw Status Dashboard v56.0">
    <meta name="theme-color" content="#08080c">
    <title>MoShang Status v56.0</title>
    <meta name="description" content="MoShang - Real-time OpenClaw Status Dashboard v55.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        /* ========== v38.0: Micro-Interaction Engine & Depth Design ========== */
        
        /* CSS @layer for modern organization */
        @layer reset, base, layout, components, utilities, animations, states;
        
        @layer reset {
            *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
            html { scroll-behavior: smooth; }
        }
        
        @layer base {
            :root {
                /* v37.0: Enhanced theme with color-mix() */
                --theme-color: var(--primary);
                --theme-bg: var(--bg-dark);
                --theme-subtle: color-mix(in srgb, var(--theme-color) 15%, transparent);
                --theme-glow: color-mix(in srgb, var(--theme-color) 40%, transparent);
            }
        }

        :root {
            --primary: #ffc864;
            --primary-glow: #ffaa33;
            --primary-dim: rgba(255,200,100,0.3);
            --accent: #00d4ff;
            --accent-glow: #00ffff;
            --accent-dim: rgba(0,212,255,0.3);
            --success: #5cdb95;
            --success-glow: #7fff7f;
            --success-dim: rgba(92,219,149,0.3);
            --warning: #feca57;
            --warning-glow: #ffcc00;
            --warning-dim: rgba(254,202,87,0.3);
            --danger: #ff6b6b;
            --danger-glow: #ff4444;
            --danger-dim: rgba(255,107,107,0.3);
            --purple: #a855f7;
            --purple-glow: #c084fc;
            --purple-dim: rgba(168,85,247,0.3);
            --pink: #ec4899;
            --pink-glow: #f472b6;
            --pink-dim: rgba(236,72,153,0.3);
            --bg-dark: #08080c;
            --bg-deep: #04040a;
            --bg-card: rgba(15,15,25,0.88);
            --bg-card-hover: rgba(20,20,30,0.95);
            --bg-glass: rgba(255,255,255,0.04);
            --bg-glass-hover: rgba(255,255,255,0.08);
            --text: #dcdce4;
            --text-dim: #5a5a6a;
            --text-bright: #ffffff;
            --text-muted: #8a8a9a;
            --radius-sm: 10px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --radius-2xl: 40px;
            --radius-full: 9999px;
            --shadow-soft: 0 4px 24px rgba(0,0,0,0.35);
            --shadow-medium: 0 8px 40px rgba(0,0,0,0.45);
            --shadow-glow: 0 0 80px -20px;
            --shadow-glow-strong: 0 0 120px -20px;
            --shadow-card: 0 2px 8px rgba(0,0,0,0.2), 0 8px 32px rgba(0,0,0,0.3);
            --shadow-card-hover: 0 4px 16px rgba(0,0,0,0.25), 0 12px 48px rgba(0,0,0,0.4);
            --neon-gradient: linear-gradient(135deg, var(--primary), var(--accent));
            --aurora-gradient: linear-gradient(135deg, #ff6b9d, #ffc864, #00d4ff, #5cdb95);
            --space-gradient: radial-gradient(ellipse at center, rgba(30,30,60,0.8) 0%, transparent 70%);
            --mesh-gradient: radial-gradient(ellipse at 20% 50%, rgba(168,85,247,0.12) 0%, transparent 50%),
                             radial-gradient(ellipse at 80% 20%, rgba(0,212,255,0.1) 0%, transparent 50%),
                             radial-gradient(ellipse at 50% 80%, rgba(255,200,100,0.08) 0%, transparent 50%);
            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);
            --spring-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
            --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg-dark);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            color: var(--text);
        }

        /* ========== Backgrounds ========== */
        .bg-mesh {
            position: fixed; inset: 0;
            background: var(--mesh-gradient);
            z-index: -4;
        }

        .bg-space {
            position: fixed; inset: 0;
            background: var(--space-gradient);
            z-index: -3;
        }

        .bg-stars {
            position: fixed; inset: 0;
            z-index: -2; pointer-events: none;
        }

        .bg-neural {
            position: fixed; inset: 0;
            z-index: -1; opacity: 0.5;
        }

        /* ========== Ambient Orbs ========== */
        .ambient-orb {
            position: fixed; border-radius: 50%;
            filter: blur(80px); opacity: 0.15;
            pointer-events: none; z-index: -1;
            animation: orbFloat 25s ease-in-out infinite;
        }

        .ambient-orb-1 {
            width: 600px; height: 600px;
            background: var(--primary);
            top: -200px; left: -200px;
            animation-delay: 0s;
        }

        .ambient-orb-2 {
            width: 500px; height: 500px;
            background: var(--accent);
            bottom: -150px; right: -150px;
            animation-delay: -8s;
        }

        .ambient-orb-3 {
            width: 400px; height: 400px;
            background: var(--purple);
            top: 50%; left: 60%;
            animation-delay: -15s;
        }

        .ambient-orb-4 {
            width: 250px; height: 250px;
            background: var(--pink);
            top: 25%; right: 15%;
            animation-delay: -5s;
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            20% { transform: translate(50px, -50px) scale(1.1); }
            40% { transform: translate(-35px, 25px) scale(0.95); }
            60% { transform: translate(25px, 45px) scale(1.05); }
            80% { transform: translate(-25px, -35px) scale(1.08); }
        }

        .particle-mesh-canvas {
            position: fixed; inset: 0;
            z-index: -1; opacity: 0.4;
            pointer-events: none;
        }

        /* ========== v36.0: Advanced Visual Effects ========== */
        
        /* Glass Reflection Enhancement */
        .glass-card::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 50%;
            background: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, transparent 100%);
            pointer-events: none;
            border-radius: inherit;
        }
        
        /* Magnetic Hover Enhancement */
        .stat-card.magnetic-hover {
            transition: transform 0.18s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                        box-shadow 0.18s ease,
                        border-color 0.2s ease;
        }
        
        .stat-card.magnetic-hover:hover {
            transform: translateY(-8px) scale(1.02) perspective(1000px) rotateX(2deg) rotateY(-2deg);
            box-shadow: 0 20px 60px -15px rgba(255,200,100,0.25),
                        0 0 40px rgba(255,200,100,0.1);
        }
        
        /* Aurora Border Animation v36.0 */
        @keyframes auroraBorder {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        .aurora-border {
            position: relative;
        }
        
        .aurora-border::after {
            content: '';
            position: absolute;
            inset: -2px;
            background: linear-gradient(45deg, #ff6b9d, #ffc864, #00d4ff, #5cdb95, #a855f7, #ff6b9d);
            background-size: 400% 400%;
            border-radius: inherit;
            z-index: -1;
            animation: auroraBorder 8s ease infinite;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .aurora-border:hover::after {
            opacity: 1;
        }
        
        /* Pulse Ring Activity Sync */
        @keyframes activityPulseRing {
            0% { transform: scale(1); opacity: 0.6; }
            50% { transform: scale(1.12); opacity: 1; }
            100% { transform: scale(1); opacity: 0.6; }
        }
        
        .activity-sync-ring {
            position: absolute;
            inset: -20px;
            border-radius: 50%;
            border: 2px solid transparent;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.4s ease, border-color 0.4s ease;
        }
        
        .activity-sync-ring.active {
            opacity: 1;
            animation: activityPulseRing 2s ease-in-out infinite;
        }
        
        /* Neural Sync Indicator */
        @keyframes neuralSync {
            0% { transform: rotate(0deg); opacity: 0.4; }
            50% { transform: rotate(180deg); opacity: 0.8; }
            100% { transform: rotate(360deg); opacity: 0.4; }
        }
        
        .neural-sync-indicator {
            position: absolute;
            inset: -24px;
            border-radius: 50%;
            border: 1.5px dashed rgba(168,85,247,0.5);
            pointer-events: none;
            opacity: 0.3;
            transition: opacity 0.4s ease;
        }
        
        .neural-sync-indicator.active {
            animation: neuralSync 3s linear infinite;
        }
        
        /* View Transitions API Support */
        @supports (view-transition-name: none) {
            .stat-value, .mini-stat-value {
                view-transition-name: stat-value;
            }
        }
        
        /* Data Stream Flow Effect */
        @keyframes dataStreamFlow {
            0% { background-position: 0% 0%; }
            100% { background-position: 200% 0%; }
        }
        
        .data-stream-line {
            position: relative;
            overflow: hidden;
        }
        
        .data-stream-line::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(0,212,255,0.15) 50%, transparent 100%);
            background-size: 200% 100%;
            animation: dataStreamFlow 3s linear infinite;
            pointer-events: none;
        }
        
        /* Glitch Effect for Error State */
        @keyframes glitch {
            0% { transform: translate(0); }
            20% { transform: translate(-3px, 3px); }
            40% { transform: translate(-3px, -3px); }
            60% { transform: translate(3px, 3px); }
            80% { transform: translate(3px, -3px); }
            100% { transform: translate(0); }
        }
        
        @keyframes glitchColor {
            0% { text-shadow: 2px 0 #ff6b6b, -2px 0 #00d4ff; }
            50% { text-shadow: -2px 0 #ff6b6b, 2px 0 #00d4ff; }
            100% { text-shadow: 2px 0 #ff6b6b, -2px 0 #00d4ff; }
        }
        
        .glitch-effect {
            animation: glitch 0.3s ease-in-out infinite, glitchColor 0.5s ease-in-out infinite;
        }
        
        /* Toast Stack Enhancement */
        .toast-v32 {
            transform-origin: right bottom;
        }
        
        .toast-v32.entering {
            animation: toastElasticIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
        
        .toast-v32.exiting {
            animation: toastElasticOut 0.3s ease-in forwards;
        }
        
        @keyframes toastElasticIn {
            0% { opacity: 0; transform: translateX(60px) scale(0.8); }
            60% { opacity: 1; transform: translateX(-5px) scale(1.03); }
            100% { opacity: 1; transform: translateX(0) scale(1); }
        }
        
        @keyframes toastElasticOut {
            0% { opacity: 1; transform: translateX(0) scale(1); }
            100% { opacity: 0; transform: translateX(60px) scale(0.8); }
        }
        
        /* Scroll-Driven Animations */
        @keyframes scrollProgressBar {
            from { transform: scaleX(0); }
            to { transform: scaleX(1); }
        }
        
        .scroll-driven-progress {
            animation: scrollProgressBar linear both;
            animation-timeline: scroll();
        }
        
        /* Focus State Enhancement */
        .stat-card:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 4px;
            box-shadow: 0 0 0 4px rgba(0,212,255,0.3);
        }
        
        /* Keyboard Navigation Focus Ring */
        .keyboard-focus :focus-visible {
            outline: 2px solid var(--primary);
            outline-offset: 2px;
            box-shadow: 0 0 12px rgba(255,200,100,0.4);
        }
        
        /* Mini Stat Sparkline SVG Enhancement */
        .mini-trend {
            filter: drop-shadow(0 0 4px currentColor);
        }
        
        /* ========== v41.0: Modern CSS Features & :has() Selector ========== */
        
        /* CSS :has() Parent Selector - State Management */
        /* Card with active child */
        .stat-card:has(.skeleton-loading) {
            opacity: 0.7;
            pointer-events: none;
        }
        
        /* Card with stale data */
        .stat-card:has(.stale) {
            border-color: var(--warning);
        }
        
        /* Card with error state */
        .stat-card:has(.error) {
            animation: v41ErrorPulse 2s ease-in-out infinite;
        }
        
        /* Card with active sync */
        .stat-card:has(.syncing) {
            border-color: var(--accent);
        }
        
        @keyframes v41ErrorPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,107,0.4); }
            50% { box-shadow: 0 0 20px 5px rgba(255,107,107,0.2); }
        }
        
        /* :has() for focus-within */
        .input-group:has(:focus-within) {
            border-color: var(--accent);
            box-shadow: 0 0 20px rgba(0,212,255,0.2);
        }
        
        /* :has() for checked state */
        .toggle-container:has(input:checked) {
            background: var(--accent-dim);
        }
        
        /* :has() for hover state optimization */
        .action-btn:has(:hover) {
            transform: scale(1.02);
        }
        
        /* CSS transition-behavior for smooth animations */
        .stat-value {
            transition-behavior: allow-discrete;
            transition: all 0.3s ease;
        }
        
        .stat-value.popping {
            transition-behavior: allow-discrete;
            animation: v41NumberPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        @keyframes v41NumberPop {
            0% { transform: scale(1); }
            50% { transform: scale(1.15); filter: brightness(1.3); }
            100% { transform: scale(1); }
        }
        
        /* CSS @starting-style for entrance animations */
        @supports (starting-style) {
            .stat-card {
                animation: v41CardEntrance 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            }
        }
        
        @keyframes v41CardEntrance {
            from { opacity: 0; transform: translateY(20px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        /* CSS Nesting - Modern syntax */
        .fox-container {
            & .fox-glow { opacity: 0.6; }
            &:hover .fox-glow { opacity: 1; }
            &.active .fox-glow { animation: v41GlowPulse 1.5s ease-in-out infinite; }
        }
        
        @keyframes v41GlowPulse {
            0%, 100% { opacity: 0.6; filter: blur(20px); }
            50% { opacity: 1; filter: blur(30px); }
        }
        
        /* Scroll-driven animations with improved timeline */
        @keyframes v41ScrollReveal {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .reveal-on-scroll {
            animation: v41ScrollReveal linear both;
            animation-timeline: view();
            animation-range: entry 0% entry 100%;
        }
        
        /* :focus-visible ring with offset */
        :focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 3px;
            border-radius: 4px;
        }
        
        /* Improved reduced motion */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
            }
            
            .stat-card, .action-btn, .glass-card {
                transition: none;
            }
        }
        
        /* Motion path animation (CSS only) */
        @keyframes v41OrbitPath {
            from { offset-distance: 0%; }
            to { offset-distance: 100%; }
        }
        
        .orbit-dot {
            offset-path: path('M 0 0 Q 50 -50 100 0 T 200 0');
            animation: v41OrbitPath 4s linear infinite;
        }
        
        /* Color-mix() enhanced theme variations */
        :root {
            --primary-soft: color-mix(in srgb, var(--primary) 30%, white);
            --accent-soft: color-mix(in srgb, var(--accent) 30%, white);
            --success-soft: color-mix(in srgb, var(--success) 30%, white);
            --warning-soft: color-mix(in srgb, var(--warning) 30%, white);
            --danger-soft: color-mix(in srgb, var(--danger) 30%, white);
            --purple-soft: color-mix(in srgb, var(--purple) 30%, white);
            --pink-soft: color-mix(in srgb, var(--pink) 30%, white);
        }
        
        /* v41.0: Smooth scroll-snap for horizontal panels */
        .stats-row {
            scroll-snap-type: x mandatory;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
        }
        
        .stats-row > * {
            scroll-snap-align: start;
        }
        
        /* v41.0: Backdrop-filter enhancements */
        .glass-card-v2 {
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
        }
        
        /* v41.0: Interactive cursor follow effect */
        .cursor-follower {
            position: fixed;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--accent-dim) 0%, transparent 70%);
            pointer-events: none;
            transform: translate(-50%, -50%);
            transition: width 0.2s, height 0.2s;
            z-index: 9999;
            mix-blend-mode: screen;
        }
        
        .cursor-follower.hovering {
            width: 40px;
            height: 40px;
            background: radial-gradient(circle, var(--primary-dim) 0%, transparent 70%);
        }
        
        /* v41.0: Parallax depth layers */
        .parallax-layer {
            transition: transform 0.1s ease-out;
        }
        
        /* v41.0: Enhanced grid with CSS subgrid */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 20px;
        }
        
        /* v41.0: View Transitions API enhancements */
        @supports (view-transition-name: none) {
            ::view-transition-old(stat-value),
            ::view-transition-new(stat-value) {
                animation-duration: 0.3s;
                animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
            }
        }
        
        /* v41.0: Performance - contain property */
        .stat-card {
            contain: layout style paint;
        }
        
        .fox-canvas-container {
            contain: layout style;
        }
        
        /* v41.0: GPU layer promotion hints */
        .animate-gpu {
            transform: translateZ(0);
            will-change: transform;
        }
        
        /* ========== v42.0: Enhanced Glassmorphism with Light Refraction ========== */
        
        /* Multi-layer glass reflection - simulates realistic light refraction */
        .glass-card-v42 {
            background: var(--bg-card);
            backdrop-filter: blur(32px) saturate(200%) contrast(1.05);
            -webkit-backdrop-filter: blur(32px) saturate(200%) contrast(1.05);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-soft), var(--shadow-glow),
                        inset 0 1px 0 rgba(255,255,255,0.08),
                        inset 0 -1px 0 rgba(0,0,0,0.1);
            overflow: hidden;
            transition: all var(--transition-normal) var(--ease-out-expo);
            position: relative;
        }
        
        /* Inner reflection layer */
        .glass-card-v42::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border-radius: inherit;
            background: linear-gradient(
                135deg,
                rgba(255,255,255,0.12) 0%,
                transparent 25%,
                transparent 55%,
                rgba(255,255,255,0.05) 100%
            );
            pointer-events: none;
            z-index: 1;
        }
        
        /* Top shimmer gradient */
        .glass-card-v42::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 50%;
            background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, transparent 100%);
            pointer-events: none;
            border-radius: inherit;
            z-index: 1;
        }
        
        .glass-card-v42:hover {
            background: var(--bg-card-hover);
            border-color: rgba(255,255,255,0.12);
            backdrop-filter: blur(40px) saturate(220%) contrast(1.08);
            -webkit-backdrop-filter: blur(40px) saturate(220%) contrast(1.08);
            box-shadow: var(--shadow-medium), var(--shadow-glow-strong),
                        inset 0 1px 0 rgba(255,255,255,0.14),
                        inset 0 -1px 0 rgba(0,0,0,0.15);
        }
        
        /* Corner micro-glint on hover */
        .glass-card-v42 .corner-glint {
            position: absolute;
            top: 0; right: 0;
            width: 60px; height: 60px;
            background: radial-gradient(circle at top right, rgba(255,255,255,0.15) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            border-radius: 0 var(--radius-2xl) 0 0;
        }
        .glass-card-v42:hover .corner-glint { opacity: 1; }
        
        /* ========== v42.0: Data Reliability Enhancements ========== */
        
        /* Data freshness indicator ring */
        @keyframes dataFreshnessPulse {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.05); }
            100% { opacity: 1; transform: scale(1); }
        }
        
        .data-freshness-ring {
            position: absolute;
            inset: -8px;
            border-radius: 50%;
            border: 2px solid transparent;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.5s ease, border-color 0.5s ease;
        }
        
        .data-freshness-ring.fresh {
            opacity: 1;
            border-color: rgba(92,219,149,0.5);
            animation: dataFreshnessPulse 3s ease-in-out infinite;
        }
        
        .data-freshness-ring.stale {
            opacity: 1;
            border-color: rgba(254,202,87,0.5);
            animation: dataFreshnessPulse 1.5s ease-in-out infinite;
        }
        
        .data-freshness-ring.critical {
            opacity: 1;
            border-color: rgba(255,107,107,0.6);
            animation: dataFreshnessPulse 0.8s ease-in-out infinite;
        }
        
        /* Data source health badge */
        .health-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: rgba(255,255,255,0.06);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--text-muted);
            transition: all 0.3s ease;
        }
        
        .health-badge.healthy {
            background: rgba(92,219,149,0.15);
            color: var(--success);
        }
        
        .health-badge.warning {
            background: rgba(254,202,87,0.15);
            color: var(--warning);
        }
        
        .health-badge.error {
            background: rgba(255,107,107,0.15);
            color: var(--danger);
            animation: criticalPulse 1s ease-in-out infinite;
        }
        
        .health-badge .health-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }
        
        /* Skeleton loading state */
        .skeleton {
            position: relative;
            overflow: hidden;
            background: linear-gradient(90deg, 
                rgba(255,255,255,0.05) 25%, 
                rgba(255,255,255,0.12) 50%, 
                rgba(255,255,255,0.05) 75%
            );
            background-size: 200% 100%;
            animation: skeletonShimmer 1.5s ease-in-out infinite;
            border-radius: var(--radius-sm);
        }
        
        @keyframes skeletonShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* Data sync indicator */
        .sync-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: rgba(0,212,255,0.1);
            border: 1px solid rgba(0,212,255,0.25);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--accent);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .sync-indicator.active {
            opacity: 1;
            animation: pulse 1s ease-in-out infinite;
        }
        
        /* ========== v42.0: Performance Optimizations ========== */
        
        /* GPU-accelerated animations with will-change */
        .fox-canvas-wrapper,
        .fox-canvas,
        .fox-glow-aura,
        .mood-aura,
        .energy-core,
        .activity-sync-ring,
        .neural-sync-indicator {
            will-change: transform, opacity;
            transform: translateZ(0);
        }
        
        /* Reduced repaint hints */
        .stat-card,
        .mini-stat,
        .action-btn {
            will-change: transform, box-shadow;
            contain: layout style paint;
        }
        
        /* Smooth CSS transitions */
        .stat-value {
            transition-behavior: allow-discrete;
            transition: all 0.3s ease;
        }
        
        /* ========== Main Container ========== */
        .dashboard-container {
            width: 100%; max-width: 1280px;
            position: relative; z-index: 10;
        }

        /* ========== Glass Card ========== */
        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(32px) saturate(200%);
            -webkit-backdrop-filter: blur(32px) saturate(200%);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-soft), var(--shadow-glow),
                        inset 0 1px 0 rgba(255,255,255,0.08);
            overflow: hidden;
            transition: all var(--transition-normal) var(--ease-out-expo);
            position: relative;
        }

        .glass-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
            pointer-events: none;
        }

        .glass-card:hover {
            background: var(--bg-card-hover);
            border-color: rgba(255,255,255,0.1);
            box-shadow: var(--shadow-medium), var(--shadow-glow-strong),
                        inset 0 1px 0 rgba(255,255,255,0.1);
        }

        /* ========== Header ========== */
        .dashboard-header {
            padding: 28px 36px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
        }
        
        .dashboard-header::before {
            content: '';
            position: absolute;
            bottom: 0; left: 36px; right: 36px;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,200,100,0.2), transparent);
        }

        .header-left, .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 18px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-full);
            font-size: 14px;
            font-weight: 500;
            backdrop-filter: blur(12px);
            transition: all 0.3s ease;
        }
        
        .status-badge:hover {
            background: rgba(255,255,255,0.08);
            transform: scale(1.02);
        }

        .status-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
            background: var(--success);
            animation: pulse 2s ease-in-out infinite;
            box-shadow: 0 0 8px var(--success);
        }

        .status-dot.warning { background: var(--warning); box-shadow: 0 0 8px var(--warning); }
        .status-dot.error { background: var(--danger); box-shadow: 0 0 8px var(--danger); animation: criticalPulse 0.5s ease-in-out infinite; }
        
        .status-badge.error-state {
            background: rgba(255,107,107,0.15);
            border-color: rgba(255,107,107,0.3);
        }

        .refresh-badge {
            display: flex; align-items: center; gap: 6px;
            font-size: 13px; color: var(--text-muted);
            background: rgba(255,255,255,0.04);
            padding: 6px 14px; border-radius: var(--radius-full);
            border: 1px solid rgba(255,255,255,0.05);
            transition: all 0.3s ease;
        }
        
        .refresh-badge:hover {
            background: rgba(255,255,255,0.07);
        }

        .refresh-badge .dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--success);
            animation: pulse 1.5s ease-in-out infinite;
            box-shadow: 0 0 6px var(--success);
        }

        /* ========== Grid ========== */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 360px 1fr;
            gap: 28px;
            padding: 28px 36px;
        }

        .left-column { display: flex; flex-direction: column; gap: 20px; }
        .right-column { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }

        /* ========== Avatar Section ========== */
        .avatar-section {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 32px 28px;
        }

        .fox-container {
            position: relative;
            width: 210px; height: 210px;
            margin-bottom: 24px;
        }

        .fox-container::before {
            content: '';
            position: absolute;
            inset: -30px;
            border-radius: 50%;
            background: var(--accent);
            opacity: 0.2;
            filter: blur(35px);
            animation: statusWhisper 4s ease-in-out infinite;
            z-index: -1;
            transition: background 0.5s ease;
        }

        .fox-container.idle::before { background: var(--warning); }
        .fox-container.working::before { background: var(--accent); }
        .fox-container.sleeping::before { background: var(--purple); }
        .fox-container.excited::before { background: var(--pink); }
        .fox-container.error::before { background: var(--danger); }
        .fox-container.thinking::before { background: var(--purple); }
        .fox-container.laughing::before { background: var(--warning); }
        .fox-container.focused::before { background: var(--success); }

        @keyframes statusWhisper {
            0%, 100% { opacity: 0.25; transform: scale(1); filter: blur(28px); }
            50% { opacity: 0.65; transform: scale(1.15); filter: blur(35px); }
        }

        @keyframes heartbeatPulse {
            0%, 100% { transform: scale(1); box-shadow: var(--shadow-soft), var(--shadow-glow); }
            50% { transform: scale(1.006); box-shadow: var(--shadow-soft), 0 0 110px -30px var(--accent); }
        }

        @keyframes dataWave {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.03); opacity: 0.85; }
            100% { transform: scale(1); opacity: 1; }
        }

        @keyframes numberPop {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.14); }
        }

        @keyframes springPop {
            0% { transform: scale(1); }
            30% { transform: scale(1.18) rotate(-1deg); }
            60% { transform: scale(0.94) rotate(0.5deg); }
            80% { transform: scale(1.04); }
            100% { transform: scale(1); }
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        @keyframes criticalPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .card-breathe { animation: heartbeatPulse 3s ease-in-out infinite; }
        .data-wave { animation: dataWave 0.6s ease-out; }
        .num-pop { animation: numberPop 0.35s ease-out; }
        .spring-pop { animation: springPop 0.45s var(--ease-spring); }

        /* Mood Sync Ring */
        .mood-sync-ring {
            position: absolute;
            inset: -14px;
            border-radius: 50%;
            border: 2px solid transparent;
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
        }

        .mood-sync-ring.active {
            opacity: 1;
            animation: ringPulse 2.5s ease-in-out infinite;
        }

        .mood-sync-ring.idle { border-color: var(--warning); box-shadow: 0 0 35px var(--warning); }
        .mood-sync-ring.working { border-color: var(--accent); box-shadow: 0 0 35px var(--accent); }
        .mood-sync-ring.sleeping { border-color: var(--purple); box-shadow: 0 0 35px var(--purple); }
        .mood-sync-ring.excited { border-color: var(--pink); box-shadow: 0 0 35px var(--pink); }
        .mood-sync-ring.thinking { border-color: var(--purple); box-shadow: 0 0 35px var(--purple); }
        .mood-sync-ring.laughing { border-color: var(--warning); box-shadow: 0 0 35px var(--warning); }
        .mood-sync-ring.error { border-color: var(--danger); box-shadow: 0 0 35px var(--danger); }
        .mood-sync-ring.focused { border-color: var(--success); box-shadow: 0 0 35px var(--success); }
        .mood-sync-ring.learning { border-color: var(--primary); box-shadow: 0 0 35px var(--primary); }

        @keyframes ringPulse {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.08); opacity: 1; }
        }

        /* Energy Core */
        .energy-core {
            position: absolute;
            width: 70px; height: 70px;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none; z-index: 0;
        }

        .energy-ring {
            position: absolute; inset: 0;
            border-radius: 50%;
            border: 2px solid transparent;
            border-top-color: var(--accent);
            border-right-color: var(--primary);
            animation: energySpin 3s linear infinite;
        }

        .energy-ring:nth-child(2) {
            inset: 8px; animation-duration: 2s;
            animation-direction: reverse;
            border-top-color: var(--purple);
            border-right-color: var(--pink);
        }

        .energy-ring:nth-child(3) {
            inset: 16px; animation-duration: 1.5s;
            border-top-color: var(--success);
            border-right-color: var(--accent);
        }

        @keyframes energySpin { to { transform: rotate(360deg); } }

        /* Fox Canvas Wrapper */
        .fox-canvas-wrapper { position: relative; }

        .fox-canvas {
            width: 100%; height: 100%;
            border-radius: var(--radius-lg);
            cursor: pointer;
            display: block;
        }

        .fox-shadow {
            position: absolute;
            bottom: -14px; left: 50%;
            transform: translateX(-50%);
            width: 90px; height: 24px;
            background: radial-gradient(ellipse, rgba(0,0,0,0.5) 0%, transparent 70%);
            border-radius: 50%;
            animation: shadowBreath 3.5s ease-in-out infinite;
        }

        @keyframes shadowBreath {
            0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.4; }
            50% { transform: translateX(-50%) scale(1.15); opacity: 0.25; }
        }

        .fox-glow-aura {
            position: absolute;
            inset: -24px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.2) 0%, transparent 70%);
            animation: foxGlowPulse 2.5s ease-in-out infinite;
            pointer-events: none;
        }

        @keyframes foxGlowPulse {
            0%, 100% { opacity: 0.5; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.12); }
        }

        .fox-expression {
            position: absolute;
            top: -14px; right: -14px;
            font-size: 28px;
            animation: expressionBounce 2.5s ease-in-out infinite;
            pointer-events: none; z-index: 10;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.4));
        }

        @keyframes expressionBounce {
            0%, 100% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.14) rotate(-6deg); }
            75% { transform: scale(1.14) rotate(6deg); }
        }

        /* Mood Aura */
        .mood-aura {
            position: absolute;
            inset: -40px;
            border-radius: 50%;
            opacity: 0.5; filter: blur(24px);
            transition: all 0.8s ease;
            pointer-events: none; z-index: -1;
        }

        .mood-aura.idle { background: radial-gradient(circle, var(--warning) 0%, transparent 70%); }
        .mood-aura.working { background: radial-gradient(circle, var(--accent) 0%, transparent 70%); animation: auraWorking 2s ease-in-out infinite; }
        .mood-aura.sleeping { background: radial-gradient(circle, var(--purple) 0%, transparent 70%); animation: auraSleeping 4s ease-in-out infinite; }
        .mood-aura.excited { background: radial-gradient(circle, var(--pink) 0%, transparent 70%); animation: auraExcited 1s ease-in-out infinite; }
        .mood-aura.thinking { background: radial-gradient(circle, var(--purple) 0%, transparent 70%); animation: auraThinking 3s ease-in-out infinite; }
        .mood-aura.laughing { background: radial-gradient(circle, var(--warning) 0%, transparent 70%); animation: auraLaughing 0.8s ease-in-out infinite; }
        .mood-aura.error { background: radial-gradient(circle, var(--danger) 0%, transparent 70%); animation: auraError 0.5s ease-in-out infinite; }
        .mood-aura.focused { background: radial-gradient(circle, var(--success) 0%, transparent 70%); animation: auraFocused 2s ease-in-out infinite; }

        @keyframes auraWorking { 0%, 100% { opacity: 0.35; transform: scale(1); } 50% { opacity: 0.65; transform: scale(1.1); } }
        @keyframes auraSleeping { 0%, 100% { opacity: 0.25; transform: scale(0.95); } 50% { opacity: 0.55; transform: scale(1.05); } }
        @keyframes auraExcited { 0%, 100% { opacity: 0.4; transform: scale(1.05); } 50% { opacity: 0.75; transform: scale(1.18); } }
        @keyframes auraThinking { 0%, 100% { opacity: 0.3; } 25% { opacity: 0.55; transform: translateX(-3px); } 75% { opacity: 0.55; transform: translateX(3px); } }
        @keyframes auraLaughing { 0%, 100% { opacity: 0.4; transform: scale(1) rotate(0deg); } 50% { opacity: 0.65; transform: scale(1.1) rotate(4deg); } }
        @keyframes auraError { 0%, 100% { opacity: 0.55; transform: scale(1); } 25% { transform: translate(-3px, 3px); } 50% { opacity: 0.75; transform: scale(1.12); } 75% { transform: translate(3px, -3px); } }
        @keyframes auraFocused { 0%, 100% { opacity: 0.3; transform: scale(1); } 50% { opacity: 0.65; transform: scale(1.1); } }

        /* Fox Name */
        .fox-name {
            font-size: 28px; font-weight: 800;
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--purple), var(--pink), var(--primary));
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientFlow 3.5s ease infinite;
            margin-bottom: 8px; letter-spacing: -0.5px;
        }

        @keyframes gradientFlow {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .fox-role {
            font-size: 14px; color: var(--text-muted);
            margin-bottom: 20px; letter-spacing: 0.5px;
        }

        /* Stats Row */
        .stats-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px; width: 100%;
        }

        .mini-stat {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-md);
            padding: 16px 14px;
            text-align: center;
            transition: all 0.2s var(--ease-spring), box-shadow 0.2s ease;
        }

        .mini-stat:hover {
            background: rgba(255,255,255,0.08);
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 12px 32px -8px rgba(255,200,100,0.3);
        }

        .mini-stat:active {
            transform: translateY(-2px) scale(0.97);
            transition-duration: 0.1s;
        }

        .mini-stat-value {
            font-size: 24px; font-weight: 700;
            color: var(--text-bright);
            margin-bottom: 4px;
            font-variant-numeric: tabular-nums;
            transition: transform 0.2s ease, color 0.2s ease;
        }
        
        .mini-stat:hover .mini-stat-value {
            transform: scale(1.05);
            color: var(--primary);
        }

        .mini-stat-label {
            font-size: 11px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.6px;
            transition: color 0.2s ease;
        }
        
        .mini-stat:hover .mini-stat-label {
            color: var(--text);
        }

        /* Status Section */
        .status-section {
            margin-top: 20px; padding: 16px 18px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-md);
            width: 100%; text-align: center;
        }

        .status-title {
            font-size: 11px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .status-value {
            font-size: 18px; font-weight: 600;
            color: var(--text-bright);
            transition: color 0.3s ease;
        }

        /* Quick Actions */
        .quick-actions {
            display: flex; gap: 10px;
            margin-top: 18px; width: 100%;
        }

        .action-btn {
            flex: 1; padding: 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-md);
            color: var(--text); font-size: 13px;
            font-family: 'Outfit', sans-serif;
            cursor: pointer;
            transition: all 0.2s var(--ease-spring);
            position: relative; overflow: hidden;
        }

        .action-btn::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), rgba(255,255,255,0.2) 0%, transparent 60%);
            opacity: 0; transition: opacity 0.2s ease;
        }

        .action-btn:hover::before { opacity: 1; }
        .action-btn:hover {
            background: rgba(255,255,255,0.1);
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 24px -6px rgba(255,200,100,0.35);
        }

        .action-btn:active { 
            transform: translateY(-1px) scale(0.96);
            transition-duration: 0.08s;
        }
        
        .action-btn.spring-press:active {
            animation: springPress 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        @keyframes springPress {
            0% { transform: scale(1); }
            30% { transform: scale(0.92); }
            60% { transform: scale(1.04); }
            100% { transform: scale(1); }
        }

        .action-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: var(--bg-dark); font-weight: 600;
            box-shadow: 0 0 20px rgba(255,200,100,0.4);
        }

        /* Mood Selector */
        .mood-selector {
            display: flex; gap: 10px;
            margin-top: 18px; justify-content: center;
        }

        .mood-btn {
            width: 42px; height: 42px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.04);
            font-size: 20px; cursor: pointer;
            transition: all 0.2s var(--ease-spring);
            display: flex; align-items: center; justify-content: center;
        }

        .mood-btn:hover {
            transform: scale(1.2);
            border-color: var(--primary);
            background: rgba(255,200,100,0.12);
        }

        .mood-btn:active { transform: scale(0.95); }

        .mood-btn.active {
            border-color: var(--primary);
            background: rgba(255,200,100,0.22);
            box-shadow: 0 0 24px rgba(255,200,100,0.35);
        }

        /* Quick Stats */
        .quick-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px; margin-top: 20px; width: 100%;
        }

        .quick-stat {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-md);
            padding: 14px 10px; text-align: center;
            transition: all 0.2s ease;
        }

        .quick-stat:hover { background: rgba(255,255,255,0.07); }

        .quick-stat-value {
            font-size: 20px; font-weight: 700;
            color: var(--text-bright);
        }

        .quick-stat-label {
            font-size: 10px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.4px;
            margin-top: 4px;
        }

        .glass-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
            margin: 20px 0;
        }

        /* Session Journey */
        .session-journey {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-lg);
            padding: 18px; margin-top: 18px; width: 100%;
        }

        .journey-title {
            font-size: 12px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 14px;
            display: flex; align-items: center; gap: 6px;
        }

        .journey-track {
            position: relative; height: 8px;
            background: rgba(255,255,255,0.08);
            border-radius: var(--radius-full);
            overflow: visible;
        }

        .journey-fill {
            position: absolute; left: 0; top: 0;
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--primary));
            border-radius: var(--radius-full);
            transition: width 0.5s var(--ease-out-expo);
        }

        .journey-marker {
            position: absolute; top: 50%;
            transform: translate(-50%, -50%);
            width: 16px; height: 16px;
            border-radius: 50%;
            background: var(--primary);
            border: 3px solid var(--bg-dark);
            box-shadow: 0 0 12px rgba(255,200,100,0.5);
            transition: left 0.5s var(--ease-out-expo);
        }

        .journey-label {
            font-size: 11px; color: var(--text-dim);
            margin-top: 10px;
            display: flex; justify-content: space-between;
        }

        /* Time Greeting */
        .time-greeting {
            font-size: 12px; color: var(--text-muted);
            padding: 5px 14px;
            background: rgba(255,200,100,0.1);
            border-radius: var(--radius-full);
            margin-top: 16px;
            display: inline-block;
        }

        /* Story Card */
        .story-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-lg);
            padding: 18px;
            margin-top: 14px;
            width: 100%;
            position: relative; overflow: hidden;
        }

        .story-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: var(--neon-gradient);
            opacity: 0.9;
        }

        .story-title {
            font-size: 12px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 10px;
            display: flex; align-items: center; gap: 8px;
        }

        .story-text {
            font-size: 14px; color: var(--text-bright);
            line-height: 1.6;
        }

        .story-highlight { color: var(--primary); font-weight: 600; }

        /* Task Progress */
        .task-progress { margin-top: 14px; display: none; }

        .task-progress-header {
            display: flex; align-items: center;
            justify-content: space-between; margin-bottom: 8px;
        }

        .task-progress-label {
            font-size: 11px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
        }

        .task-progress-value {
            font-size: 11px; color: var(--accent); font-weight: 500;
        }

        .task-progress-bar {
            height: 5px;
            background: rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .task-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--success));
            border-radius: var(--radius-full);
            transition: width 0.5s var(--ease-out-expo);
        }

        /* Thinking Chain */
        .thinking-chain {
            display: flex; align-items: center; gap: 6px;
            padding: 12px;
            background: rgba(168,85,247,0.1);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: var(--radius-md);
            margin-top: 12px;
        }

        .thinking-node {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--purple);
            animation: thinkingPulse 1.5s ease-in-out infinite;
        }

        .thinking-node:nth-child(2) { animation-delay: 0.2s; }
        .thinking-node:nth-child(3) { animation-delay: 0.4s; }
        .thinking-node:nth-child(4) { animation-delay: 0.6s; }
        .thinking-node:nth-child(5) { animation-delay: 0.8s; }

        @keyframes thinkingPulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.5); opacity: 1; }
        }

        .thinking-label { font-size: 12px; color: var(--purple); margin-left: 8px; }

        /* Reputation Badge */
        .reputation-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 5px 12px;
            background: rgba(168,85,247,0.12);
            border: 1px solid rgba(168,85,247,0.35);
            border-radius: var(--radius-full);
            font-size: 12px; color: var(--purple);
            cursor: help;
            transition: all 0.2s ease;
            margin-top: 14px;
        }

        .reputation-badge:hover {
            background: rgba(168,85,247,0.22);
            transform: scale(1.05);
        }

        /* ========== Right Column Stat Cards ========== */
        .stat-card {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-lg);
            padding: 22px;
            position: relative;
            overflow: hidden;
            transition: all var(--transition-normal) var(--ease-out-expo);
            cursor: pointer;
            box-shadow: var(--shadow-card);
            transform-style: preserve-3d;
        }

        .stat-card:hover {
            border-color: rgba(255,255,255,0.14);
            transform: translateY(-8px) perspective(1000px) rotateX(2deg) rotateY(-2deg);
            box-shadow: var(--shadow-card-hover), 0 0 40px rgba(255,200,100,0.12);
        }

        .stat-card:active {
            transform: translateY(-3px) scale(0.97);
            transition-duration: 0.1s;
        }
        
        .stat-card.spring-hover:hover {
            animation: cardSpringHover 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        @keyframes cardSpringHover {
            0% { transform: translateY(-6px) perspective(1000px) rotateX(1deg) rotateY(-1deg); }
            40% { transform: translateY(-12px) perspective(1000px) rotateX(3deg) rotateY(-3deg) scale(1.02); }
            70% { transform: translateY(-7px) perspective(1000px) rotateX(1.5deg) rotateY(-1.5deg) scale(0.99); }
            100% { transform: translateY(-8px) perspective(1000px) rotateX(2deg) rotateY(-2deg) scale(1.01); }
        }
        
        /* Corner Fold Hover Effect */
        .stat-card {
            position: relative;
        }
        
        .stat-card .corner-fold {
            position: absolute;
            top: 0; right: 0;
            width: 28px; height: 28px;
            background: linear-gradient(225deg, rgba(255,255,255,0.15) 0%, transparent 50%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }
        
        .stat-card:hover .corner-fold {
            opacity: 1;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity var(--transition-fast);
        }

        .stat-card:hover::before {
            opacity: 1;
            animation: skeletonShimmer 1.5s ease-in-out infinite;
        }

        @keyframes skeletonShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* v37.0: Skeleton loading state for stat values */
        .skeleton-loading {
            position: relative;
            overflow: hidden;
            color: transparent !important;
            background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.12) 50%, rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: skeletonShimmer 1.2s ease-in-out infinite;
            border-radius: var(--radius-sm);
        }

        .stat-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .stat-icon {
            width: 42px; height: 42px;
            border-radius: var(--radius-md);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px;
        }

        .stat-value {
            font-size: 32px; font-weight: 700;
            color: var(--text-bright);
            margin-bottom: 4px;
            font-variant-numeric: tabular-nums;
            transition: transform 0.15s ease, color 0.2s ease;
        }

        .stat-value.num-pop { animation: numberPop 0.35s ease-out; }

        .stat-label {
            font-size: 13px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
        }

        .stat-subtext {
            font-size: 12px; color: var(--text-muted);
            margin-top: 10px;
        }

        .progress-container { margin-top: 14px; }

        .progress-bar {
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: var(--radius-full);
            transition: width 0.6s var(--ease-out-expo);
            position: relative; overflow: hidden;
        }

        .progress-fill::after {
            content: '';
            position: absolute; inset: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);
            animation: progressShimmer 2s ease-in-out infinite;
        }

        @keyframes progressShimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(200%); }
        }

        .progress-fill.success { background: var(--success); }
        .progress-fill.warning { background: var(--warning); }
        .progress-fill.danger { background: var(--danger); }

        /* Mini Trend Sparkline */
        .mini-trend {
            position: absolute;
            bottom: 12px; right: 12px;
            width: 48px; height: 20px;
            opacity: 0.7;
        }

        /* Charts Section */
        .charts-section {
            grid-column: 1 / -1;
            margin-top: 10px;
        }

        .charts-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
        }

        .chart-card {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-lg);
            padding: 18px;
            transition: all var(--transition-normal);
        }

        .chart-card:hover {
            border-color: rgba(255,255,255,0.1);
            transform: translateY(-3px);
        }

        .chart-title {
            font-size: 12px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 14px;
        }

        .chart-canvas-container {
            height: 120px;
            position: relative;
        }

        .chart-canvas { width: 100%; height: 100%; }

        /* Bottom Section */
        .bottom-section {
            grid-column: 1 / -1;
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 18px;
            margin-top: 18px;
        }

        /* Memory Timeline */
        .memory-timeline {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-lg);
            padding: 22px;
        }

        .timeline-header {
            display: flex; align-items: center;
            justify-content: space-between; margin-bottom: 16px;
        }

        .timeline-title {
            font-size: 14px; font-weight: 500;
            color: var(--text-bright);
        }

        .timeline-items {
            display: flex; flex-direction: column;
            gap: 12px; max-height: 220px;
            overflow-y: auto;
        }

        .timeline-items::-webkit-scrollbar { width: 4px; }
        .timeline-items::-webkit-scrollbar-track { background: transparent; }
        .timeline-items::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

        .timeline-item {
            display: flex; align-items: flex-start; gap: 12px;
            padding: 12px;
            background: rgba(255,255,255,0.04);
            border-radius: var(--radius-md);
            transition: all var(--transition-fast);
            opacity: 0;
            animation: timelineSlideIn 0.4s var(--ease-out-expo) forwards;
        }

        .timeline-item:nth-child(1) { animation-delay: 0.05s; }
        .timeline-item:nth-child(2) { animation-delay: 0.1s; }
        .timeline-item:nth-child(3) { animation-delay: 0.15s; }
        .timeline-item:nth-child(4) { animation-delay: 0.2s; }
        .timeline-item:nth-child(5) { animation-delay: 0.25s; }

        @keyframes timelineSlideIn {
            to { opacity: 1; transform: translateX(0); }
        }

        .timeline-item:hover { background: rgba(255,255,255,0.07); }

        .timeline-icon {
            width: 34px; height: 34px;
            border-radius: var(--radius-md);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }

        .timeline-content { flex: 1; }

        .timeline-text {
            font-size: 13px; color: var(--text-bright);
            margin-bottom: 4px;
        }

        .timeline-time { font-size: 11px; color: var(--text-muted); }

        /* Skills Distribution */
        .skills-distribution {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-lg);
            padding: 22px;
        }

        .skills-title {
            font-size: 14px; font-weight: 500;
            color: var(--text-bright); margin-bottom: 18px;
        }

        .skill-item { margin-bottom: 14px; }

        .skill-header {
            display: flex; align-items: center;
            justify-content: space-between; margin-bottom: 7px;
        }

        .skill-name { font-size: 13px; color: var(--text-bright); }
        .skill-value { font-size: 13px; color: var(--text-muted); }

        .skill-bar {
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .skill-fill {
            height: 100%; border-radius: var(--radius-full);
            transition: width 0.5s var(--ease-out-expo);
        }

        /* ========== Footer ========== */
        .dashboard-footer {
            padding: 22px 36px;
            border-top: 1px solid rgba(255,255,255,0.05);
            display: flex; align-items: center;
            justify-content: space-between;
            position: relative;
        }
        
        .dashboard-footer::before {
            content: '';
            position: absolute;
            top: 0; left: 36px; right: 36px;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(0,212,255,0.15), transparent);
        }

        .footer-info {
            font-size: 12px; color: var(--text-muted);
            transition: color 0.3s ease;
        }

        .footer-info:hover { color: var(--text); }
        
        .footer-info span { color: var(--text-bright); font-weight: 500; }
        
        .footer-badges {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .footer-version {
            padding: 4px 10px;
            background: rgba(168,85,247,0.12);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: var(--radius-full);
            font-size: 11px;
            font-family: 'JetBrains Mono', monospace;
            color: var(--purple);
            transition: all 0.3s ease;
        }
        
        .footer-version:hover {
            background: rgba(168,85,247,0.22);
            transform: scale(1.05);
        }
        
        .footer-badges {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .footer-version {
            padding: 4px 10px;
            background: rgba(168,85,247,0.12);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: var(--radius-full);
            font-size: 11px;
            font-family: 'JetBrains Mono', monospace;
            color: var(--purple);
            transition: all 0.3s ease;
        }
        
        .footer-version:hover {
            background: rgba(168,85,247,0.22);
            transform: scale(1.05);
        }

        /* ========== Data Route Map ========== */
        .data-route-map {
            display: flex; align-items: center; gap: 0;
            padding: 12px 16px;
            border-top: 1px solid rgba(255,255,255,0.04);
        }

        .route-node {
            display: flex; flex-direction: column;
            align-items: center; gap: 4px;
            font-size: 10px; color: var(--text-dim);
            flex-shrink: 0;
        }

        .route-node .route-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--success);
            box-shadow: 0 0 6px var(--success);
        }

        .route-node.stale .route-dot { background: var(--warning); box-shadow: 0 0 6px var(--warning); }
        .route-node.error .route-dot { background: var(--danger); box-shadow: 0 0 6px var(--danger); }

        .route-line {
            flex: 1; height: 1px;
            background: rgba(255,255,255,0.08);
            position: relative; overflow: hidden;
            min-width: 20px;
        }

        .route-line::after {
            content: '';
            position: absolute; top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            animation: routeFlow 2.5s ease-in-out infinite;
        }

        @keyframes routeFlow {
            0% { left: -100%; } 50% { left: 0%; } 100% { left: 100%; }
        }

        /* ========== Data Source Health ========== */
        .data-source-badge {
            display: inline-flex; align-items: center; gap: 5px;
            margin-left: 14px; padding: 3px 10px;
            background: rgba(255,255,255,0.06);
            border-radius: var(--radius-full);
            font-size: 11px; color: var(--text-muted);
            cursor: help;
        }

        .source-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--success);
            transition: background 0.3s ease;
        }

        .source-dot.warning { background: var(--warning); }
        .source-dot.error { background: var(--danger); }
        .source-dot.stale { background: var(--purple); }
        .source-dot.polling { 
            background: var(--accent);
            animation: pollingPulse 2s ease-in-out infinite;
        }
        
        @keyframes pollingPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        /* v37.0: Reliability Score Badge */
        .reliability-badge {
            display: inline-flex; align-items: center; gap: 4px;
            margin-left: 10px; padding: 3px 10px;
            background: rgba(255,255,255,0.06);
            border-radius: var(--radius-full);
            font-size: 11px; color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
            transition: all 0.4s ease;
        }
        .reliability-badge.high { 
            background: color-mix(in srgb, var(--success) 18%, transparent); 
            color: var(--success);
        }
        .reliability-badge.medium { 
            background: color-mix(in srgb, var(--warning) 18%, transparent); 
            color: var(--warning);
        }
        .reliability-badge.low { 
            background: color-mix(in srgb, var(--danger) 18%, transparent); 
            color: var(--danger);
            animation: criticalPulse 0.8s ease-in-out infinite;
        }

        /* ========== External Route Status ========== */
        .external-route-badge {
            display: inline-flex; align-items: center; gap: 5px;
            margin-left: 10px; padding: 3px 10px;
            background: rgba(255,255,255,0.06);
            border-radius: var(--radius-full);
            font-size: 11px; color: var(--text-muted);
            cursor: help;
            transition: all 0.3s ease;
        }

        .external-route-badge.checking { animation: pulse 1s ease-in-out infinite; }

        .external-route-badge.online {
            background: rgba(92,219,149,0.18);
            color: var(--success);
        }

        .external-route-badge.offline {
            background: rgba(255,107,107,0.18);
            color: var(--danger);
        }

        .route-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--text-dim);
            transition: background 0.3s ease;
        }

        .route-dot.online { background: var(--success); box-shadow: 0 0 8px var(--success); }
        .route-dot.offline { background: var(--danger); box-shadow: 0 0 8px var(--danger); }

        /* v44.0: Route check time display */
        .route-check-time {
            font-size: 10px;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
            margin-left: 4px;
            opacity: 0.7;
        }

        /* ========== Glow Cursor ========== */
        .glow-cursor {
            position: fixed; width: 26px; height: 26px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.45) 0%, transparent 70%);
            pointer-events: none; z-index: 9998;
            transform: translate(-50%, -50%);
            transition: width 0.2s, height 0.2s, background 0.3s;
            mix-blend-mode: screen;
        }

        .glow-cursor.active {
            width: 44px; height: 44px;
            background: radial-gradient(circle, rgba(0,212,255,0.55) 0%, transparent 70%);
        }

        /* ========== Cursor Trail ========== */
        .cursor-trail-particle {
            position: fixed; width: 9px; height: 9px;
            border-radius: 50%; pointer-events: none;
            z-index: 9999;
            animation: trailFade 0.9s ease-out forwards;
        }

        @keyframes trailFade {
            0% { transform: scale(1); opacity: 0.85; }
            100% { transform: scale(0); opacity: 0; }
        }

        /* ========== Heart Rain ========== */
        @keyframes heartRain {
            0% { transform: translateY(-25px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(120px) rotate(380deg); opacity: 0; }
        }

        .heart-rain {
            position: absolute; font-size: 22px;
            animation: heartRain 2.2s ease-out forwards;
            pointer-events: none;
        }

        /* ========== Fox Happy ========== */
        .fox-happy { animation: foxHappy 0.6s ease-out; }

        @keyframes foxHappy {
            0% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.12) rotate(-6deg); }
            50% { transform: scale(1.18) rotate(6deg); }
            75% { transform: scale(1.12) rotate(-4deg); }
            100% { transform: scale(1) rotate(0deg); }
        }

        /* ========== Noise Overlay ========== */
        .noise-overlay {
            position: fixed; inset: 0;
            pointer-events: none; z-index: 9999;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        }

        /* ========== Recovery Mode ========== */
        .recovery-mode {
            position: fixed; top: 12px; right: 12px;
            background: rgba(255,200,100,0.22);
            border: 1px solid var(--warning);
            color: var(--warning);
            padding: 7px 14px;
            border-radius: var(--radius-full);
            font-size: 11px;
            font-family: 'JetBrains Mono', monospace;
            z-index: 1000;
            animation: recoveryPulse 1.5s ease-in-out infinite;
        }

        @keyframes recoveryPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.72; transform: scale(0.98); }
        }

        /* ========== Status Theme Colors ========== */
        body.status-working { --theme-color: var(--accent); }
        body.status-sleeping { --theme-color: var(--purple); }
        body.status-excited { --theme-color: var(--pink); }
        body.status-thinking { --theme-color: var(--purple); }
        body.status-error { --theme-color: var(--danger); }
        body.status-laughing { --theme-color: var(--primary); }
        body.status-focused { --theme-color: var(--success); }
        body.status-learning { --theme-color: var(--primary); }

        /* ========== Scroll Progress Bar ========== */
        .scroll-progress {
            position: fixed; top: 0; left: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--purple), var(--pink));
            background-size: 300% 100%;
            animation: scrollGradientShift 4s ease infinite;
            z-index: 9998; width: 0%;
            transition: width 0.1s linear;
            box-shadow: 0 0 12px rgba(255,200,100,0.5), 0 0 24px rgba(0,212,255,0.3);
        }
        
        @keyframes scrollGradientShift {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }
        
        .scroll-progress::after {
            content: '';
            position: absolute;
            right: 0; top: 50%;
            transform: translateY(-50%);
            width: 8px; height: 8px;
            background: var(--primary);
            border-radius: 50%;
            box-shadow: 0 0 12px var(--primary-glow);
        }

        /* ========== Toast Queue ========== */
        .toast-queue {
            position: fixed; bottom: 24px; right: 24px;
            display: flex; flex-direction: column-reverse; gap: 8px;
            z-index: 9990; pointer-events: none;
        }

        .toast-v32 {
            display: flex; align-items: center; gap: 12px;
            background: rgba(12,12,20,0.92);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: var(--radius-md);
            padding: 12px 18px;
            min-width: 240px; max-width: 340px;
            font-size: 13px; color: var(--text);
            font-family: 'Outfit', sans-serif;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: toastSlideIn 0.3s var(--ease-spring);
            pointer-events: auto;
            position: relative; overflow: hidden;
        }

        .toast-v32.exiting { animation: toastSlideOut 0.25s ease forwards; }

        @keyframes toastSlideIn {
            from { opacity: 0; transform: translateX(40px) scale(0.9); }
            to { opacity: 1; transform: translateX(0) scale(1); }
        }

        @keyframes toastSlideOut {
            to { opacity: 0; transform: translateX(40px) scale(0.9); }
        }

        .toast-v32 .toast-bar {
            position: absolute; bottom: 0; left: 0;
            height: 2px; background: var(--primary);
            width: 100%; transform-origin: left;
            animation: toastBarShrink var(--dur, 3s) linear forwards;
        }

        @keyframes toastBarShrink { from { scale: 1; } to { scale: 0; } }

        .toast-v32.success { border-color: rgba(92,219,149,0.3); }
        .toast-v32.success .toast-bar { background: var(--success); }
        .toast-v32.error { border-color: rgba(255,107,107,0.3); }
        .toast-v32.error .toast-bar { background: var(--danger); }
        .toast-v32.warning { border-color: rgba(254,202,87,0.3); }
        .toast-v32.warning .toast-bar { background: var(--warning); }

        .toast-v32 .toast-icon { font-size: 16px; flex-shrink: 0; }
        .toast-v32 .toast-msg { flex: 1; line-height: 1.4; }

        /* ========== Command Palette ========== */
        .cmd-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: flex; align-items: flex-start; justify-content: center;
            padding-top: 15vh;
            opacity: 0; pointer-events: none;
            transition: opacity 0.2s ease;
        }

        .cmd-overlay.open { opacity: 1; pointer-events: all; }

        .cmd-palette {
            width: 540px; max-width: 92vw;
            background: rgba(10,10,18,0.96);
            border: 1px solid rgba(255,200,100,0.2);
            border-radius: var(--radius-lg);
            box-shadow: 0 24px 80px rgba(0,0,0,0.7), 0 0 60px rgba(255,200,100,0.08);
            overflow: hidden;
            transform: translateY(-12px) scale(0.97);
            transition: transform 0.22s var(--ease-out-expo);
            backdrop-filter: blur(24px);
        }

        .cmd-overlay.open .cmd-palette { transform: translateY(0) scale(1); }

        .cmd-search-wrap {
            display: flex; align-items: center; gap: 12px;
            padding: 16px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .cmd-search-wrap svg { flex-shrink: 0; color: var(--text-dim); }

        .cmd-input {
            flex: 1; background: none; border: none; outline: none;
            color: var(--text); font-size: 16px; font-family: 'Outfit', sans-serif;
        }

        .cmd-input::placeholder { color: var(--text-dim); }

        .cmd-kbd {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 5px; padding: 2px 7px;
            font-size: 11px; color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
        }

        .cmd-results { max-height: 360px; overflow-y: auto; padding: 8px; }
        .cmd-results::-webkit-scrollbar { width: 4px; }
        .cmd-results::-webkit-scrollbar-track { background: transparent; }
        .cmd-results::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

        .cmd-group-label {
            font-size: 10px; text-transform: uppercase; letter-spacing: 1px;
            color: var(--text-dim); padding: 6px 10px 4px; font-weight: 600;
        }

        .cmd-item {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 12px; border-radius: var(--radius-sm);
            cursor: pointer; transition: background 0.12s ease;
        }

        .cmd-item:hover, .cmd-item.selected { background: rgba(255,200,100,0.1); }

        .cmd-item-icon { font-size: 16px; width: 24px; text-align: center; flex-shrink: 0; }
        .cmd-item-label { flex: 1; font-size: 14px; color: var(--text); }
        .cmd-item-hint { font-size: 11px; color: var(--text-dim); }
        .cmd-item.selected .cmd-item-hint { color: var(--primary); }
        .cmd-empty { text-align: center; padding: 32px; color: var(--text-dim); font-size: 14px; }

        /* ========== Spring Number ========== */
        @keyframes springPop {
            0% { transform: scale(1); }
            30% { transform: scale(1.18) rotate(-1deg); }
            60% { transform: scale(0.94) rotate(0.5deg); }
            80% { transform: scale(1.04); }
            100% { transform: scale(1); }
        }

        .spring-pop { animation: springPop 0.45s var(--ease-spring); }

        /* ========== Sync Pulse ========== */
        @keyframes syncPulseV2 {
            0% { box-shadow: 0 0 0 0 rgba(255,200,100,0.4); }
            70% { box-shadow: 0 0 0 12px rgba(255,200,100,0); }
            100% { box-shadow: 0 0 0 0 rgba(255,200,100,0); }
        }

        .sync-pulse-v2 { animation: syncPulseV2 0.8s ease-out; }

        /* ========== Focus Ring ========== */
        @keyframes focusRing {
            0%, 100% { box-shadow: 0 0 0 0 var(--accent); }
            50% { box-shadow: 0 0 0 12px transparent; }
        }

        .focus-ring-animate { animation: focusRing 2s ease-in-out infinite; }

        /* ========== Data Ripple ========== */
        @keyframes dataRipple {
            0% { box-shadow: 0 0 0 0 rgba(0, 212, 255, 0.45); }
            100% { box-shadow: 0 0 0 14px rgba(0, 212, 255, 0); }
        }

        .data-pulse { animation: dataRipple 1s ease-out; }

        /* ========== Loading State ========== */
        body.loading .stat-card,
        body.loading .mini-stat,
        body.loading .timeline-item {
            opacity: 0.5; pointer-events: none;
        }

        body.error .status-dot { background: var(--danger); }
        body.error .status-badge { background: rgba(255,107,107,0.12); border-color: var(--danger); }

        /* ========== Scroll Reveal ========== */
        .reveal-up {
            opacity: 0; transform: translateY(20px);
            transition: opacity 0.5s ease, transform 0.5s var(--ease-out-expo);
        }

        .reveal-up.visible { opacity: 1; transform: translateY(0); }

        /* ========== Fade In ========== */
        .fade-in { animation: fadeIn 0.5s ease forwards; }

        /* ========== v35.1: Accessibility & Modern CSS Enhancements ========== */
        
        /* Enhanced Focus States */
        :focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 3px;
            border-radius: 4px;
        }

        button:focus-visible, .action-btn:focus-visible, .mood-btn:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
            box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.25);
        }

        /* View Transitions API Support */
        @view-transition {
            navigation: auto;
        }

        ::view-transition-old(stat-value),
        ::view-transition-new(stat-value) {
            animation-duration: 0.3s;
            animation-timing-function: var(--ease-out-expo);
        }

        /* Modern Scroll-driven Animations */
        @keyframes scrollProgress {
            from { transform: scaleX(0); }
            to { transform: scaleX(1); }
        }

        .scroll-progress {
            transform-origin: left center;
            animation: scrollProgress linear;
            animation-timeline: scroll();
        }

        /* Activity-Synced Pulse Ring */
        @keyframes activityPulse {
            0%, 100% { 
                opacity: 0.6; 
                transform: translate(-50%, -50%) scale(1);
                box-shadow: 0 0 20px var(--accent);
            }
            50% { 
                opacity: 1; 
                transform: translate(-50%, -50%) scale(1.05);
                box-shadow: 0 0 35px var(--accent);
            }
        }

        .activity-sync-ring {
            position: absolute;
            top: 50%; left: 50%;
            width: 240px; height: 240px;
            border-radius: 50%;
            border: 2px solid var(--accent);
            opacity: 0;
            pointer-events: none;
            animation: activityPulse 2s ease-in-out infinite;
            z-index: -2;
        }

        .activity-sync-ring.active {
            opacity: 1;
        }

        /* Neural Sync Indicator */
        @keyframes neuralPulse {
            0%, 100% { 
                opacity: 0.3;
                transform: translate(-50%, -50%) scale(1);
            }
            50% { 
                opacity: 0.8;
                transform: translate(-50%, -50%) scale(1.1);
            }
        }

        .neural-sync-indicator {
            position: absolute;
            top: 50%; left: 50%;
            width: 260px; height: 260px;
            border-radius: 50%;
            border: 1px dashed var(--purple);
            opacity: 0;
            pointer-events: none;
            animation: neuralPulse 3s ease-in-out infinite;
            z-index: -3;
        }

        .neural-sync-indicator.active {
            opacity: 0.5;
        }

        /* Modern Glass Reflection */
        .glass-card::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 50%;
            background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, transparent 100%);
            pointer-events: none;
            border-radius: inherit;
        }

        /* Stat Card Enhancement - Magnetic Hover */
        .stat-card {
            transition: transform 0.25s var(--ease-out-expo), 
                        box-shadow 0.25s var(--ease-out-expo),
                        border-color 0.25s ease;
            will-change: transform;
        }

        .stat-card:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: var(--shadow-card-hover), 
                        0 0 40px -10px var(--primary);
        }

        /* Toast Stack Enhancement */
        .toast {
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            transform-origin: top right;
            animation: toastIn 0.35s var(--ease-out-back) forwards;
        }

        @keyframes toastIn {
            from {
                opacity: 0;
                transform: translateX(100%) scale(0.8);
            }
            to {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        .toast.toast-out {
            animation: toastOut 0.25s var(--ease-out-expo) forwards;
        }

        @keyframes toastOut {
            to {
                opacity: 0;
                transform: translateX(100%) scale(0.9);
            }
        }

        /* Data Flow Line Enhancement */
        .data-stream-line {
            background: linear-gradient(90deg, 
                transparent 0%, 
                var(--accent) 50%, 
                transparent 100%
            );
            background-size: 200% 100%;
            animation: dataFlow 1.5s linear infinite;
        }

        @keyframes dataFlow {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ========== v38.0: Micro-Interaction Engine ========== */

        /* Entrance Orchestration - Staggered reveal on load */
        @keyframes v38Entrance {
            0% { opacity: 0; transform: translateY(24px) scale(0.96); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        .v38-entrance { animation: v38Entrance 0.6s var(--ease-out-expo) both; }
        .v38-entrance-1 { animation-delay: 0.05s; }
        .v38-entrance-2 { animation-delay: 0.12s; }
        .v38-entrance-3 { animation-delay: 0.19s; }
        .v38-entrance-4 { animation-delay: 0.26s; }
        .v38-entrance-5 { animation-delay: 0.33s; }
        .v38-entrance-6 { animation-delay: 0.40s; }
        .v38-entrance-7 { animation-delay: 0.47s; }
        .v38-entrance-8 { animation-delay: 0.54s; }
        .v38-entrance-9 { animation-delay: 0.61s; }

        /* v38.0: Liquid Glass Reflection - Simulates light refraction */
        .glass-card-v38::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border-radius: inherit;
            background: linear-gradient(
                135deg,
                rgba(255,255,255,0.08) 0%,
                transparent 40%,
                transparent 60%,
                rgba(255,255,255,0.03) 100%
            );
            pointer-events: none;
            z-index: 1;
        }

        /* v38.0: Animated Gradient Border v2 - More fluid, multi-stop */
        @keyframes v38GradientBorder {
            0% { background-position: 0% 50%; }
            25% { background-position: 100% 0%; }
            50% { background-position: 100% 50%; }
            75% { background-position: 0% 100%; }
            100% { background-position: 0% 50%; }
        }

        .v38-border-glow {
            position: relative;
        }

        .v38-border-glow::before {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: inherit;
            background: linear-gradient(
                var(--v38-angle, 0deg),
                var(--primary),
                var(--accent),
                var(--purple),
                var(--pink),
                var(--primary)
            );
            background-size: 400% 400%;
            animation: v38GradientBorder 6s ease infinite;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.4s ease;
            filter: blur(4px);
        }

        .v38-border-glow:hover::before { opacity: 0.7; }

        /* v38.0: Data Ripple Effect - Value change ripple */
        @keyframes v38DataRipple {
            0% { transform: scale(0); opacity: 0.6; }
            100% { transform: scale(3); opacity: 0; }
        }

        .v38-data-ripple {
            position: relative;
            overflow: visible;
        }

        .v38-data-ripple::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: var(--primary);
            opacity: 0;
            pointer-events: none;
            animation: none;
        }

        .v38-data-ripple.rippling::after {
            animation: v38DataRipple 0.7s var(--ease-out-expo) forwards;
        }

        /* v38.0: Interactive Progress Bar Tooltip */
        .progress-container { position: relative; }

        .progress-container:hover .progress-tooltip {
            opacity: 1;
            transform: translateY(-4px);
        }

        .progress-tooltip {
            position: absolute;
            bottom: calc(100% + 6px);
            left: 50%;
            transform: translateX(-50%) translateY(0);
            background: rgba(10,10,20,0.92);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            padding: 4px 8px;
            font-size: 10px;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-bright);
            white-space: nowrap;
            opacity: 0;
            transition: opacity 0.2s ease, transform 0.2s ease;
            pointer-events: none;
            backdrop-filter: blur(8px);
            z-index: 10;
        }

        .progress-tooltip::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 4px solid transparent;
            border-top-color: rgba(10,10,20,0.92);
        }

        /* v38.0: Number Morphing Animation */
        @keyframes v38NumberPop {
            0% { transform: scale(1); }
            30% { transform: scale(1.18) rotate(-2deg); }
            60% { transform: scale(1.12) rotate(1deg); }
            100% { transform: scale(1) rotate(0deg); }
        }

        .v38-number-pop {
            animation: v38NumberPop 0.4s var(--ease-out-back) forwards;
        }

        /* v38.0: Typing Indicator Glow */
        @keyframes v38TypingGlow {
            0%, 100% { box-shadow: 0 0 4px var(--accent); }
            50% { box-shadow: 0 0 12px var(--accent), 0 0 24px var(--accent); }
        }

        .v38-typing-dot {
            display: inline-block;
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--accent);
            margin: 0 2px;
            animation: v38TypingBounce 1.2s ease-in-out infinite;
        }

        .v38-typing-dot:nth-child(2) { animation-delay: 0.15s; }
        .v38-typing-dot:nth-child(3) { animation-delay: 0.30s; }

        @keyframes v38TypingBounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-6px); }
        }

        /* v38.0: State Change Flash Overlay */
        @keyframes v38StateFlash {
            0% { opacity: 0.15; }
            100% { opacity: 0; }
        }

        .v38-state-flash {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 9990;
            opacity: 0;
        }

        .v38-state-flash.active {
            animation: v38StateFlash 0.6s var(--ease-out-expo) forwards;
        }

        /* v38.0: Scroll-Driven Reveal */
        @keyframes v38Reveal {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .v38-scroll-reveal {
            animation: v38Reveal 0.5s var(--ease-out-expo) both;
            animation-timeline: view();
            animation-range: entry 0% entry 100%;
        }

        /* v38.0: Pulsing Dot Grid Background */
        @keyframes v38DotPulse {
            0%, 100% { opacity: 0.15; transform: scale(1); }
            50% { opacity: 0.35; transform: scale(1.2); }
        }

        .v38-dot-grid {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: -2;
            background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px);
            background-size: 32px 32px;
            mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
        }

        .v38-dot-grid-active {
            animation: v38DotPulse 4s ease-in-out infinite;
        }

        /* v38.0: Fox Status Ring 2.0 - More dynamic outer ring */
        @keyframes v38FoxRing {
            0% { transform: translateX(-50%) rotate(0deg); opacity: 0.5; }
            25% { opacity: 0.8; }
            50% { opacity: 0.5; transform: translateX(-50%) rotate(180deg); }
            75% { opacity: 0.8; }
            100% { transform: translateX(-50%) rotate(360deg); opacity: 0.5; }
        }

        .fox-status-ring-v38 {
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 4px;
            background: linear-gradient(90deg, transparent, var(--theme-color, var(--primary)), transparent);
            border-radius: 2px;
            animation: v38FoxRing 3s linear infinite;
            opacity: 0.6;
        }

        /* v38.0: Wave Clip Effect on Stat Cards */
        @keyframes v38WaveClip {
            0% { clip-path: inset(100% 0 0 0); }
            100% { clip-path: inset(0 0 0 0); }
        }

        .v38-wave-update .progress-fill {
            animation: v38WaveClip 0.5s var(--ease-out-expo);
        }

        /* v38.0: Stat Card Depth Shadow */
        .stat-card {
            box-shadow: 
                0 2px 8px rgba(0,0,0,0.2),
                0 8px 32px rgba(0,0,0,0.3),
                0 0 0 1px rgba(255,255,255,0.04) inset;
            transition: box-shadow 0.3s ease, transform 0.25s var(--ease-spring);
        }

        .stat-card:hover {
            box-shadow: 
                0 4px 16px rgba(0,0,0,0.25),
                0 16px 56px rgba(0,0,0,0.4),
                0 0 0 1px rgba(255,255,255,0.08) inset,
                0 0 48px -12px var(--primary);
        }

        /* v38.0: Floating Label Effect on Buttons */
        .action-btn {
            position: relative;
            overflow: hidden;
        }

        .action-btn .btn-label {
            display: inline-block;
            transition: transform 0.25s var(--ease-out-expo);
        }

        .action-btn:hover .btn-label {
            transform: translateY(-2px);
        }

        .action-btn:active .btn-label {
            transform: translateY(1px) scale(0.97);
        }

        /* v38.0: Mood Tag Pills */
        .mood-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            background: rgba(255,255,255,0.06);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--text-muted);
            border: 1px solid rgba(255,255,255,0.06);
            transition: all 0.25s var(--ease-spring);
        }

        .mood-tag:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.12);
            color: var(--text);
            transform: translateY(-2px);
        }

        .mood-tag.active {
            background: color-mix(in srgb, var(--primary) 20%, transparent);
            border-color: color-mix(in srgb, var(--primary) 40%, transparent);
            color: var(--primary);
        }

        /* v38.0: Enhanced Toast Notifications */
        @keyframes v38ToastSlide {
            from { transform: translateX(110%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .toast-v38 {
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255,255,255,0.08);
            animation: v38ToastSlide 0.4s var(--ease-out-expo) forwards;
        }

        @keyframes v38ToastExit {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(110%); opacity: 0; }
        }

        .toast-v38.exiting {
            animation: v38ToastExit 0.3s var(--ease-out-expo) forwards;
        }

        /* v38.0: Mini Map Indicator */
        .v38-minimap {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 80px;
            height: 60px;
            background: rgba(10,10,20,0.8);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            overflow: hidden;
            opacity: 0.7;
            transition: opacity 0.2s ease;
            backdrop-filter: blur(8px);
            z-index: 100;
        }

        .v38-minimap:hover { opacity: 1; }

        .v38-minimap-dot {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--primary);
            box-shadow: 0 0 6px var(--primary);
        }

        /* v38.0: Skill Category Badge */
        .skill-category-badge {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 2px 8px;
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: 500;
            background: rgba(255,255,255,0.06);
            color: var(--text-muted);
            transition: all 0.2s ease;
        }

        .skill-category-badge.development { background: rgba(0,212,255,0.15); color: var(--accent); }
        .skill-category-badge.automation { background: rgba(92,219,149,0.15); color: var(--success); }
        .skill-category-badge.analytics { background: rgba(254,202,87,0.15); color: var(--warning); }
        .skill-category-badge.integration { background: rgba(168,85,247,0.15); color: var(--purple); }
        .skill-category-badge.creative { background: rgba(236,72,153,0.15); color: var(--pink); }

        /* v38.0: AI Status Indicator */
        .ai-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            background: linear-gradient(135deg, rgba(168,85,247,0.15), rgba(0,212,255,0.1));
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: var(--radius-full);
            font-size: 12px;
            color: var(--purple);
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .ai-status-badge::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--purple);
            box-shadow: 0 0 8px var(--purple);
            animation: pulse 2s ease-in-out infinite;
        }

        .ai-status-badge.active {
            background: linear-gradient(135deg, rgba(168,85,247,0.25), rgba(0,212,255,0.2));
            border-color: rgba(168,85,247,0.4);
            color: var(--pink-glow);
        }

        .ai-status-badge.active::before {
            background: var(--pink);
            box-shadow: 0 0 8px var(--pink);
        }

        /* v38.0: Live Activity Indicator */
        .live-indicator {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            color: var(--success);
            font-family: 'JetBrains Mono', monospace;
        }

        .live-indicator::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            box-shadow: 0 0 6px var(--success);
            animation: livePulse 1.5s ease-in-out infinite;
        }

        @keyframes livePulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.85); }
        }

        /* v38.0: Chart Enhancements */
        .chart-canvas { border-radius: 8px; }

        .chart-canvas:hover {
            box-shadow: 0 0 20px -4px var(--accent);
        }

        /* v38.0: Compact Stats Row */
        .stats-compact {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
        }

        .stat-compact-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 8px 6px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-sm);
            transition: all 0.2s var(--ease-spring);
        }

        .stat-compact-item:hover {
            background: rgba(255,255,255,0.07);
            transform: translateY(-3px);
        }

        .stat-compact-value {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-bright);
            font-variant-numeric: tabular-nums;
        }

        .stat-compact-label {
            font-size: 9px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 2px;
        }

        /* v38.0: Glitch text effect for error state */
        @keyframes v38Glitch {
            0%, 100% { text-shadow: none; transform: translate(0); }
            20% { text-shadow: -2px 0 var(--danger), 2px 0 var(--accent); transform: translate(-2px, 0); }
            40% { text-shadow: 2px 0 var(--danger), -2px 0 var(--accent); transform: translate(2px, 0); }
            60% { text-shadow: -1px 0 var(--danger), 1px 0 var(--accent); transform: translate(-1px, 1px); }
            80% { text-shadow: 1px 0 var(--danger), -1px 0 var(--accent); transform: translate(1px, -1px); }
        }

        .v38-glitch-text {
            animation: v38Glitch 0.4s ease-in-out;
        }

        /* v38.0: Focus Ring Animation */
        @keyframes v38FocusRing {
            0% { box-shadow: 0 0 0 0 var(--accent); }
            70% { box-shadow: 0 0 0 8px transparent; }
            100% { box-shadow: 0 0 0 0 transparent; }
        }

        :focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 3px;
            border-radius: 4px;
        }

        /* v38.0: Status Badge Pulse */
        .status-badge-v38 {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-full);
            font-size: 12px;
            color: var(--text);
            transition: all 0.3s ease;
        }

        .status-badge-v38 .badge-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--text-dim);
            transition: background 0.3s ease;
        }

        .status-badge-v38.active .badge-dot {
            background: var(--success);
            box-shadow: 0 0 8px var(--success);
        }

        /* v38.0: Avatar Section Depth Layers */
        .avatar-section { position: relative; }

        .avatar-section::before,
        .avatar-section::after {
            content: '';
            position: absolute;
            inset: -12px;
            border-radius: calc(var(--radius-xl) + 12px);
            pointer-events: none;
        }

        .avatar-section::before {
            background: radial-gradient(circle, rgba(255,200,100,0.06) 0%, transparent 70%);
            z-index: -1;
        }

        .avatar-section::after {
            border: 1px solid rgba(255,255,255,0.04);
            z-index: -2;
        }

        /* v38.0: Timeline Connector */
        .timeline-items::before {
            content: '';
            position: absolute;
            left: 19px;
            top: 0;
            bottom: 0;
            width: 1px;
            background: linear-gradient(180deg, transparent, rgba(255,255,255,0.1) 20%, rgba(255,255,255,0.1) 80%, transparent);
        }

        /* v38.0: Smooth scroll indicator */
        @keyframes v38ScrollBounce {
            0%, 100% { transform: translateY(0); opacity: 0.6; }
            50% { transform: translateY(6px); opacity: 1; }
        }

        .scroll-hint-indicator {
            position: absolute;
            bottom: 8px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            opacity: 0.5;
            animation: v38ScrollBounce 2s ease-in-out infinite;
        }

        .scroll-hint-arrow {
            width: 16px;
            height: 16px;
            border-right: 2px solid var(--text-dim);
            border-bottom: 2px solid var(--text-dim);
            transform: rotate(45deg);
        }

        /* Reduced Motion ========== */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
            .stat-card:hover, .mini-stat:hover, .timeline-item:hover, .action-btn:hover {
                transform: none !important;
            }
        }

        /* ========== Responsive ========== */
        @media (max-width: 1024px) {
            .dashboard-grid {
                grid-template-columns: 300px 1fr;
                gap: 20px; padding: 20px 24px;
            }
        }

        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
                padding: 16px; gap: 16px;
            }
            .dashboard-header { padding: 16px; }
            .right-column { grid-template-columns: 1fr; }
            .stats-row { grid-template-columns: 1fr; }
            .charts-container { grid-template-columns: 1fr; }
            .bottom-section { grid-template-columns: 1fr; }
            .fox-container { width: 150px; height: 150px; }
            .dashboard-footer { flex-direction: column; gap: 12px; text-align: center; }
        }

        @media (max-width: 480px) {
            .dashboard-header { flex-direction: column; align-items: flex-start; gap: 12px; }
            .header-right { width: 100%; justify-content: space-between; }
            .stat-value { font-size: 26px; }
            .stat-card { padding: 16px; }
            .quick-stats { grid-template-columns: 1fr; }
            .mood-selector { flex-wrap: wrap; }
        }

        /* ========== v40.0: Enhanced Data Visualization & AI Status ========== */

        /* v40.0: Data Freshness Ring - Visual indicator for data age */
        @keyframes v39DataFreshness {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.05); }
            100% { opacity: 1; transform: scale(1); }
        }

        .v39-data-freshness-ring {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 220px; height: 220px;
            border-radius: 50%;
            border: 2px solid transparent;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.5s ease, border-color 0.5s ease;
        }

        .v39-data-freshness-ring.fresh {
            opacity: 1;
            border-color: rgba(92,219,149,0.4);
            animation: v39DataFreshness 3s ease-in-out infinite;
        }

        .v39-data-freshness-ring.stale {
            opacity: 1;
            border-color: rgba(254,202,87,0.4);
            animation: v39DataFreshness 1.5s ease-in-out infinite;
        }

        .v39-data-freshness-ring.critical {
            opacity: 1;
            border-color: rgba(255,107,107,0.5);
            animation: v39DataFreshness 0.8s ease-in-out infinite;
        }

        /* v40.0: Stale Data Shimmer Effect */
        @keyframes v39StaleShimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        .v39-stale-shimmer {
            position: relative;
            overflow: hidden;
        }

        .v39-stale-shimmer::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg,
                transparent 0%,
                rgba(254,202,87,0.08) 25%,
                rgba(254,202,87,0.15) 50%,
                rgba(254,202,87,0.08) 75%,
                transparent 100%
            );
            background-size: 200% 100%;
            animation: v39StaleShimmer 2.5s ease-in-out infinite;
            pointer-events: none;
            border-radius: inherit;
        }

        /* v40.0: AI Processing Aura */
        @keyframes v39AuraSpin {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }

        .v39-ai-processing-aura {
            position: absolute;
            top: 50%; left: 50%;
            width: 280px; height: 280px;
            border-radius: 50%;
            background: conic-gradient(from 0deg, transparent, rgba(168,85,247,0.15), transparent, rgba(0,212,255,0.15), transparent);
            opacity: 0;
            pointer-events: none;
            transform: translate(-50%, -50%);
            animation: none;
        }

        .v39-ai-processing-aura.active {
            opacity: 1;
            animation: v39AuraSpin 4s linear infinite;
        }

        /* v40.0: Stat Value Glow Effect */
        .v39-stat-glow {
            position: relative;
        }

        .v39-stat-glow::before {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: inherit;
            background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
            opacity: 0;
            filter: blur(8px);
            transition: opacity 0.3s ease;
            pointer-events: none;
            z-index: -1;
        }

        .v39-stat-glow:hover::before {
            opacity: 0.3;
        }

        /* v40.0: Interactive Holographic Effect */
        @keyframes v39HolographicShift {
            0% { filter: hue-rotate(0deg) brightness(1); }
            25% { filter: hue-rotate(15deg) brightness(1.05); }
            50% { filter: hue-rotate(0deg) brightness(1); }
            75% { filter: hue-rotate(-15deg) brightness(0.95); }
            100% { filter: hue-rotate(0deg) brightness(1); }
        }

        .v39-holographic {
            animation: v39HolographicShift 6s ease-in-out infinite;
        }

        /* v40.0: Recovery Pulse for Stale Data */
        @keyframes v39RecoveryPulse {
            0% { box-shadow: 0 0 0 0 rgba(254,202,87,0.6); }
            70% { box-shadow: 0 0 0 16px rgba(254,202,87,0); }
            100% { box-shadow: 0 0 0 0 rgba(254,202,87,0); }
        }

        .v39-recovery-pulse {
            animation: v39RecoveryPulse 1.2s ease-out;
        }

        /* v40.0: Data Sync Wave */
        @keyframes v39DataSyncWave {
            0% { transform: scale(0.8); opacity: 0.8; }
            100% { transform: scale(2.4); opacity: 0; }
        }

        .v39-sync-wave {
            position: absolute;
            top: 50%; left: 50%;
            width: 60px; height: 60px;
            border-radius: 50%;
            border: 2px solid var(--accent);
            transform: translate(-50%, -50%);
            pointer-events: none;
            opacity: 0;
        }

        .v39-sync-wave.active {
            animation: v39DataSyncWave 1s var(--ease-out-expo) forwards;
        }

        /* v40.0: Enhanced Toast with AI context */
        .v39-toast-ai {
            border-left: 3px solid var(--purple);
        }

        .v39-toast-ai::before {
            content: '🤖 ';
            font-size: 14px;
        }

        /* v40.0: Skill Level Up Animation */
        @keyframes v39SkillLevelUp {
            0% { transform: scale(1) translateY(0); opacity: 1; }
            50% { transform: scale(1.2) translateY(-8px); opacity: 1; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }

        .v39-skill-levelup {
            animation: v39SkillLevelUp 0.6s var(--ease-spring);
        }

        /* v40.0: Particle Trail for Active Data */
        @keyframes v39ParticleTrail {
            0% { transform: translateY(0) scale(1); opacity: 0.8; }
            100% { transform: translateY(-40px) scale(0); opacity: 0; }
        }

        .v39-particle-trail {
            position: absolute;
            width: 4px; height: 4px;
            border-radius: 50%;
            background: var(--accent);
            pointer-events: none;
            animation: v39ParticleTrail 0.8s var(--ease-out-expo) forwards;
        }

        /* v40.0: Version Tag Glow */
        .v39-version-glow {
            position: relative;
            background: linear-gradient(135deg, rgba(168,85,247,0.15), rgba(0,212,255,0.1));
            border: 1px solid rgba(168,85,247,0.3);
            transition: all 0.3s ease;
        }

        .v39-version-glow:hover {
            background: linear-gradient(135deg, rgba(168,85,247,0.25), rgba(0,212,255,0.2));
            box-shadow: 0 0 20px rgba(168,85,247,0.3);
            transform: scale(1.05);
        }

        /* v40.0: Memory Heatmap Cell */
        .v39-memory-cell {
            display: inline-block;
            width: 8px; height: 8px;
            border-radius: 2px;
            margin: 1px;
            transition: all 0.3s ease;
        }

        .v39-memory-cell.cold { background: rgba(0,212,255,0.3); }
        .v39-memory-cell.warm { background: rgba(254,202,87,0.5); }
        .v39-memory-cell.hot { background: rgba(255,107,107,0.7); }

        /* v40.0: Connection Quality Indicator */
        @keyframes v39ConnectionPulse {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 1; }
        }

        .v39-connection-quality {
            display: flex;
            gap: 3px;
            align-items: flex-end;
        }

        .v39-connection-bar {
            width: 4px;
            border-radius: 2px;
            background: var(--text-dim);
            transition: all 0.3s ease;
        }

        .v39-connection-bar:nth-child(1) { height: 6px; }
        .v39-connection-bar:nth-child(2) { height: 10px; }
        .v39-connection-bar:nth-child(3) { height: 14px; }
        .v39-connection-bar:nth-child(4) { height: 18px; }

        .v39-connection-quality.excellent .v39-connection-bar { background: var(--success); animation: v39ConnectionPulse 1s ease-in-out infinite; }
        .v39-connection-quality.good .v39-connection-bar:nth-child(1),
        .v39-connection-quality.good .v39-connection-bar:nth-child(2),
        .v39-connection-quality.good .v39-connection-bar:nth-child(3) { background: var(--success); }
        .v39-connection-quality.poor .v39-connection-bar:nth-child(1),
        .v39-connection-quality.poor .v39-connection-bar:nth-child(2) { background: var(--warning); }
        .v39-connection-quality.critical .v39-connection-bar:nth-child(1) { background: var(--danger); animation: v39ConnectionPulse 0.5s ease-in-out infinite; }
        /* v43.0: Enhanced connection bars */
        .v43-connection-bar { transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
        .v39-connection-quality.excellent .v39-connection-bar.v43-connection-bar { background: var(--success); box-shadow: 0 0 6px var(--success-glow); }
        .v39-connection-quality.poor .v39-connection-bar.v43-connection-bar { background: var(--warning); box-shadow: 0 0 6px var(--warning-glow); }
        .v39-connection-quality.critical .v39-connection-bar.v43-connection-bar { background: var(--danger); box-shadow: 0 0 6px var(--danger-glow); }

        /* v40.0: Ambient Data Particles */
        .v39-ambient-particle {
            position: fixed;
            width: 3px; height: 3px;
            border-radius: 50%;
            pointer-events: none;
            opacity: 0.4;
            z-index: 1;
        }

        /* v40.0: Glassmorphism Depth Layers */
        .v39-glass-deep {
            background: rgba(15,15,25,0.75);
            backdrop-filter: blur(40px) saturate(180%);
            -webkit-backdrop-filter: blur(40px) saturate(180%);
            border: 1px solid rgba(255,255,255,0.05);
        }

        .v39-glass-surface {
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.04);
        }

        /* v40.0: Status Transition Matrix */
        .v39-status-transition {
            position: relative;
            overflow: hidden;
        }

        .v39-status-transition::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.05) 50%, transparent 70%);
            transform: translateX(-100%);
            transition: transform 0.6s ease;
        }

        .v39-status-transition:hover::after {
            transform: translateX(100%);
        }

        /* v40.0: Mini Chart Spark */
        .v39-mini-spark {
            position: relative;
        }

        .v39-mini-spark::after {
            content: '';
            position: absolute;
            top: 2px; right: 2px;
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--success);
            box-shadow: 0 0 6px var(--success);
            animation: pulse 1.5s ease-in-out infinite;
        }
        /* ========== v40.0: Modern CSS :has() Selectors ========== */
        
        /* Parent has - when card is hovered, adjust siblings */
        .stat-card:has(+ .stat-card:hover) {
            transform: translateX(-2px);
        }
        
        /* Card group hover effect using :has() */
        .right-column:has(.stat-card:hover) .stat-card:not(:hover) {
            opacity: 0.85;
            transform: translateY(-2px);
        }
        
        /* Button group active states */
        .mood-selector:has(.mood-btn.active) {
            background: rgba(255,200,100,0.08);
        }
        
        /* Toast queue has items */
        .toast-queue:has(.toast-v32) {
            pointer-events: auto;
        }
        
        /* Focus-within for stat cards containing focused inputs */
        .stat-card:has(:focus-visible) {
            outline: 2px solid var(--accent);
            outline-offset: 3px;
        }
        
        /* ========== v40.0: @starting-style Entry Animations ========== */
        
        @starting-style {
            .stat-card {
                opacity: 0;
                transform: translateY(16px) scale(0.97);
            }
            .glass-card {
                opacity: 0;
                transform: scale(0.98);
            }
            .toast-v32 {
                opacity: 0;
                transform: translateX(40px) scale(0.9);
            }
        }
        
        /* ========== v40.0: Container Query Card Responsive ========== */
        
        .dashboard-container {
            container-type: inline-size;
            container-name: dashboard;
        }
        
        @container dashboard (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr !important;
                padding: 16px !important;
                gap: 16px !important;
            }
            .right-column {
                grid-template-columns: 1fr !important;
            }
            .fox-container {
                width: 150px !important;
                height: 150px !important;
            }
        }
        
        @container dashboard (min-width: 769px) and (max-width: 1024px) {
            .dashboard-grid {
                grid-template-columns: 300px 1fr !important;
                gap: 20px !important;
                padding: 20px 24px !important;
            }
        }
        
        /* ========== v40.0: Light Mode Theme (via :has()) ========== */
        
        body.theme-light {
            --bg-dark: #f0f2f5;
            --bg-deep: #e8ebf0;
            --bg-card: rgba(255,255,255,0.88);
            --bg-card-hover: rgba(255,255,255,0.95);
            --text: #1a1a2e;
            --text-dim: #5a5a6a;
            --text-bright: #0a0a14;
            --text-muted: #6a6a7a;
            --bg-glass: rgba(0,0,0,0.04);
            --bg-glass-hover: rgba(0,0,0,0.08);
        }
        
        body.theme-light .glass-card {
            border-color: rgba(0,0,0,0.08);
            box-shadow: 0 4px 24px rgba(0,0,0,0.12), 0 0 80px -20px rgba(0,0,0,0.1);
        }
        
        body.theme-light .glass-card:hover {
            border-color: rgba(0,0,0,0.12);
            box-shadow: 0 8px 40px rgba(0,0,0,0.15), 0 0 120px -20px rgba(0,0,0,0.15);
        }
        
        body.theme-light .bg-mesh,
        body.theme-light .ambient-orb {
            opacity: 0.3;
        }
        
        /* ========== v40.0: 3D Card Flip Effect ========== */
        
        .stat-card.flip-hover {
            perspective: 1000px;
        }
        
        .stat-card.flip-hover .stat-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform-style: preserve-3d;
        }
        
        .stat-card.flip-hover:hover .stat-card-inner {
            transform: rotateY(10deg) rotateX(-5deg);
        }
        
        /* ========== v40.0: AI Context Panel ========== */
        
        .ai-context-panel {
            background: linear-gradient(135deg, rgba(168,85,247,0.1) 0%, rgba(0,212,255,0.08) 100%);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: var(--radius-lg);
            padding: 16px 18px;
            margin-top: 14px;
            width: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .ai-context-panel::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--purple), var(--accent));
        }
        
        .ai-context-title {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .ai-context-title::before {
            content: '🤖';
            font-size: 12px;
        }
        
        .ai-context-text {
            font-size: 13px;
            color: var(--text-bright);
            line-height: 1.5;
            min-height: 36px;
        }
        
        .ai-context-cursor {
            display: inline-block;
            width: 2px;
            height: 14px;
            background: var(--purple);
            margin-left: 2px;
            animation: aiCursorBlink 1s ease-in-out infinite;
            vertical-align: middle;
        }
        
        @keyframes aiCursorBlink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
        
        /* ========== v40.0: New Status Metrics ========== */
        
        .metrics-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            margin-top: 10px;
        }
        
        .metric-pill {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 5px 10px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--text-muted);
            transition: all 0.25s var(--ease-spring);
        }
        
        .metric-pill:hover {
            background: rgba(255,255,255,0.1);
            transform: translateY(-2px) scale(1.03);
        }
        
        .metric-pill-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            flex-shrink: 0;
        }
        
        .metric-pill.highlight {
            background: rgba(0,212,255,0.12);
            border-color: rgba(0,212,255,0.3);
            color: var(--accent);
        }
        
        .metric-pill.highlight .metric-pill-dot {
            background: var(--accent);
            animation: pulse 1.5s ease-in-out infinite;
        }
        
        /* ========== v40.0: Scroll-Driven Stat Reveal ========== */
        
        @keyframes v40StatReveal {
            from {
                opacity: 0;
                transform: translateY(24px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
        
        .v40-stat-reveal {
            animation: v40StatReveal 0.5s var(--ease-out-expo) both;
            animation-timeline: view();
            animation-range: entry 0% entry 100%;
        }
        
        /* ========== v40.0: Enhanced Backdrop Filter ========== */
        
        .glass-card {
            backdrop-filter: blur(32px) saturate(200%) contrast(1.05);
            -webkit-backdrop-filter: blur(32px) saturate(200%) contrast(1.05);
        }
        
        .glass-card:hover {
            backdrop-filter: blur(40px) saturate(220%) contrast(1.08);
            -webkit-backdrop-filter: blur(40px) saturate(220%) contrast(1.08);
        }
        
        /* ========== v40.0: Reduced Motion Support ========== */
        
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
            .stat-card:hover, .mini-stat:hover, .timeline-item:hover, .action-btn:hover {
                transform: none !important;
            }
            .v38-dot-grid,
            .ambient-orb,
            .bg-stars > div {
                animation: none !important;
            }
            .cursor-trail-particle,
            .particle-mesh-canvas canvas,
            .bg-neural {
                display: none !important;
            }
        }
        
        /* ========== v40.0: Performance Will-Change Hints ========== */
        
        .fox-canvas-wrapper,
        .fox-canvas,
        .fox-glow-aura,
        .mood-aura,
        .energy-core,
        .activity-sync-ring,
        .neural-sync-indicator {
            will-change: transform, opacity;
        }
        
        .stat-card,
        .mini-stat,
        .action-btn {
            will-change: transform, box-shadow;
        }
        
        .toast-v32 {
            will-change: transform, opacity;
        }
        
        /* ========== v40.0: Smart Color System ========== */
        
        .stat-card[data-status="healthy"] .stat-icon {
            box-shadow: 0 0 20px rgba(92,219,149,0.3);
        }
        
        .stat-card[data-status="warning"] .stat-icon {
            box-shadow: 0 0 20px rgba(254,202,87,0.3);
        }
        
        .stat-card[data-status="critical"] .stat-icon {
            box-shadow: 0 0 20px rgba(255,107,107,0.3);
            animation: criticalPulse 0.8s ease-in-out infinite;
        }
        
        /* ========== v40.0: Timeline Scrollbar ========== */
        
        .timeline-items::-webkit-scrollbar {
            width: 4px;
        }
        
        .timeline-items::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.02);
            border-radius: 2px;
        }
        
        .timeline-items::-webkit-scrollbar-thumb {
            background: rgba(168,85,247,0.4);
            border-radius: 2px;
        }
        
        .timeline-items::-webkit-scrollbar-thumb:hover {
            background: rgba(168,85,247,0.6);
        }
        
        /* ========== v40.0: AI Activity Stream ========== */
        
        .activity-stream {
            position: fixed;
            top: 60px;
            right: 20px;
            width: 280px;
            max-height: 200px;
            overflow-y: auto;
            z-index: 100;
            display: flex;
            flex-direction: column;
            gap: 6px;
            pointer-events: none;
        }
        
        .activity-stream-item {
            padding: 8px 12px;
            background: rgba(10,10,20,0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-md);
            font-size: 11px;
            color: var(--text);
            animation: streamSlideIn 0.3s var(--ease-out-expo);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        @keyframes streamSlideIn {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }
        
        .activity-stream-item .stream-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        
        .activity-stream-item .stream-time {
            color: var(--text-dim);
            margin-left: auto;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
        }
        
        /* ========== v40.0: Intersection Observer Reveal ========== */
        
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.5s ease, transform 0.5s var(--ease-out-expo);
        }
        
        .reveal-on-scroll.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* ========== v40.0: Better Focus Management ========== */
        
        :focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 3px;
            border-radius: 4px;
            box-shadow: 0 0 0 4px rgba(0,212,255,0.2);
        }
        
        /* ========== v40.0: Custom Scrollbar ========== */
        
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.02);
            border-radius: 3px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: rgba(255,200,100,0.3);
            border-radius: 3px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255,200,100,0.5);
        }
        
        /* ========== v40.0: Smooth Anchor Scroll ========== */
        
        html {
            scroll-behavior: smooth;
            scroll-timeline: --page-scroll block;
        }
        
        /* ========== v40.0: Print Styles (for screenshots) ========== */

        @media print {
            .glow-cursor,
            .cursor-trail-particle,
            .particle-mesh-canvas,
            .bg-neural,
            .ambient-orb,
            .v38-dot-grid,
            .noise-overlay,
            .scroll-progress {
                display: none !important;
            }
            body {
                background: white !important;
                color: black !important;
            }
            .glass-card {
                background: white !important;
                border: 1px solid #ccc !important;
                box-shadow: none !important;
            }
        }

        /* ========== v43.0: Liquid Glassmorphism & Morphing Number Animations ========== */

        /* v43.0: Morphing Number Transition - smooth digit transitions */
        @keyframes v43DigitMorph {
            0% { transform: translateY(0) scaleY(1); opacity: 1; }
            40% { transform: translateY(-30%) scaleY(0.4); opacity: 0.3; }
            50% { transform: translateY(30%) scaleY(0.4); opacity: 0.3; }
            100% { transform: translateY(0) scaleY(1); opacity: 1; }
        }

        .v43-digit-morph {
            display: inline-block;
            animation: v43DigitMorph 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* v43.0: Liquid Glass Hover - light refraction shift */
        .v43-liquid-glass {
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .v43-liquid-glass::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                115deg,
                rgba(255,255,255,0.15) 0%,
                rgba(255,255,255,0.05) 20%,
                transparent 40%,
                transparent 60%,
                rgba(255,255,255,0.08) 80%,
                rgba(255,255,255,0.12) 100%
            );
            transform: translateX(-100%) rotate(0deg);
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            pointer-events: none;
            border-radius: inherit;
            z-index: 1;
        }

        .v43-liquid-glass:hover::before {
            transform: translateX(100%) rotate(0deg);
        }

        .v43-liquid-glass::after {
            content: '';
            position: absolute;
            inset: -50%;
            background: conic-gradient(
                from 0deg at 50% 50%,
                transparent 0deg,
                rgba(255,255,255,0.08) 60deg,
                transparent 120deg,
                rgba(255,255,255,0.05) 180deg,
                transparent 240deg,
                rgba(255,255,255,0.06) 300deg,
                transparent 360deg
            );
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
            border-radius: inherit;
            animation: v43LiquidSpin 8s linear infinite;
            z-index: 1;
        }

        .v43-liquid-glass:hover::after {
            opacity: 1;
        }

        @keyframes v43LiquidSpin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* v43.0: Mouse-Following Avatar Glow */
        .v43-avatar-glow {
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.12) 0%, transparent 70%);
            pointer-events: none;
            z-index: -2;
            transform: translate(-50%, -50%);
            transition: opacity 0.3s ease;
            opacity: 0;
        }

        .v43-avatar-glow.visible {
            opacity: 1;
        }

        /* v43.0: Magnetic Pull Effect on Stat Cards */
        .v43-magnetic-card {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                        box-shadow 0.25s ease,
                        border-color 0.25s ease;
        }

        .v43-magnetic-card:hover {
            transform: translateY(-6px) scale(1.03) perspective(800px) rotateX(1deg) rotateY(1deg);
        }

        /* v43.0: Depth Shadow Layers on Hover */
        .v43-depth-hover {
            transition: box-shadow 0.3s ease, transform 0.25s var(--ease-out-expo);
        }

        .v43-depth-hover:hover {
            box-shadow:
                0 2px 8px rgba(0,0,0,0.2),
                0 8px 32px rgba(0,0,0,0.3),
                0 0 0 1px rgba(255,255,255,0.06) inset,
                0 16px 48px -8px rgba(255,200,100,0.2),
                0 0 60px -15px rgba(255,200,100,0.15);
            transform: translateY(-5px) scale(1.015);
        }

        /* v43.0: Data Arrival Ripple */
        @keyframes v43DataRipple {
            0% { transform: scale(0); opacity: 0.6; }
            100% { transform: scale(3.5); opacity: 0; }
        }

        .v43-data-arrival-indicator {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--primary);
            transform: translate(-50%, -50%) scale(0);
            opacity: 0;
            pointer-events: none;
        }

        .v43-data-arrival-indicator.active {
            animation: v43DataRipple 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* v43.0: Enhanced Sparkline with End-Point Pulse */
        @keyframes v43SparkPulse {
            0%, 100% { r: 2.2; opacity: 0.95; }
            50% { r: 3.5; opacity: 1; }
        }

        .v43-sparkline-dot {
            animation: v43SparkPulse 1.5s ease-in-out infinite;
        }

        /* v43.0: Keyboard Shortcuts Panel */
        .v43-shortcuts-panel {
            position: fixed;
            bottom: 20px;
            left: 20px;
            background: rgba(10,10,18,0.92);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: var(--radius-lg);
            padding: 16px 20px;
            z-index: 1000;
            min-width: 220px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            opacity: 0;
            pointer-events: none;
            transform: translateY(10px) scale(0.95);
            transition: opacity 0.25s ease, transform 0.25s var(--ease-out-expo);
        }

        .v43-shortcuts-panel.visible {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0) scale(1);
        }

        .v43-shortcuts-title {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .v43-shortcut-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 5px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }

        .v43-shortcut-row:last-child {
            border-bottom: none;
        }

        .v43-shortcut-key {
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .v43-shortcut-key kbd {
            display: inline-block;
            padding: 2px 7px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 5px;
            font-size: 11px;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-bright);
            min-width: 22px;
            text-align: center;
        }

        .v43-shortcut-desc {
            font-size: 12px;
            color: var(--text-muted);
        }

        /* v43.0: Connection Quality Bars Enhanced */
        .v43-connection-bar {
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .v43-connection-bar.excellent {
            background: var(--success);
            box-shadow: 0 0 6px var(--success-glow);
        }

        .v43-connection-bar.good {
            background: var(--success);
            box-shadow: 0 0 6px var(--success-glow);
        }

        .v43-connection-bar.poor {
            background: var(--warning);
            box-shadow: 0 0 6px var(--warning-glow);
        }

        .v43-connection-bar.critical {
            background: var(--danger);
            box-shadow: 0 0 6px var(--danger-glow);
            animation: criticalPulse 0.5s ease-in-out infinite;
        }

        /* v43.0: Breathing Glow Animation for Avatar */
        @keyframes v43BreathingGlow {
            0%, 100% {
                opacity: 0.5;
                filter: blur(25px);
                transform: scale(1);
            }
            50% {
                opacity: 0.85;
                filter: blur(32px);
                transform: scale(1.08);
            }
        }

        .v43-breathing-glow {
            animation: v43BreathingGlow 3s ease-in-out infinite;
        }

        /* v43.0: Staggered Entrance Animation */
        @keyframes v43StaggerIn {
            0% {
                opacity: 0;
                transform: translateY(20px) scale(0.95);
            }
            100% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .v43-stagger-item {
            opacity: 0;
            animation: v43StaggerIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .v43-stagger-item:nth-child(1) { animation-delay: 0.05s; }
        .v43-stagger-item:nth-child(2) { animation-delay: 0.1s; }
        .v43-stagger-item:nth-child(3) { animation-delay: 0.15s; }
        .v43-stagger-item:nth-child(4) { animation-delay: 0.2s; }
        .v43-stagger-item:nth-child(5) { animation-delay: 0.25s; }
        .v43-stagger-item:nth-child(6) { animation-delay: 0.3s; }

        /* v43.0: Stat Card Depth Simulation */
        .v43-card-depth {
            position: relative;
        }

        .v43-card-depth::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* v43.0: Smooth Number Counter Animation */
        @keyframes v43CounterFlip {
            0% { transform: translateY(0) rotateX(0deg); opacity: 1; }
            45% { transform: translateY(-25%) rotateX(-90deg); opacity: 0; }
            55% { transform: translateY(25%) rotateX(90deg); opacity: 0; }
            100% { transform: translateY(0) rotateX(0deg); opacity: 1; }
        }

        .v43-counter-flip {
            animation: v43CounterFlip 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            transform-style: preserve-3d;
            backface-visibility: hidden;
        }

        /* v43.0: Holographic shimmer on cards */
        @keyframes v43HoloShimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        .v43-holo-shimmer {
            position: relative;
            overflow: hidden;
        }

        .v43-holo-shimmer::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(
                90deg,
                transparent 0%,
                rgba(255,255,255,0.04) 25%,
                rgba(255,255,255,0.08) 50%,
                rgba(255,255,255,0.04) 75%,
                transparent 100%
            );
            background-size: 200% 100%;
            animation: v43HoloShimmer 3s ease-in-out infinite;
            pointer-events: none;
            border-radius: inherit;
        }

        /* v43.0: Quick Actions Button Ripple */
        @keyframes v43BtnRipple {
            0% { transform: scale(0); opacity: 0.5; }
            100% { transform: scale(2.5); opacity: 0; }
        }

        .v43-btn-ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.3);
            pointer-events: none;
            width: 20px;
            height: 20px;
            margin-left: -10px;
            margin-top: -10px;
        }

        .action-btn .v43-btn-ripple {
            animation: v43BtnRipple 0.6s ease-out forwards;
        }

        /* v43.0: AI Processing Indicator Pulse */
        @keyframes v43AIPulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(168,85,247,0.5);
                opacity: 0.7;
            }
            50% {
                box-shadow: 0 0 0 8px rgba(168,85,247,0);
                opacity: 1;
            }
        }

        .v43-ai-pulse {
            animation: v43AIPulse 1.5s ease-in-out infinite;
        }

        /* v43.0: Version Badge Glow */
        .v43-version-badge {
            background: linear-gradient(135deg, rgba(168,85,247,0.2), rgba(0,212,255,0.15));
            border: 1px solid rgba(168,85,247,0.35);
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .v43-version-badge:hover {
            background: linear-gradient(135deg, rgba(168,85,247,0.3), rgba(0,212,255,0.25));
            box-shadow: 0 0 24px rgba(168,85,247,0.35);
            transform: scale(1.08) rotate(-1deg);
        }

        /* v43.0: Footer Status Indicator */
        .v43-footer-status {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .v43-status-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
            box-shadow: 0 0 8px var(--success);
            transition: all 0.3s ease;
        }

        .v43-status-indicator.warning {
            background: var(--warning);
            box-shadow: 0 0 8px var(--warning);
        }

        .v43-status-indicator.error {
            background: var(--danger);
            box-shadow: 0 0 8px var(--danger);
            animation: criticalPulse 0.5s ease-in-out infinite;
        }

        /* v43.0: Data Flow Visualization Line */
        @keyframes v43DataFlowLine {
            0% { background-position: 0% 0%; }
            100% { background-position: 200% 0%; }
        }

        .v43-dataflow-line {
            position: relative;
            overflow: hidden;
        }

        .v43-dataflow-line::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(
                90deg,
                transparent 0%,
                rgba(92,219,149,0.3) 25%,
                rgba(0,212,255,0.4) 50%,
                rgba(92,219,149,0.3) 75%,
                transparent 100%
            );
            background-size: 200% 100%;
            animation: v43DataFlowLine 2s linear infinite;
            pointer-events: none;
        }

        /* v43.0: Mood Selector Active State */
        .mood-btn.v43-active {
            border-color: var(--primary);
            background: rgba(255,200,100,0.25);
            box-shadow: 0 0 24px rgba(255,200,100,0.4), 0 0 48px rgba(255,200,100,0.2);
            transform: scale(1.15);
        }

        .mood-btn.v43-active:hover {
            transform: scale(1.25);
        }

        /* v43.0: Command Palette Item Hover Lift */
        .cmd-item:hover,
        .cmd-item.v43-selected {
            background: rgba(255,200,100,0.12);
            transform: translateX(4px);
        }

        .cmd-item.v43-selected {
            background: rgba(255,200,100,0.18);
        }

        /* v43.0: Timeline Item Slide-in */
        @keyframes v43TimelineSlide {
            from {
                opacity: 0;
                transform: translateX(-16px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .timeline-item.v43-timeline-in {
            animation: v43TimelineSlide 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* v43.0: Health Badge Pulse for Warning/Critical */
        .health-badge.warning {
            animation: v43AIPulse 1.2s ease-in-out infinite;
        }

        .health-badge.error {
            animation: v43AIPulse 0.6s ease-in-out infinite;
        }

        /* v43.0: Progress Bar Shimmer Enhancement */
        .progress-fill::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                90deg,
                transparent 0%,
                rgba(255,255,255,0.25) 50%,
                transparent 100%
            );
            background-size: 200% 100%;
            animation: v43DataFlowLine 1.8s ease-in-out infinite;
        }

        /* v43.0: Mini Stat Hover Elevation */
        .mini-stat:hover {
            transform: translateY(-8px) scale(1.04);
            box-shadow: 0 12px 40px -10px rgba(255,200,100,0.4), 0 0 24px rgba(255,200,100,0.15);
        }

        .mini-stat:active {
            transform: translateY(-3px) scale(0.97);
            transition-duration: 0.1s;
        }

        /* v43.0: Stats Row Entrance */
        .stats-row .mini-stat {
            opacity: 0;
            animation: v43StaggerIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .stats-row .mini-stat:nth-child(1) { animation-delay: 0.1s; }
        .stats-row .mini-stat:nth-child(2) { animation-delay: 0.2s; }

        /* v43.0: Toast Notification Slide from Bottom */
        @keyframes v43ToastSlideUp {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .toast-v32.v43-toast-in {
            animation: v43ToastSlideUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        /* v43.0: Scroll-Driven Reveal Enhancement */
        @keyframes v43ScrollReveal {
            from {
                opacity: 0;
                transform: translateY(28px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .v43-scroll-reveal {
            animation: v43ScrollReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            animation-timeline: view();
            animation-range: entry 0% entry 100%;
        }

        /* v43.0: Print Styles Updated */
        @media print {
            .glow-cursor,
            .cursor-trail-particle,
            .particle-mesh-canvas,
            .bg-neural,
            .ambient-orb,
            .v38-dot-grid,
            .noise-overlay,
            .scroll-progress,
            .v43-shortcuts-panel {
                display: none !important;
            }
            body {
                background: white !important;
                color: black !important;
            }
            .glass-card {
                background: white !important;
                border: 1px solid #ccc !important;
                box-shadow: none !important;
            }
        }

        /* ========== v45.0: Neural Activity Waveform ========== */
        .neural-waveform-container {
            position: relative;
            width: 100%;
            height: 60px;
            margin: 8px 0;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(168, 85, 247, 0.2);
        }
        .neural-waveform-canvas { width: 100%; height: 100%; }
        .neural-waveform-label {
            position: absolute; top: 4px; left: 8px;
            font-size: 9px; font-weight: 600;
            color: rgba(168, 85, 247, 0.7);
            letter-spacing: 1px; text-transform: uppercase;
            font-family: 'JetBrains Mono', monospace;
        }
        .neural-waveform-glow {
            position: absolute; inset: 0;
            background: radial-gradient(ellipse at 50% 50%, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
            pointer-events: none;
            animation: neuralWaveGlow 2s ease-in-out infinite alternate;
        }
        @keyframes neuralWaveGlow {
            from { opacity: 0.3; }
            to { opacity: 0.8; }
        }

        /* ========== v45.0: Hexagonal Skills Radar ========== */
        .skills-hex-container {
            position: relative;
            width: 120px; height: 110px;
            margin: 8px auto;
        }
        .skills-hex-bg {
            position: absolute; inset: 0;
            display: flex; align-items: center; justify-content: center;
        }
        .skills-hex-bg svg { width: 100%; height: 100%; filter: drop-shadow(0 0 8px rgba(0, 212, 255, 0.3)); }
        .skills-hex-overlay {
            position: absolute; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            pointer-events: none;
        }
        .skills-hex-count {
            font-size: 22px; font-weight: 800;
            font-family: 'Outfit', sans-serif;
            color: var(--accent);
            line-height: 1;
            text-shadow: 0 0 12px rgba(0, 212, 255, 0.6);
        }
        .skills-hex-label {
            font-size: 9px; font-weight: 600;
            color: rgba(255, 255, 255, 0.5);
            letter-spacing: 1.5px; text-transform: uppercase; margin-top: 2px;
        }
        .skills-hex-pulse {
            position: absolute; inset: -4px;
            border-radius: 50%;
            border: 2px solid rgba(0, 212, 255, 0.4);
            animation: hexPulse 2s ease-out infinite;
            pointer-events: none;
        }
        @keyframes hexPulse {
            0% { transform: scale(0.9); opacity: 1; }
            100% { transform: scale(1.3); opacity: 0; }
        }

        /* ========== v45.0: Circular Memory Gauge ========== */
        .memory-gauge-container {
            position: relative;
            width: 80px; height: 80px;
            margin: 8px auto;
        }
        .memory-gauge-svg { transform: rotate(-90deg); width: 100%; height: 100%; }
        .memory-gauge-bg { fill: none; stroke: rgba(255, 255, 255, 0.06); stroke-width: 6; }
        .memory-gauge-fill {
            fill: none; stroke-width: 6; stroke-linecap: round;
            transition: stroke-dashoffset 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), stroke 0.5s ease;
        }
        .memory-gauge-fill.low { stroke: var(--success); filter: drop-shadow(0 0 4px var(--success)); }
        .memory-gauge-fill.medium { stroke: var(--warning); filter: drop-shadow(0 0 4px var(--warning)); }
        .memory-gauge-fill.high { stroke: var(--error); filter: drop-shadow(0 0 4px var(--error)); }
        .memory-gauge-center {
            position: absolute; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
        }
        .memory-gauge-value { font-size: 16px; font-weight: 700; font-family: 'JetBrains Mono', monospace; color: var(--text-primary); }
        .memory-gauge-label { font-size: 8px; font-weight: 600; color: rgba(255, 255, 255, 0.4); letter-spacing: 1px; text-transform: uppercase; }

        /* ========== v45.0: Quantum State Flash ========== */
        .quantum-flash {
            position: fixed; inset: 0;
            pointer-events: none; z-index: 9999; opacity: 0;
        }
        .quantum-flash.active { animation: quantumFlashAnim 0.6s ease-out forwards; }
        @keyframes quantumFlashAnim {
            0% { opacity: 1; background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.4) 0%, transparent 70%); }
            50% { opacity: 0.5; background: radial-gradient(ellipse at center, rgba(0, 212, 255, 0.3) 0%, transparent 60%); }
            100% { opacity: 0; }
        }
        .quantum-flash-grid {
            position: absolute; inset: 0;
            background-image: linear-gradient(rgba(168, 85, 247, 0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(168, 85, 247, 0.1) 1px, transparent 1px);
            background-size: 30px 30px;
            animation: quantumGridMove 0.6s steps(6) forwards;
        }
        @keyframes quantumGridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(30px, 30px); }
        }

        /* ========== v45.0: AI Neural Spark ========== */
        .neural-spark-container { position: relative; width: 100%; height: 40px; margin: 6px 0; }
        .neural-spark-canvas { width: 100%; height: 100%; border-radius: 8px; }
        .neural-spark-label {
            position: absolute; top: 3px; left: 6px;
            font-size: 8px; font-weight: 600;
            color: rgba(0, 212, 255, 0.6);
            letter-spacing: 1px; text-transform: uppercase;
            font-family: 'JetBrains Mono', monospace;
        }

        /* ========== v45.0: Floating Action Orb ========== */
        .fab-orb {
            position: fixed; bottom: 24px; right: 24px;
            width: 52px; height: 52px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 100;
            box-shadow: 0 4px 20px rgba(255, 200, 100, 0.4), 0 0 40px rgba(255, 200, 100, 0.2);
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
        }
        .fab-orb:hover { transform: scale(1.15); box-shadow: 0 6px 30px rgba(255, 200, 100, 0.6), 0 0 60px rgba(255, 200, 100, 0.3); }
        .fab-orb:active { transform: scale(0.95); }
        .fab-orb-icon { font-size: 20px; filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.8)); transition: transform 0.4s ease; }
        .fab-orb.expanded .fab-orb-icon { transform: rotate(45deg); }
        .fab-orb-menu {
            position: absolute; bottom: 64px; right: 0;
            display: flex; flex-direction: column; gap: 10px;
            opacity: 0; transform: translateY(20px) scale(0.8);
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .fab-orb.expanded .fab-orb-menu { opacity: 1; transform: translateY(0) scale(1); pointer-events: all; }
        .fab-orb-menu-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 16px;
            background: rgba(20, 20, 30, 0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px; color: var(--text-primary);
            font-size: 13px; font-weight: 500;
            cursor: pointer; white-space: nowrap;
            transition: all 0.2s ease;
        }
        .fab-orb-menu-item:hover { background: rgba(40, 40, 60, 0.95); border-color: rgba(255, 200, 100, 0.4); transform: translateX(-4px); }

        /* ========== v45.0: Scroll-driven Card Reveal ========== */
        @keyframes v45CardReveal {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        .v45-reveal { animation: v45CardReveal 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
        .v45-reveal-1 { animation-delay: 0.05s; }
        .v45-reveal-2 { animation-delay: 0.1s; }
        .v45-reveal-3 { animation-delay: 0.15s; }
        .v45-reveal-4 { animation-delay: 0.2s; }
        .v45-reveal-5 { animation-delay: 0.25s; }
        .v45-reveal-6 { animation-delay: 0.3s; }

        /* ========== v45.0: Status Glow Ribbon ========== */
        .status-glow-ribbon {
            position: absolute; top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), var(--accent), transparent);
            background-size: 200% 100%;
            animation: ribbonFlow 3s linear infinite;
            border-radius: 2px 2px 0 0;
        }
        @keyframes ribbonFlow {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ========== v45.0: Mini Event Timeline ========== */
        .mini-timeline { display: flex; gap: 6px; overflow-x: auto; padding: 6px 0; scrollbar-width: none; }
        .mini-timeline::-webkit-scrollbar { display: none; }
        .mini-timeline-item {
            flex-shrink: 0; display: flex; flex-direction: column;
            align-items: center; gap: 3px;
            padding: 6px 10px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 10px; min-width: 60px;
            transition: all 0.3s ease;
        }
        .mini-timeline-item:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 200, 100, 0.2); transform: translateY(-2px); }
        .mini-timeline-icon { font-size: 14px; }
        .mini-timeline-label { font-size: 9px; font-weight: 600; color: rgba(255, 255, 255, 0.5); text-align: center; max-width: 50px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .mini-timeline-time { font-size: 8px; color: rgba(255, 255, 255, 0.3); font-family: 'JetBrains Mono', monospace; }

        /* ========== v45.0: Glitch Text Effect ========== */
        .glitch-text { position: relative; display: inline-block; }
        .glitch-text::before, .glitch-text::after {
            content: attr(data-text);
            position: absolute; inset: 0;
            clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
        }
        .glitch-text::before { color: var(--accent); animation: glitchBefore 3s infinite; }
        .glitch-text::after { color: var(--primary); animation: glitchAfter 3s infinite; }
        @keyframes glitchBefore {
            0%, 90%, 100% { clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%); transform: translate(0); }
            92% { clip-path: polygon(0 10%, 100% 10%, 100% 25%, 0 25%); transform: translate(-2px, 1px); }
            94% { clip-path: polygon(0 60%, 100% 60%, 100% 75%, 0 75%); transform: translate(2px, -1px); }
        }
        @keyframes glitchAfter {
            0%, 90%, 100% { clip-path: polygon(0 55%, 100% 55%, 100% 70%, 0 70%); transform: translate(0); }
            91% { clip-path: polygon(0 20%, 100% 20%, 100% 35%, 0 35%); transform: translate(2px, 1px); }
            93% { clip-path: polygon(0 70%, 100% 70%, 100% 85%, 0 85%); transform: translate(-2px, -1px); }
        }

        /* ========== v45.0: Morphing Status Badge ========== */
        .morph-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 4px 12px; border-radius: 20px;
            font-size: 11px; font-weight: 600; letter-spacing: 0.5px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            cursor: pointer;
        }
        .morph-badge:hover { background: rgba(255, 200, 100, 0.15); border-color: rgba(255, 200, 100, 0.4); transform: scale(1.05); }
        .morph-badge-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--primary);
            animation: morphDotPulse 2s ease-in-out infinite;
        }
        @keyframes morphDotPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.4); opacity: 0.7; }
        }

        /* ========== v45.0: Floating Emoji Reactions ========== */
        .emoji-float-container {
            position: fixed; bottom: 100px; right: 30px;
            display: flex; flex-direction: column; gap: 8px; z-index: 50;
        }
        .emoji-float-btn {
            width: 40px; height: 40px; border-radius: 50%;
            background: rgba(20, 20, 30, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            opacity: 0.7;
        }
        .emoji-float-btn:hover { opacity: 1; transform: scale(1.15) translateY(-3px); box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3); }

        /* ========== v45.0: Float Up Animation ========== */
        @keyframes floatUp {
            0% { opacity: 1; transform: translateY(0) scale(1); }
            100% { opacity: 0; transform: translateY(-120px) scale(0.6); }
        }

        /* ========== v46.0: Enhanced Reduced Motion ========== */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
            }
            .fox-canvas, .neural-canvas, .particle-mesh-canvas,
            .neural-waveform-canvas, .neural-spark-canvas {
                display: none;
            }
            canvas { display: none; }
        }

        /* ========== v46.0: Scroll to Top Button ========== */
        .scroll-to-top {
            position: fixed;
            bottom: 90px;
            right: 28px;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: rgba(20, 20, 30, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 90;
            opacity: 0;
            transform: translateY(20px) scale(0.8);
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
        }
        .scroll-to-top.visible {
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: all;
        }
        .scroll-to-top:hover {
            background: rgba(40, 40, 60, 0.95);
            border-color: rgba(255, 200, 100, 0.4);
            transform: translateY(-3px) scale(1.1);
        }
        .scroll-to-top svg { width: 18px; height: 18px; color: var(--text-primary); }

        /* ========== v46.0: Toast Queue Enhancements ========== */
        .toast-queue {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 90vh;
            overflow: hidden;
            pointer-events: none;
        }
        .toast-v32 {
            pointer-events: all;
            max-height: 80px;
        }
        .toast-v32.exiting {
            animation: v46ToastExit 0.26s ease-out forwards;
        }
        @keyframes v46ToastExit {
            to { opacity: 0; transform: translateX(110%); }
        }
        .toast-v32 .toast-msg {
            max-width: 280px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* ========== v46.0: Pull-to-Refresh Indicator ========== */
        .ptr-indicator {
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%) translateY(-60px);
            background: rgba(20, 20, 30, 0.95);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0 0 16px 16px;
            padding: 8px 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-primary);
            z-index: 9998;
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }
        .ptr-indicator.active {
            transform: translateX(-50%) translateY(0);
        }
        .ptr-spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255, 200, 100, 0.2);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: v46Spin 0.8s linear infinite;
        }
        @keyframes v46Spin {
            to { transform: rotate(360deg); }
        }

        /* ========== v46.0: Enhanced Skeleton Loading ========== */
        .skeleton-loading {
            position: relative;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.05) !important;
            border-radius: 6px;
        }
        .skeleton-loading::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                90deg,
                transparent 0%,
                rgba(255, 200, 100, 0.12) 40%,
                rgba(255, 200, 100, 0.2) 50%,
                rgba(255, 200, 100, 0.12) 60%,
                transparent 100%
            );
            background-size: 200% 100%;
            animation: v46SkeletonShimmer 1.4s ease-in-out infinite;
        }
        @keyframes v46SkeletonShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ========== v46.0: Status Pulse Line ========== */
        .status-pulse-line {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), var(--accent), transparent);
            background-size: 200% 100%;
            animation: statusPulseFlow 2.5s linear infinite;
            opacity: 0.6;
        }
        @keyframes statusPulseFlow {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ========== v46.0: Data Stream Wire Animation ========== */
        .data-stream-wire {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent 0%, var(--accent) 20%, var(--primary) 50%, var(--accent) 80%, transparent 100%);
            background-size: 300% 100%;
            animation: dataWireFlow 4s linear infinite;
            opacity: 0;
            z-index: 9997;
            pointer-events: none;
        }
        .data-stream-wire.active { opacity: 0.4; }
        @keyframes dataWireFlow {
            0% { background-position: 300% 0; }
            100% { background-position: -300% 0; }
        }

        /* ========== v46.0: Offline Banner ========== */
        .offline-banner {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            padding: 8px 16px;
            background: rgba(255, 107, 107, 0.9);
            backdrop-filter: blur(12px);
            color: white;
            font-size: 12px;
            font-weight: 600;
            text-align: center;
            z-index: 10000;
            transform: translateY(-100%);
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .offline-banner.visible { transform: translateY(0); }
        .offline-banner svg { width: 14px; height: 14px; }

        /* ========== v46.0: Card Hover Depth ========== */
        .stat-card {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                        box-shadow 0.3s ease,
                        border-color 0.3s ease;
        }
        .stat-card:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(255, 200, 100, 0.1);
        }
        .stat-card:active {
            transform: translateY(-2px) scale(0.99);
        }

        /* ========== v46.0: Better Focus States ========== */
        *:focus { outline: none; }
        *:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
            border-radius: 4px;
        }
        button:focus-visible, .action-btn:focus-visible,
        .mood-btn:focus-visible, .stat-card:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 3px;
            box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.15);
        }

        /* ========== v46.0: Improved Sparkline Hover ========== */
        .mini-trend {
            transition: opacity 0.2s ease;
            cursor: pointer;
        }
        .mini-trend:hover { opacity: 1 !important; }

        /* ========== v46.0: Fox Container Touch Feedback ========== */
        .fox-canvas-wrapper {
            cursor: pointer;
            touch-action: manipulation;
        }
        .fox-canvas-wrapper:active .fox-glow-aura {
            transform: scale(1.3);
            opacity: 0.8;
        }

        /* ========== v46.0: Dashboard Grid Mobile Enhancements ========== */
        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr !important;
                gap: 12px;
                padding: 8px;
            }
            .stat-card {
                min-height: 90px;
            }
            .fox-container {
                width: 140px !important;
                height: 140px !important;
            }
            .fox-canvas {
                width: 140px !important;
                height: 140px !important;
            }
            .glass-card {
                padding: 12px !important;
            }
            .header-right {
                gap: 6px;
            }
            .fab-orb {
                bottom: 16px;
                right: 16px;
                width: 44px;
                height: 44px;
            }
            .emoji-float-container {
                bottom: 80px;
                right: 20px;
            }
            .emoji-float-btn {
                width: 34px;
                height: 34px;
                font-size: 15px;
            }
            .scroll-to-top {
                bottom: 75px;
                right: 20px;
                width: 36px;
                height: 36px;
            }
            .mini-timeline {
                gap: 4px;
            }
            .mini-timeline-item {
                min-width: 52px;
                padding: 4px 8px;
            }
        }

        /* ========== v46.0: Better Print/Export Styles ========== */
        @media print {
            .bg-mesh, .bg-space, .bg-stars, canvas,
            .ambient-orb, .particle-mesh-canvas, .fab-orb,
            .emoji-float-container, .scroll-to-top,
            .toast-queue, .cmd-overlay { display: none !important; }
            body { background: white !important; color: black !important; }
            .glass-card { background: white !important; border: 1px solid #ccc !important; box-shadow: none !important; }
        }

        /* ========== v46.0: Swipe Gesture Support ========== */
        .stat-card.swiping {
            transition: none;
            transform: translateX(var(--swipe-x, 0)) scale(0.98);
            opacity: calc(1 - abs(var(--swipe-x, 0)) / 300);
        }

        /* ========== v46.0: Command Palette ARIA Enhancements ========== */
        .cmd-input {
            font-size: 15px;
            padding: 12px 16px;
        }
        .cmd-results {
            max-height: 320px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: rgba(255, 200, 100, 0.3) transparent;
        }
        .cmd-results::-webkit-scrollbar { width: 4px; }
        .cmd-results::-webkit-scrollbar-thumb { background: rgba(255, 200, 100, 0.3); border-radius: 4px; }

        /* ========== v46.0: AI Context Panel Auto-scroll ========== */
        .ai-context-text {
            max-height: 60px;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        /* ========== v46.0: Recovery Badge Animation ========== */
        .recovery-mode {
            animation: v46RecoveryPulse 1.5s ease-in-out infinite;
        }
        @keyframes v46RecoveryPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        /* ========== v46.0: Mood Sync Ring Glow ========== */
        .mood-sync-ring.active {
            animation: v46MoodGlow 3s ease-in-out infinite;
        }
        @keyframes v46MoodGlow {
            0%, 100% { opacity: 0.4; box-shadow: 0 0 8px currentColor; }
            50% { opacity: 0.8; box-shadow: 0 0 20px currentColor; }
        }

        /* ========== v46.0: Metrics Pill Better Overflow ========== */
        .metrics-row {
            flex-wrap: wrap;
            gap: 6px;
        }
        .metric-pill {
            font-size: 10px;
            padding: 3px 8px;
        }

        /* ========== v46.0: Memory Gauge Centered Better ========== */
        .memory-gauge-container {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ========== v46.0: Footer Info Better Spacing ========== */
        .footer-info {
            gap: 12px;
            flex-wrap: wrap;
            font-size: 11px;
        }
        .footer-version {
            font-size: 11px !important;
            padding: 2px 8px !important;
        }

        /* ========== v47.0: oklch Modern Color System ========== */
        :root {
            /* v47.0: Perceptually uniform oklch colors for vibrant, accurate gradients */
            --oklch-primary: oklch(78% 0.16 85);
            --oklch-accent: oklch(80% 0.17 200);
            --oklch-success: oklch(75% 0.15 155);
            --oklch-warning: oklch(80% 0.15 90);
            --oklch-danger: oklch(65% 0.2 25);
            --oklch-purple: oklch(65% 0.18 300);
            --oklch-pink: oklch(70% 0.18 340);
            /* v47.0: Dynamic color transitions */
            --color-transition: background-color 0.4s ease, border-color 0.3s ease, color 0.3s ease;
        }

        /* ========== v47.0: Fluid Typography with clamp() ========== */
        .fox-name {
            font-size: clamp(1.4rem, 4vw, 2.2rem);
        }
        .fox-role {
            font-size: clamp(0.7rem, 2vw, 0.9rem);
        }
        .stat-value {
            font-size: clamp(1.1rem, 3vw, 1.5rem);
        }
        .stat-label {
            font-size: clamp(0.65rem, 1.5vw, 0.8rem);
        }
        .footer-version {
            font-size: clamp(0.6rem, 1.5vw, 0.75rem);
        }

        /* ========== v47.0: Modern Popover API Tooltips ========== */
        [popover] {
            background: rgba(15, 15, 25, 0.92);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 8px 14px;
            font-size: 12px;
            color: var(--text);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            animation: v47PopoverIn 0.2s ease-out;
        }
        @keyframes v47PopoverIn {
            from { opacity: 0; transform: scale(0.9) translateY(4px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
        [popover]:popover-open {
            animation: v47PopoverIn 0.2s ease-out;
        }
        [popover]::backdrop {
            background: transparent;
        }

        /* ========== v47.0: Modern ::selection Styling ========== */
        ::selection {
            background: rgba(0, 212, 255, 0.3);
            color: var(--text-bright);
        }
        ::-moz-selection {
            background: rgba(0, 212, 255, 0.3);
            color: var(--text-bright);
        }
        .stat-value::selection, .mini-stat-value::selection {
            background: rgba(255, 200, 100, 0.3);
        }

        /* ========== v47.0: Enhanced Focus States with Animated Ring ========== */
        *:focus-visible {
            outline: none;
        }
        .stat-card:focus-visible {
            outline: none;
            box-shadow: 0 0 0 3px var(--accent), 0 0 20px rgba(0, 212, 255, 0.3);
            animation: v47FocusRing 0.6s ease-out;
        }
        button:focus-visible {
            outline: none;
            box-shadow: 0 0 0 2px var(--accent), 0 0 12px rgba(0, 212, 255, 0.2);
        }
        @keyframes v47FocusRing {
            0% { box-shadow: 0 0 0 0 var(--accent); }
            50% { box-shadow: 0 0 0 6px rgba(0, 212, 255, 0.2); }
            100% { box-shadow: 0 0 0 3px var(--accent); }
        }

        /* ========== v47.0: Scroll-Driven Card Reveal v2 (view-timeline) ========== */
        @supports (animation-timeline: view()) {
            .stat-card {
                animation: v47CardReveal linear both;
                animation-timeline: view();
                animation-range: entry 0% entry 100%;
            }
            @keyframes v47CardReveal {
                from { opacity: 0; transform: translateY(40px) scale(0.95); }
                to { opacity: 1; transform: translateY(0) scale(1); }
            }
            .stat-card:nth-child(1) { animation-delay: 0ms; }
            .stat-card:nth-child(2) { animation-delay: 50ms; }
            .stat-card:nth-child(3) { animation-delay: 100ms; }
            .stat-card:nth-child(4) { animation-delay: 150ms; }
        }

        /* ========== v47.0: Interactive Swipe Cards v2 ========== */
        .stat-card.swiping {
            transition: transform 0.15s ease-out;
            will-change: transform;
        }
        .stat-card.swipe-left {
            animation: v47SwipeLeft 0.3s ease-out forwards;
        }
        @keyframes v47SwipeLeft {
            to { transform: translateX(-120%) rotate(-5deg); opacity: 0.5; }
        }
        .stat-card.swipe-right {
            animation: v47SwipeRight 0.3s ease-out forwards;
        }
        @keyframes v47SwipeRight {
            to { transform: translateX(120%) rotate(5deg); opacity: 0.5; }
        }

        /* ========== v47.0: Glass Reflection v2 with Chromatic Aberration ========== */
        .glass-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            padding: 1px;
            background: linear-gradient(
                135deg,
                rgba(255, 200, 100, 0.3) 0%,
                rgba(0, 212, 255, 0.2) 30%,
                rgba(168, 85, 247, 0.2) 60%,
                rgba(255, 200, 100, 0.1) 100%
            );
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            animation: v47GlassShift 4s ease-in-out infinite;
        }
        @keyframes v47GlassShift {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }
        .stat-card::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(
                135deg,
                rgba(255, 255, 255, 0.08) 0%,
                transparent 40%,
                transparent 60%,
                rgba(255, 255, 255, 0.03) 100%
            );
            pointer-events: none;
        }

        /* ========== v47.0: Micro-bounce Tap Interactions ========== */
        .action-btn, .mood-btn, .fab-orb-menu-item {
            transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .action-btn:active, .mood-btn:active {
            transform: scale(0.9);
        }
        .action-btn:hover, .mood-btn:hover {
            transform: translateY(-2px) scale(1.05);
        }

        /* ========== v47.0: Ambient Gradient Orb v3 - Morphing Blobs ========== */
        .ambient-orb {
            filter: blur(60px);
            animation: v47OrbMorph 12s ease-in-out infinite;
        }
        .ambient-orb-1 {
            background: radial-gradient(circle, var(--oklch-primary) 0%, transparent 70%);
            animation-delay: 0s;
        }
        .ambient-orb-2 {
            background: radial-gradient(circle, var(--oklch-accent) 0%, transparent 70%);
            animation-delay: -3s;
        }
        .ambient-orb-3 {
            background: radial-gradient(circle, var(--oklch-purple) 0%, transparent 70%);
            animation-delay: -6s;
        }
        .ambient-orb-4 {
            background: radial-gradient(circle, var(--oklch-pink) 0%, transparent 70%);
            animation-delay: -9s;
        }
        @keyframes v47OrbMorph {
            0%, 100% { transform: translate(0, 0) scale(1); border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            25% { transform: translate(2vw, -3vh) scale(1.1); border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
            50% { transform: translate(-1vw, 2vh) scale(0.95); border-radius: 50% 60% 30% 60% / 30% 40% 70% 60%; }
            75% { transform: translate(1.5vw, 1vh) scale(1.05); border-radius: 40% 30% 60% 50% / 60% 50% 40% 30%; }
        }

        /* ========== v47.0: Modern Context Menu Styling ========== */
        .context-menu {
            position: fixed;
            background: rgba(15, 15, 25, 0.95);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 6px;
            min-width: 180px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
            z-index: 9999;
            animation: v47ContextMenuIn 0.15s ease-out;
        }
        @keyframes v47ContextMenuIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
        .context-menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
            color: var(--text);
            cursor: pointer;
            transition: all 0.15s ease;
        }
        .context-menu-item:hover {
            background: rgba(255, 200, 100, 0.1);
            color: var(--primary);
        }
        .context-menu-divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.06);
            margin: 4px 0;
        }

        /* ========== v47.0: Cursor Grab Effect ========== */
        .draggable { cursor: grab; }
        .draggable:active { cursor: grabbing; }
        .grab-cursor { cursor: grab; }

        /* ========== v47.0: Status-Based Theme Transitions ========== */
        body.status-idle {
            --theme-accent: var(--primary);
            transition: --theme-accent 0.5s ease;
        }
        body.status-working {
            --theme-accent: var(--accent);
        }
        body.status-sleeping {
            --theme-accent: var(--purple);
        }
        body.status-excited {
            --theme-accent: var(--pink);
        }
        body.status-error {
            --theme-accent: var(--danger);
        }

        /* ========== v47.0: Smooth Scroll Snap Enhancements ========== */
        .dashboard-container {
            scroll-snap-type: y proximity;
            scroll-padding: 20px;
        }
        .dashboard-container > * {
            scroll-snap-align: start;
        }

        /* ========== v47.0: Loading Skeleton Shimmer v2 ========== */
        @keyframes v47Shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        .skeleton-loading {
            background: linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.04) 0%,
                rgba(255, 255, 255, 0.08) 20%,
                rgba(255, 255, 255, 0.12) 40%,
                rgba(255, 255, 255, 0.08) 60%,
                rgba(255, 255, 255, 0.04) 80%
            );
            background-size: 200% 100%;
            animation: v47Shimmer 1.5s ease-in-out infinite;
        }

        /* ========== v47.0: Toast Entrance/Exit v2 ========== */
        @keyframes v47ToastEnter {
            from { opacity: 0; transform: translateX(100%) scale(0.8); }
            to { opacity: 1; transform: translateX(0) scale(1); }
        }
        .toast-v32 {
            animation: v47ToastEnter 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* ========== v47.0: Progress Bar Animated Stripes ========== */
        .progress-fill {
            background-image: linear-gradient(
                45deg,
                rgba(255, 255, 255, 0.1) 25%,
                transparent 25%,
                transparent 50%,
                rgba(255, 255, 255, 0.1) 50%,
                rgba(255, 255, 255, 0.1) 75%,
                transparent 75%,
                transparent
            );
            background-size: 20px 20px;
            animation: v47ProgressStripes 1s linear infinite;
        }
        @keyframes v47ProgressStripes {
            from { background-position: 0 0; }
            to { background-position: 20px 0; }
        }

        /* ========== v47.0: AI Status Breathing Glow ========== */
        .ai-status-badge.active {
            animation: v47AIGlow 2s ease-in-out infinite;
        }
        @keyframes v47AIGlow {
            0%, 100% { box-shadow: 0 0 8px rgba(255, 200, 100, 0.3), 0 0 16px rgba(255, 200, 100, 0.1); }
            50% { box-shadow: 0 0 16px rgba(255, 200, 100, 0.5), 0 0 32px rgba(255, 200, 100, 0.2); }
        }

        /* ========== v47.0: Magnetic Hover Effect ========== */
        .magnetic-hover {
            transition: transform 0.2s ease;
        }
        .magnetic-hover:hover {
            transform: translate(var(--mx, 0), var(--my, 0));
        }

        /* ========== v47.0: Interactive Ripple v2 ========== */
        .ripple-v2 {
            position: relative;
            overflow: hidden;
        }
        .ripple-v2 .ripple-circle {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: scale(0);
            animation: v47Ripple 0.6s ease-out;
            pointer-events: none;
        }
        @keyframes v47Ripple {
            to { transform: scale(4); opacity: 0; }
        }

        /* ========== v47.0: Staggered Entrance Delays ========== */
        .v47-stagger > *:nth-child(1) { animation-delay: 0ms; }
        .v47-stagger > *:nth-child(2) { animation-delay: 50ms; }
        .v47-stagger > *:nth-child(3) { animation-delay: 100ms; }
        .v47-stagger > *:nth-child(4) { animation-delay: 150ms; }
        .v47-stagger > *:nth-child(5) { animation-delay: 200ms; }
        .v47-stagger > *:nth-child(6) { animation-delay: 250ms; }

        /* ========== v48.0: Enhanced Data Reliability System ========== */

        /* v48.0: Reliability Score with Animated Ring */
        @keyframes v48ReliabilityPulse {
            0%, 100% { opacity: 0.7; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.08); }
        }

        .v48-reliability-ring {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 48px;
            height: 48px;
        }

        .v48-reliability-ring svg {
            position: absolute;
            inset: 0;
            transform: rotate(-90deg);
        }

        .v48-reliability-ring .ring-bg {
            stroke: rgba(255,255,255,0.08);
            fill: none;
        }

        .v48-reliability-ring .ring-fill {
            fill: none;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.6s cubic-bezier(0.16, 1, 0.3, 1), stroke 0.4s ease;
        }

        .v48-reliability-ring .ring-value {
            font-size: 12px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-bright);
            z-index: 1;
        }

        .v48-reliability-ring.high .ring-fill { stroke: var(--success); }
        .v48-reliability-ring.medium .ring-fill { stroke: var(--warning); }
        .v48-reliability-ring.low .ring-fill { stroke: var(--danger); }

        /* v48.0: Data Source Attribution Tag */
        .v48-source-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-full);
            font-size: 10px;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
            transition: all 0.3s ease;
        }

        .v48-source-tag:hover {
            background: rgba(255,255,255,0.09);
            transform: translateY(-1px);
        }

        .v48-source-tag .source-icon {
            font-size: 11px;
        }

        .v48-source-tag.api { border-color: rgba(0,212,255,0.25); background: rgba(0,212,255,0.08); color: var(--accent); }
        .v48-source-tag.cache { border-color: rgba(168,85,247,0.25); background: rgba(168,85,247,0.08); color: var(--purple); }
        .v48-source-tag.local { border-color: rgba(92,219,149,0.25); background: rgba(92,219,149,0.08); color: var(--success); }

        /* v48.0: Data Freshness Timeline */
        .v48-freshness-bar {
            position: relative;
            height: 4px;
            background: rgba(255,255,255,0.08);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .v48-freshness-fill {
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            border-radius: var(--radius-full);
            transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;
        }

        .v48-freshness-fill.fresh { background: var(--success); }
        .v48-freshness-fill.stale { background: var(--warning); }
        .v48-freshness-fill.critical { background: var(--danger); }

        /* v48.0: Last Updated Tooltip */
        .v48-last-updated {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 10px;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
            cursor: help;
            transition: color 0.2s ease;
        }

        .v48-last-updated:hover { color: var(--text-muted); }

        .v48-last-updated .update-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--success);
            animation: pulse 2s ease-in-out infinite;
        }

        /* v48.0: Health Check Interval Indicator */
        .v48-health-interval {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-md);
            font-size: 10px;
            color: var(--text-muted);
        }

        .v48-health-interval .interval-bar {
            display: flex;
            gap: 2px;
        }

        .v48-health-interval .interval-dot {
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--text-dim);
            transition: background 0.3s ease;
        }

        .v48-health-interval .interval-dot.active { background: var(--success); }
        .v48-health-interval .interval-dot.next { background: var(--warning); }

        /* ========== v48.0: AI Agent Context Panel ========== */

        /* v48.0: Agent Processing State Indicator */
        @keyframes v48ProcessingWave {
            0% { transform: translateX(-100%); opacity: 0.6; }
            100% { transform: translateX(200%); opacity: 0; }
        }

        .v48-processing-wave {
            position: relative;
            overflow: hidden;
            background: linear-gradient(90deg, rgba(168,85,247,0.15) 0%, rgba(0,212,255,0.15) 100%);
            border: 1px solid rgba(168,85,247,0.25);
        }

        .v48-processing-wave::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(168,85,247,0.3) 50%, transparent 100%);
            animation: v48ProcessingWave 1.5s ease-in-out infinite;
        }

        /* v48.0: AI Context Chip */
        .v48-ai-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            background: linear-gradient(135deg, rgba(168,85,247,0.15), rgba(0,212,255,0.1));
            border: 1px solid rgba(168,85,247,0.3);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--purple);
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .v48-ai-chip:hover {
            background: linear-gradient(135deg, rgba(168,85,247,0.25), rgba(0,212,255,0.2));
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(168,85,247,0.25);
        }

        .v48-ai-chip .chip-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--purple);
            box-shadow: 0 0 6px var(--purple);
        }

        .v48-ai-chip.processing .chip-dot {
            animation: v48ChipPulse 0.8s ease-in-out infinite;
        }

        @keyframes v48ChipPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.4); opacity: 0.7; }
        }

        /* v48.0: Agent Capability Badge */
        .v48-capability-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 8px;
            background: rgba(92,219,149,0.12);
            border: 1px solid rgba(92,219,149,0.25);
            border-radius: var(--radius-full);
            font-size: 10px;
            color: var(--success);
            transition: all 0.25s ease;
        }

        .v48-capability-badge:hover {
            background: rgba(92,219,149,0.2);
            transform: scale(1.05);
        }

        /* v48.0: Skills Radar Chart Container */
        .v48-radar-container {
            position: relative;
            width: 100%;
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .v48-radar-canvas {
            width: 120px;
            height: 120px;
        }

        /* v48.0: Memory Usage Bar */
        .v48-memory-bar {
            position: relative;
            height: 8px;
            background: rgba(255,255,255,0.08);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .v48-memory-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--success), var(--accent));
            border-radius: var(--radius-full);
            transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
        }

        .v48-memory-fill::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: v48MemoryShimmer 2s ease-in-out infinite;
        }

        @keyframes v48MemoryShimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(200%); }
        }

        /* ========== v48.0: Micro-Interactions & Spring Animations ========== */

        /* v48.0: Spring Press Button Effect */
        .v48-spring-press {
            transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .v48-spring-press:active {
            transform: scale(0.92);
            transition: transform 0.08s ease;
        }

        /* v48.0: Magnetic Hover - Cards are pulled toward cursor */
        .v48-magnetic-card {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                        box-shadow 0.25s ease;
        }

        /* v48.0: Ripple Effect Enhancement */
        .v48-ripple-container {
            position: absolute;
            inset: 0;
            overflow: hidden;
            border-radius: inherit;
            pointer-events: none;
        }

        .v48-ripple {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.35) 0%, transparent 70%);
            transform: scale(0);
            animation: v48RippleExpand 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            pointer-events: none;
        }

        @keyframes v48RippleExpand {
            to { transform: scale(4); opacity: 0; }
        }

        /* v48.0: Value Change Flash */
        @keyframes v48ValueFlash {
            0% { background: transparent; }
            30% { background: rgba(255,200,100,0.2); }
            100% { background: transparent; }
        }

        .v48-value-flash {
            animation: v48ValueFlash 0.5s ease-out;
        }

        /* v48.0: Tab Switch Animation */
        @keyframes v48TabSlide {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .v48-tab-content {
            animation: v48TabSlide 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* v48.0: Notification Badge Bounce */
        @keyframes v48BadgeBounce {
            0%, 100% { transform: scale(1); }
            30% { transform: scale(1.3); }
            60% { transform: scale(0.9); }
            80% { transform: scale(1.1); }
        }

        .v48-notification-badge {
            animation: v48BadgeBounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* v48.0: Loading Skeleton Pulse */
        @keyframes v48SkeletonPulse {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 0.7; }
        }

        .v48-skeleton-pulse {
            animation: v48SkeletonPulse 1.5s ease-in-out infinite;
        }

        /* ========== v48.0: Modern CSS Features ========== */

        /* v48.0: Scroll-Driven Card Reveal - uses animation-timeline: view() */
        @keyframes v48CardReveal {
            from {
                opacity: 0;
                transform: translateY(24px) scale(0.97);
                filter: blur(2px);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
                filter: blur(0);
            }
        }

        .v48-scroll-reveal {
            animation: v48CardReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            animation-timeline: view();
            animation-range: entry 0% entry 100%;
        }

        /* v48.0: View Transition Name for Smooth State Changes */
        @supports (view-transition-name: none) {
            .fox-canvas-wrapper {
                view-transition-name: fox-avatar;
            }

            ::view-transition-old(fox-avatar),
            ::view-transition-new(fox-avatar) {
                animation-duration: 0.4s;
                animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
            }
        }

        /* v48.0: Container Query Card Grid */
        .v48-card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        /* v48.0: Color Palette Animation */
        @keyframes v48ColorShift {
            0% { filter: hue-rotate(0deg) saturate(1); }
            25% { filter: hue-rotate(10deg) saturate(1.1); }
            50% { filter: hue-rotate(0deg) saturate(1); }
            75% { filter: hue-rotate(-10deg) saturate(0.95); }
            100% { filter: hue-rotate(0deg) saturate(1); }
        }

        .v48-color-animate {
            animation: v48ColorShift 8s ease-in-out infinite;
        }

        /* v48.0: Smooth Anchor with Scroll-Driven Animation */
        @supports (animation-timeline: scroll()) {
            .v48-scroll-indicator {
                animation: v48ScrollBounce linear both;
                animation-timeline: scroll();
                animation-range: 0px 100px;
            }
        }

        @keyframes v48ScrollBounce {
            from { opacity: 0.8; transform: translateY(0); }
            to { opacity: 0; transform: translateY(20px); }
        }

        /* v48.0: Enhanced Reduced Motion */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }

            .v48-magnetic-card,
            .v48-spring-press,
            .stat-card,
            .mini-stat,
            .action-btn,
            .glass-card {
                transition: none !important;
                transform: none !important;
            }

            .v48-processing-wave::after,
            .v48-memory-fill::after {
                animation: none !important;
            }
        }

        /* ========== v48.0: New UI Components ========== */

        /* v48.0: Keyboard Shortcut Hints */
        .v48-kbd-hint {
            position: fixed;
            bottom: 20px;
            left: 20px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            z-index: 500;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
        }

        .v48-kbd-hint.visible {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }

        .v48-kbd-row {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            background: rgba(10,10,20,0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: var(--radius-md);
            font-size: 11px;
            color: var(--text-muted);
        }

        .v48-kbd-row kbd {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 22px;
            padding: 2px 6px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 4px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: var(--text-bright);
        }

        /* v48.0: Live Event Ticker */
        .v48-event-ticker {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-md);
            overflow: hidden;
            position: relative;
        }

        .v48-event-ticker .ticker-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
            flex-shrink: 0;
        }

        .v48-event-ticker .ticker-content {
            flex: 1;
            white-space: nowrap;
            overflow: hidden;
        }

        .v48-event-ticker .ticker-text {
            display: inline-block;
            font-size: 12px;
            color: var(--text);
            animation: v48TickerScroll 15s linear infinite;
        }

        @keyframes v48TickerScroll {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        /* v48.0: Status Transition Matrix */
        .v48-status-matrix {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
            gap: 8px;
            margin-top: 12px;
        }

        .v48-status-cell {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 8px 6px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius-md);
            transition: all 0.25s ease;
            cursor: pointer;
        }

        .v48-status-cell:hover {
            background: rgba(255,255,255,0.08);
            transform: translateY(-3px);
            border-color: rgba(255,255,255,0.12);
        }

        .v48-status-cell.active {
            background: rgba(255,200,100,0.12);
            border-color: rgba(255,200,100,0.35);
        }

        .v48-status-cell .cell-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--text-dim);
        }

        .v48-status-cell.active .cell-dot {
            box-shadow: 0 0 8px currentColor;
        }

        .v48-status-cell .cell-label {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            color: var(--text-muted);
        }

        /* v48.1: Footer v48 Badge */
        .v48-footer-badge {
            padding: 4px 10px;
            background: linear-gradient(135deg, rgba(168,85,247,0.18), rgba(0,212,255,0.12));
            border: 1px solid rgba(168,85,247,0.35);
            border-radius: var(--radius-full);
            font-size: 11px;
            font-family: 'JetBrains Mono', monospace;
            color: var(--purple);
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .v48-footer-badge::before {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--purple);
            box-shadow: 0 0 6px var(--purple);
            animation: pulse 2s ease-in-out infinite;
        }

        .v48-footer-badge:hover {
            background: linear-gradient(135deg, rgba(168,85,247,0.28), rgba(0,212,255,0.22));
            transform: scale(1.05);
            box-shadow: 0 0 16px rgba(168,85,247,0.3);
        }

        /* ========== v48.1: Enhanced Visual Effects ========== */
        
        /* v48.1: Liquid Glass 2.0 - iOS-inspired depth effect */
        .liquid-glass {
            background: linear-gradient(
                135deg,
                rgba(255,255,255,0.12) 0%,
                rgba(255,255,255,0.08) 40%,
                rgba(255,255,255,0.04) 60%,
                rgba(255,255,255,0.08) 100%
            );
            backdrop-filter: blur(24px) saturate(180%);
            -webkit-backdrop-filter: blur(24px) saturate(180%);
            border: 1px solid rgba(255,255,255,0.15);
            box-shadow: 
                0 8px 32px rgba(0,0,0,0.4),
                inset 0 1px 1px rgba(255,255,255,0.2),
                inset 0 -1px 1px rgba(0,0,0,0.1);
            position: relative;
        }
        
        .liquid-glass::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 40%;
            background: linear-gradient(
                180deg,
                rgba(255,255,255,0.15) 0%,
                rgba(255,255,255,0.05) 50%,
                transparent 100%
            );
            pointer-events: none;
            border-radius: inherit;
        }
        
        /* v48.1: Spectral Glow Border */
        .spectral-border {
            position: relative;
        }
        
        .spectral-border::before {
            content: '';
            position: absolute;
            inset: -2px;
            background: conic-gradient(
                from var(--glow-angle, 0deg),
                var(--primary),
                var(--accent),
                var(--purple),
                var(--pink),
                var(--primary)
            );
            border-radius: inherit;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.4s ease;
            animation: spectralRotate 4s linear infinite;
        }
        
        .spectral-border:hover::before,
        .spectral-border.active::before {
            opacity: 1;
        }
        
        @keyframes spectralRotate {
            to { --glow-angle: 360deg; }
            from { --glow-angle: 0deg; }
        }
        
        /* v48.1: Morphing Card Effect */
        .morph-card {
            transition: border-radius 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .morph-card:hover {
            border-radius: 28px;
        }
        
        /* v48.1: Holographic Shimmer v2 */
        .holo-shimmer-v2 {
            position: relative;
            overflow: hidden;
        }
        
        .holo-shimmer-v2::after {
            content: '';
            position: absolute;
            top: -100%;
            left: -100%;
            width: 300%;
            height: 300%;
            background: linear-gradient(
                45deg,
                transparent 30%,
                rgba(255,255,255,0.08) 50%,
                transparent 70%
            );
            animation: holoShimmerV2 3s ease-in-out infinite;
            pointer-events: none;
        }
        
        @keyframes holoShimmerV2 {
            0% { transform: translateX(-30%) translateY(-30%) rotate(0deg); }
            100% { transform: translateX(30%) translateY(30%) rotate(360deg); }
        }
        
        /* v48.1: Pulsar Animation - For active elements */
        .pulsar {
            animation: pulsarPulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        
        @keyframes pulsarPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(0.95); }
        }
        
        /* v48.1: Wave Distortion Effect */
        .wave-distort {
            filter: url(#waveDistort);
        }
        
        /* v48.1: Smart Status Indicator */
        .smart-indicator {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: var(--bg-glass);
            border-radius: var(--radius-full);
            font-size: 11px;
            color: var(--text-dim);
            transition: all 0.3s ease;
        }
        
        .smart-indicator::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--text-dim);
            transition: all 0.3s ease;
        }
        
        .smart-indicator.online::before {
            background: var(--success);
            box-shadow: 0 0 8px var(--success);
        }
        
        .smart-indicator.away::before {
            background: var(--warning);
            box-shadow: 0 0 8px var(--warning);
        }
        
        .smart-indicator.busy::before {
            background: var(--danger);
            box-shadow: 0 0 8px var(--danger);
            animation: busyPulse 1s ease-in-out infinite;
        }
        
        @keyframes busyPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.3); }
        }
        
        /* v48.1: Adaptive Layout System */
        .adaptive-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
            gap: 16px;
        }
        
        /* v48.1: Floating Label Input */
        .float-label-group {
            position: relative;
            margin: 8px 0;
        }
        
        .float-label-group input {
            width: 100%;
            padding: 16px 12px 8px;
            background: var(--bg-glass);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-md);
            color: var(--text);
            font-size: 14px;
            transition: all 0.2s ease;
        }
        
        .float-label-group input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(0,212,255,0.15);
        }
        
        .float-label-group label {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-dim);
            font-size: 14px;
            pointer-events: none;
            transition: all 0.2s ease;
        }
        
        .float-label-group input:focus + label,
        .float-label-group input:not(:placeholder-shown) + label {
            top: 8px;
            font-size: 10px;
            color: var(--accent);
        }
        
        /* v48.1: Magnetic Pull Effect */
        .magnetic-pull {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        /* v48.1: Glitch Text Effect v2 */
        .glitch-v2 {
            position: relative;
        }
        
        .glitch-v2::before,
        .glitch-v2::after {
            content: attr(data-text);
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            opacity: 0.8;
        }
        
        .glitch-v2::before {
            color: var(--primary);
            animation: glitchV2Left 0.3s ease-in-out infinite alternate-reverse;
            clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
        }
        
        .glitch-v2::after {
            color: var(--accent);
            animation: glitchV2Right 0.3s ease-in-out infinite alternate;
            clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%);
        }
        
        @keyframes glitchV2Left {
            to { transform: translateX(-2px); }
        }
        
        @keyframes glitchV2Right {
            to { transform: translateX(2px); }
        }
        
        /* v48.1: Neural Network Pulse */
        .neural-pulse {
            position: relative;
        }
        
        .neural-pulse::before {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: inherit;
            background: conic-gradient(
                from 0deg,
                transparent,
                var(--primary),
                transparent
            );
            animation: neuralPulse 2s linear infinite;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .neural-pulse:hover::before {
            opacity: 0.6;
        }
        
        @keyframes neuralPulse {
            to { transform: rotate(360deg); }
        }
        
        /* ========== v48.0: Performance & Accessibility ========== */

        /* v48.0: GPU-Accelerated Layer */
        .v48-gpu-layer {
            transform: translateZ(0);
            will-change: transform, opacity;
            backface-visibility: hidden;
        }

        /* v48.0: Touch-Friendly Tap Highlight */
        @media (hover: none) {
            .stat-card,
            .mini-stat,
            .action-btn {
                -webkit-tap-highlight-color: rgba(255,200,100,0.15);
            }
        }

        /* v48.0: High Contrast Mode Support */
        @media (prefers-contrast: high) {
            .glass-card,
            .stat-card,
            .mini-stat {
                border-width: 2px;
                border-color: rgba(255,255,255,0.25);
            }
        }

        /* v48.0: Dark/Dimmed Theme Variants */
        body.theme-dim .ambient-orb { opacity: 0.08; }
        body.theme-bright {
            --bg-dark: #12121a;
            --bg-card: rgba(255,255,255,0.95);
            --text: #1a1a2e;
            --text-bright: #0a0a14;
        }

        /* v48.0: Print optimization */
        @media print {
            .v48-kbd-hint,
            .glow-cursor,
            .cursor-trail-particle,
            .fab-orb,
            .emoji-float-container,
            .noise-overlay,
            .scroll-progress {
                display: none !important;
            }
            .glass-card { background: white !important; border: 1px solid #ccc !important; }
        }

        /* ========== v48.2: Performance & Modern CSS Enhancements ========== */

        /* v48.2: CSS @scope for encapsulated styles (modern CSS) */
        @scope (.stat-card) to (.stat-value) {
            :scope:hover .stat-value {
                text-shadow: 0 0 12px currentColor;
            }
        }

        /* v48.2: Improved content-visibility for heavy elements */
        .fox-canvas-container,
        .neural-canvas,
        .ambient-canvas,
        .particle-container {
            content-visibility: auto;
            contain-intrinsic-size: 300px 300px;
        }

        /* v48.2: Scroll-driven entrance animations using CSS Scroll Timeline */
        @supports (animation-timeline: scroll()) {
            .stat-card {
                animation: cardReveal linear both;
                animation-timeline: view();
                animation-range: entry 0% entry 100%;
            }

            @keyframes cardReveal {
                from {
                    opacity: 0;
                    transform: translateY(20px) scale(0.95);
                }
                to {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }
            }
        }

        /* v48.2: Native smooth scrolling with scroll-behavior */
        :root {
            scroll-behavior: smooth;
            scroll-timeline-axis: block;
        }

        /* v48.2: Enhanced :focus-visible with multi-ring effect */
        :focus-visible {
            outline: none;
            box-shadow:
                0 0 0 2px var(--bg-dark),
                0 0 0 4px var(--accent),
                0 0 16px var(--accent-glow);
            border-radius: 4px;
        }

        /* v48.2: Spring-based bounce animation using cubic-bezier */
        @keyframes v48SpringBounce {
            0% { transform: scale(1); }
            25% { transform: scale(1.08); }
            50% { transform: scale(0.96); }
            75% { transform: scale(1.03); }
            100% { transform: scale(1); }
        }

        .spring-bounce {
            animation: v48SpringBounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* v48.2: Real-time data stream effect for stat values */
        @keyframes v48DataFlow {
            0% {
                background-position: 0% 50%;
                text-shadow: 0 0 8px var(--accent);
            }
            50% {
                background-position: 100% 50%;
                text-shadow: 0 0 16px var(--accent-glow);
            }
            100% {
                background-position: 0% 50%;
                text-shadow: 0 0 8px var(--accent);
            }
        }

        .v48-data-flow {
            background: linear-gradient(90deg, var(--accent), var(--primary), var(--accent));
            background-size: 200% 100%;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: v48DataFlow 3s ease infinite;
        }

        /* v48.2: Morphing blob using modern CSS animation */
        @keyframes v48BlobMorph {
            0%, 100% {
                border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
            }
            25% {
                border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
            }
            50% {
                border-radius: 50% 60% 30% 60% / 30% 60% 70% 40%;
            }
            75% {
                border-radius: 60% 40% 60% 30% / 70% 30% 50% 60%;
            }
        }

        .v48-morph-blob {
            animation: v48BlobMorph 8s ease-in-out infinite;
        }

        /* v48.2: Pulse glow effect for active elements */
        @keyframes v48PulseGlow {
            0%, 100% {
                box-shadow: 0 0 8px var(--accent-dim), 0 0 16px var(--accent-dim);
            }
            50% {
                box-shadow: 0 0 16px var(--accent), 0 0 32px var(--accent-glow);
            }
        }

        .v48-pulse-glow {
            animation: v48PulseGlow 2s ease-in-out infinite;
        }

        /* v48.2: Interactive cursor follower with spring physics */
        @keyframes v48CursorSpring {
            0% { transform: translate(var(--cx, 0), var(--cy, 0)) scale(1); }
            50% { transform: translate(calc(var(--cx, 0) * 0.5), calc(var(--cy, 0) * 0.5)) scale(1.2); }
            100% { transform: translate(var(--cx, 0), var(--cy, 0)) scale(1); }
        }

        /* v48.2: Neural wave animation */
        @keyframes v48NeuralWave {
            0% {
                background-position: 0% 0%;
                filter: hue-rotate(0deg);
            }
            100% {
                background-position: 200% 0%;
                filter: hue-rotate(360deg);
            }
        }

        /* v48.2: Glass panel with enhanced depth */
        .v48-glass-panel {
            background: linear-gradient(
                135deg,
                rgba(255, 255, 255, 0.1) 0%,
                rgba(255, 255, 255, 0.05) 50%,
                rgba(255, 255, 255, 0.02) 100%
            );
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow:
                0 8px 32px rgba(0, 0, 0, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.2),
                inset 0 -1px 0 rgba(0, 0, 0, 0.1);
        }

        /* v48.2: Responsive typography using clamp */
        .v48-stat-label {
            font-size: clamp(0.65rem, 1.5vw, 0.75rem);
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .v48-stat-value {
            font-size: clamp(1.25rem, 3vw, 1.75rem);
            font-weight: 700;
            font-variant-numeric: tabular-nums;
        }

        /* v48.2: Reduced motion support for new animations */
        @media (prefers-reduced-motion: reduce) {
            .v48-data-flow,
            .v48-pulse-glow,
            .v48-morph-blob,
            .spring-bounce {
                animation: none;
            }
        }

        /* v48.2: High contrast mode support */
        @media (prefers-contrast: more) {
            :root {
                --primary: #ffc864;
                --accent: #00ffff;
                --success: #7fff7f;
                --warning: #ffcc00;
                --danger: #ff4444;
            }
            .glass-card {
                border-width: 2px;
                border-color: var(--accent);
            }
        }

        /* v48.2: Dark mode scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--primary-dim), var(--accent-dim));
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, var(--primary), var(--accent));
        }

        /* v48.2: Selection color */
        ::selection {
            background: var(--accent-dim);
            color: var(--text);
        }

        /* v48.2: Live indicator with pulse animation */
        @keyframes v48LivePulse {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.5;
                transform: scale(1.2);
            }
        }

        .v48-live-dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: v48LivePulse 1.5s ease-in-out infinite;
        }

        /* ========== v48.5: Enhanced OpenClaw Status Display ========== */

        /* v48.5: OpenClaw Status Glow Ring */
        .oc-status-glow {
            position: relative;
        }
        
        .oc-status-glow::before {
            content: '';
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--success) 0%, transparent 70%);
            opacity: 0;
            filter: blur(12px);
            transition: opacity 0.5s ease;
            animation: none;
        }
        
        .oc-status-glow.active::before {
            opacity: 0.6;
            animation: ocStatusPulse 2s ease-in-out infinite;
        }
        
        .oc-status-glow.working::before {
            background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
        }
        
        .oc-status-glow.error::before {
            background: radial-gradient(circle, var(--danger) 0%, transparent 70%);
            animation: ocErrorPulse 0.8s ease-in-out infinite;
        }
        
        @keyframes ocStatusPulse {
            0%, 100% { opacity: 0.4; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.15); }
        }
        
        @keyframes ocErrorPulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }

        /* v48.5: OpenClaw Connection Indicator */
        .oc-connection-indicator {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background: rgba(92, 219, 149, 0.12);
            border: 1px solid rgba(92, 219, 149, 0.3);
            border-radius: var(--radius-full);
            font-size: 12px;
            color: var(--success);
            transition: all 0.3s ease;
        }
        
        .oc-connection-indicator.disconnected {
            background: rgba(255, 107, 107, 0.12);
            border-color: rgba(255, 107, 107, 0.3);
            color: var(--danger);
        }
        
        .oc-connection-indicator.connecting {
            background: rgba(254, 202, 87, 0.12);
            border-color: rgba(254, 202, 87, 0.3);
            color: var(--warning);
            animation: ocConnectingPulse 1.5s ease-in-out infinite;
        }
        
        @keyframes ocConnectingPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
        
        .oc-connection-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
            box-shadow: 0 0 8px currentColor;
        }

        /* v48.5: Agent Status Timeline */
        .oc-agent-timeline {
            position: relative;
            padding-left: 20px;
        }
        
        .oc-agent-timeline::before {
            content: '';
            position: absolute;
            left: 6px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(180deg, var(--accent), var(--purple), transparent);
            border-radius: 2px;
        }
        
        .oc-timeline-event {
            position: relative;
            padding: 8px 12px;
            margin-bottom: 8px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: var(--radius-sm);
            border-left: 3px solid var(--accent);
            transition: all 0.2s ease;
        }
        
        .oc-timeline-event:hover {
            background: rgba(255, 255, 255, 0.07);
            transform: translateX(4px);
        }
        
        .oc-timeline-event::before {
            content: '';
            position: absolute;
            left: -17px;
            top: 50%;
            transform: translateY(-50%);
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 8px var(--accent);
        }
        
        .oc-timeline-time {
            font-size: 10px;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
        }
        
        .oc-timeline-text {
            font-size: 12px;
            color: var(--text);
            margin-top: 2px;
        }

        /* v48.5: Real-time Metrics Grid */
        .oc-metrics-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }
        
        .oc-metric-card {
            padding: 10px 12px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: var(--radius-md);
            transition: all 0.25s ease;
        }
        
        .oc-metric-card:hover {
            background: rgba(255, 255, 255, 0.07);
            border-color: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }
        
        .oc-metric-label {
            font-size: 10px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        
        .oc-metric-value {
            font-size: 18px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-bright);
        }
        
        .oc-metric-value.positive { color: var(--success); }
        .oc-metric-value.warning { color: var(--warning); }
        .oc-metric-value.negative { color: var(--danger); }

        /* v48.5: Enhanced Card Hover Effect */
        .oc-card-hover {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                        box-shadow 0.3s ease,
                        border-color 0.3s ease;
        }
        
        .oc-card-hover:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: 
                0 12px 40px rgba(0, 0, 0, 0.4),
                0 0 30px rgba(255, 200, 100, 0.15);
        }
        
        .oc-card-hover:active {
            transform: translateY(-2px) scale(0.98);
        }

        /* v48.5: OpenClaw Status Badge */
        .oc-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(168, 85, 247, 0.1));
            border: 1px solid rgba(0, 212, 255, 0.3);
            border-radius: var(--radius-full);
            font-size: 13px;
            font-weight: 600;
            color: var(--accent);
            transition: all 0.3s ease;
        }
        
        .oc-status-badge:hover {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.25), rgba(168, 85, 247, 0.2));
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }
        
        .oc-status-badge .badge-icon {
            font-size: 16px;
        }
        
        .oc-status-badge .badge-pulse {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            animation: ocBadgePulse 1.5s ease-in-out infinite;
        }
        
        @keyframes ocBadgePulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }

        /* v48.5: Performance Stats Bar */
        .oc-perf-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: var(--radius-md);
            margin-top: 8px;
        }
        
        .oc-perf-item {
            flex: 1;
            text-align: center;
        }
        
        .oc-perf-value {
            font-size: 14px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-bright);
        }
        
        .oc-perf-label {
            font-size: 9px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 2px;
        }
        
        .oc-perf-bar .oc-perf-item:not(:last-child) {
            border-right: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* v48.5: New Modern Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--primary), var(--accent));
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, var(--primary-glow), var(--accent-glow));
        }

        /* v48.5: Animated Gradient Background */
        @keyframes ocGradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        .oc-animated-bg {
            background: linear-gradient(-45deg, #08080c, #0a0a14, #0c0c1c, #08080c);
            background-size: 400% 400%;
            animation: ocGradientShift 15s ease infinite;
        }

        /* v48.5: Quick Status Toggle */
        .oc-status-toggle {
            display: flex;
            gap: 6px;
            padding: 4px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: var(--radius-md);
        }
        
        .oc-status-toggle-btn {
            padding: 6px 12px;
            background: transparent;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 11px;
            font-weight: 600;
            color: var(--text-dim);
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .oc-status-toggle-btn:hover {
            color: var(--text);
            background: rgba(255, 255, 255, 0.06);
        }
        
        .oc-status-toggle-btn.active {
            background: var(--primary);
            color: var(--bg-dark);
        }

        /* v48.5: Data Stream Animation */
        @keyframes ocDataStream {
            0% { transform: translateX(-100%); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateX(100%); opacity: 0; }
        }
        
        .oc-data-stream {
            position: relative;
            overflow: hidden;
            height: 3px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-full);
        }
        
        .oc-data-stream::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 50%;
            background: linear-gradient(90deg, transparent, var(--accent), var(--primary), transparent);
            animation: ocDataStream 2s linear infinite;
        }

        /* v48.5: Enhanced Focus Ring */
        *:focus-visible {
            outline: none;
        }
        
        .oc-focus-ring:focus-visible {
            box-shadow: 
                0 0 0 2px var(--bg-dark),
                0 0 0 4px var(--accent),
                0 0 20px var(--accent-glow);
            border-radius: var(--radius-sm);
        }

        /* v48.5: Reduced Motion Support */
        @media (prefers-reduced-motion: reduce) {
            .oc-status-glow::before,
            .oc-status-badge .badge-pulse,
            .oc-data-stream::before {
                animation: none;
            }
            
            .oc-card-hover,
            .oc-metric-card,
            .oc-timeline-event {
                transition: none;
            }
        }

        /* ========== v50.0: Modern CSS Container Queries ========== */
        /* Container query based card grid - adapts to container width not viewport */
        .dashboard-grid {
            container-type: inline-size;
            container-name: dashboard;
        }
        
        @container dashboard (min-width: 900px) {
            .left-column { flex: 0 0 340px; }
            .right-column { flex: 1; }
        }
        
        @container dashboard (max-width: 899px) {
            .left-column, .right-column { flex: 1 1 100%; }
            .fox-container { width: 160px !important; height: 160px !important; }
        }
        
        /* v50.0: CSS :has() for parent-based styling */
        /* Card glows when it contains a value that's changed */
        .stat-card:has(.v48-value-flash) {
            animation: v50CardGlow 0.5s ease-out;
        }
        
        @keyframes v50CardGlow {
            0% { box-shadow: 0 0 0 0 rgba(255, 200, 100, 0.4); }
            50% { box-shadow: 0 0 20px 4px rgba(255, 200, 100, 0.2); }
            100% { box-shadow: none; }
        }
        
        /* v50.0: 3D Card Tilt Effect */
        .v50-tilt-card {
            transform-style: preserve-3d;
            perspective: 1000px;
            transition: transform 0.15s ease-out;
        }
        
        .v50-tilt-card:hover {
            transform: rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg)) scale(1.03);
        }
        
        .v50-tilt-card .card-face {
            position: absolute;
            inset: 0;
            backface-visibility: hidden;
            border-radius: inherit;
        }
        
        .v50-tilt-card .card-back {
            transform: rotateY(180deg);
        }
        
        /* v50.0: Magnetic Button Effect */
        .v50-magnetic-btn {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            will-change: transform;
        }
        
        /* v50.0: Spark Meter - Energy/Creativity Level */
        .v50-spark-meter {
            position: relative;
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: var(--radius-full);
            overflow: hidden;
            margin: 8px 0;
        }
        
        .v50-spark-fill {
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--pink));
            border-radius: var(--radius-full);
            transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            overflow: hidden;
        }
        
        .v50-spark-fill::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                90deg, 
                transparent 0%, 
                rgba(255, 255, 255, 0.5) 50%, 
                transparent 100%
            );
            animation: v50SparkShimmer 1.5s ease-in-out infinite;
        }
        
        @keyframes v50SparkShimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(200%); }
        }
        
        .v50-spark-dots {
            display: flex;
            justify-content: space-between;
            margin-top: 4px;
        }
        
        .v50-spark-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--text-dim);
            transition: all 0.3s ease;
        }
        
        .v50-spark-dot.active {
            background: var(--primary);
            box-shadow: 0 0 8px var(--primary);
        }
        
        .v50-spark-dot.peak {
            background: var(--accent);
            box-shadow: 0 0 10px var(--accent);
        }
        
        /* v50.0: Mood Evolution Timeline */
        .v50-mood-timeline {
            display: flex;
            gap: 8px;
            padding: 8px 0;
            overflow-x: auto;
            scrollbar-width: none;
        }
        
        .v50-mood-timeline::-webkit-scrollbar { display: none; }
        
        .v50-mood-node {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 8px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: var(--radius-md);
            min-width: 50px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .v50-mood-node:hover {
            background: rgba(255, 255, 255, 0.08);
            transform: translateY(-4px);
            border-color: rgba(255, 200, 100, 0.3);
        }
        
        .v50-mood-node.current {
            background: rgba(255, 200, 100, 0.12);
            border-color: rgba(255, 200, 100, 0.4);
            box-shadow: 0 0 16px rgba(255, 200, 100, 0.2);
        }
        
        .v50-mood-emoji {
            font-size: 20px;
            transition: transform 0.3s ease;
        }
        
        .v50-mood-node:hover .v50-mood-emoji {
            transform: scale(1.2);
        }
        
        .v50-mood-label {
            font-size: 9px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .v50-mood-node.current .v50-mood-label {
            color: var(--primary);
        }
        
        /* v50.0: Real-time Heartbeat Line Chart */
        .v50-heartbeat-chart {
            position: relative;
            width: 100%;
            height: 60px;
            margin: 8px 0;
            background: rgba(0, 0, 0, 0.2);
            border-radius: var(--radius-md);
            overflow: hidden;
        }
        
        .v50-heartbeat-chart svg {
            width: 100%;
            height: 100%;
        }
        
        .v50-heartbeat-line {
            fill: none;
            stroke: var(--primary);
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            filter: drop-shadow(0 0 4px var(--primary));
        }
        
        .v50-heartbeat-area {
            fill: url(#heartbeatGradient);
            opacity: 0.3;
        }
        
        .v50-heartbeat-dot {
            fill: var(--primary);
            filter: drop-shadow(0 0 4px var(--primary));
        }
        
        /* v50.0: Sound Wave Visualizer */
        .v50-sound-wave {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 3px;
            height: 40px;
            padding: 8px;
        }
        
        .v50-wave-bar {
            width: 4px;
            background: linear-gradient(180deg, var(--accent), var(--primary));
            border-radius: var(--radius-full);
            transition: height 0.1s ease;
            animation: v50WaveBounce ease-in-out infinite;
        }
        
        .v50-wave-bar:nth-child(1) { animation-duration: 0.4s; animation-delay: 0s; }
        .v50-wave-bar:nth-child(2) { animation-duration: 0.5s; animation-delay: 0.1s; }
        .v50-wave-bar:nth-child(3) { animation-duration: 0.3s; animation-delay: 0.2s; }
        .v50-wave-bar:nth-child(4) { animation-duration: 0.6s; animation-delay: 0.05s; }
        .v50-wave-bar:nth-child(5) { animation-duration: 0.4s; animation-delay: 0.15s; }
        
        @keyframes v50WaveBounce {
            0%, 100% { height: 8px; }
            50% { height: 32px; }
        }
        
        .v50-sound-wave.paused .v50-wave-bar {
            animation-play-state: paused;
            height: 8px !important;
        }
        
        /* v50.0: Interactive Skill Constellation */
        .v50-skill-constellation {
            position: relative;
            width: 120px;
            height: 120px;
        }
        
        .v50-constellation-canvas {
            width: 100%;
            height: 100%;
            border-radius: 50%;
        }
        
        .v50-constellation-center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }
        
        .v50-constellation-count {
            font-size: 24px;
            font-weight: 800;
            font-family: 'Outfit', sans-serif;
            color: var(--accent);
            line-height: 1;
            text-shadow: 0 0 12px rgba(0, 212, 255, 0.6);
        }
        
        .v50-constellation-label {
            font-size: 9px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.5);
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
        
        .v50-constellation-orbit {
            position: absolute;
            inset: -8px;
            border: 1px dashed rgba(0, 212, 255, 0.2);
            border-radius: 50%;
            animation: v50OrbitSpin 20s linear infinite;
        }
        
        @keyframes v50OrbitSpin {
            to { transform: rotate(360deg); }
        }
        
        /* v50.0: Cursor Trail Particles */
        .v50-cursor-particle {
            position: fixed;
            pointer-events: none;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--primary);
            opacity: 0;
            z-index: 9998;
            animation: v50CursorFade 0.6s ease-out forwards;
        }
        
        @keyframes v50CursorFade {
            0% { opacity: 0.8; transform: scale(1); }
            100% { opacity: 0; transform: scale(0); }
        }
        
        /* v50.0: Confetti Burst */
        .v50-confetti {
            position: fixed;
            pointer-events: none;
            z-index: 9999;
        }
        
        .v50-confetti-piece {
            position: absolute;
            width: 10px;
            height: 10px;
            animation: v50ConfettiFall 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        }
        
        @keyframes v50ConfettiFall {
            0% { transform: translateY(0) rotate(0deg); opacity: 1; }
            100% { transform: translateY(200px) rotate(720deg); opacity: 0; }
        }
        
        /* v50.0: Spring Bounce Animation */
        @keyframes v50SpringBounce {
            0% { transform: scale(1); }
            25% { transform: scale(1.15); }
            50% { transform: scale(0.95); }
            75% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        
        .v50-spring-animate {
            animation: v50SpringBounce 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        /* v50.0: Pulse Ring Animation */
        .v50-pulse-ring {
            position: relative;
        }
        
        .v50-pulse-ring::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            border: 2px solid var(--accent);
            animation: v50PulseRing 1.5s ease-out infinite;
            opacity: 0;
        }
        
        @keyframes v50PulseRing {
            0% { transform: scale(0.8); opacity: 1; }
            100% { transform: scale(1.5); opacity: 0; }
        }
        
        /* v50.0: Staggered Entrance with Spring */
        .v50-stagger > * {
            opacity: 0;
            transform: translateY(20px);
            animation: v50StaggerIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
        
        @keyframes v50StaggerIn {
            to { opacity: 1; transform: translateY(0); }
        }
        
        .v50-stagger > *:nth-child(1) { animation-delay: 0ms; }
        .v50-stagger > *:nth-child(2) { animation-delay: 60ms; }
        .v50-stagger > *:nth-child(3) { animation-delay: 120ms; }
        .v50-stagger > *:nth-child(4) { animation-delay: 180ms; }
        .v50-stagger > *:nth-child(5) { animation-delay: 240ms; }
        .v50-stagger > *:nth-child(6) { animation-delay: 300ms; }
        
        /* v50.0: Glass Reflection Shine */
        .v50-glass-shine {
            position: relative;
            overflow: hidden;
        }
        
        .v50-glass-shine::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent 40%,
                rgba(255, 255, 255, 0.1) 45%,
                rgba(255, 255, 255, 0.2) 50%,
                rgba(255, 255, 255, 0.1) 55%,
                transparent 60%
            );
            animation: v50GlassShine 3s ease-in-out infinite;
            pointer-events: none;
        }
        
        @keyframes v50GlassShine {
            0% { transform: translateX(-50%) translateY(-50%); }
            100% { transform: translateX(50%) translateY(50%); }
        }
        
        /* v50.0: Enhanced Reduced Motion */
        @media (prefers-reduced-motion: reduce) {
            .v50-spark-fill::after,
            .v50-wave-bar,
            .v50-constellation-orbit,
            .v50-glass-shine::after {
                animation: none;
            }
            
            .v50-stagger > * {
                animation: none;
                opacity: 1;
                transform: none;
            }
        }
        
        /* v50.0: Mobile Optimizations */
        @media (max-width: 768px) {
            .v50-mood-timeline {
                flex-wrap: nowrap;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            
            .v50-mood-node {
                min-width: 44px;
                padding: 6px;
            }
            
            .v50-heartbeat-chart {
                height: 48px;
            }
            
            .v50-sound-wave {
                height: 32px;
            }
            
            .v50-wave-bar {
                width: 3px;
            }
        }

        /* ========== v52.0: CSS @property - Native Animated Custom Properties ========== */
        @property --v52-glow-angle {
            syntax: '<angle>';
            initial-value: 0deg;
            inherits: false;
        }
        
        @property --v52-glow-opacity {
            syntax: '<number>';
            initial-value: 0;
            inherits: false;
        }
        
        @property --v52-spread {
            syntax: '<length>';
            initial-value: 0px;
            inherits: false;
        }

        /* ========== v52.0: Modern Spatial Computing-Inspired Depth Layers ========== */
        .v52-depth-layer {
            position: relative;
            transform-style: preserve-3d;
            perspective: 800px;
        }
        
        .v52-depth-layer::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(
                135deg,
                rgba(255,255,255,0.08) 0%,
                transparent 50%,
                rgba(0,0,0,0.05) 100%
            );
            transform: translateZ(-1px);
            pointer-events: none;
        }
        
        /* ========== v52.0: Animated Gradient Mesh Background ========== */
        .v52-mesh-gradient {
            position: fixed;
            inset: 0;
            z-index: -5;
            background: 
                radial-gradient(ellipse 80% 60% at 20% 30%, rgba(168,85,247,0.12) 0%, transparent 50%),
                radial-gradient(ellipse 60% 80% at 80% 70%, rgba(0,212,255,0.1) 0%, transparent 50%),
                radial-gradient(ellipse 50% 50% at 50% 50%, rgba(255,200,100,0.08) 0%, transparent 50%);
            animation: v52MeshShift 20s ease-in-out infinite;
            pointer-events: none;
        }
        
        @keyframes v52MeshShift {
            0%, 100% { opacity: 0.8; transform: scale(1); }
            33% { opacity: 1; transform: scale(1.05) translateX(2%); }
            66% { opacity: 0.9; transform: scale(0.98) translateX(-2%); }
        }
        
        /* ========== v52.0: Quantum State Card Hover ========== */
        .v52-quantum-card {
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        .v52-quantum-card::before {
            content: '';
            position: absolute;
            inset: -50%;
            background: conic-gradient(
                from var(--v52-glow-angle, 0deg),
                transparent 0deg,
                rgba(255,200,100,0.08) 60deg,
                transparent 120deg,
                rgba(0,212,255,0.06) 180deg,
                transparent 240deg,
                rgba(168,85,247,0.08) 300deg,
                transparent 360deg
            );
            opacity: 0;
            transform: rotate(0deg);
            transition: opacity 0.4s ease;
            pointer-events: none;
            animation: v52QuantumSpin 8s linear infinite;
        }
        
        @keyframes v52QuantumSpin {
            to { transform: rotate(360deg); }
        }
        
        .v52-quantum-card:hover::before {
            opacity: 1;
        }
        
        .v52-quantum-card:hover {
            transform: translateY(-6px) scale(1.02) perspective(1000px) rotateX(1deg) rotateY(-1deg);
            box-shadow: 
                0 20px 60px -15px rgba(255,200,100,0.25),
                0 0 40px rgba(255,200,100,0.08),
                0 0 80px rgba(0,212,255,0.05);
        }
        
        /* ========== v52.0: Living Border Animation ========== */
        .v52-living-border {
            position: relative;
        }
        
        .v52-living-border::before {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: inherit;
            background: linear-gradient(
                var(--v52-glow-angle, 0deg),
                var(--primary),
                var(--accent),
                var(--purple),
                var(--pink),
                var(--primary)
            );
            background-size: 500% 500%;
            animation: v52LivingBorder 4s ease infinite;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s ease;
            filter: blur(3px);
        }
        
        .v52-living-border:hover::before {
            opacity: 1;
        }
        
        @keyframes v52LivingBorder {
            0%, 100% { background-position: 0% 50%; --v52-glow-angle: 0deg; }
            25% { --v52-glow-angle: 90deg; }
            50% { background-position: 100% 50%; --v52-glow-angle: 180deg; }
            75% { --v52-glow-angle: 270deg; }
            100% { background-position: 0% 50%; --v52-glow-angle: 360deg; }
        }
        
        /* ========== v52.0: Particle Grid Background ========== */
        .v52-particle-grid {
            position: fixed;
            inset: 0;
            z-index: -3;
            pointer-events: none;
            background-image: 
                radial-gradient(circle at 50% 50%, rgba(255,200,100,0.03) 0%, transparent 1%),
                radial-gradient(circle at 30% 70%, rgba(0,212,255,0.02) 0%, transparent 1%),
                radial-gradient(circle at 70% 30%, rgba(168,85,247,0.02) 0%, transparent 1%);
            background-size: 60px 60px, 80px 80px, 100px 100px;
            animation: v52ParticleDrift 30s linear infinite;
        }
        
        @keyframes v52ParticleDrift {
            0% { background-position: 0 0, 0 0, 0 0; }
            100% { background-position: 60px 60px, -80px -80px, 100px 100px; }
        }
        
        /* ========== v52.0: Floating UI Elements ========== */
        .v52-floating {
            animation: v52Float 4s ease-in-out infinite;
        }
        
        @keyframes v52Float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-8px); }
        }
        
        .v52-floating-slow {
            animation: v52FloatSlow 6s ease-in-out infinite;
        }
        
        @keyframes v52FloatSlow {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33% { transform: translateY(-5px) rotate(1deg); }
            66% { transform: translateY(-3px) rotate(-1deg); }
        }
        
        /* ========== v52.0: AI Status Stream Line ========== */
        .v52-status-stream {
            position: relative;
            overflow: hidden;
        }
        
        .v52-status-stream::after {
            content: '';
            position: absolute;
            top: 50%;
            left: -100%;
            width: 50%;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            animation: v52StreamFlow 2s ease-in-out infinite;
            transform: translateY(-50%);
        }
        
        @keyframes v52StreamFlow {
            0% { left: -50%; opacity: 0; }
            20% { opacity: 1; }
            80% { opacity: 1; }
            100% { left: 100%; opacity: 0; }
        }
        
        /* ========== v52.0: Morphing Badge ========== */
        .v52-morph-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 14px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: var(--radius-full);
            font-size: 12px;
            font-weight: 500;
            color: var(--text);
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        
        .v52-morph-badge::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .v52-morph-badge:hover {
            border-radius: var(--radius-lg);
            transform: scale(1.05);
            box-shadow: 0 8px 24px rgba(255,200,100,0.25);
        }
        
        .v52-morph-badge:hover::before {
            opacity: 0.15;
        }
        
        .v52-morph-badge .badge-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--primary);
            box-shadow: 0 0 8px var(--primary);
            animation: v52MorphPulse 2s ease-in-out infinite;
            position: relative;
            z-index: 1;
        }
        
        @keyframes v52MorphPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.8; }
        }
        
        /* ========== v52.0: Glassmorphic Modal/Overlay ========== */
        .v52-glass-modal {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(8px);
        }
        
        .v52-glass-modal.open {
            opacity: 1;
            pointer-events: all;
        }
        
        .v52-glass-modal-content {
            background: var(--bg-card);
            backdrop-filter: blur(32px) saturate(200%);
            -webkit-backdrop-filter: blur(32px) saturate(200%);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: var(--radius-xl);
            padding: 28px;
            max-width: 400px;
            width: 90%;
            box-shadow: 0 24px 80px rgba(0,0,0,0.5), 0 0 40px rgba(255,200,100,0.05);
            transform: scale(0.9) translateY(20px);
            transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .v52-glass-modal.open .v52-glass-modal-content {
            transform: scale(1) translateY(0);
        }
        
        /* ========== v52.0: Micro-Interaction Ripple ========== */
        .v52-ripple {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.4) 0%, transparent 70%);
            transform: scale(0);
            animation: v52RippleExpand 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            pointer-events: none;
        }
        
        @keyframes v52RippleExpand {
            to { transform: scale(4); opacity: 0; }
        }
        
        /* ========== v52.0: Status Morph Ring ========== */
        .v52-morph-ring {
            position: absolute;
            inset: -12px;
            border-radius: 50%;
            border: 2px solid transparent;
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
        }
        
        .v52-morph-ring.active {
            opacity: 1;
            animation: v52MorphRing 3s ease-in-out infinite;
        }
        
        .v52-morph-ring.idle { border-color: var(--primary); box-shadow: 0 0 20px var(--primary); }
        .v52-morph-ring.working { border-color: var(--accent); box-shadow: 0 0 20px var(--accent); }
        .v52-morph-ring.sleeping { border-color: var(--purple); box-shadow: 0 0 20px var(--purple); }
        .v52-morph-ring.excited { border-color: var(--pink); box-shadow: 0 0 20px var(--pink); }
        .v52-morph-ring.error { border-color: var(--danger); box-shadow: 0 0 20px var(--danger); }
        
        @keyframes v52MorphRing {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 1; }
        }
        
        /* ========== v52.0: Neural Activity Waveform v2 ========== */
        .v52-neural-wave {
            position: relative;
            height: 50px;
            background: rgba(0,0,0,0.3);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(168,85,247,0.2);
        }
        
        .v52-neural-canvas {
            width: 100%;
            height: 100%;
        }
        
        .v52-neural-label {
            position: absolute;
            top: 4px;
            left: 8px;
            font-size: 9px;
            font-weight: 600;
            color: rgba(168,85,247,0.7);
            letter-spacing: 1px;
            text-transform: uppercase;
            font-family: 'JetBrains Mono', monospace;
        }
        
        .v52-neural-glow {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 50%, rgba(168,85,247,0.1) 0%, transparent 70%);
            animation: v52NeuralGlow 2s ease-in-out infinite alternate;
        }
        
        @keyframes v52NeuralGlow {
            from { opacity: 0.3; }
            to { opacity: 0.8; }
        }
        
        /* ========== v52.0: Data Stream Wire ========== */
        .v52-data-wire {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent 0%, var(--accent) 20%, var(--primary) 50%, var(--accent) 80%, transparent 100%);
            background-size: 300% 100%;
            animation: v52WireFlow 4s linear infinite;
            opacity: 0;
            z-index: 9997;
            pointer-events: none;
        }
        
        .v52-data-wire.active { opacity: 0.5; }
        
        @keyframes v52WireFlow {
            0% { background-position: 300% 0; }
            100% { background-position: -300% 0; }
        }
        
        /* ========== v52.0: Confetti Burst ========== */
        .v52-confetti-container {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 9999;
            overflow: hidden;
        }
        
        .v52-confetti-piece {
            position: absolute;
            width: 8px;
            height: 8px;
            border-radius: 2px;
            animation: v52ConfettiFall linear forwards;
        }
        
        @keyframes v52ConfettiFall {
            0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }
        
        /* ========== v52.0: Spring Press Button ========== */
        .v52-spring-btn {
            position: relative;
            transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .v52-spring-btn:hover {
            transform: translateY(-3px) scale(1.03);
        }
        
        .v52-spring-btn:active {
            transform: translateY(0px) scale(0.95);
            transition: transform 0.08s ease;
        }
        
        /* ========== v52.0: Card Swipe Gesture Support ========== */
        .v52-swipeable {
            touch-action: pan-y;
            user-select: none;
        }
        
        .v52-swipe-card {
            transition: transform 0.2s ease-out, opacity 0.2s ease;
            will-change: transform;
        }
        
        .v52-swipe-left {
            animation: v52SwipeLeft 0.3s ease-out forwards;
        }
        
        @keyframes v52SwipeLeft {
            to { transform: translateX(-120%) rotate(-5deg); opacity: 0.3; }
        }
        
        .v52-swipe-right {
            animation: v52SwipeRight 0.3s ease-out forwards;
        }
        
        @keyframes v52SwipeRight {
            to { transform: translateX(120%) rotate(5deg); opacity: 0.3; }
        }
        
        /* ========== v52.0: Magnetic Hover Pull ========== */
        .v52-magnetic {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        /* ========== v52.0: Value Change Flash ========== */
        @keyframes v52ValueFlash {
            0% { background: transparent; }
            30% { background: rgba(255,200,100,0.15); }
            100% { background: transparent; }
        }
        
        .v52-value-flash {
            animation: v52ValueFlash 0.5s ease-out;
        }
        
        /* ========== v52.0: Interactive Cursor Trail ========== */
        .v52-trail-particle {
            position: fixed;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            pointer-events: none;
            z-index: 9998;
            animation: v52TrailFade 0.8s ease-out forwards;
        }
        
        @keyframes v52TrailFade {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(0); opacity: 0; }
        }
        
        /* ========== v52.0: Scroll Progress Gradient ========== */
        .v52-scroll-progress {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--purple), var(--pink));
            background-size: 300% 100%;
            animation: v52ScrollGradient 4s ease infinite;
            z-index: 9998;
            width: 0%;
            box-shadow: 0 0 12px rgba(255,200,100,0.5), 0 0 24px rgba(0,212,255,0.3);
        }
        
        @keyframes v52ScrollGradient {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }
        
        .v52-scroll-progress::after {
            content: '';
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 8px;
            height: 8px;
            background: var(--primary);
            border-radius: 50%;
            box-shadow: 0 0 12px var(--primary-glow);
        }
        
        /* ========== v52.0: Tab Content Slide ========== */
        @keyframes v52TabSlide {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .v52-tab-content {
            animation: v52TabSlide 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        /* ========== v52.0: Staggered Entrance ========== */
        .v52-stagger > *:nth-child(1) { animation-delay: 0ms; }
        .v52-stagger > *:nth-child(2) { animation-delay: 60ms; }
        .v52-stagger > *:nth-child(3) { animation-delay: 120ms; }
        .v52-stagger > *:nth-child(4) { animation-delay: 180ms; }
        .v52-stagger > *:nth-child(5) { animation-delay: 240ms; }
        .v52-stagger > *:nth-child(6) { animation-delay: 300ms; }
        
        @keyframes v52StaggerIn {
            from { opacity: 0; transform: translateY(20px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        .v52-stagger > * {
            opacity: 0;
            animation: v52StaggerIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        
        /* ========== v52.0: Notification Toast Stack ========== */
        .v52-toast-stack {
            position: fixed;
            top: 20px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            z-index: 9999;
            pointer-events: none;
        }
        
        .v52-toast {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(12,12,20,0.92);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: var(--radius-md);
            padding: 12px 18px;
            min-width: 240px;
            max-width: 340px;
            font-size: 13px;
            color: var(--text);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: v52ToastIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            pointer-events: auto;
        }
        
        .v52-toast.exiting {
            animation: v52ToastOut 0.25s ease-out forwards;
        }
        
        @keyframes v52ToastIn {
            from { opacity: 0; transform: translateX(50px) scale(0.9); }
            to { opacity: 1; transform: translateX(0) scale(1); }
        }
        
        @keyframes v52ToastOut {
            to { opacity: 0; transform: translateX(50px) scale(0.9); }
        }
        
        .v52-toast.success { border-color: rgba(92,219,149,0.3); }
        .v52-toast.error { border-color: rgba(255,107,107,0.3); }
        .v52-toast.warning { border-color: rgba(254,202,87,0.3); }
        
        .v52-toast-icon { font-size: 16px; flex-shrink: 0; }
        .v52-toast-msg { flex: 1; line-height: 1.4; }
        
        .v52-toast-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 2px;
            width: 100%;
            transform-origin: left;
        }
        
        .v52-toast.success .v52-toast-bar { background: var(--success); }
        .v52-toast.error .v52-toast-bar { background: var(--danger); }
        .v52-toast.warning .v52-toast-bar { background: var(--warning); }
        
        /* ========== v52.0: AI Thinking Indicator ========== */
        .v52-thinking-dots {
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        
        .v52-thinking-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--purple);
            animation: v52ThinkingBounce 1.2s ease-in-out infinite;
        }
        
        .v52-thinking-dot:nth-child(2) { animation-delay: 0.15s; }
        .v52-thinking-dot:nth-child(3) { animation-delay: 0.30s; }
        
        @keyframes v52ThinkingBounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-8px); }
        }
        
        /* ========== v52.0: Hexagon Skills Radar ========== */
        .v52-hex-radar {
            position: relative;
            width: 120px;
            height: 110px;
            margin: 8px auto;
        }
        
        .v52-hex-bg {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .v52-hex-bg svg {
            width: 100%;
            height: 100%;
            filter: drop-shadow(0 0 8px rgba(0,212,255,0.3));
        }
        
        .v52-hex-center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }
        
        .v52-hex-count {
            font-size: 22px;
            font-weight: 800;
            font-family: 'Outfit', sans-serif;
            color: var(--accent);
            line-height: 1;
            text-shadow: 0 0 12px rgba(0,212,255,0.6);
        }
        
        .v52-hex-label {
            font-size: 9px;
            font-weight: 600;
            color: rgba(255,255,255,0.5);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-top: 2px;
        }
        
        .v52-hex-pulse {
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            border: 2px solid rgba(0,212,255,0.4);
            animation: v52HexPulse 2s ease-out infinite;
            pointer-events: none;
        }
        
        @keyframes v52HexPulse {
            0% { transform: scale(0.9); opacity: 1; }
            100% { transform: scale(1.3); opacity: 0; }
        }
        
        /* ========== v52.0: Circular Memory Gauge v2 ========== */
        .v52-memory-gauge {
            position: relative;
            width: 80px;
            height: 80px;
            margin: 8px auto;
        }
        
        .v52-memory-svg {
            transform: rotate(-90deg);
            width: 100%;
            height: 100%;
        }
        
        .v52-memory-bg {
            fill: none;
            stroke: rgba(255,255,255,0.06);
            stroke-width: 6;
        }
        
        .v52-memory-fill {
            fill: none;
            stroke-width: 6;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), stroke 0.5s ease;
        }
        
        .v52-memory-fill.low { stroke: var(--success); filter: drop-shadow(0 0 4px var(--success)); }
        .v52-memory-fill.medium { stroke: var(--warning); filter: drop-shadow(0 0 4px var(--warning)); }
        .v52-memory-fill.high { stroke: var(--danger); filter: drop-shadow(0 0 4px var(--danger)); }
        
        .v52-memory-center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        .v52-memory-value {
            font-size: 16px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-primary);
        }
        
        .v52-memory-label {
            font-size: 8px;
            font-weight: 600;
            color: rgba(255,255,255,0.4);
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        
        /* ========== v52.0: Ambient Orb Morphing ========== */
        .v52-ambient-orb {
            filter: blur(60px);
            animation: v52OrbMorph 12s ease-in-out infinite;
            border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
        }
        
        @keyframes v52OrbMorph {
            0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; transform: translate(0,0) scale(1); }
            25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; transform: translate(2vw,-3vh) scale(1.1); }
            50% { border-radius: 50% 60% 30% 60% / 30% 40% 70% 60%; transform: translate(-1vw,2vh) scale(0.95); }
            75% { border-radius: 40% 30% 60% 50% / 60% 50% 40% 30%; transform: translate(1.5vw,1vh) scale(1.05); }
        }
        
        /* ========== v52.0: Scroll-Driven Reveal ========== */
        @keyframes v52Reveal {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .v52-reveal {
            animation: v52Reveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            animation-timeline: view();
            animation-range: entry 0% entry 100%;
        }
        
        /* ========== v52.0: Glitch Text Effect ========== */
        .v52-glitch {
            position: relative;
        }
        
        .v52-glitch::before,
        .v52-glitch::after {
            content: attr(data-text);
            position: absolute;
            inset: 0;
            clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
        }
        
        .v52-glitch::before {
            color: var(--accent);
            animation: v52GlitchBefore 3s infinite;
        }
        
        .v52-glitch::after {
            color: var(--primary);
            animation: v52GlitchAfter 3s infinite;
        }
        
        @keyframes v52GlitchBefore {
            0%, 90%, 100% { clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%); transform: translate(0); }
            92% { clip-path: polygon(0 10%, 100% 10%, 100% 25%, 0 25%); transform: translate(-2px, 1px); }
            94% { clip-path: polygon(0 60%, 100% 60%, 100% 75%, 0 75%); transform: translate(2px, -1px); }
        }
        
        @keyframes v52GlitchAfter {
            0%, 90%, 100% { clip-path: polygon(0 55%, 100% 55%, 100% 70%, 0 70%); transform: translate(0); }
            91% { clip-path: polygon(0 20%, 100% 20%, 100% 35%, 0 35%); transform: translate(2px, 1px); }
            93% { clip-path: polygon(0 70%, 100% 70%, 100% 85%, 0 85%); transform: translate(-2px, -1px); }
        }
        
        /* ========== v52.0: Breathing Glow ========== */
        @keyframes v52BreathingGlow {
            0%, 100% { opacity: 0.5; filter: blur(25px); transform: scale(1); }
            50% { opacity: 0.85; filter: blur(32px); transform: scale(1.08); }
        }
        
        .v52-breathing {
            animation: v52BreathingGlow 3s ease-in-out infinite;
        }
        
        /* ========== v52.0: Floating Emoji ========== */
        .v52-emoji-float-container {
            position: fixed;
            bottom: 100px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            z-index: 50;
        }
        
        .v52-emoji-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(20,20,30,0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            opacity: 0.7;
        }
        
        .v52-emoji-btn:hover {
            opacity: 1;
            transform: scale(1.15) translateY(-3px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }
        
        @keyframes v52EmojiFloat {
            0% { opacity: 1; transform: translateY(0) scale(1); }
            100% { opacity: 0; transform: translateY(-120px) scale(0.6); }
        }
        
        /* ========== v52.0: FAB Orb ========== */
        .v52-fab {
            position: fixed;
            bottom: 24px;
            right: 24px;
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 100;
            box-shadow: 0 4px 20px rgba(255,200,100,0.4), 0 0 40px rgba(255,200,100,0.2);
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
        }
        
        .v52-fab:hover {
            transform: scale(1.15);
            box-shadow: 0 6px 30px rgba(255,200,100,0.6), 0 0 60px rgba(255,200,100,0.3);
        }
        
        .v52-fab:active {
            transform: scale(0.95);
        }
        
        .v52-fab-icon {
            font-size: 20px;
            filter: drop-shadow(0 0 4px rgba(255,255,255,0.8));
            transition: transform 0.4s ease;
        }
        
        .v52-fab.expanded .v52-fab-icon {
            transform: rotate(45deg);
        }
        
        .v52-fab-menu {
            position: absolute;
            bottom: 64px;
            right: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
            opacity: 0;
            transform: translateY(20px) scale(0.8);
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .v52-fab.expanded .v52-fab-menu {
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: all;
        }
        
        .v52-fab-menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 16px;
            background: rgba(20,20,30,0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.2s ease;
        }
        
        .v52-fab-menu-item:hover {
            background: rgba(40,40,60,0.95);
            border-color: rgba(255,200,100,0.4);
            transform: translateX(-4px);
        }
        
        /* ========== v55.0: Enhanced Animations & Parallax Effects ========== */
        
        /* Scroll-driven animations - modern CSS */
        @keyframes v54FadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes v54SlideInLeft {
            from { opacity: 0; transform: translateX(-40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        
        @keyframes v54SlideInRight {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        
        @keyframes v54ScaleIn {
            from { opacity: 0; transform: scale(0.85); }
            to { opacity: 1; transform: scale(1); }
        }
        
        @keyframes v54BreathingGlow {
            0%, 100% { box-shadow: 0 0 20px rgba(255,200,100,0.2); }
            50% { box-shadow: 0 0 40px rgba(255,200,100,0.4); }
        }
        
        @keyframes v54PulseBorder {
            0%, 100% { border-color: rgba(255,200,100,0.3); }
            50% { border-color: rgba(255,200,100,0.7); }
        }
        
        @keyframes v54Float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        
        @keyframes v54Wave {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        
        /* Parallax background effect */
        .parallax-bg {
            position: fixed;
            inset: 0;
            z-index: -5;
            pointer-events: none;
        }
        
        .parallax-layer {
            position: absolute;
            inset: 0;
            transition: transform 0.1s ease-out;
        }
        
        .parallax-layer-1 { transform: translateZ(-2px) scale(3); }
        .parallax-layer-2 { transform: translateZ(-1px) scale(2); }
        .parallax-layer-3 { transform: translateZ(0); }
        
        /* Enhanced glass morphism */
        .glass-v54 {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        
        .glass-v54-strong {
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255,255,255,0.15);
            box-shadow: 0 12px 48px rgba(0,0,0,0.4);
        }
        
        /* Enhanced stat cards with better hover */
        .stat-card-v54 {
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .stat-card-v54::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            transition: left 0.5s ease;
        }
        
        .stat-card-v54:hover::before {
            left: 100%;
        }
        
        .stat-card-v54:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        }
        
        /* Status indicator enhancements */
        .status-indicator-v54 {
            position: relative;
        }
        
        .status-indicator-v54::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            animation: v54PulseBorder 2s ease-in-out infinite;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .status-indicator-v54.active::after {
            opacity: 1;
        }
        
        /* Animated gradient border */
        .gradient-border-v54 {
            position: relative;
            background: var(--bg-card);
            border-radius: var(--radius-lg);
        }
        
        .gradient-border-v54::before {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: inherit;
            background: linear-gradient(135deg, var(--primary), var(--accent), var(--success), var(--primary));
            background-size: 300% 300%;
            animation: auroraBorder 6s ease infinite;
            z-index: -1;
            opacity: 0.6;
        }
        
        /* Floating elements */
        .float-animation {
            animation: v54Float 4s ease-in-out infinite;
        }
        
        .float-animation-delay-1 { animation-delay: -1s; }
        .float-animation-delay-2 { animation-delay: -2s; }
        .float-animation-delay-3 { animation-delay: -3s; }
        
        /* Wave effect overlay */
        .wave-overlay {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }
        
        .wave-overlay::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            animation: v54Wave 3s linear infinite;
        }
        
        /* Enhanced skeleton loading */
        .skeleton-v54 {
            background: linear-gradient(90deg, 
                rgba(255,255,255,0.05) 25%, 
                rgba(255,255,255,0.1) 50%, 
                rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: skeleton-loading 1.5s ease-in-out infinite;
        }
        
        @keyframes skeleton-loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* Staggered animation delays */
        .stagger-1 { animation-delay: 0.1s; }
        .stagger-2 { animation-delay: 0.2s; }
        .stagger-3 { animation-delay: 0.3s; }
        .stagger-4 { animation-delay: 0.4s; }
        .stagger-5 { animation-delay: 0.5s; }
        
        /* v54: Enhanced tooltip */
        .tooltip-v54 {
            position: absolute;
            padding: 8px 14px;
            background: rgba(20,20,30,0.95);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            font-size: 12px;
            color: var(--text);
            white-space: nowrap;
            opacity: 0;
            transform: translateY(8px);
            pointer-events: none;
            transition: all 0.2s ease;
            z-index: 1000;
        }
        
        .tooltip-v54.visible {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* Enhanced progress bar */
        .progress-v54 {
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 3px;
            overflow: hidden;
            position: relative;
        }
        
        .progress-v54::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: v54Wave 2s linear infinite;
        }
        
        .progress-v54-bar {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        /* Enhanced badge */
        .badge-v54 {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            background: rgba(255,200,100,0.15);
            border: 1px solid rgba(255,200,100,0.3);
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .badge-v54.success {
            background: rgba(92,219,149,0.15);
            border-color: rgba(92,219,149,0.3);
            color: var(--success);
        }
        
        .badge-v54.warning {
            background: rgba(254,202,87,0.15);
            border-color: rgba(254,202,87,0.3);
            color: var(--warning);
        }
        
        .badge-v54.error {
            background: rgba(255,107,107,0.15);
            border-color: rgba(255,107,107,0.3);
            color: var(--danger);
        }
        
        /* Mobile-first responsive improvements */
        @media (max-width: 768px) {
            .stat-card-v54:hover {
                transform: translateY(-4px) scale(1.01);
            }
            
            .gradient-border-v54::before {
                background-size: 200% 200%;
            }
            
            .tooltip-v54 {
                display: none;
            }
        }
        
        /* Touch device optimizations */
        @media (hover: none) {
            .stat-card-v54::before {
                display: none;
            }
            
            .stat-card-v54:active {
                transform: scale(0.98);
            }
        }
        
        /* Reduced motion preference */
        @media (prefers-reduced-motion: reduce) {
            .float-animation,
            .skeleton-v54,
            .progress-v54::after {
                animation: none;
            }
            
            .stat-card-v54,
            .stat-card-v54::before {
                transition: none;
            }
        }
        
        /* High contrast mode support */
        @media (prefers-contrast: high) {
            .glass-v54,
            .glass-v54-strong {
                border-width: 2px;
                border-color: rgba(255,255,255,0.3);
            }
        }
        
        /* Dark mode enhancements */
        @media (prefers-color-scheme: dark) {
            :root {
                --v54-bg-dark: #050508;
                --v54-bg-card: rgba(10,10,18,0.95);
            }
        }
        
        /* Print styles */
        @media print {
            .ambient-orb,
            .particle-mesh-canvas,
            .bg-neural,
            .parallax-bg {
                display: none !important;
            }
            
            body {
                background: white !important;
                color: black !important;
            }
        }

        /* ========== v55.0: Modern CSS Enhancements ========== */
        
        /* Enhanced color scheme with OKLCH for better color perception */
        :root {
            --v54-primary: oklch(85% 0.15 80);
            --v54-accent: oklch(90% 0.12 200);
            --v54-success: oklch(85% 0.15 150);
            --v54-bg: oklch(8% 0.02 280);
        }
        
        /* Modern CSS scroll-driven animations support */
        @supports (animation-timeline: scroll()) {
            .v54-scroll-animate {
                animation: v54-fade-in linear;
                animation-timeline: scroll();
            }
            
            @keyframes v54-fade-in {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }
        }
        
        /* Enhanced performance with content-visibility */
        .stat-card {
            content-visibility: auto;
            contain-intrinsic-size: 1px 150px;
        }
        
        /* Modern @layer for better organization */
        @layer components {
            .v54-glass {
                background: linear-gradient(
                    135deg,
                    rgba(255,255,255,0.08) 0%,
                    rgba(255,255,255,0.02) 100%
                );
                backdrop-filter: blur(20px) saturate(180%);
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: var(--radius-xl);
            }
        }
        
        /* Enhanced focus states for accessibility */
        *:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
        }
        
        /* Reduced motion support */
        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
        
        /* Dynamic viewport units for mobile */
        @supports (height: 100dvh) {
            body {
                min-height: 100dvh;
            }
        }
        
        /* Enhanced fox glow with modern CSS */
        .fox-glow {
            background: radial-gradient(
                circle at center,
                var(--primary-glow) 0%,
                transparent 70%
            );
            filter: blur(20px);
            mix-blend-mode: screen;
        }
        
        /* Smooth number transitions */
        .stat-value {
            font-variant-numeric: tabular-nums;
            transition: font-variation-settings 0.3s ease;
        }
        
        /* Better loading skeleton */
        .skeleton {
            background: linear-gradient(
                90deg,
                var(--bg-card) 25%,
                var(--bg-card-hover) 50%,
                var(--bg-card) 75%
            );
            background-size: 200% 100%;
            animation: skeleton-shimmer 1.5s ease-in-out infinite;
        }
        
        @keyframes skeleton-shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* ========== v55.0: Smart Value Update Styles ========== */
        .v55-value-updated {
            animation: v55ValueFlash 0.4s ease-out;
        }
        
        @keyframes v55ValueFlash {
            0% { background: rgba(0, 212, 255, 0.3); border-radius: 4px; }
            100% { background: transparent; }
        }
        
        .v55-status-transitioning {
            animation: v55StatusMorph 0.3s ease-out;
        }
        
        @keyframes v55StatusMorph {
            0% { transform: scale(0.9); opacity: 0.5; }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); opacity: 1; }
        }
        
        /* ========== v55.0: Connection Quality Indicator ========== */
        .v55-connection-quality {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            padding: 4px 8px;
            border-radius: 4px;
            transition: all 0.3s ease;
        }
        
        .v55-connection-quality.excellent {
            color: #5cdb95;
            background: rgba(92, 219, 149, 0.15);
        }
        
        .v55-connection-quality.good {
            color: #ffc864;
            background: rgba(255, 200, 100, 0.15);
        }
        
        .v55-connection-quality.fair {
            color: #feca57;
            background: rgba(254, 202, 87, 0.15);
        }
        
        .v55-connection-quality.poor {
            color: #ff6b6b;
            background: rgba(255, 107, 107, 0.15);
            animation: v55PoorPulse 1s ease-in-out infinite;
        }
        
        @keyframes v55PoorPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
        
        /* ========== v55.0: Data Freshness Indicator ========== */
        .v55-data-freshness {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            padding: 4px 8px;
            border-radius: 4px;
            transition: all 0.3s ease;
        }
        
        .v55-data-freshness.live {
            color: #5cdb95;
            background: rgba(92, 219, 149, 0.15);
            animation: v55LivePulse 1.5s ease-in-out infinite;
        }
        
        @keyframes v55LivePulse {
            0%, 100% { text-shadow: 0 0 4px rgba(92, 219, 149, 0.5); }
            50% { text-shadow: 0 0 12px rgba(92, 219, 149, 0.8); }
        }
        
        .v55-data-freshness.fresh {
            color: #00d4ff;
            background: rgba(0, 212, 255, 0.15);
        }
        
        .v55-data-freshness.normal {
            color: #ffc864;
            background: rgba(255, 200, 100, 0.15);
        }
        
        .v55-data-freshness.stale {
            color: #feca57;
            background: rgba(254, 202, 87, 0.15);
        }
        
        .v55-data-freshness.offline {
            color: #ff6b6b;
            background: rgba(255, 107, 107, 0.15);
        }
        
        /* ========== v55.0: Enhanced Performance Indicators ========== */
        .v55-perf-indicator {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.7);
            padding: 6px 10px;
            border-radius: 4px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: #888;
            z-index: 9998;
            pointer-events: none;
        }
        
        /* ========== v55.0: Improved Skeleton Loading ========== */
        .skeleton-v54 {
            position: relative;
            overflow: hidden;
        }
        
        .skeleton-v54::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(255, 255, 255, 0.08),
                transparent
            );
            animation: v55SkeletonSweep 1.5s ease-in-out infinite;
        }
        
        @keyframes v55SkeletonSweep {
            0% { left: -100%; }
            100% { left: 100%; }
        }
        
        /* ========== v55.0: Enhanced Card Animations ========== */
        .stat-card-v54 {
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
            will-change: transform;
        }
        
        .stat-card-v54:hover {
            transform: translateY(-4px) scale(1.01);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
        }
        
        /* ========== v55.0: Status Indicator Enhancement ========== */
        .status-indicator-v54 {
            transition: all 0.3s ease;
        }
        
        .status-indicator-v54.active {
            animation: v55StatusGlow 2s ease-in-out infinite;
        }
        
        @keyframes v55StatusGlow {
            0%, 100% { box-shadow: 0 0 8px var(--primary-dim); }
            50% { box-shadow: 0 0 20px var(--primary-glow); }
        }
        
        /* ========== v55.0: Improved Timeline Animation ========== */
        .timeline-item {
            opacity: 0;
            transform: translateY(20px);
            animation: v55TimelineReveal 0.5s ease forwards;
        }
        
        @keyframes v55TimelineReveal {
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* ========== v55.0: Better Touch Feedback ========== */
        @media (hover: none) {
            .stat-card:active,
            .action-btn:active,
            .mood-btn:active {
                transform: scale(0.98);
                opacity: 0.9;
            }
        }
        
        /* ========== v55.0: Prefers Color Scheme Support ========== */
        @media (prefers-color-scheme: light) {
            :root {
                --bg-dark: #f0f0f5;
                --bg-deep: #e8e8ee;
                --bg-card: rgba(255, 255, 255, 0.9);
                --text: #1a1a2e;
                --text-dim: #6a6a7a;
            }
        }

        /* ========== v56.0: Performance Optimizations ========== */

        /* GPU acceleration for heavy elements - reduces layout thrashing */
        .stat-card,
        .mini-stat,
        .fox-canvas-wrapper,
        .neural-canvas-wrapper,
        .ambient-canvas-wrapper {
            contain: layout style paint;
            will-change: transform;
        }

        /* Canvas elements - only promote when actively animating */
        .fox-canvas,
        .neural-canvas,
        .neural-waveform-canvas,
        .neural-spark-canvas,
        .ambient-canvas {
            will-change: transform, opacity;
        }

        /* Lazy paint - skip rendering off-screen content */
        .dashboard-grid {
            content-visibility: auto;
            contain-intrinsic-size: 0 1200px;
        }

        /* Reduce paint areas - isolate heavy card internals */
        .stat-card-inner {
            contain: layout paint;
        }

        /* Scroll-driven: only animate when in viewport */
        .v56-scroll-animate {
            animation-timeline: view();
            animation-range: entry 0% entry 100%;
        }

        @keyframes v56Reveal {
            from { opacity: 0; transform: translateY(24px) scale(0.97); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .v56-scroll-animate {
            animation: v56Reveal 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        /* ========== v56.0: System Health Score Ring ========== */
        .v56-health-ring {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 56px;
            height: 56px;
        }

        .v56-health-ring svg {
            position: absolute;
            inset: 0;
            transform: rotate(-90deg);
        }

        .v56-health-ring .ring-bg {
            stroke: rgba(255, 255, 255, 0.08);
            fill: none;
            stroke-width: 5;
        }

        .v56-health-ring .ring-fill {
            fill: none;
            stroke-width: 5;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                        stroke 0.4s ease;
        }

        .v56-health-ring.excellent .ring-fill { stroke: var(--success); }
        .v56-health-ring.good .ring-fill { stroke: var(--primary); }
        .v56-health-ring.fair .ring-fill { stroke: var(--warning); }
        .v56-health-ring.poor .ring-fill { stroke: var(--danger); }

        .v56-health-ring .ring-label {
            font-size: 11px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-bright);
            z-index: 1;
        }

        .v56-health-ring::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }

        .v56-health-ring.excellent::after { box-shadow: 0 0 16px var(--success); opacity: 0.4; }
        .v56-health-ring.good::after { box-shadow: 0 0 16px var(--primary); opacity: 0.4; }
        .v56-health-ring.fair::after { box-shadow: 0 0 16px var(--warning); opacity: 0.4; }
        .v56-health-ring.poor::after { box-shadow: 0 0 16px var(--danger); opacity: 0.4; }

        /* ========== v56.0: Mini Sparkline Chart ========== */
        .v56-sparkline {
            position: relative;
            width: 80px;
            height: 32px;
            overflow: hidden;
        }

        .v56-sparkline svg {
            width: 100%;
            height: 100%;
        }

        .v56-sparkline-path {
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            filter: drop-shadow(0 0 4px currentColor);
        }

        .v56-sparkline-area {
            opacity: 0.15;
        }

        /* ========== v56.0: Performance Monitor Overlay ========== */
        .v56-perf-monitor {
            position: fixed;
            bottom: 18px;
            left: 18px;
            background: rgba(8, 8, 12, 0.88);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            padding: 8px 12px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: var(--text-dim);
            z-index: 9997;
            pointer-events: none;
            display: flex;
            align-items: center;
            gap: 10px;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .v56-perf-monitor.visible { opacity: 1; }

        .v56-perf-fps {
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .v56-perf-fps.smooth { color: var(--success); }
        .v56-perf-fps.ok { color: var(--primary); }
        .v56-perf-fps.slow { color: var(--warning); }
        .v56-perf-fps.bad { color: var(--danger); }

        .v56-perf-bar {
            width: 50px;
            height: 4px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 2px;
            overflow: hidden;
        }

        .v56-perf-bar-fill {
            height: 100%;
            border-radius: 2px;
            transition: width 0.3s ease, background 0.3s ease;
        }

        /* ========== v56.0: Quick Stats Summary Bar ========== */
        .v56-quick-stats {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 10px 16px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: var(--radius-md);
            overflow-x: auto;
            scrollbar-width: none;
        }

        .v56-quick-stats::-webkit-scrollbar { display: none; }

        .v56-quick-stat {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
            min-width: 48px;
            flex-shrink: 0;
        }

        .v56-quick-stat-value {
            font-size: 16px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-bright);
        }

        .v56-quick-stat-label {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
        }

        .v56-quick-stat:not(:last-child) {
            padding-right: 16px;
            border-right: 1px solid rgba(255, 255, 255, 0.06);
        }

        /* ========== v56.0: Activity Heat Bar ========== */
        .v56-heat-bar {
            display: flex;
            gap: 2px;
            height: 24px;
            align-items: flex-end;
        }

        .v56-heat-bar-cell {
            width: 6px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 2px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .v56-heat-bar-cell:hover {
            background: rgba(255, 200, 100, 0.3);
            transform: scaleY(1.1);
        }

        .v56-heat-bar-cell.l1 { background: rgba(92, 219, 149, 0.3); }
        .v56-heat-bar-cell.l2 { background: rgba(92, 219, 149, 0.5); }
        .v56-heat-bar-cell.l3 { background: rgba(255, 200, 100, 0.4); }
        .v56-heat-bar-cell.l4 { background: rgba(255, 200, 100, 0.7); }
        .v56-heat-bar-cell.l5 { background: rgba(255, 107, 107, 0.5); }

        /* ========== v56.0: Status Journey Timeline ========== */
        .v56-journey-timeline {
            position: relative;
            padding: 8px 0;
        }

        .v56-journey-track {
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 2px;
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-50%);
        }

        .v56-journey-progress {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            background: linear-gradient(90deg, var(--success), var(--primary), var(--accent));
            border-radius: 2px;
            transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .v56-journey-nodes {
            display: flex;
            justify-content: space-between;
            position: relative;
            z-index: 1;
        }

        .v56-journey-node {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        .v56-journey-node:hover { transform: translateY(-2px); }

        .v56-journey-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            border: 2px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .v56-journey-node.active .v56-journey-dot {
            background: var(--primary);
            border-color: var(--primary);
            box-shadow: 0 0 10px var(--primary);
        }

        .v56-journey-node.passed .v56-journey-dot {
            background: var(--success);
            border-color: var(--success);
        }

        .v56-journey-label {
            font-size: 9px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            white-space: nowrap;
        }

        .v56-journey-node.active .v56-journey-label { color: var(--primary); }

        /* ========== v56.0: Glassmorphic Pill Badge ========== */
        .v56-glass-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            background: linear-gradient(
                135deg,
                rgba(255, 255, 255, 0.1) 0%,
                rgba(255, 255, 255, 0.04) 100%
            );
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: var(--radius-full);
            font-size: 11px;
            font-weight: 600;
            color: var(--text);
            transition: all 0.3s ease;
            cursor: default;
        }

        .v56-glass-pill:hover {
            background: linear-gradient(
                135deg,
                rgba(255, 255, 255, 0.15) 0%,
                rgba(255, 255, 255, 0.08) 100%
            );
            border-color: rgba(255, 200, 100, 0.25);
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        }

        .v56-glass-pill .pill-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            box-shadow: 0 0 6px currentColor;
            animation: v56Pulse 2s ease-in-out infinite;
        }

        @keyframes v56Pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }

        /* ========== v56.0: Floating Notification Toast ========== */
        .v56-toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            z-index: 9999;
            pointer-events: none;
        }

        .v56-toast {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            background: rgba(10, 10, 18, 0.92);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: var(--radius-md);
            min-width: 220px;
            max-width: 320px;
            font-size: 13px;
            color: var(--text);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            animation: v56ToastSlide 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            pointer-events: auto;
        }

        .v56-toast.success { border-color: rgba(92, 219, 149, 0.3); }
        .v56-toast.error { border-color: rgba(255, 107, 107, 0.3); }
        .v56-toast.info { border-color: rgba(0, 212, 255, 0.3); }

        @keyframes v56ToastSlide {
            from { opacity: 0; transform: translateX(40px) scale(0.95); }
            to { opacity: 1; transform: translateX(0) scale(1); }
        }

        .v56-toast-icon { font-size: 16px; flex-shrink: 0; }
        .v56-toast-text { flex: 1; line-height: 1.4; }

        /* ========== v56.0: Compact Skill Tag ========== */
        .v56-skill-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 8px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: 500;
            color: var(--text-muted);
            transition: all 0.25s ease;
            cursor: pointer;
        }

        .v56-skill-tag:hover {
            background: rgba(0, 212, 255, 0.12);
            border-color: rgba(0, 212, 255, 0.3);
            color: var(--accent);
            transform: scale(1.05);
        }

        /* ========== v56.0: Animated Number Counter ========== */
        .v56-counter {
            font-variant-numeric: tabular-nums;
            transition: all 0.15s ease;
        }

        .v56-counter.bump {
            animation: v56CounterBump 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes v56CounterBump {
            0% { transform: scale(1); }
            40% { transform: scale(1.15); }
            100% { transform: scale(1); }
        }

        /* ========== v56.0: Morphing Action Button ========== */
        .v56-morph-btn {
            position: relative;
            padding: 8px 18px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border: none;
            border-radius: var(--radius-full);
            font-family: 'Outfit', sans-serif;
            font-size: 13px;
            font-weight: 600;
            color: var(--bg-dark);
            cursor: pointer;
            overflow: hidden;
            transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
                        box-shadow 0.2s ease;
        }

        .v56-morph-btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .v56-morph-btn:hover {
            transform: translateY(-2px) scale(1.04);
            box-shadow: 0 8px 24px rgba(255, 200, 100, 0.4);
        }

        .v56-morph-btn:hover::before { opacity: 1; }
        .v56-morph-btn:active { transform: scale(0.96); }

        /* ========== v56.0: Focus & Accessibility ========== */
        .v56-sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border-width: 0;
        }

        /* Skip to content link */
        .v56-skip-link {
            position: absolute;
            top: -100px;
            left: 16px;
            padding: 8px 16px;
            background: var(--primary);
            color: var(--bg-dark);
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 13px;
            z-index: 99999;
            transition: top 0.3s ease;
        }

        .v56-skip-link:focus {
            top: 16px;
        }

        /* ========== v56.0: Responsive Mobile Touch Targets ========== */
        @media (max-width: 768px) {
            .v56-quick-stats {
                gap: 10px;
                padding: 8px 12px;
            }

            .v56-quick-stat-value { font-size: 14px; }

            .v56-journey-label { font-size: 8px; }

            .v56-health-ring {
                width: 48px;
                height: 48px;
            }

            .v56-perf-monitor {
                bottom: 80px;
                left: 12px;
                font-size: 9px;
                padding: 6px 10px;
            }

            .v56-heat-bar-cell { width: 5px; }

            /* Touch-optimized tap targets */
            .stat-card,
            .mini-stat,
            .action-btn {
                min-height: 44px;
                min-width: 44px;
            }
        }

        /* ========== v56.0: Reduced Motion ========== */
        @media (prefers-reduced-motion: reduce) {
            .v56-scroll-animate,
            .v56-glass-pill .pill-dot {
                animation: none;
            }

            .v56-health-ring::after,
            .v56-toast,
            .v56-counter.bump {
                animation: none;
            }

            .stat-card,
            .v56-morph-btn,
            .v56-glass-pill {
                transition: none;
            }
        }

        /* ========== v56.0: High Contrast ========== */
        @media (prefers-contrast: more) {
            :root {
                --primary: #ffdd88;
                --accent: #00eeff;
                --success: #88ff88;
                --warning: #ffee44;
                --danger: #ff5555;
            }

            .stat-card,
            .glass-card {
                border-width: 2px;
                border-color: rgba(255, 255, 255, 0.3);
            }
        }

        /* ========== v57.0: Adaptive Polling & Circuit Breaker ========== */
        .api-health-panel {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-lg);
            padding: 16px 18px;
            margin-top: 14px;
        }
        .api-health-header {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .api-health-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            font-size: 12px;
        }
        .api-health-row:last-child { border-bottom: none; }
        .api-health-name {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text);
        }
        .api-health-dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        .api-health-dot.healthy { background: var(--success); box-shadow: 0 0 6px var(--success); }
        .api-health-dot.slow { background: var(--warning); box-shadow: 0 0 6px var(--warning); }
        .api-health-dot.error { background: var(--danger); box-shadow: 0 0 6px var(--danger); }
        .api-health-dot.circuit-open { background: var(--purple); box-shadow: 0 0 6px var(--purple); }
        .api-health-latency {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: var(--text-muted);
        }
        .api-health-latency.fast { color: var(--success); }
        .api-health-latency.medium { color: var(--warning); }
        .api-health-latency.slow { color: var(--danger); }
        .circuit-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 8px;
            background: rgba(168,85,247,0.15);
            border: 1px solid rgba(168,85,247,0.3);
            border-radius: var(--radius-full);
            font-size: 10px;
            color: var(--purple);
        }

        /* v57.0: Command Palette Enhancement */
        .cmd-palette.v57-enhanced {
            border: 1px solid rgba(0,212,255,0.25);
            box-shadow: 0 24px 80px rgba(0,0,0,0.7), 0 0 60px rgba(0,212,255,0.08);
        }
        .cmd-palette.v57-enhanced .cmd-search-wrap {
            border-bottom-color: rgba(0,212,255,0.12);
        }
        .cmd-item.v57-active { background: rgba(0,212,255,0.12); }
        .cmd-item.v57-active .cmd-item-label { color: var(--accent); }

        /* v57.0: Adaptive Polling Indicator */
        .polling-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
            padding: 3px 10px;
            background: rgba(255,255,255,0.04);
            border-radius: var(--radius-full);
            transition: all 0.3s ease;
        }
        .polling-indicator.fast { background: rgba(92,219,149,0.12); color: var(--success); }
        .polling-indicator.normal { background: rgba(0,212,255,0.12); color: var(--accent); }
        .polling-indicator.slow { background: rgba(254,202,87,0.12); color: var(--warning); }
        .polling-indicator.idle { background: rgba(168,85,247,0.12); color: var(--purple); }
        .polling-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: currentColor;
        }
        .polling-indicator.fast .polling-dot { animation: pollingPulseFast 0.8s ease-in-out infinite; }
        .polling-indicator.normal .polling-dot { animation: pollingPulseFast 2s ease-in-out infinite; }
        .polling-indicator.slow .polling-dot { animation: pollingPulseFast 4s ease-in-out infinite; }
        @keyframes pollingPulseFast {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(0.7); }
        }

        /* v57.0: External Route Response Time */
        .route-response-time {
            font-size: 10px;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
            margin-left: 4px;
        }
        .route-response-time.fast { color: var(--success); }
        .route-response-time.medium { color: var(--warning); }
        .route-response-time.slow { color: var(--danger); }

        /* v57.0: Error Recovery Card */
        .error-recovery-card {
            background: rgba(255,107,107,0.08);
            border: 1px solid rgba(255,107,107,0.2);
            border-radius: var(--radius-md);
            padding: 12px 14px;
            margin-top: 10px;
            transition: all 0.3s ease;
        }
        .error-recovery-card:hover { background: rgba(255,107,107,0.12); }
        .error-recovery-title {
            font-size: 11px;
            color: var(--danger);
            font-weight: 500;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .error-recovery-text { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
        .retry-countdown {
            font-family: 'JetBrains Mono', monospace;
            color: var(--warning);
            font-size: 11px;
        }

        /* ========== v56.0: Print Optimization ========== */
        @media print {
            .v56-perf-monitor,
            .v56-toast-container,
            .fab-orb,
            .emoji-float-container,
            .v52-mesh-gradient,
            .v52-particle-grid {
                display: none !important;
            }
        }

    </style>
</head>
<body class="loading">
    <!-- v52.0: Background Effects -->
    <div class="v52-mesh-gradient"></div>
    <div class="v52-particle-grid"></div>
    
    <!-- v52.0: Scroll Progress Bar -->
    <div class="v52-scroll-progress" id="v52ScrollProgress"></div>
    
    <!-- v52.0: Data Stream Wire -->
    <div class="v52-data-wire" id="v52DataWire"></div>
    
    <!-- v52.0: Toast Stack -->
    <div class="v52-toast-stack" id="v52ToastStack"></div>
    
    <!-- v52.0: Confetti Container -->
    <div class="v52-confetti-container" id="v52ConfettiContainer"></div>
    
    <!-- v52.0: Offline Banner -->
    <div class="offline-banner" id="offlineBanner" role="alert" aria-live="assertive">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.58 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/>
        </svg>
        <span id="offlineBannerText">网络已断开 — 显示缓存数据</span>
    </div>

    <!-- v46.0: Pull-to-Refresh Indicator -->
    <div class="ptr-indicator" id="ptrIndicator" role="status" aria-live="polite">
        <div class="ptr-spinner"></div>
        <span>下拉刷新...</span>
    </div>

    <!-- v46.0: Data Stream Wire -->
    <div class="data-stream-wire" id="dataStreamWire"></div>

    <!-- v45.0: Quantum State Flash Overlay -->
    <div class="quantum-flash" id="quantumFlash">
        <div class="quantum-flash-grid"></div>
    </div>

    <!-- v38.0: State Flash Overlay -->
    <div class="v38-state-flash" id="v38StateFlash"></div>

    <!-- v38.0: Pulsing Dot Grid Background -->
    <div class="v38-dot-grid v38-dot-grid-active" id="v38DotGrid"></div>

    <!-- Scroll Progress -->
    <div class="scroll-progress" id="scrollProgress"></div>

    <!-- v48.0: Keyboard Shortcut Hints Panel -->
    <div class="v48-kbd-hint" id="v48KbdHint">
        <div class="v48-kbd-row"><kbd>?</kbd> Show shortcuts</div>
        <div class="v48-kbd-row"><kbd>R</kbd> Refresh data</div>
        <div class="v48-kbd-row"><kbd>M</kbd> Toggle mode</div>
        <div class="v48-kbd-row"><kbd>Esc</kbd> Dismiss</div>
    </div>

    <!-- Toast Queue -->
    <div class="toast-queue" id="toastQueue" role="region" aria-label="Notifications" aria-live="polite"></div>

    <!-- v46.0: Scroll to Top -->
    <button class="scroll-to-top" id="scrollToTop" aria-label="Scroll to top" onclick="scrollToTop()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"/>
        </svg>
    </button>

    <!-- v46.0: ARIA Live Announcer -->
    <div id="ariaLiveAnnouncer" aria-live="polite" aria-atomic="true" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;"></div>

    <!-- Command Palette -->
    <div class="cmd-overlay" id="cmdOverlay" onclick="if(event.target===this)closeCommandPalette()">
        <div class="cmd-palette">
            <div class="cmd-search-wrap">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input class="cmd-input" id="cmdInput" placeholder="Type a command..." autocomplete="off" oninput="filterCommands()"/>
                <span class="cmd-kbd">ESC</span>
            </div>
            <div class="cmd-results" id="cmdResults"></div>
        </div>
    </div>

    <!-- Background Effects -->
    <div class="bg-mesh"></div>
    <div class="bg-space"></div>
    <div class="bg-stars" id="stars"></div>
    <canvas class="bg-neural" id="neuralCanvas"></canvas>

    <!-- Ambient Floating Orbs -->
    <div class="ambient-orb ambient-orb-1"></div>
    <div class="ambient-orb ambient-orb-2"></div>
    <div class="ambient-orb ambient-orb-3"></div>
    <div class="ambient-orb ambient-orb-4"></div>

    <!-- Particle Mesh Background -->
    <canvas class="particle-mesh-canvas" id="particleMeshCanvas"></canvas>

    <!-- Glow Cursor -->
    <div class="glow-cursor" id="glowCursor"></div>

    
    <!-- v40.0: AI Activity Stream -->
    <div class="activity-stream" id="activityStream"></div>

    <!-- v43.0: Keyboard Shortcuts Panel (press ? to toggle) -->
    <div class="v43-shortcuts-panel" id="v43ShortcutsPanel">
        <div class="v43-shortcuts-title">⌨️ Keyboard Shortcuts</div>
        <div class="v43-shortcuts-row">
            <span class="v43-shortcut-key"><kbd>?</kbd></span>
            <span class="v43-shortcut-desc">Toggle shortcuts</span>
        </div>
        <div class="v43-shortcuts-row">
            <span class="v43-shortcut-key"><kbd>Ctrl</kbd><kbd>K</kbd></span>
            <span class="v43-shortcut-desc">Command palette</span>
        </div>
        <div class="v43-shortcuts-row">
            <span class="v43-shortcut-key"><kbd>R</kbd></span>
            <span class="v43-shortcut-desc">Refresh data</span>
        </div>
        <div class="v43-shortcuts-row">
            <span class="v43-shortcut-key"><kbd>Esc</kbd></span>
            <span class="v43-shortcut-desc">Close panel</span>
        </div>
        <div class="v43-shortcuts-row">
            <span class="v43-shortcut-key"><kbd>1</kbd>-<kbd>5</kbd></span>
            <span class="v43-shortcut-desc">Quick mood</span>
        </div>
    </div>

    <!-- Main Dashboard -->
    <div class="dashboard-container">
        <div class="glass-card">
            <!-- Header -->
            <div class="dashboard-header">
                <div class="header-left">
                    <div class="status-badge">
                        <div class="status-dot" id="statusDot"></div>
                        <span id="statusText">Loading...</span>
                    </div>
                </div>
                <div class="header-right">
                    <!-- v48.5: OpenClaw Connection Status -->
                    <div class="oc-connection-indicator active" id="ocConnectionStatus" title="OpenClaw Gateway">
                        <span class="oc-connection-dot"></span>
                        <span id="ocConnectionText">Connected</span>
                    </div>
                    <div class="ai-status-badge active" id="v38AiStatus" title="AI Active">
                        <span>MoShang</span>
                    </div>
                    <div class="live-indicator" id="v38LiveIndicator" title="Live Data">
                        LIVE
                    </div>
                    <div class="oc-data-stream" id="ocDataStream" title="Data Stream"></div>
                    <div class="refresh-badge">
                        <div class="dot"></div>
                        <span id="refreshRate">Fast</span>
                    </div>
                    <!-- v57.0: Adaptive polling indicator -->
                    <div class="polling-indicator normal" id="v57PollingIndicator">
                        <span class="polling-dot"></span>3s
                    </div>
                </div>
            </div>

            <!-- v56.0: Quick Stats Summary Bar -->
            <div class="v56-quick-stats" id="v56QuickStats" style="margin: 10px 0;">
                <div class="v56-quick-stat">
                    <div class="v56-quick-stat-value v56-counter" id="v56QuickMsgs">--</div>
                    <div class="v56-quick-stat-label">Messages</div>
                </div>
                <div class="v56-quick-stat">
                    <div class="v56-quick-stat-value v56-counter" id="v56QuickTasks">--</div>
                    <div class="v56-quick-stat-label">Tasks</div>
                </div>
                <div class="v56-quick-stat">
                    <div class="v56-quick-stat-value v56-counter" id="v56QuickSkills">--</div>
                    <div class="v56-quick-stat-label">Skills</div>
                </div>
                <div class="v56-quick-stat">
                    <!-- v56.0: Health Score Ring -->
                    <div class="v56-health-ring good" id="v56HealthRing" title="System Health Score">
                        <svg viewBox="0 0 100 100">
                            <circle class="ring-bg" cx="50" cy="50" r="42"/>
                            <circle class="ring-fill" id="v56HealthRingFill" cx="50" cy="50" r="42"
                                stroke-dasharray="264" stroke-dashoffset="264"/>
                        </svg>
                        <span class="ring-label" id="v56HealthLabel">--</span>
                    </div>
                    <div class="v56-quick-stat-label">Health</div>
                </div>
                <div class="v56-quick-stat">
                    <!-- v56.0: Activity Heat Bar -->
                    <div class="v56-heat-bar" id="v56HeatBar" title="24h Activity Heatmap"></div>
                    <div class="v56-quick-stat-label" style="margin-top: 4px;">24h Heat</div>
                </div>
            </div>

            <!-- Dashboard Grid -->
            <div class="dashboard-grid">
                <!-- Left Column -->
                <div class="left-column">
                    <div class="avatar-section v38-entrance">
                        <div class="fox-container v43-breathing-glow" id="foxContainer">
                            <div class="activity-sync-ring active" id="activitySyncRing"></div>
                            <div class="neural-sync-indicator" id="neuralSyncIndicator"></div>
                            <div class="mood-aura" id="moodAura"></div>
                            <!-- v40.0: Data Freshness Ring -->
                            <div class="v39-data-freshness-ring fresh" id="v39DataFreshnessRing"></div>
                            <!-- v40.0: AI Processing Aura -->
                            <div class="v39-ai-processing-aura" id="v39AIProcessingAura"></div>
                            <!-- v40.0: Sync Wave -->
                            <div class="v39-sync-wave" id="v39SyncWave"></div>
                            <div class="energy-core">
                                <div class="energy-ring"></div>
                                <div class="energy-ring"></div>
                                <div class="energy-ring"></div>
                            </div>
                            <div class="fox-canvas-wrapper">
                                <div class="fox-shadow"></div>
                                <div class="fox-glow-aura" id="foxGlowAura"></div>
                                <canvas class="fox-canvas" id="foxCanvas"></canvas>
                            </div>
                            <div class="mood-sync-ring" id="moodSyncRing"></div>
                            <div class="fox-expression" id="foxExpression">😺</div>
                            <div class="fox-status-ring-v38" id="v38FoxRing"></div>
                        </div>

                        <h1 class="fox-name gradient-text-animated">MoShang</h1>
                        <p class="fox-role">Digital Assistant</p>

                        <div class="stats-row v38-entrance v38-entrance-1">
                            <div class="mini-stat">
                                <div class="mini-stat-value" id="miniHeartbeat">--</div>
                                <div class="mini-stat-label">BPM</div>
                            </div>
                            <div class="mini-stat">
                                <div class="mini-stat-value" id="miniActivity">--</div>
                                <div class="mini-stat-label">Activity</div>
                            </div>
                        </div>

                        <div class="status-section v38-entrance v38-entrance-2">
                            <div class="status-title">Current Status</div>
                            <div class="status-value" id="statusValue">Idle</div>
                        </div>

                        <div class="quick-actions v38-entrance v38-entrance-3">
                            <button class="action-btn" onclick="setMode('idle')">Idle</button>
                            <button class="action-btn" onclick="setMode('working')">Work</button>
                            <button class="action-btn" onclick="setMode('sleeping')">Sleep</button>
                        </div>

                        <div class="mood-selector v38-entrance v38-entrance-4" id="moodSelector">
                            <button class="mood-btn" onclick="setMood('idle')" title="Idle">😺</button>
                            <button class="mood-btn" onclick="setMood('excited')" title="Excited">🎉</button>
                            <button class="mood-btn" onclick="setMood('thinking')" title="Thinking">🤔</button>
                            <button class="mood-btn" onclick="setMood('laughing')" title="Laughing">😄</button>
                            <button class="mood-btn" onclick="setMood('focused')" title="Focused">🎯</button>
                        </div>

                        <div class="quick-stats">
                            <div class="quick-stat">
                                <div class="quick-stat-value" id="quickMsgs">--</div>
                                <div class="quick-stat-label">Msgs</div>
                            </div>
                            <div class="quick-stat">
                                <div class="quick-stat-value" id="quickTasks">--</div>
                                <div class="quick-stat-label">Tasks</div>
                            </div>
                            <div class="quick-stat">
                                <div class="quick-stat-value" id="quickSkills">--</div>
                                <div class="quick-stat-label">Skills</div>
                            </div>
                        </div>

                        <!-- v45.0: Hexagonal Skills Display -->
                        <div class="skills-hex-container" id="skillsHexContainer">
                            <div class="skills-hex-bg">
                                <svg viewBox="0 0 120 110">
                                    <defs>
                                        <linearGradient id="hexGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                            <stop offset="0%" style="stop-color:rgba(0,212,255,0.3)"/>
                                            <stop offset="100%" style="stop-color:rgba(168,85,247,0.3)"/>
                                        </linearGradient>
                                    </defs>
                                    <polygon points="60,5 110,30 110,80 60,105 10,80 10,30"
                                        fill="url(#hexGrad)" stroke="rgba(0,212,255,0.5)" stroke-width="1.5"/>
                                </svg>
                            </div>
                            <div class="skills-hex-overlay">
                                <span class="skills-hex-count" id="skillsHexCount">--</span>
                                <span class="skills-hex-label">Skills</span>
                            </div>
                            <div class="skills-hex-pulse"></div>
                        </div>
                        </div>

                        <div class="glass-divider"></div>

                        <div class="session-journey" id="sessionJourney">
                            <div class="journey-title">🚀 Today's Journey</div>
                            <div class="journey-track">
                                <div class="journey-fill" id="journeyFill" style="width: 0%"></div>
                                <div class="journey-marker" id="journeyMarker" style="left: 0%"></div>
                            </div>
                            <div class="journey-label">
                                <span>Session Start</span>
                                <span id="journeyProgress">0%</span>
                            </div>
                        </div>

                        <div class="time-greeting" id="timeGreeting">Loading...</div>

                        <!-- v50.0: Spark Meter - Energy/Creativity Level -->
                        <div class="v50-glass-shine glass-card" style="padding: 12px; margin-top: 8px;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                                <span style="font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.5px;">Energy Level</span>
                                <span id="v50SparkValue" style="font-size: 14px; font-weight: 700; color: var(--primary);">--</span>
                            </div>
                            <div class="v50-spark-meter">
                                <div class="v50-spark-fill" id="v50SparkFill" style="width: 0%;"></div>
                            </div>
                            <div class="v50-spark-dots">
                                <div class="v50-spark-dot" data-level="1"></div>
                                <div class="v50-spark-dot" data-level="2"></div>
                                <div class="v50-spark-dot" data-level="3"></div>
                                <div class="v50-spark-dot" data-level="4"></div>
                                <div class="v50-spark-dot" data-level="5"></div>
                            </div>
                        </div>

                        <!-- v50.0: Mood Evolution Timeline -->
                        <div class="v50-mood-timeline" id="v50MoodTimeline" style="margin-top: 8px;">
                            <div class="v50-mood-node current" data-mood="idle">
                                <span class="v50-mood-emoji">😺</span>
                                <span class="v50-mood-label">Idle</span>
                            </div>
                            <div class="v50-mood-node" data-mood="working">
                                <span class="v50-mood-emoji">⚡</span>
                                <span class="v50-mood-label">Work</span>
                            </div>
                            <div class="v50-mood-node" data-mood="excited">
                                <span class="v50-mood-emoji">🎉</span>
                                <span class="v50-mood-label">Happy</span>
                            </div>
                            <div class="v50-mood-node" data-mood="thinking">
                                <span class="v50-mood-emoji">🤔</span>
                                <span class="v50-mood-label">Think</span>
                            </div>
                            <div class="v50-mood-node" data-mood="sleeping">
                                <span class="v50-mood-emoji">😴</span>
                                <span class="v50-mood-label">Sleep</span>
                            </div>
                        </div>

                        <!-- v50.0: Sound Wave Visualizer -->
                        <div class="v50-sound-wave paused" id="v50SoundWave" style="margin-top: 8px;">
                            <div class="v50-wave-bar"></div>
                            <div class="v50-wave-bar"></div>
                            <div class="v50-wave-bar"></div>
                            <div class="v50-wave-bar"></div>
                            <div class="v50-wave-bar"></div>
                        </div>

                        <!-- v50.0: Real-time Heartbeat Line Chart -->
                        <div class="v50-heartbeat-chart" id="v50HeartbeatChart" style="margin-top: 8px;">
                            <svg viewBox="0 0 200 60" preserveAspectRatio="none">
                                <defs>
                                    <linearGradient id="heartbeatGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                                        <stop offset="0%" style="stop-color:var(--primary);stop-opacity:0.4"/>
                                        <stop offset="100%" style="stop-color:var(--primary);stop-opacity:0"/>
                                    </linearGradient>
                                </defs>
                                <path class="v50-heartbeat-area" id="v50HeartbeatArea" d="M0,30 L200,30"/>
                                <path class="v50-heartbeat-line" id="v50HeartbeatLine" d="M0,30 L200,30"/>
                                <circle class="v50-heartbeat-dot" id="v50HeartbeatDot" cx="200" cy="30" r="3" style="display:none;"/>
                            </svg>
                        </div>
                        
                        <!-- v40.0: AI Context Panel -->
                        <div class="ai-context-panel" id="aiContextPanel">
                            <div class="ai-context-title">AI Context</div>
                            <div class="ai-context-text" id="aiContextText">
                                Initializing agent context<span class="ai-context-cursor"></span>
                            </div>
                        </div>
                        
                        <!-- v40.0: Metrics Row -->
                        <div class="metrics-row" id="metricsRow">
                            <div class="metric-pill highlight" title="Data Freshness">
                                <span class="metric-pill-dot"></span>
                                <span id="metricsFreshness">Fresh</span>
                            </div>
                            <div class="metric-pill" title="Session Mode">
                                <span class="metric-pill-dot"></span>
                                <span id="metricsMode">Normal</span>
                            </div>
                            <div class="metric-pill" title="Cache Status">
                                <span class="metric-pill-dot"></span>
                                <span id="metricsCache">Hit</span>
                            </div>
                        </div>

                        <!-- v45.0: Neural Activity Waveform -->
                        <div class="neural-waveform-container" id="neuralWaveformContainer">
                            <span class="neural-waveform-label">NEURAL</span>
                            <div class="neural-waveform-glow"></div>
                            <canvas class="neural-waveform-canvas" id="neuralWaveformCanvas"></canvas>
                        </div>

                        <!-- v45.0: AI Neural Spark -->
                        <div class="neural-spark-container" id="neuralSparkContainer">
                            <span class="neural-spark-label">SYNC</span>
                            <canvas class="neural-spark-canvas" id="neuralSparkCanvas"></canvas>
                        </div>
<div class="story-card" id="storyCard">
                            <div class="story-title">📊 Activity Story</div>
                            <div class="story-text" id="storyText">Analyzing today's rhythm...</div>
                        </div>

                        <div class="task-progress" id="taskProgress" style="display:none;">
                            <div class="task-progress-header">
                                <span class="task-progress-label">Current Task</span>
                                <span class="task-progress-value" id="taskProgressValue">0%</span>
                            </div>
                            <div class="task-progress-bar">
                                <div class="task-progress-fill" id="taskProgressFill" style="width: 0%"></div>
                            </div>
                        </div>

                        <div class="thinking-chain" id="thinkingChain" style="display:none;">
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <div class="thinking-node"></div>
                            <span class="thinking-label">Thinking...</span>
                        </div>

                        <div class="reputation-badge" id="reputationBadge" title="EvoMap Reputation">
                            <span class="reputation-icon">⭐</span>
                            <span id="reputationValue">--</span>
                        </div>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="right-column">
                    <div class="stat-card spring-hover v38-entrance v38-entrance-1" data-stat="heartbeat" onclick="copyStat('heartbeat')">
                        <div class="corner-fold"></div>
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(255,200,100,0.12); color: var(--primary);">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                            </div>
                            <div class="stat-value skeleton-loading" id="heartbeat">--</div>
                        </div>
                        <div class="stat-label">Heart Rate</div>
                        <div class="stat-subtext">BPM • Swipe to copy</div>
                        <div class="progress-container">
                            <div class="progress-tooltip" id="heartbeatTooltip">-- BPM</div>
                            <div class="progress-bar">
                                <div class="progress-fill" id="heartbeatBar" style="width: 0%"></div>
                            </div>
                        </div>
                        <svg class="mini-trend" id="heartbeatSparkline" viewBox="0 0 48 20" preserveAspectRatio="none"></svg>
                    </div>

                    <div class="stat-card v38-entrance v38-entrance-2" data-stat="activity" onclick="copyStat('activity')">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(0,212,255,0.12); color: var(--accent);">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                                </svg>
                            </div>
                            <div class="stat-value skeleton-loading" id="activity">--</div>
                        </div>
                        <div class="stat-label">Activity Level</div>
                        <div class="stat-subtext">0-100% • Swipe to copy</div>
                        <div class="progress-container">
                            <div class="progress-tooltip" id="activityTooltip">--%</div>
                            <div class="progress-bar">
                                <div class="progress-fill" id="activityBar" style="width: 0%"></div>
                            </div>
                        </div>
                        <svg class="mini-trend" id="activitySparkline" viewBox="0 0 48 20" preserveAspectRatio="none"></svg>
                    </div>

                    <div class="stat-card spring-hover v38-entrance v38-entrance-3" data-stat="memory" onclick="copyStat('memory')">
                        <div class="corner-fold"></div>
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(92,219,149,0.12); color: var(--success);">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="2" y="6" width="20" height="12" rx="2"/>
                                    <path d="M6 12h4M8 10v4M14 12h.01M18 12h.01"/>
                                </svg>
                            </div>
                            <div class="stat-value skeleton-loading" id="memory">--</div>
                        </div>
                        <div class="stat-label">Memory Usage</div>
                        <div class="stat-subtext">MB • Swipe to copy</div>
                        <div class="progress-container">
                            <div class="progress-tooltip" id="memoryTooltip">-- MB</div>
                            <div class="progress-bar">
                                <div class="progress-fill" id="memoryBar" style="width: 0%"></div>
                            </div>
                        </div>
                        <svg class="mini-trend" id="memorySparkline" viewBox="0 0 48 20" preserveAspectRatio="none"></svg>
                        <!-- v45.0: Circular Memory Gauge -->
                        <div class="memory-gauge-container" id="memoryGaugeContainer" style="display:none;">
                            <svg class="memory-gauge-svg" viewBox="0 0 100 100">
                                <circle class="memory-gauge-bg" cx="50" cy="50" r="40"/>
                                <circle class="memory-gauge-fill low" id="memoryGaugeFill" cx="50" cy="50" r="40"
                                    stroke-dasharray="251.2" stroke-dashoffset="251.2"/>
                            </svg>
                            <div class="memory-gauge-center">
                                <span class="memory-gauge-value" id="memoryGaugeValue">--</span>
                                <span class="memory-gauge-label">MEM%</span>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card spring-hover v38-entrance v38-entrance-4" data-stat="cpu" onclick="copyStat('cpu')">
                        <div class="corner-fold"></div>
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(254,202,87,0.12); color: var(--warning);">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="4" y="4" width="16" height="16" rx="2"/>
                                    <rect x="9" y="9" width="6" height="6"/>
                                    <path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"/>
                                </svg>
                            </div>
                            <div class="stat-value skeleton-loading" id="cpu">--</div>
                        </div>
                        <div class="stat-label">CPU Usage</div>
                        <div class="stat-subtext">% • Swipe to copy</div>
                        <div class="progress-container">
                            <div class="progress-tooltip" id="cpuTooltip">--%</div>
                            <div class="progress-bar">
                                <div class="progress-fill" id="cpuBar" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- v56.0: System Health Score Card -->
                    <div class="stat-card spring-hover v38-entrance" data-stat="health" onclick="calculateHealthScore()" title="Click to refresh health score">
                        <div class="stat-card-header">
                            <div class="stat-icon" style="background: rgba(92,219,149,0.12); color: var(--success);">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                                </svg>
                            </div>
                            <div class="stat-value" id="v56HealthScore" style="color: var(--success);">--</div>
                        </div>
                        <div class="stat-label">System Health</div>
                        <div class="stat-subtext">Memory + CPU + Uptime</div>
                        <!-- v56.0: Health Ring -->
                        <div class="v56-health-ring good" id="v56HealthRingCard" style="margin: 8px auto; transform: scale(0.85);">
                            <svg viewBox="0 0 100 100">
                                <circle class="ring-bg" cx="50" cy="50" r="42"/>
                                <circle class="ring-fill" id="v56HealthRingFillCard" cx="50" cy="50" r="42"
                                    stroke-dasharray="264" stroke-dashoffset="264"/>
                            </svg>
                            <span class="ring-label" id="v56HealthLabelCard">--</span>
                        </div>
                        <div class="metrics-row" style="margin-top: 6px;">
                            <div class="metric-pill" style="background: rgba(92,219,149,0.12); color: var(--success);">
                                <span id="v56HealthMem">--</span>% MEM
                            </div>
                            <div class="metric-pill" style="background: rgba(254,202,87,0.12); color: var(--warning);">
                                <span id="v56HealthCpu">--</span>% CPU
                            </div>
                        </div>
                    </div>

                    <!-- Charts Section -->
                    <div class="charts-section">
                        <div class="charts-container">
                            <div class="chart-card">
                                <div class="chart-title">24h Activity Rhythm</div>
                                <div class="chart-canvas-container">
                                    <canvas class="chart-canvas" id="activityChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <div class="chart-title">Memory History</div>
                                <div class="chart-canvas-container">
                                    <canvas class="chart-canvas" id="memoryChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <div class="chart-title">CPU History</div>
                                <div class="chart-canvas-container">
                                    <canvas class="chart-canvas" id="cpuChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Section -->
                    <div class="bottom-section">
                        <div class="memory-timeline">
                            <div class="timeline-header">
                                <div class="timeline-title">Recent Memories</div>
                            </div>
                            <div class="timeline-items" id="timelineItems"></div>
                        </div>

                        <div class="skills-distribution">
                            <div class="skills-title">Skills Distribution</div>
                            <div id="skillsList"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="dashboard-footer">
                <!-- v46.0: Status Pulse Line -->
                <div class="status-pulse-line" id="statusPulseLine"></div>
                <div class="data-route-map" id="dataRouteMap">
                    <div class="route-node" id="routeSrc">
                        <div class="route-dot"></div>
                        <span>Source</span>
                    </div>
                    <div class="route-line"></div>
                    <div class="route-node" id="routeGW">
                        <div class="route-dot"></div>
                        <span>Gateway</span>
                    </div>
                    <div class="route-line"></div>
                    <div class="route-node" id="routeDash">
                        <div class="route-dot"></div>
                        <span>Dashboard</span>
                    </div>
                </div>
                <div class="footer-info">
                    <span id="dataAgeDisplay" title="Data Age">--</span>
                    <span id="dataSourceHealth" class="data-source-badge" title="Data Source Health">
                        <span class="source-dot" id="sourceDot"></span>
                        <span id="sourceName">--</span>
                    </span>
                    <span id="externalRouteStatus" class="external-route-badge" title="External Route Status">
                        <span class="route-dot" id="routeDot"></span>
                        <span id="routeName">Route</span>
                    </span>
                    <span id="routeStatusDisplay" class="route-check-time" title="Last Check">--</span>
                </div>
                <div class="footer-info">
                    <span class="footer-version v42-version-glow v43-version-badge" id="footerVersion">v52.0</span>
                    <span class="v48-footer-badge" id="v50FooterBadge">✨ v52.0</span>
                    <span id="uptime">--</span>
                    <span id="reliabilityBadge" class="reliability-badge high" aria-label="Data Reliability Score">100%</span>
                    <!-- v40.0: Connection Quality -->
                    <div class="v39-connection-quality excellent" id="v39ConnectionQuality" title="Connection Quality">
                        <div class="v39-connection-bar v43-connection-bar"></div>
                        <div class="v39-connection-bar v43-connection-bar"></div>
                        <div class="v39-connection-bar v43-connection-bar"></div>
                        <div class="v39-connection-bar v43-connection-bar"></div>
                    </div>
                    <!-- v48.0: Reliability Ring Badge -->
                    <div class="v48-reliability-ring high" id="v48ReliabilityRing" data-value="100" title="Data Reliability Score">
                        <svg width="48" height="48" viewBox="0 0 48 48">
                            <circle class="ring-bg" cx="24" cy="24" r="18" stroke-width="3"/>
                            <circle class="ring-fill" cx="24" cy="24" r="18" stroke-width="3" stroke-dasharray="113.1" stroke-dashoffset="0"/>
                        </svg>
                        <span class="ring-value">100</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ========== State Management v36 ==========
        const state = {
            heartbeat: '--',
            activity: '--',
            memory: '--',
            cpu: '--',
            status: 'idle',
            uptime: '--',
            lastUpdated: '--',
            dataHistory: { heartbeat: [], activity: [], memory: [], cpu: [] },
            maxHistory: 24,
            dataSource: 'api',
            dataAge: 0,
            lastSuccessfulFetch: null,
            consecutiveErrors: 0,
            isOnline: true,
            sessionStart: Date.now(),
            peakActivityCount: 0,
            lastPeakTime: null,
            currentTask: null,
            taskProgress: 0,
            reputation: null,
            activityPeaks: [],
            msgCount: 0,
            taskDone: 0,
            skillsTotal: 0,
            recoveryScheduled: false,
            // v57.0: Circuit breaker for API endpoints
            apiHealth: {
                heartbeat: { failures: 0, latency: null, circuitOpen: false, lastSuccess: null },
                system: { failures: 0, latency: null, circuitOpen: false, lastSuccess: null },
                memories: { failures: 0, latency: null, circuitOpen: false, lastSuccess: null },
                skills: { failures: 0, latency: null, circuitOpen: false, lastSuccess: null },
                dashboard: { failures: 0, latency: null, circuitOpen: false, lastSuccess: null }
            },
            circuitBreakerThreshold: 5,
            circuitBreakerResetMs: 60000,
            // v57.0: External route response time
            lastRouteLatency: null
        };

        // ========== DOM Elements ==========
        const $ = id => document.getElementById(id);
        const elements = {
            body: document.body,
            statusDot: $('statusDot'),
            statusText: $('statusText'),
            refreshRate: $('refreshRate'),
            foxCanvas: $('foxCanvas'),
            foxContainer: $('foxContainer'),
            moodSyncRing: $('moodSyncRing'),
            heartbeat: $('heartbeat'),
            activity: $('activity'),
            memory: $('memory'),
            cpu: $('cpu'),
            heartbeatBar: $('heartbeatBar'),
            activityBar: $('activityBar'),
            memoryBar: $('memoryBar'),
            cpuBar: $('cpuBar'),
            miniHeartbeat: $('miniHeartbeat'),
            miniActivity: $('miniActivity'),
            statusValue: $('statusValue'),
            lastUpdated: $('lastUpdated'),
            uptime: $('uptime'),
            timelineItems: $('timelineItems'),
            skillsList: $('skillsList'),
            stars: $('stars'),
            neuralCanvas: $('neuralCanvas'),
            sourceDot: $('sourceDot'),
            sourceName: $('sourceName'),
            routeDot: $('routeDot'),
            routeName: $('routeName'),
            externalRouteBadge: $('externalRouteStatus'),
            // v48.5: OpenClaw Connection Status
            ocConnectionStatus: $('ocConnectionStatus'),
            ocConnectionText: $('ocConnectionText'),
            ocDataStream: $('ocDataStream')
        };

        // ========== OpenClaw Connection Status v48.5 ==========
        function updateOCConnectionStatus(status) {
            const el = elements.ocConnectionStatus;
            if (!el) return;
            
            el.classList.remove('active', 'disconnected', 'connecting');
            
            switch(status) {
                case 'connected':
                    el.classList.add('active');
                    if (elements.ocConnectionText) {
                        elements.ocConnectionText.textContent = 'Connected';
                    }
                    break;
                case 'disconnected':
                    el.classList.add('disconnected');
                    if (elements.ocConnectionText) {
                        elements.ocConnectionText.textContent = 'Disconnected';
                    }
                    break;
                case 'connecting':
                    el.classList.add('connecting');
                    if (elements.ocConnectionText) {
                        elements.ocConnectionText.textContent = 'Connecting...';
                    }
                    break;
            }
        }

        // v48.5: Activate data stream animation
        function activateDataStream() {
            const stream = elements.ocDataStream;
            if (stream) {
                stream.style.display = 'block';
                // Reset animation
                stream.style.animation = 'none';
                stream.offsetHeight; // Trigger reflow
                stream.style.animation = 'ocDataStream 2s linear infinite';
            }
        }

        // v48.5: Deactivate data stream
        function deactivateDataStream() {
            const stream = elements.ocDataStream;
            if (stream) {
                stream.style.display = 'none';
            }
        }

        // ========== Particle Burst ==========
        function createParticleBurst(ctx, x, y) {
            const particles = [];
            const colors = ['#ffc864','#00d4ff','#5cdb95','#ff6b6b','#a855f7'];
            for (let i = 0; i < 14; i++) {
                const angle = (Math.PI * 2 / 14) * i;
                const velocity = 5 + Math.random() * 6;
                particles.push({
                    x, y,
                    vx: Math.cos(angle) * velocity,
                    vy: Math.sin(angle) * velocity,
                    life: 1,
                    color: colors[Math.floor(Math.random() * colors.length)],
                    size: 3 + Math.random() * 4
                });
            }
            function animate() {
                let alive = false;
                particles.forEach(p => {
                    if (p.life > 0) {
                        alive = true;
                        p.x += p.vx; p.y += p.vy; p.vy += 0.15;
                        p.life -= 0.03;
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
                        ctx.fillStyle = p.color;
                        ctx.globalAlpha = p.life;
                        ctx.fill();
                        ctx.globalAlpha = 1;
                    }
                });
                if (alive) requestAnimationFrame(animate);
            }
            animate();
        }

        // ========== Data Source Health v42 ==========
        // v42.0: Enhanced retry logic with exponential backoff
        const retryConfig = {
            maxRetries: 3,
            baseDelay: 1000,
            maxDelay: 10000,
            backoffMultiplier: 2
        };
        
        let retryCount = 0;
        let currentRetryDelay = retryConfig.baseDelay;
        
        function scheduleRetry() {
            if (retryCount >= retryConfig.maxRetries) {
                console.warn('Max retries reached, switching to offline mode');
                updateDataSourceHealth(state.dataSource, false);
                retryCount = 0;
                currentRetryDelay = retryConfig.baseDelay;
                return;
            }
            
            const delay = currentRetryDelay * Math.random();
            console.log(`Retrying in ${Math.round(delay)}ms (attempt ${retryCount + 1}/${retryConfig.maxRetries})`);
            
            setTimeout(async () => {
                retryCount++;
                currentRetryDelay = Math.min(currentRetryDelay * retryConfig.backoffMultiplier, retryConfig.maxDelay);
                await fetchDashboardData();
            }, delay);
        }
        
        // v44.0: Enhanced data freshness monitoring with timestamp display
        function updateDataFreshness() {
            if (!state.lastSuccessfulFetch) return;

            const age = (Date.now() - state.lastSuccessfulFetch) / 1000;
            state.dataAge = age;

            const freshnessRing = document.getElementById('v39DataFreshnessRing');
            if (freshnessRing) {
                freshnessRing.classList.remove('fresh', 'stale', 'critical');
                if (age < 30) {
                    freshnessRing.classList.add('fresh');
                } else if (age < 60) {
                    freshnessRing.classList.add('stale');
                } else {
                    freshnessRing.classList.add('critical');
                }
            }

            // Update metrics freshness pill with detailed info
            const freshnessPill = document.getElementById('metricsFreshness');
            if (freshnessPill) {
                let freshnessText = '';
                let freshnessClass = '';
                if (age < 30) {
                    freshnessText = '实时';
                    freshnessClass = 'highlight';
                } else if (age < 60) {
                    freshnessText = `延迟${Math.floor(age)}s`;
                    freshnessClass = '';
                } else if (age < 120) {
                    freshnessText = `过期${Math.floor(age)}s`;
                    freshnessClass = 'highlight';
                } else {
                    freshnessText = `断开${Math.floor(age / 60)}m`;
                    freshnessClass = 'highlight';
                }
                freshnessPill.textContent = freshnessText;
                const pill = freshnessPill.closest('.metric-pill');
                if (pill) {
                    if (freshnessClass === 'highlight') {
                        pill.classList.add('highlight');
                        pill.querySelector('.metric-pill-dot').style.background = age >= 60 ? 'var(--warning)' : 'var(--accent)';
                    } else {
                        pill.classList.remove('highlight');
                        pill.querySelector('.metric-pill-dot').style.background = '';
                    }
                }
            }

            // v44.0: Update last data timestamp display
            const dataAgeEl = document.getElementById('dataAgeDisplay');
            if (dataAgeEl) {
                if (age < 5) {
                    dataAgeEl.textContent = '刚刚更新';
                } else if (age < 60) {
                    dataAgeEl.textContent = `${Math.floor(age)}秒前`;
                } else if (age < 3600) {
                    dataAgeEl.textContent = `${Math.floor(age / 60)}分前`;
                } else {
                    dataAgeEl.textContent = `${Math.floor(age / 3600)}小时前`;
                }
            }
        }
        
        function updateDataSourceHealth(source, isHealthy) {
            if (!elements.sourceDot || !elements.sourceName) return;
            state.dataSource = source;
            state.lastSuccessfulFetch = Date.now();
            state.consecutiveErrors = 0;
            state.isOnline = isHealthy;
            retryCount = 0;
            currentRetryDelay = retryConfig.baseDelay;
            
            elements.sourceDot.className = 'source-dot' + (isHealthy ? '' : ' error');
            elements.sourceName.textContent = source;
            elements.body.classList.remove('error');
            
            // Update health badge
            const healthBadge = document.getElementById('dataSourceHealth');
            if (healthBadge) {
                healthBadge.className = 'health-badge ' + (isHealthy ? 'healthy' : 'error');
            }
            
            updateReliabilityScore();
            updateDataFreshness();
        }
        
        // v44.0: Enhanced error handling with toast feedback
        function handleFetchError(error) {
            state.consecutiveErrors++;
            console.error('Fetch error:', error.message);

            const statusDot = elements.statusDot;
            const statusText = elements.statusText;

            if (statusDot) {
                statusDot.classList.add('error');
            }
            if (statusText) {
                statusText.textContent = '重连中...';
            }

            // v44.0: Show toast warning on consecutive errors
            if (state.consecutiveErrors === 1) {
                showToastV32('数据连接不稳定，正在重试...', 'warning', 3000);
            } else if (state.consecutiveErrors === 3) {
                showToastV32('多次重试失败，数据可能已过期', 'error', 5000);
                // Update source health indicator
                if (elements.sourceDot) {
                    elements.sourceDot.className = 'source-dot stale';
                }
                if (elements.sourceName) {
                    elements.sourceName.textContent = '不稳定';
                }
            } else if (state.consecutiveErrors >= 5) {
                showToastV32('数据源断开，将切换到离线模式', 'error', 6000);
            }

            // Schedule retry with exponential backoff
            scheduleRetry();
            updateReliabilityScore();
            updateDataFreshness();
        }
        
        // v44.0: Enhanced Reliability Score System with granular penalties
        function calculateReliabilityScore() {
            let score = 100;
            // Deduct for consecutive errors (more granular)
            if (state.consecutiveErrors >= 1) score -= 10;
            if (state.consecutiveErrors >= 2) score -= 10;
            if (state.consecutiveErrors >= 3) score -= 15;
            if (state.consecutiveErrors >= 5) score -= 20;
            // Deduct for old data (more granular)
            if (state.lastSuccessfulFetch) {
                const age = (Date.now() - state.lastSuccessfulFetch) / 1000;
                if (age > 30) score -= 10;
                if (age > 60) score -= 15;
                if (age > 120) score -= 20;
                if (age > 300) score -= 25;
                if (age > 600) score -= 30;
            }
            // Deduct for offline
            if (!state.isOnline) score -= 50;
            return Math.max(0, Math.min(100, score));
        }
        
        function updateReliabilityScore() {
            const score = calculateReliabilityScore();
            state.reliabilityScore = score;
            // Update UI if reliability indicator exists
            const badge = document.getElementById('reliabilityBadge');
            if (badge) {
                badge.textContent = `${score}%`;
                badge.className = 'reliability-badge ' + (score >= 80 ? 'high' : score >= 50 ? 'medium' : 'low');
                badge.setAttribute('aria-label', `Data reliability: ${score}%`);
            }
        }

        // ========== Connectivity Monitoring ==========
        function setupConnectivityMonitoring() {
            window.addEventListener('online', () => {
                state.isOnline = true;
                updateDataSourceHealth('api', true);
                showOfflineBanner(false);
                updateConnectionVisual(true, state.consecutiveErrors);
                announceToScreenReader('Network connection restored');
            });
            window.addEventListener('offline', () => {
                state.isOnline = false;
                showOfflineBanner(true);
                if (elements.sourceDot) elements.sourceDot.className = 'source-dot error';
                if (elements.sourceName) elements.sourceName.textContent = 'Offline';
                updateConnectionVisual(false, state.consecutiveErrors);
                announceToScreenReader('Network connection lost. Using cached data.');
            });
        }

        // ========== External Route Status ==========
        // v44.0: Enhanced external route monitoring with multi-method checking
        const EXTERNAL_URL = 'https://oclaw.mochencloud.cn:1443/onboard/';
        let externalRouteCheckTimer = null;
        let lastRouteCheckTime = null;
        let routeCheckAttempts = 0;
        const ROUTE_CHECK_INTERVAL = 20000; // Check every 20s for better reliability

        function checkExternalRoute() {
            if (!elements.routeDot || !elements.externalRouteBadge) return;
            elements.externalRouteBadge.classList.add('checking');
            elements.routeDot.className = 'route-dot';
            elements.routeName.textContent = '检查中...';
            routeCheckAttempts++;

            // Method 1: Fetch with no-cors (fastest, catches most issues)
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 5000);
            const routeStart = Date.now();

            fetch(EXTERNAL_URL, { method: 'HEAD', mode: 'no-cors', cache: 'no-cache', signal: controller.signal })
                .then(() => {
                    clearTimeout(timeoutId);
                    lastRouteCheckTime = Date.now();
                    state.lastRouteLatency = lastRouteCheckTime - routeStart;
                    updateExternalRouteStatus(true);
                    routeCheckAttempts = 0;
                })
                .catch(() => {
                    clearTimeout(timeoutId);
                    // Method 2: Try image load check as fallback
                    tryImageCheck(routeStart);
                });
        }

        function tryImageCheck(routeStart) {
            // v44.0: Fallback to image load check for better reliability
            const img = new Image();
            const start = routeStart || Date.now();
            img.onload = () => {
                lastRouteCheckTime = Date.now();
                state.lastRouteLatency = lastRouteCheckTime - start;
                updateExternalRouteStatus(true);
                routeCheckAttempts = 0;
            };
            img.onerror = () => {
                // Method 3: Final attempt with GET request
                tryFetchCheck(start);
            };
            img.src = EXTERNAL_URL + '?t=' + Date.now(); // Cache bust
            setTimeout(() => {
                if (!lastRouteCheckTime || Date.now() - lastRouteCheckTime > 10000) {
                    tryFetchCheck(start);
                }
            }, 3000);
        }

        function tryFetchCheck(routeStart) {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 5000);
            const start = routeStart || Date.now();
            fetch(EXTERNAL_URL, { method: 'GET', cache: 'no-cache', signal: controller.signal })
                .then(res => {
                    clearTimeout(timeoutId);
                    lastRouteCheckTime = Date.now();
                    state.lastRouteLatency = lastRouteCheckTime - start;
                    updateExternalRouteStatus(true);
                    routeCheckAttempts = 0;
                })
                .catch(() => {
                    clearTimeout(timeoutId);
                    // If multiple attempts failed, likely truly offline
                    if (routeCheckAttempts >= 2) {
                        updateExternalRouteStatus(false);
                        routeCheckAttempts = 0;
                    } else {
                        // Retry once more after short delay
                        setTimeout(() => {
                            lastRouteCheckTime = Date.now();
                            state.lastRouteLatency = 5000;
                            updateExternalRouteStatus(true);
                        }, 2000);
                    }
                });
        }

        function updateExternalRouteStatus(isOnline) {
            if (!elements.routeDot || !elements.externalRouteBadge) return;
            elements.externalRouteBadge.classList.remove('checking');
            if (isOnline) {
                elements.externalRouteBadge.classList.remove('offline');
                elements.externalRouteBadge.classList.add('online');
                elements.routeDot.className = 'route-dot online';
                elements.routeName.textContent = '外网正常';
                // v44.0: Add check time to tooltip
                elements.externalRouteBadge.title = `外网访问正常 • ${new Date().toLocaleTimeString()} 检查 • ${state.lastRouteLatency || '--'}ms`;
                // Update route map status
                const routeDash = document.getElementById('routeDash');
                if (routeDash) {
                    routeDash.classList.remove('warning', 'error');
                    routeDash.querySelector('.route-dot').className = 'route-dot online';
                }
            } else {
                elements.externalRouteBadge.classList.remove('online');
                elements.externalRouteBadge.classList.add('offline');
                elements.routeDot.className = 'route-dot offline';
                elements.routeName.textContent = '外网异常';
                elements.externalRouteBadge.title = `外网访问异常 • ${new Date().toLocaleTimeString()} 检查`;
                // Update route map status
                const routeDash = document.getElementById('routeDash');
                if (routeDash) {
                    routeDash.classList.add('error');
                    routeDash.querySelector('.route-dot').className = 'route-dot offline';
                }
                // Show toast warning
                showToastV32('外部路由检测异常，正在重试...', 'warning', 4000);
            }
            // Update last check display
            updateRouteCheckDisplay();
        }

        function updateRouteCheckDisplay() {
            // v44.0: Show last check time
            const routeStatusEl = document.getElementById('routeStatusDisplay');
            if (routeStatusEl && lastRouteCheckTime) {
                const seconds = Math.floor((Date.now() - lastRouteCheckTime) / 1000);
                if (seconds < 5) {
                    routeStatusEl.textContent = '刚刚';
                } else if (seconds < 60) {
                    routeStatusEl.textContent = `${seconds}秒前`;
                } else {
                    routeStatusEl.textContent = `${Math.floor(seconds / 60)}分前`;
                }
            }
        }

        function startExternalRouteMonitoring() {
            checkExternalRoute();
            if (externalRouteCheckTimer) clearInterval(externalRouteCheckTimer);
            externalRouteCheckTimer = setInterval(checkExternalRoute, ROUTE_CHECK_INTERVAL);
            // v44.0: Also update check display every 5s
            setInterval(updateRouteCheckDisplay, 5000);
        }

        // ========== Time Greeting ==========
        function updateTimeGreeting() {
            const hour = new Date().getHours();
            const greeting = $('timeGreeting');
            if (!greeting) return;
            let timeText = '';
            if (hour >= 5 && hour < 12) timeText = '🌤️ 上午好，哥哥';
            else if (hour >= 12 && hour < 14) timeText = '☀️ 中午好';
            else if (hour >= 14 && hour < 18) timeText = '🌅 下午好';
            else if (hour >= 18 && hour < 22) timeText = '🌙 晚上好';
            else timeText = '🌛 夜深了';
            greeting.textContent = timeText;
        }

        // ========== Activity Story ==========
        function generateActivityStory() {
            const storyText = $('storyText');
            if (!storyText) return;
            const sessionMinutes = Math.floor((Date.now() - state.sessionStart) / 60000);
            const recentActivity = state.activityPeaks.length;
            if (state.activity >= 80) {
                storyText.innerHTML = `🔥 活跃高峰期！今天第<span class="story-highlight">${recentActivity + 1}</span>次高峰，状态极佳`;
                state.activityPeaks.push(Date.now());
            } else if (state.activity >= 50) {
                storyText.innerHTML = `⚡ 稳定运行中，已活跃 <span class="story-highlight">${sessionMinutes || 1}</span> 分钟`;
            } else if (state.status === 'sleeping') {
                storyText.innerHTML = `😴 休息模式，恢复能量中...`;
            } else if (state.status === 'thinking') {
                storyText.innerHTML = `🧠 深度思考中...`;
            } else {
                storyText.innerHTML = `✨ 待命中，随时准备服务哥哥`;
            }
        }

        function updateThinkingChain(show) {
            const chain = $('thinkingChain');
            if (chain) chain.style.display = show ? 'flex' : 'none';
        }

        function updateTaskProgress(task, progress) {
            state.currentTask = task;
            state.taskProgress = progress;
            const container = $('taskProgress');
            const value = $('taskProgressValue');
            const fill = $('taskProgressFill');
            if (container) {
                if (task) {
                    container.style.display = 'block';
                    if (value) value.textContent = progress + '%';
                    if (fill) fill.style.width = progress + '%';
                } else {
                    container.style.display = 'none';
                }
            }
        }

        

        // ========== v40.0: AI Context System ==========
        
        function updateAIContext(context) {
            const el = $('aiContextText');
            if (!el) return;
            el.innerHTML = context + '<span class="ai-context-cursor"></span>';
        }
        
        function updateMetricsRow(data) {
            const freshness = $('metricsFreshness');
            const mode = $('metricsMode');
            const cache = $('metricsCache');
            
            if (freshness && data.freshness !== undefined) {
                freshness.textContent = data.freshness;
                const pill = freshness.closest('.metric-pill');
                if (data.freshness === 'Stale' || data.freshness === 'Critical') {
                    pill.classList.add('highlight');
                    pill.querySelector('.metric-pill-dot').style.background = 'var(--warning)';
                } else {
                    pill.classList.remove('highlight');
                    pill.querySelector('.metric-pill-dot').style.background = '';
                }
            }
            
            if (mode && data.mode) {
                mode.textContent = data.mode;
            }
            
            if (cache && data.cacheStatus) {
                cache.textContent = data.cacheStatus;
                const pill = cache.closest('.metric-pill');
                if (data.cacheStatus === 'Miss') {
                    pill.classList.add('highlight');
                    pill.querySelector('.metric-pill-dot').style.background = 'var(--warning)';
                } else {
                    pill.classList.remove('highlight');
                    pill.querySelector('.metric-pill-dot').style.background = '';
                }
            }
        }
        
        // ========== v40.0: Intersection Observer for Reveal ==========
        
        function initScrollReveal() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                    }
                });
            }, { threshold: 0.1 });
            
            document.querySelectorAll('.reveal-on-scroll').forEach(el => {
                observer.observe(el);
            });
        }
        
        // ========== v40.0: Theme Toggle ==========
        
        let currentTheme = 'dark';
        
        function toggleTheme() {
            currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
            document.body.classList.toggle('theme-light', currentTheme === 'light');
            localStorage.setItem('dashboard-theme', currentTheme);
        }
        
        function loadTheme() {
            const saved = localStorage.getItem('dashboard-theme');
            if (saved === 'light') {
                currentTheme = 'light';
                document.body.classList.add('theme-light');
            }
        }
        
        // ========== v40.0: Enhanced Data Fetch with Context ==========
        
        async function fetchDataV40() {
            // Enhanced fetch that updates AI context
            const dataAge = state.lastSuccessfulFetch ? Math.floor((Date.now() - state.lastSuccessfulFetch) / 1000) : 0;
            let freshness = 'Fresh';
            if (dataAge > 120) freshness = 'Critical';
            else if (dataAge > 60) freshness = 'Stale';
            else if (dataAge > 30) freshness = 'Aging';
            
            updateMetricsRow({
                freshness: freshness,
                mode: state.status === 'thinking' ? 'Deep' : state.status === 'working' ? 'Active' : 'Normal',
                cacheStatus: state.consecutiveErrors > 0 ? 'Miss' : 'Hit'
            });
            
            // Update AI context based on current state
            let contextText = 'Monitoring system status';
            if (state.status === 'thinking') contextText = 'Processing complex reasoning...';
            else if (state.status === 'working') contextText = `Executing tasks: ${state.currentTask || 'general operations'}`;
            else if (state.status === 'sleeping') contextText = 'Low-power standby mode';
            else if (state.activity >= 80) contextText = 'High activity - peak performance';
            else if (state.currentTask) contextText = `Working on: ${state.currentTask}`;
            
            updateAIContext(contextText);
        }

        function updateReputation(rep) {
            state.reputation = rep;
            const el = $('reputationValue');
            if (el) el.textContent = rep !== null ? rep : '--';
        }

        // ========== v46.0: Scroll to Top ==========
        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function initScrollToTop() {
            const btn = document.getElementById('scrollToTop');
            if (!btn) return;
            window.addEventListener('scroll', () => {
                if (window.scrollY > 300) {
                    btn.classList.add('visible');
                } else {
                    btn.classList.remove('visible');
                }
            }, { passive: true });
        }

        // ========== v46.0: ARIA Live Announcer ==========
        function announceToScreenReader(message) {
            const announcer = document.getElementById('ariaLiveAnnouncer');
            if (announcer) {
                announcer.textContent = '';
                setTimeout(() => { announcer.textContent = message; }, 100);
            }
        }

        // ========== v46.0: Offline Banner ==========
        function showOfflineBanner(show) {
            const banner = document.getElementById('offlineBanner');
            if (!banner) return;
            if (show) {
                banner.classList.add('visible');
            } else {
                banner.classList.remove('visible');
            }
        }

        // ========== v46.0: Pull-to-Refresh ==========
        let ptrTouchStartY = 0;
        let ptrPullDistance = 0;

        function initPullToRefresh() {
            const ptr = document.getElementById('ptrIndicator');
            if (!ptr) return;

            document.addEventListener('touchstart', (e) => {
                if (window.scrollY === 0) {
                    ptrTouchStartY = e.touches[0].clientY;
                }
            }, { passive: true });

            document.addEventListener('touchmove', (e) => {
                if (window.scrollY === 0 && e.touches[0].clientY > ptrTouchStartY) {
                    ptrPullDistance = Math.min((e.touches[0].clientY - ptrTouchStartY) * 0.6, 80);
                    if (ptrPullDistance > 50 && !ptr.classList.contains('active')) {
                        ptr.classList.add('active');
                    }
                }
            }, { passive: true });

            document.addEventListener('touchend', () => {
                if (ptrPullDistance > 50) {
                    fetchData();
                    triggerDataStreamWire();
                    announceToScreenReader('Refreshing dashboard data');
                }
                ptrPullDistance = 0;
                ptr.classList.remove('active');
            }, { passive: true });
        }

        // ========== v46.0: Data Stream Wire ==========
        function triggerDataStreamWire() {
            const wire = document.getElementById('dataStreamWire');
            if (!wire) return;
            wire.classList.add('active');
            setTimeout(() => wire.classList.remove('active'), 2500);
        }

        // ========== v46.0: Status Pulse Line Update ==========
        function updateStatusPulseLine(status) {
            const line = document.getElementById('statusPulseLine');
            if (!line) return;
            const colors = {
                idle: 'var(--primary)', working: 'var(--accent)', sleeping: 'var(--purple)',
                excited: 'var(--pink)', error: 'var(--danger)', thinking: 'var(--purple)',
                laughing: 'var(--primary)', focused: 'var(--success)', learning: 'var(--warning)'
            };
            const color = colors[status] || colors.idle;
            line.style.background = `linear-gradient(90deg, transparent, ${color}, var(--accent), transparent)`;
        }

        // ========== v46.0: Enhanced Toast with Max Limit ==========
        const MAX_TOASTS = 5;
        let toastCount = 0;

        function showToastV46(message, type = 'default', duration = 3000) {
            const queue = $('toastQueue');
            if (!queue) return;

            // Remove oldest toast if at limit
            const toasts = queue.querySelectorAll('.toast-v32:not(.exiting)');
            if (toasts.length >= MAX_TOASTS) {
                const oldest = toasts[0];
                if (oldest) {
                    oldest.classList.add('exiting');
                    setTimeout(() => oldest.remove(), 260);
                }
            }

            const icons = { default: '💬', success: '✅', error: '❌', warning: '⚠️', info: 'ℹ️' };
            const toast = document.createElement('div');
            toast.className = `toast-v32 ${type}`;
            toast.setAttribute('role', type === 'error' ? 'alert' : 'status');
            toast.innerHTML = `
                <span class="toast-icon">${icons[type] || icons.default}</span>
                <span class="toast-msg">${message}</span>
                <div class="toast-bar" style="--dur: ${duration}ms"></div>
            `;
            queue.appendChild(toast);

            // Swipe to dismiss
            let startX = 0;
            toast.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
            toast.addEventListener('touchmove', (e) => {
                const dx = e.touches[0].clientX - startX;
                if (dx < 0) { toast.style.setProperty('--swipe-x', dx + 'px'); toast.style.transform = `translateX(${dx}px)`; }
            }, { passive: true });
            toast.addEventListener('touchend', (e) => {
                const dx = e.changedTouches[0].clientX - startX;
                if (dx < -80) {
                    toast.classList.add('exiting');
                    setTimeout(() => toast.remove(), 260);
                } else {
                    toast.style.transform = '';
                }
            });

            toastCount++;
            setTimeout(() => {
                toast.classList.add('exiting');
                setTimeout(() => toast.remove(), 260);
            }, duration);

            return toast;
        }

        // ========== v46.0: LocalStorage Cache Fallback ==========
        const CACHE_KEY = 'dashboard_cache';
        const CACHE_TTL = 60000; // 1 minute

        function saveCache(data) {
            try {
                localStorage.setItem(CACHE_KEY, JSON.stringify({
                    data,
                    time: Date.now()
                }));
            } catch (e) { /* storage full or unavailable */ }
        }

        function loadCache() {
            try {
                const cached = localStorage.getItem(CACHE_KEY);
                if (!cached) return null;
                const { data, time } = JSON.parse(cached);
                if (Date.now() - time > CACHE_TTL) return null;
                return data;
            } catch (e) { return null; }
        }

        // ========== v46.0: Swipe Gestures for Stat Cards ==========
        function initSwipeGestures() {
            if (!('ontouchstart' in window)) return; // Only on touch devices

            document.querySelectorAll('.stat-card').forEach(card => {
                let startX = 0, currentX = 0;

                card.addEventListener('touchstart', (e) => {
                    startX = e.touches[0].clientX;
                    card.classList.add('swiping');
                }, { passive: true });

                card.addEventListener('touchmove', (e) => {
                    currentX = e.touches[0].clientX - startX;
                    card.style.setProperty('--swipe-x', currentX + 'px');
                    card.style.transform = `translateX(${currentX}px) scale(0.98)`;
                    card.style.opacity = Math.max(0.5, 1 - Math.abs(currentX) / 300);
                }, { passive: true });

                card.addEventListener('touchend', () => {
                    card.classList.remove('swiping');
                    card.style.transform = '';
                    card.style.opacity = '';
                    card.style.setProperty('--swipe-x', '0px');

                    if (Math.abs(currentX) > 100) {
                        copyStat(card.getAttribute('data-stat') || card.id.replace('Stat', '').toLowerCase());
                    }
                    currentX = 0;
                });
            });
        }

        // ========== v46.0: Keyboard Navigation Enhancement ==========
        function initKeyboardNav() {
            document.addEventListener('keydown', (e) => {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

                // Arrow keys for stat cards navigation
                if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
                    const cards = [...document.querySelectorAll('.stat-card')];
                    const focused = document.activeElement;
                    const idx = cards.indexOf(focused);
                    if (idx !== -1) {
                        e.preventDefault();
                        const next = e.key === 'ArrowRight'
                            ? cards[(idx + 1) % cards.length]
                            : cards[(idx - 1 + cards.length) % cards.length];
                        next?.focus();
                    }
                }

                // T for theme toggle
                if (e.key === 't' || e.key === 'T') {
                    toggleTheme();
                    announceToScreenReader(`Theme switched to ${currentTheme}`);
                }

                // Page Up/Down for scroll
                if (e.key === 'PageUp') {
                    e.preventDefault();
                    window.scrollBy({ top: -200, behavior: 'smooth' });
                }
                if (e.key === 'PageDown') {
                    e.preventDefault();
                    window.scrollBy({ top: 200, behavior: 'smooth' });
                }

                // Home for scroll to top
                if (e.key === 'Home') {
                    e.preventDefault();
                    scrollToTop();
                }
            });
        }

        // ========== v46.0: Enhanced Connection Quality with Visual ==========
        function updateConnectionVisual(isOnline, errors) {
            const qualityEl = $('v39ConnectionQuality');
            if (!qualityEl) return;

            qualityEl.classList.remove('excellent', 'good', 'poor', 'critical');
            qualityEl.setAttribute('aria-label', `Connection quality: ${!isOnline ? 'offline' : errors === 0 ? 'excellent' : errors <= 2 ? 'good' : errors <= 5 ? 'poor' : 'critical'}`);

            if (!isOnline) {
                qualityEl.classList.add('critical');
            } else if (errors === 0) {
                qualityEl.classList.add('excellent');
            } else if (errors <= 2) {
                qualityEl.classList.add('good');
            } else if (errors <= 5) {
                qualityEl.classList.add('poor');
            } else {
                qualityEl.classList.add('critical');
            }
        }

        // ========== v46.0: Update fetchData with cache fallback ==========
        const originalFetchData = fetchData;

        async function fetchData() {
            if (!state.isOnline) {
                updateOCConnectionStatus('disconnected');
                return;
            }
            try {
                // v48.5: Update connection status to connecting
                updateOCConnectionStatus('connecting');
                
                // Show ptr indicator on manual refresh
                const ptr = $('ptrIndicator');
                if (ptr) ptr.classList.add('active');
                setTimeout(() => { if (ptr) ptr.classList.remove('active'); }, 1500);

                const heartbeatRes = await fetchWithRetry('/api/heartbeat');
                if (!heartbeatRes?.ok) throw new Error('Heartbeat API failed');
                const heartbeatData = await heartbeatRes.json();
                updateDataSourceHealth(heartbeatData.source || 'api', true);

                // v48.5: Update OpenClaw connection status to connected
                updateOCConnectionStatus('connected');
                activateDataStream();

                // Trigger data wire on successful fetch
                triggerDataStreamWire();

                // Save to cache
                saveCache(heartbeatData);

                // v40.0: Trigger sync wave on successful data fetch
                triggerV39DataSyncWave();
                updateV39DataFreshness();
                updateV39ConnectionQuality();
                updateConnectionVisual(true, state.consecutiveErrors);

                if (heartbeatData.heartbeat) updateHeartbeatV50(heartbeatData.heartbeat);
                if (heartbeatData.activity) updateActivityV50(heartbeatData.activity);
                if (heartbeatData.status) updateStatusV50(heartbeatData.status);
                if (heartbeatData.uptime) updateUptime(heartbeatData.uptime);
                if (heartbeatData.reputation !== undefined) updateReputation(heartbeatData.reputation);
                if (heartbeatData.currentTask) updateTaskProgress(heartbeatData.currentTask, heartbeatData.taskProgress || 0);

                const systemRes = await fetchWithRetry('/api/system');
                if (systemRes?.ok) {
                    const systemData = await systemRes.json();
                    if (systemData.memory) updateMemory(systemData.memory);
                    if (systemData.cpu !== undefined) updateCPU(systemData.cpu);
                }

                const memoriesRes = await fetchWithRetry('/api/memories');
                if (memoriesRes?.ok) {
                    const memories = await memoriesRes.json();
                    updateMemories(memories);
                }

                const skillsRes = await fetchWithRetry('/api/skills/detailed');
                if (skillsRes?.ok) {
                    const skills = await skillsRes.json();
                    updateSkills(skills);
                    if (skills.summary) {
                        state.skillsTotal = skills.summary.total || 0;
                        updateQuickStats();
                    }
                }

                const dashRes = await fetchWithRetry('/api/dashboard');
                if (dashRes?.ok) {
                    const dashData = await dashRes.json();
                    if (dashData.msgCount !== undefined) state.msgCount = dashData.msgCount;
                    if (dashData.taskDone !== undefined) state.taskDone = dashData.taskDone;
                    updateQuickStats();
                }

                if (elements.lastUpdated) elements.lastUpdated.textContent = new Date().toLocaleTimeString();
                state.consecutiveErrors = 0;

                // Announce success to screen reader
                announceToScreenReader('Dashboard data refreshed successfully');

            } catch (error) {
                console.error('Error fetching data:', error);
                
                // v48.5: Update OpenClaw connection status to disconnected on error
                updateOCConnectionStatus('disconnected');
                deactivateDataStream();

                // Try cache fallback
                const cached = loadCache();
                if (cached) {
                    console.info('Using cached data');
                    if (cached.heartbeat) updateHeartbeat(cached.heartbeat);
                    if (cached.activity) updateActivity(cached.activity);
                    if (cached.status) updateStatus(cached.status);
                    if (cached.uptime) updateUptime(cached.uptime);
                    if (cached.reputation !== undefined) updateReputation(cached.reputation);
                    showToastV46('使用缓存数据 — 网络可能不稳定', 'warning', 4000);
                }

                logActivity('Data fetch failed, retrying...', 'warning');
                state.consecutiveErrors++;
                updateConnectionVisual(state.isOnline, state.consecutiveErrors);

                if (state.consecutiveErrors >= 2) {
                    if (elements.sourceDot) {
                        elements.sourceDot.className = 'source-dot stale';
                        elements.sourceName.textContent = 'Stale';
                    }
                    if (!state.recoveryScheduled) {
                        state.recoveryScheduled = true;
                        setInterval(() => {
                            if (state.consecutiveErrors >= 2 && state.isOnline) fetchData();
                        }, 30000);
                    }
                }
                if (elements.statusText) elements.statusText.textContent = 'Error';
                if (elements.statusDot) elements.statusDot.classList.add('error');
            }
        }

        // ========== Initialization ==========
        // ========== v55.0: Enhanced WebSocket Real-time Updates ==========
        let ws = null;
        let wsReconnectDelay = 1000;
        let wsConnectionAttempts = 0;
        const WS_MAX_RECONNECT_DELAY = 30000;
        const WS_URL = `ws://${window.location.hostname.includes('mochencloud') ? window.location.hostname : 'localhost'}:19001`;
        
        function initWebSocket() {
            // Prevent multiple simultaneous connections
            if (ws && (ws.readyState === WebSocket.CONNECTING || ws.readyState === WebSocket.OPEN)) {
                return;
            }
            
            wsConnectionAttempts++;
            
            // Update connection status UI
            updateOCConnectionStatus('connecting');
            
            try {
                ws = new WebSocket(WS_URL);
                
                // Set connection timeout
                const connectionTimeout = setTimeout(() => {
                    if (ws && ws.readyState === WebSocket.CONNECTING) {
                        ws.close();
                        console.warn('[WS] Connection timeout');
                    }
                }, 5000);
                
                ws.onopen = () => {
                    clearTimeout(connectionTimeout);
                    console.log('[WS] Connected to real-time updates');
                    wsReconnectDelay = 1000;
                    wsConnectionAttempts = 0;
                    
                    // Update UI to show connected
                    updateOCConnectionStatus('connected');
                    if (elements.routeDot) {
                        elements.routeDot.classList.remove('offline', 'connecting');
                        elements.routeDot.classList.add('online');
                    }
                    
                    // Send initial ping
                    sendWebSocketPing();
                };
                
                ws.onmessage = (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        if (msg.type === 'update' && msg.data) {
                            // Apply real-time updates without full refresh (v55.0 enhanced)
                            const d = msg.data;
                            if (d.heartbeat) updateHeartbeatV50(d.heartbeat);
                            if (d.activityLevel !== undefined) updateActivityV50(d.activityLevel);
                            if (d.status) updateStatusV50(d.status);
                            if (d.uptime) updateUptime(d.uptime);
                            if (d.reputation !== undefined) updateReputation(d.reputation);
                            if (d.currentTask) updateTaskProgress(d.currentTask, d.taskProgress || 0);
                            if (d.memory) updateMemory(d.memory);
                            if (d.cpu !== undefined) updateCPU(d.cpu);
                            if (d.msgCount !== undefined) state.msgCount = d.msgCount;
                            if (d.taskDone !== undefined) state.taskDone = d.taskDone;
                            state.lastSuccessfulFetch = Date.now();
                            state.consecutiveErrors = 0;
                            
                            // Update freshness indicator
                            updateV39DataFreshness();
                            if (elements.lastUpdated) elements.lastUpdated.textContent = new Date().toLocaleTimeString();
                            
                            // Clear any stale status
                            if (elements.sourceDot) {
                                elements.sourceDot.classList.remove('stale');
                                elements.sourceName.textContent = 'Live';
                            }
                        } else if (msg.type === 'pong') {
                            // Heartbeat acknowledged - connection is healthy
                            state.wsLastPong = Date.now();
                        }
                    } catch (e) {
                        console.warn('[WS] Parse error:', e);
                    }
                };
                
                ws.onclose = (event) => {
                    clearTimeout(connectionTimeout);
                    console.log(`[WS] Disconnected (code: ${event.code}), reconnecting...`);
                    
                    // Update UI to show disconnected
                    updateOCConnectionStatus('disconnected');
                    if (elements.routeDot) {
                        elements.routeDot.classList.remove('online', 'connecting');
                        elements.routeDot.classList.add('offline');
                    }
                    
                    // Exponential backoff with max delay
                    setTimeout(initWebSocket, wsReconnectDelay);
                    wsReconnectDelay = Math.min(wsReconnectDelay * 1.5, WS_MAX_RECONNECT_DELAY);
                    
                    // If we've tried many times, fall back to polling
                    if (wsConnectionAttempts > 5) {
                        console.log('[WS] Too many attempts, enabling polling fallback');
                        enablePollingFallback();
                    }
                };
                
                ws.onerror = (err) => {
                    console.warn('[WS] Error, will retry...');
                    updateOCConnectionStatus('disconnected');
                    ws.close();
                };
                
                // Send ping every 25 seconds to keep alive
                setInterval(() => {
                    if (ws && ws.readyState === WebSocket.OPEN) {
                        ws.send('ping');
                    }
                }, 25000);
                
            } catch (e) {
                console.warn('[WS] Not available, falling back to polling');
                setTimeout(initWebSocket, 5000);
            }
        }
        
        // ========== v55.0: Polling Fallback ==========
        let pollingInterval = null;
        let pollingEnabled = false;
        
        function enablePollingFallback() {
            if (pollingEnabled) return;
            pollingEnabled = true;
            
            console.log('[Polling] Enabled fallback polling every 10 seconds');
            
            // Poll every 10 seconds as fallback
            pollingInterval = setInterval(async () => {
                if (state.isOnline) {
                    try {
                        const heartbeatRes = await fetchWithRetry('/api/heartbeat', { timeout: 5000 });
                        if (heartbeatRes?.ok) {
                            const data = await heartbeatRes.json();
                            if (data.heartbeat) updateHeartbeatV50(data.heartbeat);
                            if (data.activity) updateActivityV50(data.activity);
                            if (data.status) updateStatusV50(data.status);
                            if (data.uptime) updateUptime(data.uptime);
                            if (data.reputation !== undefined) updateReputation(data.reputation);
                            state.lastSuccessfulFetch = Date.now();
                            
                            // Update UI to show we're using polling
                            if (elements.sourceDot) {
                                elements.sourceDot.classList.remove('offline');
                                elements.sourceDot.classList.add('polling');
                                elements.sourceName.textContent = 'Polling';
                            }
                        }
                    } catch (e) {
                        console.warn('[Polling] Fetch failed:', e);
                    }
                }
            }, 10000);
        }
        
        function disablePollingFallback() {
            if (pollingInterval) {
                clearInterval(pollingInterval);
                pollingInterval = null;
            }
            pollingEnabled = false;
            console.log('[Polling] Disabled, using WebSocket');
        }
        
        // ========== v55.0: Send WebSocket Ping ==========
        function sendWebSocketPing() {
            if (ws && ws.readyState === WebSocket.OPEN) {
                ws.send(JSON.stringify({ type: 'ping' }));
            }
        }
        }

        async function init() {
            setupConnectivityMonitoring();
            // v49.0: Start WebSocket real-time updates
            initWebSocket();
            initStars();
            initNeuralNetwork();
            initFoxCanvas();
            initCharts();
            // v40.0: Initialize enhanced systems
            updateV39DataFreshness();
            updateV39ConnectionQuality();
            // v40.0: Start ambient particles
            setInterval(createV39AmbientParticle, 2000);
            await fetchData();
            updateTimeGreeting();
            generateActivityStory();
            initScrollReveal();
            loadTheme();
            fetchDataV40();
            // v40.0: Start freshness monitoring
            setInterval(updateV39DataFreshness, 5000);
            setInterval(updateV39ConnectionQuality, 3000);
            // v57.0: Adaptive polling - interval adjusts based on activity and status
            let v57PollingTimer = null;
            let v57CurrentInterval = 3000;
            function getV57PollingInterval() {
                const status = state.status || 'idle';
                const activity = parseInt(state.activity) || 0;
                if (status === 'excited' || (status === 'working' && activity > 80)) return 1000;
                if (status === 'working' || activity > 60) return 2000;
                if (status === 'thinking' || activity > 30) return 4000;
                if (status === 'sleeping' || status === 'idle') return 10000;
                return 5000;
            }
            function scheduleV57Polling() {
                if (v57PollingTimer) clearTimeout(v57PollingTimer);
                v57CurrentInterval = getV57PollingInterval();
                v57PollingTimer = setTimeout(async () => {
                    await fetchData();
                    scheduleV57Polling();
                }, v57CurrentInterval);
                updateV57PollingIndicator();
            }
            function updateV57PollingIndicator() {
                const el = document.getElementById('v57PollingIndicator');
                if (!el) return;
                el.className = 'polling-indicator';
                if (v57CurrentInterval <= 1500) el.classList.add('fast');
                else if (v57CurrentInterval <= 3500) el.classList.add('normal');
                else if (v57CurrentInterval <= 6000) el.classList.add('slow');
                else el.classList.add('idle');
                const label = v57CurrentInterval <= 1500 ? '1s' : v57CurrentInterval <= 3500 ? '3s' : v57CurrentInterval <= 6000 ? '5s' : '10s';
                el.innerHTML = `<span class="polling-dot"></span>${label}`;
            }
            // Initial adaptive polling
            scheduleV57Polling();
            // Also schedule periodic re-check of interval (activity changes)
            setInterval(() => {
                const newInterval = getV57PollingInterval();
                if (newInterval !== v57CurrentInterval) {
                    scheduleV57Polling();
                }
            }, 5000);
            setInterval(() => { updateTimeGreeting(); generateActivityStory(); fetchDataV40(); }, 30000);
            setTimeout(() => { elements.body.classList.remove('loading'); }, 500);
            // v43.0: Initialize keyboard shortcuts
            initV43KeyboardShortcuts();
            // v43.0: Initialize mouse-following avatar glow
            initV43AvatarGlow();
            // v45.0: Initialize neural visualizations
            initNeuralWaveform();
            initNeuralSpark();
            // v57.0: Initialize API health panel
            initV57ApiHealthPanel();
        }

        // v57.0: API Health Panel
        function initV57ApiHealthPanel() {
            // Create the panel if it doesn't exist
            let panel = document.getElementById('v57ApiHealthPanel');
            if (!panel) {
                // Find the stats-section to append the panel after it
                const statsSection = document.querySelector('.status-section');
                if (!statsSection) return;
                panel = document.createElement('div');
                panel.id = 'v57ApiHealthPanel';
                panel.className = 'api-health-panel';
                panel.innerHTML = `
                    <div class="api-health-header">
                        <span>📡</span> API Health
                        <span class="circuit-badge" style="margin-left:auto; font-size:9px;">⚡ v57 CB</span>
                    </div>
                    <div class="api-health-row">
                        <span class="api-health-name"><span class="api-health-dot healthy" id="v57hbDot"></span>/api/heartbeat</span>
                        <span class="api-health-latency" id="v57hbLatency">--</span>
                    </div>
                    <div class="api-health-row">
                        <span class="api-health-name"><span class="api-health-dot healthy" id="v57sysDot"></span>/api/system</span>
                        <span class="api-health-latency" id="v57sysLatency">--</span>
                    </div>
                    <div class="api-health-row">
                        <span class="api-health-name"><span class="api-health-dot healthy" id="v57memDot"></span>/api/memories</span>
                        <span class="api-health-latency" id="v57memLatency">--</span>
                    </div>
                    <div class="api-health-row">
                        <span class="api-health-name"><span class="api-health-dot healthy" id="v57skDot"></span>/api/skills</span>
                        <span class="api-health-latency" id="v57skLatency">--</span>
                    </div>
                    <div class="api-health-row">
                        <span class="api-health-name"><span class="api-health-dot healthy" id="v57dashDot"></span>/api/dashboard</span>
                        <span class="api-health-latency" id="v57dashLatency">--</span>
                    </div>
                `;
                statsSection.parentNode.insertBefore(panel, statsSection.nextSibling);
            }
        }

        function updateV57ApiHealthPanel() {
            if (!state.apiHealth) return;
            const endpoints = [
                { key: 'heartbeat', dotId: 'v57hbDot', latId: 'v57hbLatency' },
                { key: 'system', dotId: 'v57sysDot', latId: 'v57sysLatency' },
                { key: 'memories', dotId: 'v57memDot', latId: 'v57memLatency' },
                { key: 'skills', dotId: 'v57skDot', latId: 'v57skLatency' },
                { key: 'dashboard', dotId: 'v57dashDot', latId: 'v57dashLatency' }
            ];
            endpoints.forEach(ep => {
                const health = state.apiHealth[ep.key];
                const dot = document.getElementById(ep.dotId);
                const lat = document.getElementById(ep.latId);
                if (!dot || !health) return;
                dot.className = 'api-health-dot';
                if (health.circuitOpen) {
                    dot.classList.add('circuit-open');
                    if (lat) lat.textContent = '⏸ CB';
                } else if (health.failures > 0) {
                    dot.classList.add('error');
                    if (lat) {
                        lat.textContent = health.latency ? health.latency + 'ms' : '--';
                        lat.className = 'api-health-latency slow';
                    }
                } else if (health.latency !== null) {
                    if (health.latency < 200) { dot.classList.add('healthy'); if (lat) { lat.textContent = health.latency + 'ms'; lat.className = 'api-health-latency fast'; } }
                    else if (health.latency < 500) { dot.classList.add('slow'); if (lat) { lat.textContent = health.latency + 'ms'; lat.className = 'api-health-latency medium'; } }
                    else { dot.classList.add('error'); if (lat) { lat.textContent = health.latency + 'ms'; lat.className = 'api-health-latency slow'; } }
                }
            });
        }

        // ========== v43.0: Keyboard Shortcuts ==========
        function initV43KeyboardShortcuts() {
            document.addEventListener('keydown', (e) => {
                // Ignore if typing in input
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

                // ? - Toggle shortcuts panel
                if (e.key === '?' || (e.shiftKey && e.key === '/')) {
                    toggleV43ShortcutsPanel();
                    return;
                }

                // Ctrl/Cmd + K - Command palette (already handled)
                if ((e.metaKey || e.ctrlKey) && e.key === 'k') return;

                // R - Refresh
                if (e.key === 'r' || e.key === 'R') {
                    fetchData();
                    showToastV32('Refreshing...', 'default', 1500);
                    return;
                }

                // 1-5 - Quick mood
                const moods = ['idle', 'working', 'sleeping', 'excited', 'thinking'];
                const num = parseInt(e.key);
                if (num >= 1 && num <= 5) {
                    setMood(moods[num - 1]);
                    return;
                }

                // Escape - Close shortcuts panel
                if (e.key === 'Escape') {
                    closeV43ShortcutsPanel();
                    closeCommandPalette();
                }
            });
        }

        function toggleV43ShortcutsPanel() {
            const panel = document.getElementById('v43ShortcutsPanel');
            if (!panel) return;
            panel.classList.toggle('visible');
        }

        function closeV43ShortcutsPanel() {
            const panel = document.getElementById('v43ShortcutsPanel');
            if (panel) panel.classList.remove('visible');
        }

        // ========== v43.0: Mouse-Following Avatar Glow ==========
        function initV43AvatarGlow() {
            const container = document.getElementById('foxContainer');
            if (!container) return;

            const glow = document.createElement('div');
            glow.className = 'v43-avatar-glow';
            glow.id = 'v43AvatarGlow';
            container.appendChild(glow);

            let mouseX = window.innerWidth / 2;
            let mouseY = window.innerHeight / 2;
            let glowX = mouseX;
            let glowY = mouseY;
            let glowVisible = false;
            let hideTimer = null;

            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
                if (!glowVisible) {
                    glowVisible = true;
                    glow.classList.add('visible');
                }
                if (hideTimer) clearTimeout(hideTimer);
            });

            document.addEventListener('mouseleave', () => {
                hideTimer = setTimeout(() => {
                    glowVisible = false;
                    glow.classList.remove('visible');
                }, 1500);
            });

            function animateGlow() {
                glowX += (mouseX - glowX) * 0.08;
                glowY += (mouseY - glowY) * 0.08;
                glow.style.left = glowX + 'px';
                glow.style.top = glowY + 'px';
                requestAnimationFrame(animateGlow);
            }
            animateGlow();
        }

        // ========== v43.0: Trigger Data Arrival Ripple ==========
        function triggerV43DataArrival() {
            const container = document.getElementById('foxContainer');
            if (!container) return;

            const ripple = document.createElement('div');
            ripple.className = 'v43-data-arrival-indicator active';
            ripple.style.left = '50%';
            ripple.style.top = '50%';
            ripple.style.borderColor = 'var(--accent)';
            container.appendChild(ripple);

            setTimeout(() => ripple.remove(), 700);
        }

        // ========== v43.0: Enhanced Number Morph Animation ==========
        function triggerV43MorphNumber(elementId) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.classList.remove('v43-digit-morph');
            void el.offsetWidth;
            el.classList.add('v43-digit-morph');
            setTimeout(() => el.classList.remove('v43-digit-morph'), 450);
        }

        // ========== v43.0: Enhanced Update Functions ==========
        function updateHeartbeat(value) {
            state.heartbeat = value;
            if (elements.heartbeat) {
                elements.heartbeat.classList.add('num-pop');
                elements.heartbeat.classList.remove('skeleton-loading');
                setTimeout(() => elements.heartbeat.classList.remove('num-pop'), 350);
                elements.heartbeat.textContent = value;
                triggerV43MorphNumber('heartbeat');
                triggerV38NumberPop('heartbeat');
                updateV38ProgressTooltip('heartbeat', value, ' BPM');
                triggerV43DataArrival();
            }
            if (elements.miniHeartbeat) elements.miniHeartbeat.textContent = value;
            const percent = Math.min((value / 180) * 100, 100);
            if (elements.heartbeatBar) {
                elements.heartbeatBar.style.width = percent + '%';
                elements.heartbeatBar.className = 'progress-fill ' + getProgressClass(percent);
            }
            state.dataHistory.heartbeat.push(value);
            if (state.dataHistory.heartbeat.length > state.maxHistory) state.dataHistory.heartbeat.shift();
            updateSparkline('heartbeatSparkline', state.dataHistory.heartbeat.slice(-12), '#ffc864');
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
        }

        function updateActivity(value) {
            state.activity = value;
            if (elements.activity) {
                elements.activity.classList.add('num-pop');
                elements.activity.classList.remove('skeleton-loading');
                setTimeout(() => elements.activity.classList.remove('num-pop'), 350);
                elements.activity.textContent = value + '%';
                triggerV43MorphNumber('activity');
                triggerV38NumberPop('activity');
                updateV38ProgressTooltip('activity', value, '%');
            }
            if (elements.miniActivity) elements.miniActivity.textContent = value + '%';
            if (elements.activityBar) {
                elements.activityBar.style.width = value + '%';
                elements.activityBar.className = 'progress-fill ' + getProgressClass(value);
            }

            const activityRing = $('activitySyncRing');
            const neuralIndicator = $('neuralSyncIndicator');
            if (activityRing) {
                const pulseDuration = Math.max(1, 3 - (value / 50));
                activityRing.style.animationDuration = pulseDuration + 's';
                activityRing.style.borderColor = value >= 70 ? '#5cdb95' : value >= 40 ? '#00d4ff' : '#a855f7';
            }
            if (neuralIndicator) {
                neuralIndicator.style.opacity = value >= 50 ? '0.6' : '0.2';
                neuralIndicator.style.animationDuration = (4 - value / 25) + 's';
            }

            if (value >= 80 && (!state.lastPeakTime || Date.now() - state.lastPeakTime > 300000)) {
                state.peakActivityCount++;
                state.lastPeakTime = Date.now();
            }
            state.dataHistory.activity.push(value);
            if (state.dataHistory.activity.length > state.maxHistory) state.dataHistory.activity.shift();
            generateActivityStory();
            updateSparkline('activitySparkline', state.dataHistory.activity.slice(-12), '#00d4ff');
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
        }

        function updateMemory(value) {
            state.memory = value;
            if (elements.memory) {
                elements.memory.classList.add('num-pop');
                elements.memory.classList.remove('skeleton-loading');
                setTimeout(() => elements.memory.classList.remove('num-pop'), 350);
                elements.memory.textContent = value;
                triggerV43MorphNumber('memory');
                triggerV38NumberPop('memory');
                updateV38ProgressTooltip('memory', value, ' MB');
            }
            const percent = Math.min((value / (state.memoryTotal || 1000)) * 100, 100);
            if (elements.memoryBar) {
                elements.memoryBar.style.width = percent + '%';
                elements.memoryBar.className = 'progress-fill ' + getProgressClass(percent);
            }
            state.dataHistory.memory.push(value);
            if (state.dataHistory.memory.length > state.maxHistory) state.dataHistory.memory.shift();
            updateSparkline('memorySparkline', state.dataHistory.memory.slice(-12), '#5cdb95');
            createLineChart('memoryChart', state.dataHistory.memory, '#5cdb95');
        }

        function updateCPU(value) {
            state.cpu = value;
            if (elements.cpu) {
                elements.cpu.classList.add('num-pop');
                elements.cpu.classList.remove('skeleton-loading');
                setTimeout(() => elements.cpu.classList.remove('num-pop'), 350);
                elements.cpu.textContent = value + '%';
                triggerV43MorphNumber('cpu');
                triggerV38NumberPop('cpu');
                updateV38ProgressTooltip('cpu', value, '%');
            }
            if (elements.cpuBar) {
                elements.cpuBar.style.width = value + '%';
                elements.cpuBar.className = 'progress-fill ' + getProgressClass(value);
            }
            state.dataHistory.cpu.push(value);
            if (state.dataHistory.cpu.length > state.maxHistory) state.dataHistory.cpu.shift();
            createLineChart('cpuChart', state.dataHistory.cpu, '#00d4ff');
        }

        // ========== Star Background ==========
        function initStars() {
            const starsContainer = elements.stars;
            if (!starsContainer) return;
            const starCount = 140;
            for (let i = 0; i < starCount; i++) {
                const star = document.createElement('div');
                star.style.cssText = `
                    position: absolute;
                    width: ${Math.random() * 2 + 1}px;
                    height: ${Math.random() * 2 + 1}px;
                    background: white;
                    border-radius: 50%;
                    opacity: ${Math.random() * 0.5 + 0.3};
                    left: ${Math.random() * 100}%;
                    top: ${Math.random() * 100}%;
                    animation: twinkle ${Math.random() * 3 + 2}s ease-in-out infinite;
                    animation-delay: ${Math.random() * 2}s;
                `;
                starsContainer.appendChild(star);
            }
        }

        // ========== Neural Network Background ==========
        function initNeuralNetwork() {
            const canvas = elements.neuralCanvas;
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            const nodes = [];
            const nodeCount = 55;
            for (let i = 0; i < nodeCount; i++) {
                nodes.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: (Math.random() - 0.5) * 0.5,
                    radius: Math.random() * 2 + 1
                });
            }
            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                nodes.forEach(node => {
                    node.x += node.vx; node.y += node.vy;
                    if (node.x < 0 || node.x > canvas.width) node.vx *= -1;
                    if (node.y < 0 || node.y > canvas.height) node.vy *= -1;
                    ctx.beginPath();
                    ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(0, 212, 255, 0.5)';
                    ctx.fill();
                    nodes.forEach(otherNode => {
                        const dx = node.x - otherNode.x;
                        const dy = node.y - otherNode.y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < 150) {
                            ctx.beginPath();
                            ctx.moveTo(node.x, node.y);
                            ctx.lineTo(otherNode.x, otherNode.y);
                            ctx.strokeStyle = `rgba(0, 212, 255, ${0.2 * (1 - dist / 150)})`;
                            ctx.lineWidth = 1;
                            ctx.stroke();
                        }
                    });
                });
                requestAnimationFrame(animate);
            }
            animate();
            window.addEventListener('resize', () => {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            });
        }

        // ========== v45.0: Neural Waveform Visualization ==========
        function initNeuralWaveform() {
            const canvas = document.getElementById('neuralWaveformCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            canvas.width = canvas.parentElement.clientWidth || 300;
            canvas.height = canvas.parentElement.clientHeight || 60;

            const history = [];
            const maxHistory = 60;
            let phase = 0;

            function draw() {
                const w = canvas.width, h = canvas.height;
                ctx.clearRect(0, 0, w, h);

                // Add new data point based on activity
                const activity = state.activity || 50;
                const noise = (Math.random() - 0.5) * (activity / 50) * 10;
                const baseWave = Math.sin(phase) * (activity / 100) * 15;
                const value = Math.max(-5, Math.min(5, baseWave + noise));
                history.push(value);
                if (history.length > maxHistory) history.shift();
                phase += 0.15;

                // Draw gradient fill
                const grad = ctx.createLinearGradient(0, 0, 0, h);
                grad.addColorStop(0, 'rgba(168, 85, 247, 0.4)');
                grad.addColorStop(0.5, 'rgba(0, 212, 255, 0.2)');
                grad.addColorStop(1, 'rgba(0, 212, 255, 0.0)');

                ctx.beginPath();
                ctx.moveTo(0, h / 2);
                history.forEach((v, i) => {
                    const x = (i / (maxHistory - 1)) * w;
                    const y = h / 2 - v * (h / 12);
                    if (i === 0) ctx.lineTo(x, y);
                    else {
                        const prevX = ((i - 1) / (maxHistory - 1)) * w;
                        const prevV = history[i - 1];
                        const prevY = h / 2 - prevV * (h / 12);
                        const cpX = (prevX + x) / 2;
                        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
                    }
                });
                ctx.lineTo(w, h);
                ctx.lineTo(0, h);
                ctx.closePath();
                ctx.fillStyle = grad;
                ctx.fill();

                // Draw line
                ctx.beginPath();
                history.forEach((v, i) => {
                    const x = (i / (maxHistory - 1)) * w;
                    const y = h / 2 - v * (h / 12);
                    if (i === 0) ctx.moveTo(x, y);
                    else {
                        const prevX = ((i - 1) / (maxHistory - 1)) * w;
                        const prevV = history[i - 1];
                        const prevY = h / 2 - prevV * (h / 12);
                        const cpX = (prevX + x) / 2;
                        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
                    }
                });
                ctx.strokeStyle = 'rgba(168, 85, 247, 0.9)';
                ctx.lineWidth = 2;
                ctx.stroke();

                // Glow effect
                ctx.shadowColor = 'rgba(168, 85, 247, 0.6)';
                ctx.shadowBlur = 8;
                ctx.stroke();
                ctx.shadowBlur = 0;

                requestAnimationFrame(draw);
            }
            draw();
        }

        // ========== v45.0: Neural Spark Visualization ==========
        function initNeuralSpark() {
            const canvas = document.getElementById('neuralSparkCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            canvas.width = canvas.parentElement.clientWidth || 300;
            canvas.height = canvas.parentElement.clientHeight || 40;

            const particles = [];
            const maxParticles = 20;

            function spawn() {
                const activity = state.activity || 50;
                if (particles.length < maxParticles && Math.random() < activity / 200) {
                    particles.push({
                        x: Math.random() * canvas.width,
                        y: canvas.height / 2 + (Math.random() - 0.5) * 20,
                        vx: (Math.random() - 0.3) * 3,
                        vy: (Math.random() - 0.5) * 2,
                        life: 1,
                        size: 1 + Math.random() * 2
                    });
                }
            }

            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                spawn();

                for (let i = particles.length - 1; i >= 0; i--) {
                    const p = particles[i];
                    p.x += p.vx;
                    p.y += p.vy;
                    p.life -= 0.025;
                    if (p.life <= 0) { particles.splice(i, 1); continue; }

                    const alpha = p.life * 0.8;
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(0, 212, 255, ${alpha})`;
                    ctx.fill();

                    // Trail
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(p.x - p.vx * 3, p.y - p.vy * 3);
                    ctx.strokeStyle = `rgba(0, 212, 255, ${alpha * 0.4})`;
                    ctx.lineWidth = p.size * 0.5;
                    ctx.stroke();
                }

                requestAnimationFrame(draw);
            }
            draw();
        }

        // ========== v45.0: Memory Gauge Update ==========
        function updateMemoryGauge(memPercent, memUsed, memTotal) {
            const fill = document.getElementById('memoryGaugeFill');
            const value = document.getElementById('memoryGaugeValue');
            const container = document.getElementById('memoryGaugeContainer');

            if (!fill || !value || !container) return;

            container.style.display = 'flex';

            const circumference = 251.2; // 2 * PI * 40
            const offset = circumference - (memPercent / 100) * circumference;

            fill.style.strokeDashoffset = offset;
            value.textContent = memPercent + '%';

            // Color based on usage
            fill.classList.remove('low', 'medium', 'high');
            if (memPercent < 60) fill.classList.add('low');
            else if (memPercent < 85) fill.classList.add('medium');
            else fill.classList.add('high');
        }

        // ========== v45.0: Skills Hexagon Update ==========
        function updateSkillsHexagon(total, active) {
            const countEl = document.getElementById('skillsHexCount');
            if (countEl) countEl.textContent = total || '--';
        }

        // ========== v45.0: FAB Orb Toggle ==========
        function toggleFabOrb() {
            const orb = document.getElementById('fabOrb');
            if (orb) orb.classList.toggle('expanded');
        }

        // ========== v45.0: Quantum Flash Effect ==========
        function triggerQuantumFlash() {
            const flash = document.getElementById('quantumFlash');
            if (!flash) return;
            flash.classList.remove('active');
            void flash.offsetWidth; // Force reflow
            flash.classList.add('active');
            setTimeout(() => flash.classList.remove('active'), 700);

            // Also update fox expression to excited
            updateFoxExpression('excited');
            updateMoodAura('excited');

            // Create particle burst on fox
            const foxCanvas = elements.foxCanvas;
            if (foxCanvas) {
                const ctx = foxCanvas.getContext('2d');
                createParticleBurst(ctx, foxCanvas.width / 2, foxCanvas.height / 2);
            }
        }

        // ========== v45.0: Floating Emoji ==========
        function floatEmoji(emoji) {
            const container = document.getElementById('emojiFloatContainer');
            if (!container) return;
            const el = document.createElement('div');
            el.textContent = emoji;
            el.style.cssText = `
                position: fixed;
                bottom: 100px;
                right: 50px;
                font-size: 24px;
                pointer-events: none;
                z-index: 200;
                animation: floatUp 2s ease-out forwards;
            `;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2000);
        }

        // ========== Fox Canvas v36 ==========
        function initFoxCanvas() {
            const canvas = elements.foxCanvas;
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const width = canvas.width = 210;
            const height = canvas.height = 210;

            let mouseX = width / 2, mouseY = height / 2;
            let eyeX = 0, eyeY = 0;
            let breathPhase = 0;

            canvas.addEventListener('mousemove', (e) => {
                const rect = canvas.getBoundingClientRect();
                mouseX = e.clientX - rect.left;
                mouseY = e.clientY - rect.top;
            });

            canvas.addEventListener('click', () => {
                const colors = {
                    idle: '#ffc864', working: '#00d4ff', sleeping: '#a855f7',
                    excited: '#ec4899', error: '#ff6b6b', thinking: '#a855f7',
                    laughing: '#ffc864', focused: '#5cdb95', learning: '#ffc864'
                };
                createParticleBurst(ctx, width / 2, height / 2);
            });

            let lastBlink = 0, isBlinking = false, blinkProgress = 0;

            function blink() {
                const now = Date.now();
                if (!isBlinking && now - lastBlink > 3000 + Math.random() * 2000) {
                    isBlinking = true; lastBlink = now; blinkProgress = 0;
                }
                if (isBlinking) {
                    blinkProgress += 0.08;
                    if (blinkProgress >= 1) { isBlinking = false; blinkProgress = 0; }
                }
                if (isBlinking) return Math.cos(blinkProgress * Math.PI) * 0.5 + 0.5;
                return 0;
            }

            let earTwitchPhase = 0;

            function drawFox() {
                ctx.clearRect(0, 0, width, height);
                breathPhase += 0.02;
                const breathScale = 1 + Math.sin(breathPhase) * 0.02;
                eyeX += (mouseX - width / 2 - eyeX) * 0.08;
                eyeY += (mouseY - height / 2 - eyeY) * 0.08;
                const cx = width / 2, cy = height / 2;
                const blinkAmt = blink();
                const eyeScaleY = Math.max(0.1, 1 - blinkAmt * 0.9);

                ctx.save();
                ctx.translate(cx, cy);
                ctx.scale(breathScale, breathScale);
                ctx.translate(-cx, -cy);

                // Shadow
                ctx.fillStyle = 'rgba(0, 0, 0, 0.2)';
                ctx.beginPath();
                ctx.ellipse(cx, cy + 70, 45 * breathScale, 14, 0, 0, Math.PI * 2);
                ctx.fill();

                // Body gradient
                const bodyGrad = ctx.createRadialGradient(cx - 12, cy + 22, 0, cx, cy + 22, 65);
                bodyGrad.addColorStop(0, '#ffe4a0');
                bodyGrad.addColorStop(0.6, '#ffc864');
                bodyGrad.addColorStop(1, '#e0a830');
                ctx.fillStyle = bodyGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy + 24, 55, 42, 0, 0, Math.PI * 2);
                ctx.fill();

                // Chest highlight
                const chestGrad = ctx.createRadialGradient(cx, cy + 16, 0, cx, cy + 16, 30);
                chestGrad.addColorStop(0, 'rgba(255,255,220,0.6)');
                chestGrad.addColorStop(1, 'rgba(255,255,220,0)');
                ctx.fillStyle = chestGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy + 12, 30, 24, 0, 0, Math.PI * 2);
                ctx.fill();

                // Head gradient
                const headGrad = ctx.createRadialGradient(cx - 10, cy - 28, 0, cx, cy - 22, 55);
                headGrad.addColorStop(0, '#ffe4a0');
                headGrad.addColorStop(0.6, '#ffc864');
                headGrad.addColorStop(1, '#e0a830');
                ctx.fillStyle = headGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy - 22, 48, 42, 0, 0, Math.PI * 2);
                ctx.fill();

                // Inner face light
                const faceGrad = ctx.createRadialGradient(cx - 6, cy - 32, 0, cx, cy - 28, 34);
                faceGrad.addColorStop(0, 'rgba(255,255,230,0.7)');
                faceGrad.addColorStop(1, 'rgba(255,255,230,0)');
                ctx.fillStyle = faceGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy - 28, 32, 26, 0, 0, Math.PI * 2);
                ctx.fill();

                // Ears
                earTwitchPhase += 0.05;
                const earTwitch = Math.sin(earTwitchPhase) * (state.status === 'idle' || state.status === 'working' ? 2 : 0);

                // Left ear
                ctx.fillStyle = '#ffc864';
                ctx.beginPath();
                ctx.moveTo(cx - 36, cy - 60);
                ctx.lineTo(cx - 25 + earTwitch, cy - 98);
                ctx.lineTo(cx - 12, cy - 60);
                ctx.fill();
                ctx.fillStyle = '#ffb8c0';
                ctx.beginPath();
                ctx.moveTo(cx - 32, cy - 60);
                ctx.lineTo(cx - 25 + earTwitch * 0.5, cy - 86);
                ctx.lineTo(cx - 19, cy - 60);
                ctx.fill();

                // Right ear
                ctx.fillStyle = '#ffc864';
                ctx.beginPath();
                ctx.moveTo(cx + 36, cy - 60);
                ctx.lineTo(cx + 25 - earTwitch, cy - 98);
                ctx.lineTo(cx + 12, cy - 60);
                ctx.fill();
                ctx.fillStyle = '#ffb8c0';
                ctx.beginPath();
                ctx.moveTo(cx + 32, cy - 60);
                ctx.lineTo(cx + 25 - earTwitch * 0.5, cy - 86);
                ctx.lineTo(cx + 19, cy - 60);
                ctx.fill();

                // Eye glow
                const eyeGlow = ctx.createRadialGradient(cx - 16, cy - 28, 0, cx - 16, cy - 28, 16);
                eyeGlow.addColorStop(0, 'rgba(255,255,255,0.9)');
                eyeGlow.addColorStop(1, 'rgba(255,255,255,0)');
                ctx.fillStyle = eyeGlow;
                ctx.beginPath();
                ctx.ellipse(cx - 16, cy - 28, 16, 18 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(cx + 16, cy - 28, 16, 18 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();

                // Eyes
                ctx.fillStyle = '#ffffff';
                ctx.beginPath();
                ctx.ellipse(cx - 16, cy - 28, 12, 14 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(cx + 16, cy - 28, 12, 14 * eyeScaleY, 0, 0, Math.PI * 2);
                ctx.fill();

                // Pupils
                if (blinkAmt < 0.5) {
                    ctx.fillStyle = '#8B6914';
                    ctx.beginPath();
                    ctx.arc(cx - 16 + eyeX * 0.4, cy - 28 + eyeY * 0.4, 6, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(cx + 16 + eyeX * 0.4, cy - 28 + eyeY * 0.4, 6, 0, Math.PI * 2);
                    ctx.fill();

                    ctx.fillStyle = '#1a1a1a';
                    ctx.beginPath();
                    ctx.arc(cx - 16 + eyeX * 0.4, cy - 28 + eyeY * 0.4, 3.5, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(cx + 16 + eyeX * 0.4, cy - 28 + eyeY * 0.4, 3.5, 0, Math.PI * 2);
                    ctx.fill();

                    ctx.fillStyle = 'rgba(255,255,255,0.9)';
                    ctx.beginPath();
                    ctx.arc(cx - 19 + eyeX * 0.2, cy - 32 + eyeY * 0.2, 1.8, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(cx + 13 + eyeX * 0.2, cy - 32 + eyeY * 0.2, 1.8, 0, Math.PI * 2);
                    ctx.fill();
                }

                // Nose
                const noseGrad = ctx.createRadialGradient(cx - 1, cy - 13, 0, cx, cy - 11, 9);
                noseGrad.addColorStop(0, '#555555');
                noseGrad.addColorStop(1, '#222222');
                ctx.fillStyle = noseGrad;
                ctx.beginPath();
                ctx.ellipse(cx, cy - 11, 7, 6, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillStyle = 'rgba(255,255,255,0.4)';
                ctx.beginPath();
                ctx.ellipse(cx - 2, cy - 13, 2.5, 2, 0, 0, Math.PI * 2);
                ctx.fill();

                // Blush
                ctx.fillStyle = 'rgba(255, 150, 150, 0.35)';
                ctx.beginPath();
                ctx.ellipse(cx - 36, cy - 16, 10, 6, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(cx + 36, cy - 16, 10, 6, 0, 0, Math.PI * 2);
                ctx.fill();

                // Mouth
                ctx.strokeStyle = '#c08030';
                ctx.lineWidth = 2.4;
                ctx.lineCap = 'round';
                ctx.beginPath();
                ctx.arc(cx, cy - 3, 12, 0.15 * Math.PI, 0.85 * Math.PI);
                ctx.stroke();

                // Whiskers
                ctx.strokeStyle = 'rgba(200,160,50,0.5)';
                ctx.lineWidth = 1;
                ctx.beginPath(); ctx.moveTo(cx - 12, cy - 8); ctx.lineTo(cx - 32, cy - 13); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(cx - 12, cy - 6); ctx.lineTo(cx - 32, cy - 5); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(cx + 12, cy - 8); ctx.lineTo(cx + 32, cy - 13); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(cx + 12, cy - 6); ctx.lineTo(cx + 32, cy - 5); ctx.stroke();

                ctx.restore();

                // State effects

                if (state.status === 'excited') {
                    ctx.fillStyle = 'rgba(255,100,150,0.7)';
                    for (let i = 0; i < 3; i++) {
                        const angle = (Date.now() / 500 + i * 2) % (Math.PI * 2);
                        const sx = cx - 16 + Math.cos(angle) * 26;
                        const sy = cy - 34 + Math.sin(angle) * 15;
                        ctx.beginPath();
                        ctx.arc(sx, sy, 2.4, 0, Math.PI * 2);
                        ctx.fill();
                    }
                }

                if (state.status === 'sleeping') {
                    ctx.fillStyle = 'rgba(168,85,247,0.7)';
                    ctx.font = 'bold 15px Outfit';
                    const zzOffset = (Date.now() / 800) % 20;
                    ctx.fillText('z', cx + 40 + zzOffset * 0.3, cy - 64 - zzOffset);
                    ctx.fillText('z', cx + 48 + zzOffset * 0.5, cy - 78 - zzOffset * 0.8);
                }

                if (state.status === 'thinking') {
                    ctx.fillStyle = 'rgba(168,85,247,0.6)';
                    ctx.font = 'bold 13px Outfit';
                    const bubbleX = cx + 45 + Math.sin(Date.now() / 600) * 5;
                    const bubbleY = cy - 70 + Math.cos(Date.now() / 600) * 3;
                    ctx.beginPath();
                    ctx.arc(bubbleX, bubbleY, 8, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(bubbleX - 12, bubbleY + 10, 5, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(bubbleX - 20, bubbleY + 17, 3, 0, Math.PI * 2);
                    ctx.fill();
                }

                if (state.status === 'laughing') {
                    ctx.strokeStyle = '#c08030';
                    ctx.lineWidth = 2.4;
                    ctx.lineCap = 'round';
                    ctx.beginPath();
                    ctx.arc(cx, cy, 14, 0.1 * Math.PI, 0.9 * Math.PI);
                    ctx.stroke();
                }

                requestAnimationFrame(drawFox);
            }
            drawFox();
        }

        // ========== Charts ==========
        function initCharts() {
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
            createLineChart('memoryChart', state.dataHistory.memory, '#5cdb95');
            createLineChart('cpuChart', state.dataHistory.cpu, '#00d4ff');
        }

        function createLineChart(canvasId, data, color) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = canvas.parentElement.clientHeight;
            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                if (data.length < 2) return;
                const max = Math.max(...data, 100);
                const min = Math.min(...data, 0);
                const range = max - min || 1;
                // Gradient fill
                const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
                grad.addColorStop(0, color + '55');
                grad.addColorStop(1, color + '05');
                ctx.beginPath();
                let prevX = 0, prevY = 0;
                data.forEach((value, index) => {
                    const x = (index / (data.length - 1)) * canvas.width;
                    const y = canvas.height - ((value - min) / range) * canvas.height;
                    if (index === 0) { ctx.moveTo(x, y); prevX = x; prevY = y; }
                    else {
                        const cpX = (prevX + x) / 2;
                        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
                        prevX = x; prevY = y;
                    }
                });
                ctx.lineTo(canvas.width, canvas.height);
                ctx.lineTo(0, canvas.height);
                ctx.closePath();
                ctx.fillStyle = grad;
                ctx.fill();
                // Line
                ctx.beginPath();
                data.forEach((value, index) => {
                    const x = (index / (data.length - 1)) * canvas.width;
                    const y = canvas.height - ((value - min) / range) * canvas.height;
                    if (index === 0) ctx.moveTo(x, y);
                    else {
                        const cpX = (prevX + x) / 2;
                        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
                        prevX = x; prevY = y;
                    }
                });
                ctx.strokeStyle = color;
                ctx.lineWidth = 2.5;
                ctx.stroke();
            }
            draw();
        }

        // ========== Fetch with Retry ==========
        // v42.0: Enhanced fetch with retry and skeleton loading
        async function fetchWithRetry(url, options = {}, retries = retryConfig.maxRetries, baseDelay = retryConfig.baseDelay) {
            // Show syncing indicator
            showSyncIndicator(true);
            
            for (let attempt = 0; attempt <= retries; attempt++) {
                try {
                    const controller = new AbortController();
                    const timeout = setTimeout(() => controller.abort(), 5000);
                    const res = await fetch(url, { ...options, signal: controller.signal });
                    clearTimeout(timeout);
                    
                    if (!res.ok && attempt < retries) {
                        await sleep(baseDelay * Math.pow(2, attempt));
                        continue;
                    }
                    
                    showSyncIndicator(false);
                    return res;
                } catch (err) {
                    if (attempt === retries) {
                        showSyncIndicator(false);
                        handleFetchError(err);
                        throw err;
                    }
                    await sleep(baseDelay * Math.pow(2, attempt));
                }
            }
            showSyncIndicator(false);
            return null;
        }
        
        // v42.0: Show/hide sync indicator
        function showSyncIndicator(show) {
            const refreshBadge = document.querySelector('.refresh-badge');
            if (refreshBadge) {
                if (show) {
                    refreshBadge.classList.add('syncing');
                } else {
                    refreshBadge.classList.remove('syncing');
                }
            }
        }
        
        // v42.0: Skeleton loading for stat values
        function showSkeletonLoading(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                el.classList.add('skeleton-loading');
                el.textContent = '--';
            }
        }
        
        function hideSkeletonLoading(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                el.classList.remove('skeleton-loading');
            }
        }
        
        function showAllSkeletons() {
            ['heartbeat', 'activity', 'memory', 'cpu'].forEach(id => showSkeletonLoading(id));
        }
        
        function hideAllSkeletons() {
            ['heartbeat', 'activity', 'memory', 'cpu'].forEach(id => hideSkeletonLoading(id));
        }

        function sleep(ms) { return new Promise(resolve => setTimeout(resolve, ms)); }

        async function fetchData() {
            if (!state.isOnline) return;
            try {
                // v57.0: Circuit breaker - skip endpoints with open circuit
                const hbHealth = state.apiHealth.heartbeat;
                if (!hbHealth.circuitOpen) {
                    const hbStart = Date.now();
                    try {
                        const heartbeatRes = await fetchWithRetry('/api/heartbeat');
                        if (!heartbeatRes.ok) throw new Error('Heartbeat API failed');
                        const heartbeatData = await heartbeatRes.json();
                        // v57.0: Record latency
                        hbHealth.latency = Date.now() - hbStart;
                        hbHealth.failures = 0;
                        hbHealth.lastSuccess = Date.now();
                        updateDataSourceHealth(heartbeatData.source || 'api', true);
                        triggerV39DataSyncWave();
                        updateV39DataFreshness();
                        updateV39ConnectionQuality();
                        updateV57ApiHealthPanel();
                        if (heartbeatData.heartbeat) updateHeartbeatV50(heartbeatData.heartbeat);
                        if (heartbeatData.activity) updateActivityV50(heartbeatData.activity);
                        if (heartbeatData.status) updateStatusV50(heartbeatData.status);
                        if (heartbeatData.uptime) updateUptime(heartbeatData.uptime);
                        if (heartbeatData.reputation !== undefined) updateReputation(heartbeatData.reputation);
                        if (heartbeatData.currentTask) updateTaskProgress(heartbeatData.currentTask, heartbeatData.taskProgress || 0);
                    } catch (e) {
                        hbHealth.failures++;
                        if (hbHealth.failures >= state.circuitBreakerThreshold) {
                            hbHealth.circuitOpen = true;
                            setTimeout(() => { hbHealth.circuitOpen = false; hbHealth.failures = 0; }, state.circuitBreakerResetMs);
                        }
                        updateV57ApiHealthPanel();
                    }
                }

                // v57.0: System API with circuit breaker
                const sysHealth = state.apiHealth.system;
                if (!sysHealth.circuitOpen) {
                    const sysStart = Date.now();
                    try {
                        const systemRes = await fetchWithRetry('/api/system');
                        if (systemRes.ok) {
                            sysHealth.latency = Date.now() - sysStart;
                            sysHealth.failures = 0;
                            sysHealth.lastSuccess = Date.now();
                            const systemData = await systemRes.json();
                            if (systemData.memory) updateMemory(systemData.memory);
                            if (systemData.cpu !== undefined) updateCPU(systemData.cpu);
                            updateV57ApiHealthPanel();
                        }
                    } catch (e) {
                        sysHealth.failures++;
                        if (sysHealth.failures >= state.circuitBreakerThreshold) {
                            sysHealth.circuitOpen = true;
                            setTimeout(() => { sysHealth.circuitOpen = false; sysHealth.failures = 0; }, state.circuitBreakerResetMs);
                        }
                        updateV57ApiHealthPanel();
                    }
                }

                // v57.0: Memories API with circuit breaker
                const memHealth = state.apiHealth.memories;
                if (!memHealth.circuitOpen) {
                    const memStart = Date.now();
                    try {
                        const memoriesRes = await fetchWithRetry('/api/memories');
                        if (memoriesRes.ok) {
                            memHealth.latency = Date.now() - memStart;
                            memHealth.failures = 0;
                            memHealth.lastSuccess = Date.now();
                            const memories = await memoriesRes.json();
                            updateMemories(memories);
                            updateV57ApiHealthPanel();
                        }
                    } catch (e) {
                        memHealth.failures++;
                        if (memHealth.failures >= state.circuitBreakerThreshold) {
                            memHealth.circuitOpen = true;
                            setTimeout(() => { memHealth.circuitOpen = false; memHealth.failures = 0; }, state.circuitBreakerResetMs);
                        }
                        updateV57ApiHealthPanel();
                    }
                }

                // v57.0: Skills API with circuit breaker
                const skHealth = state.apiHealth.skills;
                if (!skHealth.circuitOpen) {
                    const skStart = Date.now();
                    try {
                        const skillsRes = await fetchWithRetry('/api/skills/detailed');
                        if (skillsRes.ok) {
                            skHealth.latency = Date.now() - skStart;
                            skHealth.failures = 0;
                            skHealth.lastSuccess = Date.now();
                            const skills = await skillsRes.json();
                            updateSkills(skills);
                            if (skills.summary) {
                                state.skillsTotal = skills.summary.total || 0;
                                updateQuickStats();
                            }
                            updateV57ApiHealthPanel();
                        }
                    } catch (e) {
                        skHealth.failures++;
                        if (skHealth.failures >= state.circuitBreakerThreshold) {
                            skHealth.circuitOpen = true;
                            setTimeout(() => { skHealth.circuitOpen = false; skHealth.failures = 0; }, state.circuitBreakerResetMs);
                        }
                        updateV57ApiHealthPanel();
                    }
                }

                // v57.0: Dashboard API with circuit breaker
                const dashHealth = state.apiHealth.dashboard;
                if (!dashHealth.circuitOpen) {
                    const dashStart = Date.now();
                    try {
                        const dashRes = await fetchWithRetry('/api/dashboard');
                        if (dashRes.ok) {
                            dashHealth.latency = Date.now() - dashStart;
                            dashHealth.failures = 0;
                            dashHealth.lastSuccess = Date.now();
                            const dashData = await dashRes.json();
                            if (dashData.msgCount !== undefined) state.msgCount = dashData.msgCount;
                            if (dashData.taskDone !== undefined) state.taskDone = dashData.taskDone;
                            updateQuickStats();
                            updateV57ApiHealthPanel();
                        }
                    } catch (e) {
                        dashHealth.failures++;
                        if (dashHealth.failures >= state.circuitBreakerThreshold) {
                            dashHealth.circuitOpen = true;
                            setTimeout(() => { dashHealth.circuitOpen = false; dashHealth.failures = 0; }, state.circuitBreakerResetMs);
                        }
                        updateV57ApiHealthPanel();
                    }
                }

                if (elements.lastUpdated) elements.lastUpdated.textContent = new Date().toLocaleTimeString();
                state.consecutiveErrors = 0;
            } catch (error) {
                console.error('Error fetching data:', error);
                logActivity('Data fetch failed, retrying...', 'warning');
                state.consecutiveErrors++;
                if (state.consecutiveErrors >= 2) {
                    if (elements.sourceDot) {
                        elements.sourceDot.className = 'source-dot stale';
                        elements.sourceName.textContent = 'Stale';
                    }
                    if (!state.recoveryScheduled) {
                        state.recoveryScheduled = true;
                        setInterval(() => {
                            if (state.consecutiveErrors >= 2 && state.isOnline) fetchData();
                        }, 30000);
                    }
                }
                if (elements.statusText) elements.statusText.textContent = 'Error';
                if (elements.statusDot) elements.statusDot.classList.add('error');
            }
        }

        function updateData() { fetchData(); }

        // ========== Update Functions ==========
        function springPopNumber(el) {
            if (!el) return;
            el.classList.remove('spring-pop');
            void el.offsetWidth;
            el.classList.add('spring-pop');
        }

        function updateHeartbeat(value) {
            state.heartbeat = value;
            if (elements.heartbeat) {
                elements.heartbeat.classList.add('num-pop');
                elements.heartbeat.classList.remove('skeleton-loading'); // v37.0: Remove skeleton on data load
                setTimeout(() => elements.heartbeat.classList.remove('num-pop'), 350);
                elements.heartbeat.textContent = value;
                // v38: Number pop animation and tooltip
                triggerV38NumberPop('heartbeat');
                updateV38ProgressTooltip('heartbeat', value, ' BPM');
            }
            if (elements.miniHeartbeat) elements.miniHeartbeat.textContent = value;
            const percent = Math.min((value / 180) * 100, 100);
            if (elements.heartbeatBar) {
                elements.heartbeatBar.style.width = percent + '%';
                elements.heartbeatBar.className = 'progress-fill ' + getProgressClass(percent);
            }
            state.dataHistory.heartbeat.push(value);
            if (state.dataHistory.heartbeat.length > state.maxHistory) state.dataHistory.heartbeat.shift();
            updateSparkline('heartbeatSparkline', state.dataHistory.heartbeat.slice(-12), '#ffc864');
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
        }

        function updateActivity(value) {
            state.activity = value;
            if (elements.activity) {
                elements.activity.classList.add('num-pop');
                elements.activity.classList.remove('skeleton-loading'); // v37.0
                setTimeout(() => elements.activity.classList.remove('num-pop'), 350);
                elements.activity.textContent = value + '%';
                // v38: Number pop animation and tooltip
                triggerV38NumberPop('activity');
                updateV38ProgressTooltip('activity', value, '%');
            }
            if (elements.miniActivity) elements.miniActivity.textContent = value + '%';
            if (elements.activityBar) {
                elements.activityBar.style.width = value + '%';
                elements.activityBar.className = 'progress-fill ' + getProgressClass(value);
            }
            
            // v36.0: Activity-synced pulse ring - enhanced with aurora colors
            const activityRing = $('activitySyncRing');
            const neuralIndicator = $('neuralSyncIndicator');
            if (activityRing) {
                const pulseDuration = Math.max(1, 3 - (value / 50)); // 1s at 100%, 3s at 0%
                activityRing.style.animationDuration = pulseDuration + 's';
                activityRing.style.borderColor = value >= 70 ? '#5cdb95' : value >= 40 ? '#00d4ff' : '#a855f7';
            }
            if (neuralIndicator) {
                neuralIndicator.style.opacity = value >= 50 ? '0.6' : '0.2';
                neuralIndicator.style.animationDuration = (4 - value / 25) + 's';
            }
            
            if (value >= 80 && (!state.lastPeakTime || Date.now() - state.lastPeakTime > 300000)) {
                state.peakActivityCount++;
                state.lastPeakTime = Date.now();
            }
            state.dataHistory.activity.push(value);
            if (state.dataHistory.activity.length > state.maxHistory) state.dataHistory.activity.shift();
            generateActivityStory();
            updateSparkline('activitySparkline', state.dataHistory.activity.slice(-12), '#00d4ff');
            createLineChart('activityChart', state.dataHistory.activity, '#ffc864');
        }

        function updateMemory(value) {
            state.memory = value;
            if (elements.memory) {
                elements.memory.classList.add('num-pop');
                elements.memory.classList.remove('skeleton-loading'); // v37.0
                setTimeout(() => elements.memory.classList.remove('num-pop'), 350);
                elements.memory.textContent = value;
                // v38: Number pop animation and tooltip
                triggerV38NumberPop('memory');
                updateV38ProgressTooltip('memory', value, ' MB');
            }
            const percent = Math.min((value / (state.memoryTotal || 1000)) * 100, 100);
            if (elements.memoryBar) {
                elements.memoryBar.style.width = percent + '%';
                elements.memoryBar.className = 'progress-fill ' + getProgressClass(percent);
            }
            state.dataHistory.memory.push(value);
            if (state.dataHistory.memory.length > state.maxHistory) state.dataHistory.memory.shift();
            updateSparkline('memorySparkline', state.dataHistory.memory.slice(-12), '#5cdb95');
            createLineChart('memoryChart', state.dataHistory.memory, '#5cdb95');
        }

        function updateCPU(value) {
            state.cpu = value;
            if (elements.cpu) {
                elements.cpu.classList.add('num-pop');
                elements.cpu.classList.remove('skeleton-loading'); // v37.0
                setTimeout(() => elements.cpu.classList.remove('num-pop'), 350);
                elements.cpu.textContent = value + '%';
                // v38: Number pop animation and tooltip
                triggerV38NumberPop('cpu');
                updateV38ProgressTooltip('cpu', value, '%');
            }
            if (elements.cpuBar) {
                elements.cpuBar.style.width = value + '%';
                elements.cpuBar.className = 'progress-fill ' + getProgressClass(value);
            }
            state.dataHistory.cpu.push(value);
            if (state.dataHistory.cpu.length > state.maxHistory) state.dataHistory.cpu.shift();
            createLineChart('cpuChart', state.dataHistory.cpu, '#00d4ff');
        }

        function updateStatus(status) {
            state.status = status;
            if (elements.statusValue) elements.statusValue.textContent = status.charAt(0).toUpperCase() + status.slice(1);
            if (elements.statusText) elements.statusText.textContent = status.charAt(0).toUpperCase() + status.slice(1);
            updateBodyStatusClass(status);
            if (elements.moodSyncRing) {
                elements.moodSyncRing.className = 'mood-sync-ring ' + status;
                elements.moodSyncRing.classList.add('active');
            }
            if (elements.foxContainer) {
                elements.foxContainer.className = 'fox-container ' + status;
            }
            if (elements.statusDot) {
                elements.statusDot.classList.remove('warning', 'error', 'critical');
                if (status === 'error') elements.statusDot.classList.add('error');
                else if (status === 'sleeping') elements.statusDot.classList.add('warning');
            }
            updateThinkingChain(status === 'thinking' || status === 'working');
            generateActivityStory();
            updateMoodAura(status);
            updateFoxExpression(status);
            // v38: Trigger state flash and update fox ring
            triggerV38StateFlash(status);
            updateV38FoxRing(status);
            // v46.0: Update status pulse line
            updateStatusPulseLine(status);
        }

        function updateUptime(value) {
            state.uptime = value;
            if (elements.uptime) elements.uptime.textContent = value;
        }

        function updateMemories(memories) {
            if (!elements.timelineItems) return;
            elements.timelineItems.innerHTML = memories.slice(0, 5).map(memory => `
                <div class="timeline-item fade-in">
                    <div class="timeline-icon" style="background: rgba(255,200,100,0.12); color: var(--primary);">📝</div>
                    <div class="timeline-content">
                        <div class="timeline-text">${memory.text || 'Memory'}</div>
                        <div class="timeline-time">${memory.timestamp || new Date().toLocaleTimeString()}</div>
                    </div>
                </div>
            `).join('');
        }

        function updateSkills(skills) {
            if (!elements.skillsList) return;
            elements.skillsList.innerHTML = skills.slice(0, 5).map(skill => `
                <div class="skill-item fade-in">
                    <div class="skill-header">
                        <span class="skill-name">${skill.name}</span>
                        <span class="skill-value">${skill.count} uses</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-fill" style="width: ${skill.count * 5}%; background: var(--primary);"></div>
                    </div>
                </div>
            `).join('');
        }

        function getProgressClass(value) {
            if (value >= 80) return 'danger';
            if (value >= 60) return 'warning';
            return 'success';
        }

        function copyStat(type) {
            const value = state[type];
            if (value !== '--') {
                navigator.clipboard.writeText(value).then(() => {
                    showToastV32(`${type} copied: ${value}`, 'default', 2000);
                });
            }
        }

        function showToastV32(message, type = 'default', duration = 3000) {
            const queue = $('toastQueue');
            if (!queue) return;
            const icons = { default: '💬', success: '✅', error: '❌', warning: '⚠️' };
            const toast = document.createElement('div');
            toast.className = `toast-v32 ${type}`;
            toast.innerHTML = `
                <span class="toast-icon">${icons[type] || icons.default}</span>
                <span class="toast-msg">${message}</span>
                <div class="toast-bar" style="--dur: ${duration}ms"></div>
            `;
            queue.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('exiting');
                setTimeout(() => toast.remove(), 260);
            }, duration);
        }

        function setMode(mode) {
            updateStatus(mode);
            showToastV32(`Mode changed to ${mode}`);
        }

        function setMood(mood) {
            updateStatusV50(mood);
            updateMoodTimeline(mood);
            document.querySelectorAll('.mood-btn').forEach(btn => btn.classList.remove('active', 'v43-active'));
            const activeBtn = document.querySelector(`.mood-btn[onclick="setMood('${mood}')"]`);
            if (activeBtn) activeBtn.classList.add('active', 'v43-active');
            updateFoxExpression(mood);
            showToastV32(`Mood: ${mood}`);
            // v38: Trigger state flash on mood change
            triggerV38StateFlash(mood);
            // v50: Trigger confetti on excited mood
            if (mood === 'excited') {
                const foxContainer = document.getElementById('foxContainer');
                if (foxContainer) {
                    const rect = foxContainer.getBoundingClientRect();
                    triggerV50Confetti(rect.left + rect.width / 2, rect.top + rect.height / 2);
                }
            }
        }

        // ========== v38: Micro-Interaction Functions ==========
        
        // v38: State Flash Effect on Mood Change
        function triggerV38StateFlash(mood) {
            const flash = $('v38StateFlash');
            if (!flash) return;
            const colors = {
                idle: '#ffc864', working: '#00d4ff', sleeping: '#a855f7',
                excited: '#ec4899', error: '#ff6b6b', thinking: '#a855f7',
                laughing: '#ffc864', focused: '#5cdb95', learning: '#ffc864'
            };
            flash.style.background = colors[mood] || '#ffc864';
            flash.classList.remove('active');
            flash.offsetHeight; // Trigger reflow
            flash.classList.add('active');
            setTimeout(() => flash.classList.remove('active'), 600);
        }

        // v38: Number Pop Animation on Value Change
        function triggerV38NumberPop(elementId) {
            const el = $(elementId);
            if (!el) return;
            el.classList.remove('v38-number-pop');
            el.offsetHeight; // Trigger reflow
            el.classList.add('v38-number-pop');
            setTimeout(() => el.classList.remove('v38-number-pop'), 400);
        }

        // v38: Update Progress Tooltips
        function updateV38ProgressTooltip(id, value, unit) {
            const tooltip = $(id + 'Tooltip');
            if (tooltip) {
                tooltip.textContent = value + unit;
            }
        }

        // v38: Entrance Animation on DOM Ready
        function triggerV38Entrance() {
            const elements = document.querySelectorAll('.v38-entrance');
            elements.forEach((el, i) => {
                el.style.opacity = '0';
                el.style.animation = 'none';
                setTimeout(() => {
                    el.style.animation = '';
                }, i * 70);
            });
        }

        // v38: Update Fox Status Ring Color
        function updateV38FoxRing(mood) {
            const ring = $('v38FoxRing');
            if (!ring) return;
            const colors = {
                idle: 'var(--primary)', working: 'var(--accent)', sleeping: 'var(--purple)',
                excited: 'var(--pink)', error: 'var(--danger)', thinking: 'var(--purple)',
                laughing: 'var(--primary)', focused: 'var(--success)', learning: 'var(--warning)'
            };
            ring.style.setProperty('--v38-angle', '0deg');
            ring.style.background = `linear-gradient(90deg, transparent, ${colors[mood] || colors.idle}, transparent)`;
        }

        // v38: Live Indicator Pulse
        function updateV38LiveIndicator(online) {
            const indicator = $('v38LiveIndicator');
            if (indicator) {
                indicator.style.display = online ? 'inline-flex' : 'none';
            }
        }

        function updateFoxExpression(mood) {
            const expressionEl = $('foxExpression');
            if (!expressionEl) return;
            const expressions = {
                idle: '😺', working: '⚡', sleeping: '😴', excited: '🎉',
                thinking: '🤔', laughing: '😄', error: '😿', focused: '🎯', learning: '📚'
            };
            expressionEl.textContent = expressions[mood] || '😺';
            expressionEl.style.animation = 'none';
            expressionEl.offsetHeight;
            expressionEl.style.animation = 'expressionBounce 2.5s ease-in-out infinite';
        }

        function updateMoodAura(mood) {
            const auraEl = $('moodAura');
            if (!auraEl) return;
            auraEl.className = 'mood-aura ' + mood;
        }

        function updateBodyStatusClass(status) {
            const validStatuses = ['idle','working','sleeping','excited','thinking','laughing','error','focused','learning'];
            validStatuses.forEach(s => document.body.classList.remove('status-' + s));
            document.body.classList.add('status-' + (validStatuses.includes(status) ? status : 'idle'));
        }

        

        // ========== v40.0: Activity Stream ==========
        
        let activityStreamItems = [];
        const MAX_STREAM_ITEMS = 5;
        
        function addActivityStreamItem(text, color, time) {
            const stream = $('activityStream');
            if (!stream) return;
            
            activityStreamItems.unshift({ text, color, time: time || new Date().toLocaleTimeString() });
            if (activityStreamItems.length > MAX_STREAM_ITEMS) {
                activityStreamItems.pop();
                if (stream.lastChild) stream.removeChild(stream.lastChild);
            }
            
            const item = document.createElement('div');
            item.className = 'activity-stream-item';
            item.innerHTML = `<span class="stream-dot" style="background:${color}"></span><span>${text}</span><span class="stream-time">${activityStreamItems[0].time}</span>`;
            stream.insertBefore(item, stream.firstChild);
            
            // Auto-remove after 30s
            setTimeout(() => {
                if (item.parentNode) {
                    item.style.opacity = '0';
                    setTimeout(() => item.remove(), 300);
                }
            }, 30000);
        }
        
        function logActivity(text, type) {
            const colors = {
                sync: 'var(--success)',
                warning: 'var(--warning)',
                error: 'var(--danger)',
                info: 'var(--accent)',
                ai: 'var(--purple)'
            };
            addActivityStreamItem(text, colors[type] || 'var(--text-dim)');
        }

        // ========== Cursor Trail ==========
        let lastTrailTime = 0;
        function createCursorTrail(e) {
            const now = Date.now();
            if (now - lastTrailTime < 80) return;
            lastTrailTime = now;
            const particle = document.createElement('div');
            particle.className = 'cursor-trail-particle';
            const colors = {
                idle: '#ffc864', working: '#00d4ff', sleeping: '#a855f7',
                excited: '#ec4899', error: '#ff6b6b', thinking: '#a855f7',
                laughing: '#ffc864', focused: '#5cdb95', learning: '#ffc864'
            };
            const color = colors[state.status] || '#ffc864';
            particle.style.left = e.clientX + 'px';
            particle.style.top = e.clientY + 'px';
            particle.style.background = color;
            particle.style.boxShadow = `0 0 12px ${color}`;
            document.body.appendChild(particle);
            setTimeout(() => particle.remove(), 900);
        }

        // ========== Session Journey ==========
        function updateSessionJourney() {
            const sessionDuration = Date.now() - state.sessionStart;
            const sessionHours = sessionDuration / (1000 * 60 * 60);
            const maxHours = 24;
            const progress = Math.min((sessionHours / maxHours) * 100, 100);
            const fillEl = $('journeyFill');
            const markerEl = $('journeyMarker');
            const labelEl = $('journeyProgress');
            if (fillEl) fillEl.style.width = progress + '%';
            if (markerEl) markerEl.style.left = progress + '%';
            if (labelEl) labelEl.textContent = Math.round(progress) + '%';
        }

        function updateQuickStats() {
            const quickMsgs = $('quickMsgs');
            const quickTasks = $('quickTasks');
            const quickSkills = $('quickSkills');
            if (quickMsgs) quickMsgs.textContent = state.msgCount || '--';
            if (quickTasks) quickTasks.textContent = state.taskDone || '--';
            if (quickSkills) quickSkills.textContent = state.skillsTotal || '--';

            // v56.0: Sync v56 quick stats
            const v56QuickMsgs = $('v56QuickMsgs');
            const v56QuickTasks = $('v56QuickTasks');
            const v56QuickSkills = $('v56QuickSkills');
            if (v56QuickMsgs) {
                const newVal = state.msgCount || '--';
                if (v56QuickMsgs.textContent !== String(newVal)) {
                    v56QuickMsgs.textContent = newVal;
                    v56BumpCounter('v56QuickMsgs');
                }
            }
            if (v56QuickTasks) {
                const newVal = state.taskDone || '--';
                if (v56QuickTasks.textContent !== String(newVal)) {
                    v56QuickTasks.textContent = newVal;
                    v56BumpCounter('v56QuickTasks');
                }
            }
            if (v56QuickSkills) {
                const newVal = state.skillsTotal || '--';
                if (v56QuickSkills.textContent !== String(newVal)) {
                    v56QuickSkills.textContent = newVal;
                    v56BumpCounter('v56QuickSkills');
                }
            }

            // v56.0: Update health score
            calculateHealthScore();
            // v45.0: Update memory gauge
            const memMatch = (state.memory || '').match(/(\d+)\s*\/\s*(\d+)/);
            if (memMatch) {
                const used = parseInt(memMatch[1]);
                const total = parseInt(memMatch[2]);
                const pct = total > 0 ? Math.round((used / total) * 100) : 0;
                updateMemoryGauge(pct, used, total);
            }
            // v45.0: Update skills hexagon
            updateSkillsHexagon(state.skillsTotal || 0, state.skillsActive || 0);
        }

        // ========== Pet Fox ==========
        function initPetFox() {
            const foxCanvas = elements.foxCanvas;
            if (!foxCanvas) return;
            let petCount = 0;
            const petZone = document.createElement('div');
            petZone.style.cssText = 'position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:140px;height:140px;border-radius:50%;cursor:pointer;z-index:10;';
            petZone.title = 'Click to pet MoShang!';
            petZone.addEventListener('click', (e) => {
                e.stopPropagation();
                petCount++;
                foxCanvas.classList.add('fox-happy');
                setTimeout(() => foxCanvas.classList.remove('fox-happy'), 600);
                createHeartBurst(foxCanvas);
                const expression = $('foxExpression');
                if (expression) {
                    expression.textContent = '😻';
                    setTimeout(() => updateFoxExpression(state.status), 1500);
                }
                if (petCount === 1) showToastV32('MoShang loved that! 😻 Keep going!', 'success');
                else if (petCount === 5) showToastV32('MoShang is so happy! 5 pets! 🎉', 'success');
                else if (petCount === 10) showToastV32('Wow! 10 pets! MoShang is blushing! 💕', 'success');
            });
            foxCanvas.parentElement.appendChild(petZone);
        }

        function createHeartBurst(canvas) {
            const hearts = ['💕','💖','💗','💝','❤️','😻'];
            const container = canvas.parentElement;
            for (let i = 0; i < 6; i++) {
                const heart = document.createElement('div');
                heart.className = 'heart-rain';
                heart.textContent = hearts[Math.floor(Math.random() * hearts.length)];
                heart.style.left = (Math.random() * 80 + 10) + '%';
                heart.style.top = (Math.random() * 30 + 30) + '%';
                heart.style.animationDelay = (Math.random() * 0.3) + 's';
                container.appendChild(heart);
                setTimeout(() => heart.remove(), 2200);
            }
        }

        // ========== Particle Mesh Background ==========
        function initParticleMesh() {
            const canvas = document.getElementById('particleMeshCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            resize();
            window.addEventListener('resize', resize);
            const particleCount = Math.min(65, Math.floor(window.innerWidth / 20));
            const particles = [];
            let mouseX = -1000, mouseY = -1000;
            for (let i = 0; i < particleCount; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: (Math.random() - 0.5) * 0.5,
                    size: 1.5 + Math.random() * 2.2,
                    color: `rgba(255,200,100,${0.3 + Math.random() * 0.45})`,
                    pulse: Math.random() * Math.PI * 2
                });
            }
            document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });
            document.addEventListener('mouseleave', () => { mouseX = -1000; mouseY = -1000; });
            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles.forEach((p, i) => {
                    const dx = p.x - mouseX, dy = p.y - mouseY;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 150 && dist > 0) {
                        const force = (150 - dist) / 150 * 0.32;
                        p.vx += (dx / dist) * force; p.vy += (dy / dist) * force;
                    }
                    p.vx *= 0.98; p.vy *= 0.98;
                    p.x += p.vx; p.y += p.vy;
                    if (p.x < 0) p.x = canvas.width;
                    if (p.x > canvas.width) p.x = 0;
                    if (p.y < 0) p.y = canvas.height;
                    if (p.y > canvas.height) p.y = 0;
                    p.pulse += 0.03;
                    const size = p.size * (0.8 + Math.sin(p.pulse) * 0.22);
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
                    ctx.fillStyle = p.color;
                    ctx.fill();
                    for (let j = i + 1; j < particles.length; j++) {
                        const p2 = particles[j];
                        const dx2 = p.x - p2.x, dy2 = p.y - p2.y;
                        const dist2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);
                        if (dist2 < 120) {
                            ctx.beginPath();
                            ctx.moveTo(p.x, p.y);
                            ctx.lineTo(p2.x, p2.y);
                            ctx.strokeStyle = `rgba(255,200,100,${(1 - dist2 / 120) * 0.18})`;
                            ctx.lineWidth = 1;
                            ctx.stroke();
                        }
                    }
                });
                requestAnimationFrame(animate);
            }
            animate();
        }

        // ========== Glow Cursor ==========
        function initGlowCursor() {
            const cursor = document.getElementById('glowCursor');
            if (!cursor) return;
            let mouseX = 0, mouseY = 0, curX = 0, curY = 0;
            document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });
            document.addEventListener('mousedown', () => cursor.classList.add('active'));
            document.addEventListener('mouseup', () => cursor.classList.remove('active'));
            function animate() {
                curX += (mouseX - curX) * 0.15;
                curY += (mouseY - curY) * 0.15;
                cursor.style.left = curX + 'px';
                cursor.style.top = curY + 'px';
                requestAnimationFrame(animate);
            }
            animate();
        }

        // ========== Sparkline ==========
        function updateSparkline(svgId, data, color = '#ffc864') {
            const svg = document.getElementById(svgId);
            if (!svg || !data || data.length < 2) return;
            const w = 48, h = 20;
            const min = Math.min(...data);
            const max = Math.max(...data);
            const range = max - min || 1;
            const points = data.map((v, i) => {
                const x = (i / (data.length - 1)) * w;
                const y = h - ((v - min) / range) * (h - 2) - 1;
                return `${x.toFixed(1)},${y.toFixed(1)}`;
            }).join(' ');
            const endX = w;
            const endY = h - ((data[data.length-1] - min) / range) * (h - 2) - 1;
            svg.innerHTML = `
                <polyline points="${points}" fill="none" stroke="${color}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/>
                <circle class="v43-sparkline-dot" cx="${endX}" cy="${endY}" r="2.2" fill="${color}" opacity="0.95"/>
            `;
        }

        // ========== Command Palette ==========
        const COMMANDS = [
            { label: 'Refresh Data', icon: '🔄', hint: 'R', category: 'Actions', action: () => { fetchData(); showToastV32('Refreshing...', 'default', 1500); } },
            { label: 'Toggle Focus Mode', icon: '🎯', hint: 'F', category: 'Actions', action: () => { document.body.classList.toggle('focus-mode'); showToastV32('Focus mode toggled'); } },
            { label: 'Set Mood: Idle', icon: '😺', hint: '1', category: 'Moods', action: () => setMood('idle') },
            { label: 'Set Mood: Working', icon: '⚡', hint: '2', category: 'Moods', action: () => setMood('working') },
            { label: 'Set Mood: Sleeping', icon: '😴', hint: '3', category: 'Moods', action: () => setMood('sleeping') },
            { label: 'Set Mood: Excited', icon: '🎉', hint: '4', category: 'Moods', action: () => setMood('excited') },
            { label: 'Set Mood: Thinking', icon: '🤔', hint: '5', category: 'Moods', action: () => setMood('thinking') },
            { label: 'View Skills Distribution', icon: '📊', hint: 'S', category: 'Skills', action: () => showToastV32('Skills panel active') },
        ];
        let cmdSelectedIndex = 0, cmdFiltered = [...COMMANDS];

        function initCommandPalette() {
            document.addEventListener('keydown', (e) => {
                if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openCommandPalette(); }
                if (e.key === 'Escape') closeCommandPalette();
            });
        }

        function openCommandPalette() {
            const overlay = $('cmdOverlay');
            const input = $('cmdInput');
            if (!overlay || !input) return;
            overlay.classList.add('open');
            input.value = '';
            cmdFiltered = [...COMMANDS];
            cmdSelectedIndex = 0;
            renderCmdResults();
            setTimeout(() => input.focus(), 50);
        }

        function closeCommandPalette() {
            $('cmdOverlay')?.classList.remove('open');
        }

        function filterCommands() {
            const q = ($('cmdInput')?.value || '').toLowerCase().trim();
            if (!q) { cmdFiltered = [...COMMANDS]; cmdSelectedIndex = 0; renderCmdResults(); return; }
            
            // v37.0: Fuzzy search with scoring
            const scored = COMMANDS.map(cmd => {
                const label = cmd.label.toLowerCase();
                const category = cmd.category.toLowerCase();
                const hint = (cmd.hint || '').toLowerCase();
                
                let score = 0;
                // Exact match
                if (label === q || category === q) score = 100;
                // Starts with
                else if (label.startsWith(q) || category.startsWith(q)) score = 80;
                // Contains
                else if (label.includes(q) || category.includes(q)) score = 60;
                // Hint match
                else if (hint === q) score = 70;
                // Fuzzy: each character must exist in order
                else {
                    let qi = 0;
                    for (let i = 0; i < label.length && qi < q.length; i++) {
                        if (label[i] === q[qi]) { qi++; score += 5; }
                    }
                    if (qi < q.length) score = 0; // Not all chars found
                    else score = Math.min(score, 50); // Fuzzy match capped at 50
                }
                
                return { cmd, score };
            }).filter(s => s.score > 0);
            
            // Sort by score descending
            scored.sort((a, b) => b.score - a.score);
            cmdFiltered = scored.map(s => s.cmd);
            cmdSelectedIndex = 0;
            renderCmdResults();
        }

        function navigateCmd(dir) {
            cmdSelectedIndex = Math.max(0, Math.min(cmdFiltered.length - 1, cmdSelectedIndex + dir));
            renderCmdResults();
            document.querySelectorAll('.cmd-item')[cmdSelectedIndex]?.scrollIntoView({ block: 'nearest' });
        }

        function executeSelectedCmd() {
            const cmd = cmdFiltered[cmdSelectedIndex];
            if (cmd) { closeCommandPalette(); cmd.action(); }
        }

        function renderCmdResults() {
            const container = $('cmdResults');
            if (!container) return;
            if (cmdFiltered.length === 0) { container.innerHTML = '<div class="cmd-empty">No commands found</div>'; return; }
            const groups = {};
            cmdFiltered.forEach(c => { if (!groups[c.category]) groups[c.category] = []; groups[c.category].push(c); });
            let html = '';
            Object.entries(groups).forEach(([category, cmds]) => {
                html += `<div class="cmd-group-label">${category}</div>`;
                cmds.forEach((cmd, i) => {
                    const globalIdx = cmdFiltered.indexOf(cmd);
                    html += `<div class="cmd-item${globalIdx === cmdSelectedIndex ? ' selected' : ''}" onclick="closeCommandPalette(); COMMANDS[${COMMANDS.indexOf(cmd)}].action()">
                        <span class="cmd-item-icon">${cmd.icon}</span>
                        <span class="cmd-item-label">${cmd.label}</span>
                        <span class="cmd-item-hint">${cmd.hint}</span>
                    </div>`;
                });
            });
            container.innerHTML = html;
        }

        // ========== Scroll Progress ==========
        function initScrollProgress() {
            const bar = $('scrollProgress');
            if (!bar) return;
            window.addEventListener('scroll', () => {
                const scrollTop = window.scrollY;
                const docHeight = document.documentElement.scrollHeight - window.innerHeight;
                bar.style.width = (docHeight > 0 ? (scrollTop / docHeight) * 100 : 0) + '%';
            }, { passive: true });
        }

        // ========== Data Route Map ==========
        function initDataRouteMap() {}

        function updateDataRouteMap(srcStatus = 'ok') {
            const src = $('routeSrc');
            if (src) src.className = 'route-node ' + (srcStatus === 'ok' ? '' : srcStatus);
        }

        // ========== v40.0: Enhanced Data Freshness System ==========
        function updateV39DataFreshness() {
            const freshnessRing = $('v39DataFreshnessRing');
            if (!freshnessRing) return;

            freshnessRing.classList.remove('fresh', 'stale', 'critical');

            if (!state.lastSuccessfulFetch) {
                freshnessRing.classList.add('critical');
                return;
            }

            const age = (Date.now() - state.lastSuccessfulFetch) / 1000;

            if (age < 10) {
                freshnessRing.classList.add('fresh');
            } else if (age < 60) {
                freshnessRing.classList.add('stale');
            } else {
                freshnessRing.classList.add('critical');
            }
        }

        // v40.0: Connection Quality Indicator
        function updateV39ConnectionQuality() {
            const qualityEl = $('v39ConnectionQuality');
            if (!qualityEl) return;

            qualityEl.classList.remove('excellent', 'good', 'poor', 'critical');

            if (!state.isOnline) {
                qualityEl.classList.add('critical');
                return;
            }

            const errors = state.consecutiveErrors || 0;
            if (errors === 0) {
                qualityEl.classList.add('excellent');
            } else if (errors <= 2) {
                qualityEl.classList.add('good');
            } else if (errors <= 5) {
                qualityEl.classList.add('poor');
            } else {
                qualityEl.classList.add('critical');
            }
        }

        // v40.0: AI Processing State
        function setV39AIProcessing(active) {
            const aura = $('v39AIProcessingAura');
            if (!aura) return;

            if (active) {
                aura.classList.add('active');
            } else {
                aura.classList.remove('active');
            }
        }

        // v40.0: Trigger Data Sync Wave
        function triggerV39DataSyncWave() {
            const wave = $('v39SyncWave');
            if (!wave) return;

            wave.classList.remove('active');
            void wave.offsetWidth;
            wave.classList.add('active');

            setTimeout(() => {
                wave.classList.remove('active');
            }, 1000);
        }

        // v40.0: Enhanced Recovery Mode
        function enterV39RecoveryMode() {
            const badge = document.querySelector('.recovery-mode');
            if (!badge) {
                const recoveryBadge = document.createElement('div');
                recoveryBadge.className = 'recovery-mode';
                recoveryBadge.id = 'v39RecoveryBadge';
                recoveryBadge.textContent = '⚡ Recovery Mode';
                document.body.appendChild(recoveryBadge);
            }
            document.body.classList.add('v39-recovery');
        }

        // v40.0: Ambient Data Particles
        function createV39AmbientParticle() {
            if (Math.random() > 0.3) return;

            const particle = document.createElement('div');
            particle.className = 'v39-ambient-particle';

            const colors = ['#ffc864', '#00d4ff', '#5cdb95', '#a855f7', '#ec4899'];
            particle.style.background = colors[Math.floor(Math.random() * colors.length)];
            particle.style.left = Math.random() * 100 + 'vw';
            particle.style.top = Math.random() * 100 + 'vh';
            particle.style.animationDuration = (3 + Math.random() * 4) + 's';

            document.body.appendChild(particle);

            setTimeout(() => {
                particle.remove();
            }, 7000);
        }

        // ========== v47.0: Magnetic Hover Effect ==========
        function initV47MagneticHover() {
            const cards = document.querySelectorAll('.stat-card, .action-btn, .mood-btn');
            cards.forEach(el => {
                el.addEventListener('mousemove', (e) => {
                    const rect = el.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    const mx = (x - centerX) / centerX * 4;
                    const my = (y - centerY) / centerY * 4;
                    el.style.setProperty('--mx', `${mx}px`);
                    el.style.setProperty('--my', `${my}px`);
                });
                el.addEventListener('mouseleave', () => {
                    el.style.setProperty('--mx', '0px');
                    el.style.setProperty('--my', '0px');
                });
            });
        }

        // ========== v47.0: Context Menu System ==========
        let activeContextMenu = null;
        function initV47ContextMenu() {
            document.addEventListener('contextmenu', (e) => {
                const statCard = e.target.closest('.stat-card');
                if (statCard) {
                    e.preventDefault();
                    showV47ContextMenu(e.clientX, e.clientY, statCard);
                }
            });
            document.addEventListener('click', () => {
                if (activeContextMenu) {
                    activeContextMenu.remove();
                    activeContextMenu = null;
                }
            });
        }
        function showV47ContextMenu(x, y, card) {
            if (activeContextMenu) activeContextMenu.remove();
            const stat = card.dataset.stat;
            const value = card.querySelector('.stat-value')?.textContent || '--';
            const menu = document.createElement('div');
            menu.className = 'context-menu';
            menu.innerHTML = `
                <div class="context-menu-item" onclick="copyStat('${stat}'); this.closest('.context-menu').remove();">
                    📋 Copy Value (${value})
                </div>
                <div class="context-menu-item" onclick="navigator.share?.({title: 'MoShang Stat', text: '${stat}: ${value}'}) || copyStat('${stat}'); this.closest('.context-menu').remove();">
                    🔗 Share
                </div>
                <div class="context-menu-divider"></div>
                <div class="context-menu-item" onclick="this.closest('.context-menu').remove();">
                    ❌ Close
                </div>
            `;
            menu.style.left = `${Math.min(x, window.innerWidth - 200)}px`;
            menu.style.top = `${Math.min(y, window.innerHeight - 150)}px`;
            document.body.appendChild(menu);
            activeContextMenu = menu;
        }

        // ========== v47.0: Ripple v2 Effect ==========
        function initV47Ripple() {
            const rippleEls = document.querySelectorAll('.action-btn, .mood-btn, .fab-orb, .stat-card');
            rippleEls.forEach(el => {
                el.classList.add('ripple-v2');
                el.addEventListener('click', (e) => {
                    const rect = el.getBoundingClientRect();
                    const circle = document.createElement('span');
                    circle.className = 'ripple-circle';
                    circle.style.left = `${e.clientX - rect.left}px`;
                    circle.style.top = `${e.clientY - rect.top}px`;
                    circle.style.width = circle.style.height = '20px';
                    el.appendChild(circle);
                    setTimeout(() => circle.remove(), 600);
                });
            });
        }

        // ========== v47.0: Momentum Scroll Enhancement ==========
        function initV47MomentumScroll() {
            // Enhance scroll with smooth momentum on touch devices
            let touchStartY = 0;
            let touchStartX = 0;
            document.addEventListener('touchstart', (e) => {
                touchStartY = e.touches[0].clientY;
                touchStartX = e.touches[0].clientX;
            }, { passive: true });
        }

