        // v48.1: Neural pulse animation trigger
        function triggerNeuralPulse(elementId) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.classList.add('neural-pulse');
            setTimeout(() => el.classList.remove('neural-pulse'), 2000);
        }
        
        // ========== v48.0: Data Reliability System ==========

        // v48.0: Initialize reliability ring with animated SVG
        function initV48ReliabilityRing() {
            const ringContainers = document.querySelectorAll('.v48-reliability-ring');
            ringContainers.forEach(container => {
                const value = parseInt(container.dataset.value) || 100;
                const circumference = 2 * Math.PI * 18; // radius = 18
                const offset = circumference - (value / 100) * circumference;
                const svg = container.querySelector('svg');
                const fill = svg.querySelector('.ring-fill');
                fill.style.strokeDasharray = circumference;
                fill.style.strokeDashoffset = offset;

                // Set class based on value
                container.classList.remove('high', 'medium', 'low');
                if (value >= 80) container.classList.add('high');
                else if (value >= 50) container.classList.add('medium');
                else container.classList.add('low');

                const valueEl = container.querySelector('.ring-value');
                if (valueEl) valueEl.textContent = value;
            });
        }

        // v48.0: Update data source tag with actual source
        function updateV48SourceTag(elementId, source, label) {
            const el = document.getElementById(elementId);
            if (!el) return;
            const icons = { api: '🌐', cache: '💾', local: '📁' };
            el.className = `v48-source-tag ${source}`;
            el.innerHTML = `<span class="source-icon">${icons[source] || '📊'}</span>${label}`;
            el.title = `Data source: ${source}`;
        }

        // v48.0: Flash value change animation
        function triggerV48ValueFlash(elementId) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.classList.remove('v48-value-flash');
            el.offsetHeight; // Reflow
            el.classList.add('v48-value-flash');
            setTimeout(() => el.classList.remove('v48-value-flash'), 500);
        }

        // v48.0: Show keyboard shortcuts panel
        let v48KbdTimeout = null;
        function showV48KeyboardHints() {
            const panel = document.querySelector('.v48-kbd-hint');
            if (!panel) return;
            panel.classList.add('visible');
            clearTimeout(v48KbdTimeout);
            v48KbdTimeout = setTimeout(() => panel.classList.remove('visible'), 4000);
        }

        // v48.0: Initialize keyboard shortcut detection
        function initV48KeyboardHints() {
            document.addEventListener('keydown', (e) => {
                if (e.key === '?' || (e.shiftKey && e.key === '/')) {
                    showV48KeyboardHints();
                }
                if (e.key === 'Escape') {
                    const panel = document.querySelector('.v48-kbd-hint');
                    if (panel) panel.classList.remove('visible');
                }
            });
        }

        // v48.0: Update memory usage bar
        function updateV48MemoryBar(elementId, percentage) {
            const el = document.getElementById(elementId);
            if (!el) return;
            const fill = el.querySelector('.v48-memory-fill');
            if (fill) {
                fill.style.width = `${Math.min(100, percentage)}%`;
                if (percentage > 85) fill.style.background = 'linear-gradient(90deg, var(--warning), var(--danger))';
                else if (percentage > 60) fill.style.background = 'linear-gradient(90deg, var(--warning), var(--accent))';
                else fill.style.background = 'linear-gradient(90deg, var(--success), var(--accent))';
            }
        }

