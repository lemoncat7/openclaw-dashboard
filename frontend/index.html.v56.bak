        // v48.1: Initialize Liquid Glass effects
        function initV48LiquidGlass() {
            const liquidElements = document.querySelectorAll('.liquid-glass');
            liquidElements.forEach(el => {
                el.addEventListener('mouseenter', () => {
                    el.style.setProperty('--glow-angle', '0deg');
                });
            });
        }
        
        // v48.1: Smart Status Indicator Update
        function updateV48SmartIndicator(elementId, status) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.classList.remove('online', 'away', 'busy');
            el.classList.add(status);
            const labels = { online: '在线', away: '离开', busy: '忙碌' };
            el.textContent = labels[status] || status;
        }
        
        // v48.1: Apply Holographic Shimmer to cards
        function applyHoloShimmerV2(selector) {
            document.querySelectorAll(selector).forEach(el => {
                el.classList.add('holo-shimmer-v2');
            });
        }
        
