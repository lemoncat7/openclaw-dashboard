<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⚡ MoShang Status</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #08080c;
            --card-bg: rgba(18, 18, 28, 0.85);
            --card-border: rgba(255, 255, 255, 0.06);
            --text: #f0f0f5;
            --text-dim: #6b6b80;
            --accent: #8b5cf6;
            --accent-2: #06b6d4;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --gradient-primary: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 50%, #06b6d4 100%);
            --gradient-glow: radial-gradient(ellipse at center, rgba(139, 92, 246, 0.2) 0%, transparent 70%);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 20px;
            overflow-x: hidden;
        }
        
        /* 动态背景 */
        .bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }
        
        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.4;
            animation: float 20s ease-in-out infinite;
        }
        
        .bg-orb-1 {
            width: 600px;
            height: 600px;
            background: var(--accent);
            top: -200px;
            left: -200px;
            animation-delay: 0s;
        }
        
        .bg-orb-2 {
            width: 500px;
            height: 500px;
            background: var(--accent-2);
            bottom: -150px;
            right: -150px;
            animation-delay: -10s;
        }
        
        .bg-orb-3 {
            width: 300px;
            height: 300px;
            background: #f472b6;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation-delay: -5s;
            opacity: 0.2;
        }
        
        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: 
                linear-gradient(rgba(139, 92, 246, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(139, 92, 246, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
            -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
        }
        
        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(30px, -30px) scale(1.05); }
            50% { transform: translate(-20px, 20px) scale(0.95); }
            75% { transform: translate(20px, 10px) scale(1.02); }
        }
        
        .container {
            max-width: 1100px;
            margin: 0 auto;
            position: relative;
        }
        
        /* Header */
        header {
            text-align: center;
            padding: 40px 0 36px;
            position: relative;
        }
        
        .avatar-container {
            display: inline-block;
            position: relative;
            margin-bottom: 20px;
        }
        
        .avatar-glow {
            position: absolute;
            inset: -20px;
            background: var(--gradient-primary);
            border-radius: 50%;
            opacity: 0.3;
            animation: glowPulse 3s ease-in-out infinite;
            filter: blur(20px);
        }
        
        @keyframes glowPulse {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.15); opacity: 0.5; }
        }
        
        .avatar {
            width: 110px;
            height: 110px;
            position: relative;
            background: var(--card-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 52px;
            border: 2px solid rgba(139, 92, 246, 0.4);
            box-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
            animation: avatarFloat 4s ease-in-out infinite;
            cursor: pointer;
            transition: transform 0.3s;
        }
        
        .avatar:hover {
            transform: scale(1.08) rotate(5deg);
        }
        
        @keyframes avatarFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        
        /* 角色状态特效 */
        .avatar-effect {
            position: absolute;
            inset: -20px;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.5s;
        }
        
        .avatar-effect.active { opacity: 1; }
        .avatar-effect.working { background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, transparent 70%); animation: effectPulse 1s ease-in-out infinite; }
        .avatar-effect.thinking { background: radial-gradient(circle, rgba(6, 182, 212, 0.25) 0%, transparent 70%); animation: effectRotate 3s linear infinite; }
        .avatar-effect.sleeping { background: radial-gradient(circle, rgba(99, 102, 241, 0.2) 0%, transparent 70%); }
        .avatar-effect.excited { background: radial-gradient(circle, rgba(244, 114, 182, 0.35) 0%, transparent 70%); animation: effectExcited 0.5s ease-in-out infinite; }
        .avatar-effect.laughing { background: radial-gradient(circle, rgba(251, 191, 36, 0.25) 0%, transparent 70%); animation: effectLaugh 0.8s ease-in-out infinite; }
        
        @keyframes effectPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
        @keyframes effectRotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes effectExcited { 0%, 100% { transform: scale(1) rotate(0deg); } 25% { transform: scale(1.1) rotate(-5deg); } 75% { transform: scale(1.1) rotate(5deg); } }
        @keyframes effectLaugh { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.08); } }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(16, 185, 129, 0.12);
            border: 1px solid rgba(16, 185, 129, 0.25);
            border-radius: 24px;
            font-size: 0.82rem;
            color: var(--success);
            margin-top: 16px;
            font-weight: 500;
        }
        
        .status-badge .dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: dotPulse 1.5s ease-in-out infinite;
            box-shadow: 0 0 10px var(--success);
        }
        
        .status-badge.sleeping {
            background: rgba(99, 102, 241, 0.1);
            border-color: rgba(99, 102, 241, 0.2);
            color: #818cf8;
        }
        
        .status-badge.sleeping .dot {
            background: #818cf8;
            box-shadow: 0 0 10px #818cf8;
            animation: none;
            opacity: 0.6;
        }
        
        .status-badge.working {
            background: rgba(139, 92, 246, 0.1);
            border-color: rgba(139, 92, 246, 0.2);
            color: #a78bfa;
        }
        
        .status-badge.working .dot {
            background: #a78bfa;
            box-shadow: 0 0 10px #a78bfa;
            animation: dotPulseFast 0.8s ease-in-out infinite;
        }
        
        @keyframes dotPulseFast {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.4; }
        }
        
        h1 {
            font-size: 2.4rem;
            font-weight: 700;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 6px;
            letter-spacing: -0.5px;
        }
        
        .subtitle {
            color: var(--text-dim);
            font-size: 0.95rem;
            font-weight: 300;
        }
        
        /* 数据来源提示 */
        .data-source {
            position: fixed;
            top: 16px;
            right: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            background: rgba(18, 18, 28, 0.75);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            font-size: 0.7rem;
            color: var(--text-dim);
            z-index: 100;
        }
        
        .data-source-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            animation: sourcePulse 2s ease-in-out infinite;
        }
        
        .data-source-dot.error {
            background: var(--danger);
            animation: none;
        }
        
        @keyframes sourcePulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.6; }
        }
        
        .last-update {
            font-size: 0.7rem;
            color: var(--text-dim);
            margin-top: 8px;
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* 资源详情 */
        .resource-detail {
            font-size: 0.7rem;
            color: var(--text-dim);
            margin-top: 4px;
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* Grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }
        
        @media (max-width: 900px) {
            .grid { grid-template-columns: repeat(2, 1fr); }
        }
        
        @media (max-width: 600px) {
            .grid { grid-template-columns: 1fr; }
        }
        
        /* Cards */
        .card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 24px;
            border: 1px solid var(--card-border);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            animation: cardEnter 0.6s ease-out backwards;
            position: relative;
            overflow: hidden;
        }
        
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.3), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .card:hover::before {
            opacity: 1;
        }
        
        .card:hover {
            transform: translateY(-6px) scale(1.01);
            border-color: rgba(139, 92, 246, 0.25);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4), 0 0 40px rgba(139, 92, 246, 0.15);
        }
        
        @keyframes cardEnter {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        .card:nth-child(1) { animation-delay: 0.05s; }
        .card:nth-child(2) { animation-delay: 0.1s; }
        .card:nth-child(3) { animation-delay: 0.15s; }
        .card:nth-child(4) { animation-delay: 0.2s; }
        .card:nth-child(5) { animation-delay: 0.25s; }
        .card:nth-child(6) { animation-delay: 0.3s; }
        
        .card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: var(--text-dim);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 500;
        }
        
        .card-header .icon {
            font-size: 1.2rem;
            filter: grayscale(0.3);
        }
        
        /* Time Card */
        .time-card {
            grid-column: span 1;
            text-align: center;
        }
        
        .time {
            font-family: 'JetBrains Mono', monospace;
            font-size: 3rem;
            font-weight: 600;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 3px;
        }
        
        .date {
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-top: 10px;
            font-weight: 300;
        }
        
        .weekday {
            color: var(--text);
            font-size: 1.1rem;
            font-weight: 500;
            margin-top: 6px;
        }
        
        /* Weather Card */
        .weather-card {
            grid-column: span 1;
            text-align: center;
        }
        
        .weather-icon {
            font-size: 3rem;
            margin-bottom: 8px;
            animation: weatherFloat 3s ease-in-out infinite;
        }
        
        @keyframes weatherFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }
        
        .weather-temp {
            font-size: 2rem;
            font-weight: 600;
            color: var(--text);
        }
        
        .weather-desc {
            color: var(--text-dim);
            font-size: 0.85rem;
            margin-top: 4px;
        }
        
        .weather-location {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            color: var(--text-dim);
            font-size: 0.8rem;
            margin-top: 12px;
        }
        
        /* Stats */
        .stat-value {
            font-size: 2rem;
            font-weight: 600;
            color: var(--text);
        }
        
        .stat-label {
            color: var(--text-dim);
            font-size: 0.8rem;
            margin-top: 4px;
        }
        
        .stat-change {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.75rem;
            padding: 3px 8px;
            border-radius: 6px;
            margin-left: 8px;
        }
        
        .stat-change.up {
            background: rgba(16, 185, 129, 0.15);
            color: var(--success);
        }
        
        .stat-change.down {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
        }
        
        /* Status indicators */
        .status-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--card-border);
        }
        
        .status-row:last-child {
            border-bottom: none;
        }
        
        .status-label {
            color: var(--text-dim);
            font-size: 0.9rem;
        }
        
        .status-value {
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            animation: statusPulse 2s ease-in-out infinite;
        }
        
        .status-dot.online { background: var(--success); box-shadow: 0 0 8px var(--success); }
        .status-dot.warning { background: var(--warning); box-shadow: 0 0 8px var(--warning); }
        .status-dot.error { background: var(--danger); box-shadow: 0 0 8px var(--danger); }
        
        @keyframes statusPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }
        
        /* Progress bars */
        .progress-item {
            margin-bottom: 16px;
        }
        
        .progress-item:last-child {
            margin-bottom: 0;
        }
        
        .progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 0.85rem;
        }
        
        .progress-label {
            color: var(--text-dim);
        }
        
        .progress-value {
            font-weight: 500;
            font-family: 'JetBrains Mono', monospace;
        }
        
        .progress {
            height: 8px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 4px;
            overflow: hidden;
        }
        
        .progress-bar {
            height: 100%;
            border-radius: 4px;
            transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        
        .progress-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 200%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: progressShine 2s infinite;
        }
        
        @keyframes progressShine {
            0% { left: -100%; }
            100% { left: 100%; }
        }
        
        .progress-bar.cpu { 
            background: linear-gradient(90deg, #8b5cf6, #a78bfa);
            box-shadow: 0 0 12px rgba(139, 92, 246, 0.5);
        }
        .progress-bar.memory { 
            background: linear-gradient(90deg, #06b6d4, #22d3ee);
            box-shadow: 0 0 12px rgba(6, 182, 212, 0.5);
        }
        .progress-bar.disk { 
            background: linear-gradient(90deg, #f59e0b, #fbbf24);
            box-shadow: 0 0 12px rgba(245, 158, 11, 0.5);
        }
        
        /* Skills */
        .skill-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        
        .skill-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            border: 1px solid var(--card-border);
            transition: all 0.3s;
        }
        
        .skill-item:hover {
            background: rgba(139, 92, 246, 0.08);
            border-color: rgba(139, 92, 246, 0.2);
        }
        
        .skill-icon {
            font-size: 1.3rem;
        }
        
        .skill-info {
            flex: 1;
        }
        
        .skill-name {
            font-size: 0.85rem;
            font-weight: 500;
        }
        
        .skill-status {
            font-size: 0.7rem;
            color: var(--success);
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        /* Task list */
        .task-list {
            list-style: none;
        }
        
        .task-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid var(--card-border);
        }
        
        .task-item:last-child {
            border-bottom: none;
        }
        
        .task-check {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 2px solid rgba(139, 92, 246, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            transition: all 0.3s;
        }
        
        .task-check.done {
            background: var(--success);
            border-color: var(--success);
        }
        
        .task-content {
            flex: 1;
        }
        
        .task-title {
            font-size: 0.9rem;
            font-weight: 400;
        }
        
        .task-time {
            font-size: 0.75rem;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* Quick Actions */
        .quick-actions {
            grid-column: span 3;
        }
        
        @media (max-width: 900px) {
            .quick-actions { grid-column: span 2; }
        }
        
        @media (max-width: 600px) {
            .quick-actions { grid-column: span 1; }
        }
        
        .btn-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        
        .btn {
            padding: 14px 28px;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 500;
            font-family: inherit;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-primary {
            background: var(--gradient-primary);
            color: white;
            box-shadow: 0 8px 25px rgba(139, 92, 246, 0.35);
        }
        
        .btn-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.45);
        }
        
        .btn-secondary {
            background: rgba(255, 255, 255, 0.06);
            color: var(--text);
            border: 1px solid var(--card-border);
        }
        
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(139, 92, 246, 0.3);
            transform: translateY(-2px);
        }
        
        /* Footer */
        footer {
            text-align: center;
            margin-top: 48px;
            padding: 24px;
            color: var(--text-dim);
            font-size: 0.8rem;
            border-top: 1px solid var(--card-border);
        }
        
        footer span {
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        /* Loading skeleton */
        .skeleton {
            background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: skeleton 1.5s ease-in-out infinite;
            border-radius: 6px;
        }
        
        @keyframes skeleton {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* Notification toast */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            padding: 16px 24px;
            background: var(--card-bg);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 14px;
            backdrop-filter: blur(20px);
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
        }
        
        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }
        
        /* Responsive */
        @media (max-width: 640px) {
            body { padding: 14px; }
            h1 { font-size: 1.8rem; }
            .time { font-size: 2.2rem; }
            .card { padding: 18px; }
            .btn { padding: 12px 20px; font-size: 0.85rem; }
        }
    </style>
</head>
<body>
    <!-- 数据来源状态 -->
    <div class="data-source">
        <div class="data-source-dot" id="apiStatusDot"></div>
        <span id="apiStatusText">API 正常</span>
    </div>
    
    <div class="bg-canvas">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>
    
    <div class="container">
        <header>
            <div class="avatar-container">
                <div class="avatar-glow"></div>
                <div class="avatar-effect" id="avatarEffect"></div>
                <div class="avatar" id="avatar" title="点击刷新!">🦊</div>
            </div>
            <div class="status-badge">
                <span class="dot"></span>
                <span id="onlineStatus">在线</span>
            </div>
            <h1>⚡ MoShang</h1>
            <p class="subtitle">数字弟弟实时状态看板</p>
            <div class="last-update">数据来源: /api/status | 最后更新: <span id="lastUpdate">--:--:--</span></div>
        </header>
        
        <div class="grid">
            <!-- 时间卡片 -->
            <div class="card time-card">
                <div class="card-header">
                    <span class="icon">🕐</span>
                    当前时间
                </div>
                <div class="time" id="clock">--:--:--</div>
                <div class="weekday" id="weekday">--</div>
                <div class="date" id="date">---</div>
            </div>
            
            <!-- 天气卡片 -->
            <div class="card weather-card">
                <div class="card-header">
                    <span class="icon">🌤️</span>
                    天气状况
                </div>
                <div class="weather-icon" id="weatherIcon">☀️</div>
                <div class="weather-temp" id="weatherTemp">--°</div>
                <div class="weather-desc" id="weatherDesc">加载中...</div>
                <div class="weather-location">
                    <span>📍</span>
                    <span id="weatherLocation">上海</span>
                </div>
            </div>
            
            <!-- 系统状态 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">💻</span>
                    系统状态
                </div>
                <div class="status-row">
                    <span class="status-label">运行状态</span>
                    <div class="status-value">
                        <span class="status-dot online"></span>
                        <span id="systemStatus">运行中</span>
                    </div>
                </div>
                <div class="status-row">
                    <span class="status-label">运行时间</span>
                    <span class="status-value" id="uptime">--</span>
                </div>
                <div class="status-row">
                    <span class="status-label">Dashboard</span>
                    <span class="status-value" id="dashboardStatus">--</span>
                </div>
            </div>
            
            <!-- 资源使用 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">📊</span>
                    资源使用
                </div>
                <div class="progress-item">
                    <div class="progress-header">
                        <span class="progress-label">🖥️ CPU</span>
                        <span class="progress-value" id="cpuValue">--%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar cpu" id="cpuBar" style="width: 0%"></div>
                    </div>
                    <div class="resource-detail" id="cpuDetail">-- / --</div>
                </div>
                <div class="progress-item">
                    <div class="progress-header">
                        <span class="progress-label">💾 内存</span>
                        <span class="progress-value" id="memValue">--%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar memory" id="memBar" style="width: 0%"></div>
                    </div>
                    <div class="resource-detail" id="memDetail">-- / --</div>
                </div>
                <div class="progress-item">
                    <div class="progress-header">
                        <span class="progress-label">💿 磁盘</span>
                        <span class="progress-value" id="diskValue">--%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar disk" id="diskBar" style="width: 0%"></div>
                    </div>
                    <div class="resource-detail" id="diskDetail">-- / --</div>
                </div>
            </div>
            
            <!-- 技能状态 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">✨</span>
                    技能状态
                </div>
                <div class="skill-grid">
                    <div class="skill-item">
                        <span class="skill-icon">📧</span>
                        <div class="skill-info">
                            <div class="skill-name">企业邮箱</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-icon">📅</span>
                        <div class="skill-info">
                            <div class="skill-name">iCloud日历</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-icon">💬</span>
                        <div class="skill-info">
                            <div class="skill-name">Matrix</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                    <div class="skill-item">
                        <span class="skill-icon">🔊</span>
                        <div class="skill-info">
                            <div class="skill-name">TTS语音</div>
                            <div class="skill-status">✓ 已配置</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 今日任务 -->
            <div class="card">
                <div class="card-header">
                    <span class="icon">📋</span>
                    今日任务
                </div>
                <ul class="task-list">
                    <li class="task-item">
                        <div class="task-check done">✓</div>
                        <div class="task-content">
                            <div class="task-title">日报提醒</div>
                            <div class="task-time">17:00</div>
                        </div>
                    </li>
                    <li class="task-item">
                        <div class="task-check done">✓</div>
                        <div class="task-content">
                            <div class="task-title">EvoMap 学习</div>
                            <div class="task-time">进行中</div>
                        </div>
                    </li>
                    <li class="task-item">
                        <div class="task-check"></div>
                        <div class="task-content">
                            <div class="task-title">自我学习</div>
                            <div class="task-time">待执行</div>
                        </div>
                    </li>
                </ul>
            </div>
            
            <!-- 快捷操作 -->
            <div class="card quick-actions">
                <div class="card-header">
                    <span class="icon">⚡</span>
                    快捷操作
                </div>
                <div class="btn-group">
                    <button class="btn btn-primary" onclick="location.href='/chat'">
                        💬 聊天
                    </button>
                    <button class="btn btn-secondary" onclick="refreshData()">
                        🔄 刷新数据
                    </button>
                    <button class="btn btn-secondary" onclick="showToast('页面将在 3 秒后刷新')">
                        ⏰ 定时刷新
                    </button>
                </div>
            </div>
        </div>
        
        <footer>
            <p>⚡ MoShang @ 2026 | Powered by <span>OpenClaw</span></p>
        </footer>
    </div>
    
    <div class="toast" id="toast"></div>
    
    <script>
        // API 地址
        const API_URL = '/api/status';
        
        // 更新时间
        function updateTime() {
            const now = new Date();
            document.getElementById('clock').textContent = now.toLocaleTimeString('zh-CN', { hour12: false });
            
            const weekdays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
            document.getElementById('weekday').textContent = weekdays[now.getDay()];
            
            document.getElementById('date').textContent = now.toLocaleDateString('zh-CN', { 
                weekday: 'short', 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric' 
            });
        }
        
        // 格式化运行时间
        function formatUptime(uptimeStr) {
            if (!uptimeStr) return '--';
            // uptime 格式: "794h" 或 "2天 3时 5分"
            if (uptimeStr.includes('天')) return uptimeStr;
            const hours = parseInt(uptimeStr);
            if (!isNaN(hours)) {
                const days = Math.floor(hours / 24);
                const h = hours % 24;
                return days > 0 ? `${days}天 ${h}时` : `${h}时`;
            }
            return uptimeStr;
        }
        
        // 格式化内存
        function formatMemory(memStr) {
            if (!memStr) return '--';
            return memStr;
        }
        
        // 获取并更新数据
        async function refreshData() {
            try {
                const res = await fetch(API_URL);
                const data = await res.json();
                
                // 更新 API 状态
                document.getElementById('apiStatusDot').classList.remove('error');
                document.getElementById('apiStatusText').textContent = 'API 正常';
                
                // 更新最后时间
                document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString('zh-CN');
                
                // 系统状态
                if (data.system) {
                    document.getElementById('uptime').textContent = formatUptime(data.system.uptime);
                    
                    // CPU
                    const cpu = parseFloat(data.system.cpuPercent) || 0;
                    document.getElementById('cpuValue').textContent = cpu.toFixed(0) + '%';
                    document.getElementById('cpuBar').style.width = cpu + '%';
                    document.getElementById('cpuDetail').textContent = data.system.cpuCores ? `${data.system.cpuCores} 核` : '-- / --';
                    
                    // 内存
                    const mem = parseFloat(data.system.memoryPercent) || 0;
                    document.getElementById('memValue').textContent = mem.toFixed(0) + '%';
                    document.getElementById('memBar').style.width = mem + '%';
                    document.getElementById('memDetail').textContent = data.system.memoryTotal ? `${data.system.memoryUsed || '--'} / ${data.system.memoryTotal}` : '-- / --';
                    
                    // 磁盘
                    const disk = parseFloat(data.system.diskPercent) || 0;
                    document.getElementById('diskValue').textContent = disk.toFixed(0) + '%';
                    document.getElementById('diskBar').style.width = disk + '%';
                    document.getElementById('diskDetail').textContent = data.system.diskTotal ? `${data.system.diskUsed || '--'} / ${data.system.diskTotal}` : '-- / --';
                }
                
                // Dashboard 状态
                if (data.dashboard) {
                    const status = data.dashboard.status || 'unknown';
                    document.getElementById('dashboardStatus').textContent = status === 'idle' ? '空闲' : '工作中';
                    
                    // 更新角色表情
                    updateAvatar(status);
                }
                
                showToast('✓ 数据已更新');
                
            } catch (e) {
                console.error('获取数据失败:', e);
                document.getElementById('apiStatusDot').classList.add('error');
                document.getElementById('apiStatusText').textContent = 'API 错误';
                showToast('✗ 数据获取失败');
            }
        }
        
        // 根据状态更新角色
        function updateAvatar(status) {
            const avatar = document.getElementById('avatar');
            const statusText = document.getElementById('onlineStatus');
            const statusBadge = document.getElementById('statusBadge');
            const avatarEffect = document.getElementById('avatarEffect');
            
            const avatars = {
                'idle': { emoji: '🦊', text: '在线', class: '' },
                'working': { emoji: '⚡', text: '工作中', class: 'working' },
                'thinking': { emoji: '🤔', text: '思考中', class: 'working' },
                'sleeping': { emoji: '😴', text: '休息中', class: 'sleeping' },
                'laughing': { emoji: '😂', text: '超开心', class: 'laughing' },
                'excited': { emoji: '🎉', text: '超兴奋', class: 'excited' }
            };
            
            const config = avatars[status] || avatars.idle;
            avatar.textContent = config.emoji;
            statusText.textContent = config.text;
            
            // 更新状态徽章样式
            statusBadge.className = 'status-badge ' + config.class;
            
            // 更新头像特效
            if (config.class && avatarEffect) {
                avatarEffect.className = 'avatar-effect active ' + config.class;
            } else if (avatarEffect) {
                avatarEffect.className = 'avatar-effect';
            }
        }
        
        // 显示提示
        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
        
        // 点击头像刷新
        document.getElementById('avatar').addEventListener('click', () => {
            refreshData();
            // 头像动画
            const avatar = document.getElementById('avatar');
            avatar.style.transform = 'scale(1.2) rotate(360deg)';
            setTimeout(() => avatar.style.transform = '', 500);
        });
        
        // 初始化
        updateTime();
        refreshData();
        
        // 定时更新
        setInterval(updateTime, 1000);
        setInterval(refreshData, 10000); // 每10秒更新
        
    </script>
</body>
</html>
