        // Show live activity when status changes to working
        const originalNotifyStatusChange = notifyStatusChange;
        notifyStatusChange = function(newStatus) {
            originalNotifyStatusChange(newStatus);

            const statusLabels = {
                idle: 'Standing by',
                working: 'Processing tasks',
                sleeping: 'Resting...',
                excited: 'Very happy!',
                thinking: 'Analyzing...',
                laughing: 'Having fun!',
                error: 'Something went wrong'
            };

            if (newStatus !== 'idle' && newStatus !== lastStatus) {
                showLiveActivity(
                    statusLabels[newStatus] || 'Status changed',
                    '🦊 ' + (document.getElementById('currentTask')?.textContent || '...'),
                    4000
                );
            }
        };

        // Particle System Enhancement
        // ===== v10.1: Enhanced ParticleSystem with Constellation =====
        class ParticleSystem {
            constructor() {
                this.canvas = document.createElement('canvas');
                this.canvas.id = 'particleCanvas';
                this.canvas.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:5;';
                document.body.appendChild(this.canvas);
                this.ctx = this.canvas.getContext('2d');
                this.particles = [];
                this.mousePos = { x: -100, y: -100 };
                this.resize();
                window.addEventListener('resize', () => this.resize());
                document.addEventListener('mousemove', (e) => this.handleMouseMove(e));
                this.constellationColor = '#ffc864';
                this.animate();
            }

            resize() {
                this.canvas.width = window.innerWidth;
                this.canvas.height = window.innerHeight;
            }

            handleMouseMove(e) {
                this.mousePos.x = e.clientX;
                this.mousePos.y = e.clientY;
                if (Math.random() > 0.7) {
                    this.spawnParticle(this.mousePos.x, this.mousePos.y);
                }
            }

            spawnParticle(x, y) {
                const colors = ['#ffc864', '#00d4ff', '#5cdb95', '#ff6b6b', '#a29bfe'];
                this.particles.push({
                    x, y,
                    vx: (Math.random() - 0.5) * 3,
                    vy: (Math.random() - 0.5) * 3,
                    life: 1,
                    decay: 0.01 + Math.random() * 0.02,
                    size: 2 + Math.random() * 3,
                    color: colors[Math.floor(Math.random() * colors.length)]
                });
            }

            animate() {
                this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
                
                // Draw constellation lines between nearby particles
                if (!document.body.classList.contains('power-saving')) {
                    for (let i = 0; i < this.particles.length; i++) {
                        for (let j = i + 1; j < this.particles.length; j++) {
                            const p1 = this.particles[i];
                            const p2 = this.particles[j];
                            const dx = p1.x - p2.x;
                            const dy = p1.y - p2.y;
                            const dist = Math.sqrt(dx * dx + dy * dy);
                            if (dist < 100) {
                                const alpha = (1 - dist / 100) * Math.min(p1.life, p2.life) * 0.35;
                                this.ctx.strokeStyle = this.constellationColor;
                                this.ctx.globalAlpha = alpha;
                                this.ctx.lineWidth = 0.8;
                                this.ctx.beginPath();
                                this.ctx.moveTo(p1.x, p1.y);
                                this.ctx.lineTo(p2.x, p2.y);
                                this.ctx.stroke();
                            }
                        }
                    }
                    this.ctx.globalAlpha = 1;
                }
                
                this.particles = this.particles.filter(p => {
                    p.x += p.vx;
                    p.y += p.vy;
                    p.life -= p.decay;
                    if (p.life <= 0) return false;
                    this.ctx.globalAlpha = p.life;
                    this.ctx.fillStyle = p.color;
                    this.ctx.beginPath();
                    this.ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
                    this.ctx.fill();
                    return true;
                });
                this.ctx.globalAlpha = 1;
                requestAnimationFrame(() => this.animate());
            }
            
            setConstellationColor(color) {
                this.constellationColor = color;
            }
        }

        // Initialize particle system (already exists in original, but safe to check)
        if (!document.getElementById('particleCanvas')) {
            new ParticleSystem();
        }

        // Enhanced ripple effect
        document.querySelectorAll('.ripple-container').forEach(el => {
            el.addEventListener('click', (e) => {
                const rect = el.getBoundingClientRect();
                const ripple = document.createElement('div');
                ripple.className = 'ripple-el';
                ripple.style.left = (e.clientX - rect.left) + 'px';
                ripple.style.top = (e.clientY - rect.top) + 'px';
                el.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            });
        });

        // Power saving mode detection
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.body.classList.add('power-saving');
        }

        // v14.0: Show welcome toast after 1 second
        setTimeout(() => {
