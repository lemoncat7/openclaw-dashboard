        .time-display:hover { color: var(--text); }
        .time-display .seconds { font-variant-numeric: tabular-nums; color: var(--accent); opacity: 0.8; transition: opacity 0.3s; }
        .time-display:hover .seconds { opacity: 1; }
        .date-display { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-dim); text-align: center; margin-bottom: 8px; }
