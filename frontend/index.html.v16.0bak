<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="MoShang - Real-time OpenClaw Status Dashboard">
    <meta name="theme-color" content="#08080c">
    <title>MoShang Status</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        /* v12.2: CSS @layer for better architecture */
        @layer reset, base, layout, components, animations, utilities;
        
        @layer reset {
            *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        }
        
        @layer base {
            :root {
            /* v12.1: Modern color system with color-mix() */
            --primary: #ffc864;
            --primary-glow: #ffaa33;
            --primary-dim: rgba(255,200,100,0.3);
            --primary-soft: color-mix(in srgb, var(--primary) 60%, transparent);
            --accent: #00d4ff;
            --accent-glow: #00ffff;
            --accent-dim: rgba(0,212,255,0.3);
            --accent-soft: color-mix(in srgb, var(--accent) 60%, transparent);
            --success: #5cdb95;
            --success-glow: #7fff7f;
            --success-dim: rgba(92,219,149,0.3);
            --success-soft: color-mix(in srgb, var(--success) 60%, transparent);
            --warning: #feca57;
            --danger: #ff6b6b;
            --danger-glow: #ff4444;
            --danger-soft: color-mix(in srgb, var(--danger) 60%, transparent);
            --bg-dark: #08080c;
            --bg-dark-elevated: color-mix(in srgb, var(--bg-dark) 95%, var(--primary) 5%);
            --bg-card: rgba(15,15,25,0.88);
            --bg-card-hover: rgba(18,18,28,0.92);
            --glass: rgba(255,255,255,0.025);
            --glass-border: rgba(255,255,255,0.06);
            --text: #e8e8ec;
            --text-dim: #5a5a6a;
            --text-bright: #ffffff;
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --shadow-soft: 0 4px 24px rgba(0,0,0,0.3);
            --shadow-glow: 0 0 80px -20px;
            --neon-gradient: linear-gradient(135deg, var(--primary), var(--accent));
            --aurora-gradient: linear-gradient(135deg, #ff6b9d, #ffc864, #00d4ff, #5cdb95);
            --cyber-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --glass-shimmer: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0.1) 100%);
            --space-gradient: radial-gradient(ellipse at center, rgba(30,30,60,0.8) 0%, transparent 70%);
            /* Animation timing functions - 2026 physics-based easing */
            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);
            --ease-in-out-circ: cubic-bezier(0.85, 0, 0.15, 1);
            --spring-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
            }
        }
        
        @layer layout {
            body {
            font-family: 'Outfit', -apple-system, sans-serif;
            background: var(--bg-dark);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            position: relative;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            }
        }
        
        @layer components {
            /* Component styles will go here */
        }
        
        @layer animations {
            /* Animation keyframes */
        }
        
        @layer utilities {
            /* Utility classes */
        }
        
        /* Legacy: Keep for compatibility */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #ffc864;
            --primary-glow: #ffaa33;
            --primary-dim: rgba(255,200,100,0.3);
            --accent: #00d4ff;
            --accent-glow: #00ffff;
            --accent-dim: rgba(0,212,255,0.3);
            --success: #5cdb95;
            --success-glow: #7fff7f;
            --success-dim: rgba(92,219,149,0.3);
            --warning: #feca57;
            --danger: #ff6b6b;
            --danger-glow: #ff4444;
            --bg-dark: #08080c;
            --bg-card: rgba(15,15,25,0.88);
            --bg-card-hover: rgba(18,18,28,0.92);
            --glass: rgba(255,255,255,0.025);
            --glass-border: rgba(255,255,255,0.06);
            --text: #e8e8ec;
            --text-dim: #5a5a6a;
            --text-bright: #ffffff;
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --shadow-soft: 0 4px 24px rgba(0,0,0,0.3);
            --shadow-glow: 0 0 80px -20px;
            /* v11.8: 2026 Design System Variables */
            --neon-gradient: linear-gradient(135deg, var(--primary), var(--accent));
            --aurora-gradient: linear-gradient(135deg, #ff6b9d, #ffc864, #00d4ff, #5cdb95);
            --cyber-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --glass-shimmer: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0.1) 100%);
            --space-gradient: radial-gradient(ellipse at center, rgba(30,30,60,0.8) 0%, transparent 70%);
            /* Animation timing functions - 2026 physics-based easing */
            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);
            --ease-in-out-circ: cubic-bezier(0.85, 0, 0.15, 1);
            --spring-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
        
        /* v14.0: 2026 Modern CSS Features */
        
        /* @starting-style support for enter animations */
        @supports (background: paint(something)) {
            .fox-container {
                animation: foxEnter 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
            }
        }
        
        @keyframes foxEnter {
            from {
                opacity: 0;
                transform: scale(0.8) translateY(20px);
            }
            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
        
        /* transition-behavior: allow-discrete for display/opacity transitions */
        .fox-container {
            transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            transition-behavior: allow-discrete;
        }
        
        .fox-container.hidden {
            opacity: 0;
            transform: scale(0.9) translateY(10px);
        }
        
        /* View Transitions API v14.0 */
        @supports (view-transition-name: none) {
            ::view-transition-old(fox-transition),
            ::view-transition-new(fox-transition) {
                animation-duration: 0.4s;
                animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
            }
            
            .fox-canvas-transition {
                view-transition-name: fox-transition;
            }
        }
        
        /* Scroll-driven animations (modern browsers) */
        @supports (animation-timeline: scroll()) {
            .viz-bar-fill {
                animation: fillBar linear both;
                animation-timeline: view();
                animation-range: entry 0% entry 100%;
            }
            
            @keyframes fillBar {
                from { transform: scaleY(0); }
                to { transform: scaleY(1); }
            }
        }
        
        /* content-visibility for performance */
        .stat-card {
            content-visibility: auto;
            contain-intrinsic-size: 0 80px;
        }
        
        /* v15.5: Container Queries for Responsive Design */
        @container (max-width: 400px) {
            .stat-card { padding: 12px !important; font-size: 0.85em; }
            .glass-hud { right: 8px !important; top: 8px !important; gap: 4px !important; }
        }
        @container (max-width: 600px) {
            .health-panel { transform: scale(0.85); transform-origin: top right; }
        }
        
        /* v15.5: Reduced motion support */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
        
        /* v14.0: Enhanced Spatial UI */
        .spatial-layer {
            transform-style: preserve-3d;
            perspective: 1200px;
        }
        
        .spatial-card {
            transform: rotateX(var(--rotate-x, 0deg)) rotateY(var(--rotate-y, 0deg));
            transition: transform 0.15s ease-out;
        }
        
        /* v14.0: Quantum State Animations */
        @keyframes quantumPulse {
            0%, 100% { 
                opacity: 1;
                filter: blur(0px);
                transform: scale(1);
            }
            25% {
                opacity: 0.8;
                filter: blur(1px);
                transform: scale(1.02);
            }
            50% { 
                opacity: 0.6;
                filter: blur(2px);
                transform: scale(0.98);
            }
            75% {
                opacity: 0.8;
                filter: blur(1px);
                transform: scale(1.01);
            }
        }
        
        .quantum-mode .fox-container {
            animation: quantumPulse 2s ease-in-out infinite;
        }
        
        /* v14.0: Neural Link Effect */
        @keyframes neuralPulse {
            0%, 100% { 
                box-shadow: 0 0 20px rgba(0, 212, 255, 0.3), inset 0 0 20px rgba(0, 212, 255, 0.1);
            }
            50% { 
                box-shadow: 0 0 40px rgba(0, 212, 255, 0.5), inset 0 0 40px rgba(0, 212, 255, 0.2);
            }
        }
        
        .neural-active {
            animation: neuralPulse 1.5s ease-in-out infinite;
        }
        
        /* v14.0: Holographic Layer Effect */
        .holo-layer {
            position: relative;
            overflow: hidden;
        }
        
        .holo-layer::before {
            content: '';
            position: absolute;
            inset: -50%;
            background: conic-gradient(
                from 0deg,
                transparent 0deg,
                rgba(0, 212, 255, 0.1) 60deg,
                transparent 120deg,
                rgba(255, 200, 100, 0.1) 180deg,
                transparent 240deg,
                rgba(92, 219, 149, 0.1) 300deg,
                transparent 360deg
            );
            animation: holoRotate 10s linear infinite;
            pointer-events: none;
        }
        
        @keyframes holoRotate {
            to { transform: rotate(360deg); }
        }
        
        /* v14.0: Liquid Metal Effect */
        @keyframes liquidMetal {
            0%, 100% { 
                background-position: 0% 50%;
                filter: hue-rotate(0deg);
            }
            25% {
                background-position: 50% 100%;
                filter: hue-rotate(10deg);
            }
            50% { 
                background-position: 100% 50%;
                filter: hue-rotate(0deg);
            }
            75% {
                background-position: 50% 0%;
                filter: hue-rotate(-10deg);
            }
        }
        
        .liquid-metal {
            background: linear-gradient(135deg, 
                var(--primary) 0%, 
                var(--accent) 25%, 
                var(--success) 50%, 
                var(--accent) 75%, 
                var(--primary) 100%);
            background-size: 400% 400%;
            animation: liquidMetal 5s ease infinite;
        }
        
        /* v14.0: Morphing Shape Animation */
        @keyframes morphShape {
            0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            25% { border-radius: 40% 60% 70% 30% / 30% 70% 40% 60%; }
            50% { border-radius: 30% 70% 40% 60% / 70% 40% 60% 30%; }
            75% { border-radius: 70% 30% 60% 40% / 40% 60% 30% 70%; }
        }
        
        .morph-shape {
            animation: morphShape 8s ease-in-out infinite;
        }
        
        /* v14.0: Glow Orb Effect */
        @keyframes glowOrb {
            0%, 100% { 
                transform: scale(1);
                opacity: 0.6;
            }
            50% { 
                transform: scale(1.15);
                opacity: 0.9;
            }
        }
        
        .glow-orb {
            animation: glowOrb 4s ease-in-out infinite;
        }
        
        /* v14.0: Interactive Ripple Effect */
        @keyframes interactiveRipple {
            0% {
                transform: scale(0);
                opacity: 0.6;
            }
            100% {
                transform: scale(4);
                opacity: 0;
            }
        }
        
        .interactive-ripple {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.4) 0%, transparent 70%);
            pointer-events: none;
            animation: interactiveRipple 0.8s ease-out forwards;
        }
        
        /* v14.0: Breathing Gradient Border */
        @keyframes breathingBorder {
            0%, 100% {
                border-color: var(--primary);
                box-shadow: 0 0 15px var(--primary-dim);
            }
            33% {
                border-color: var(--accent);
                box-shadow: 0 0 15px var(--accent-dim);
            }
            66% {
                border-color: var(--success);
                box-shadow: 0 0 15px var(--success-dim);
            }
        }
        
        .breathing-border {
            animation: breathingBorder 4s ease-in-out infinite;
        }
        
        /* v14.0: Floating Particles Container */
        .floating-particles {
            position: fixed;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
            z-index: 0;
        }
        
        .floating-particle {
            position: absolute;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            animation: floatUp 10s linear infinite;
            opacity: 0.4;
        }
        
        @keyframes floatUp {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.4;
            }
            90% {
                opacity: 0.4;
            }
            100% {
                transform: translateY(-100vh) rotate(360deg);
                opacity: 0;
            }
        }
        
        /* v14.0: Status-based Glow Enhancement */
        .fox-glow-idle {
            filter: drop-shadow(0 0 15px rgba(255, 200, 100, 0.4)) drop-shadow(0 0 30px rgba(255, 200, 100, 0.2));
        }
        
        .fox-glow-working {
            filter: drop-shadow(0 0 20px rgba(0, 212, 255, 0.5)) drop-shadow(0 0 40px rgba(0, 212, 255, 0.3));
        }
        
        .fox-glow-sleeping {
            filter: drop-shadow(0 0 12px rgba(95, 108, 175, 0.4)) drop-shadow(0 0 25px rgba(95, 108, 175, 0.2));
        }
        
        .fox-glow-excited {
            filter: drop-shadow(0 0 25px rgba(255, 107, 157, 0.6)) drop-shadow(0 0 50px rgba(255, 107, 157, 0.4));
        }
        
        .fox-glow-thinking {
            filter: drop-shadow(0 0 18px rgba(165, 94, 234, 0.5)) drop-shadow(0 0 35px rgba(165, 94, 234, 0.3));
        }
        
        .fox-glow-laughing {
            filter: drop-shadow(0 0 22px rgba(255, 200, 100, 0.5)) drop-shadow(0 0 45px rgba(255, 200, 100, 0.3));
        }
        
        .fox-glow-error {
            filter: drop-shadow(0 0 20px rgba(255, 107, 107, 0.6)) drop-shadow(0 0 40px rgba(255, 107, 107, 0.4));
        }
        
        /* v14.0: Focused and Learning state styles */
        .fox-glow-focused {
            filter: drop-shadow(0 0 20px rgba(0, 255, 136, 0.6)) drop-shadow(0 0 40px rgba(0, 255, 136, 0.4));
        }
        
        .fox-glow-learning {
            filter: drop-shadow(0 0 20px rgba(255, 149, 0, 0.6)) drop-shadow(0 0 40px rgba(255, 149, 0, 0.4));
        }
        
        .status-dot.focused {
            background: #00ff88;
            box-shadow: 0 0 12px #00ff88, 0 0 24px rgba(0, 255, 136, 0.4);
        }
        
        .status-dot.learning {
            background: #ff9500;
            box-shadow: 0 0 12px #ff9500, 0 0 24px rgba(255, 149, 0, 0.4);
        }
        
        .status.focused { color: #00ff88; }
        .status.learning { color: #ff9500; }
        
        .avatar.focused {
            filter: drop-shadow(0 0 15px rgba(0, 255, 136, 0.5));
        }
        
        .avatar.learning {
            filter: drop-shadow(0 0 15px rgba(255, 149, 0, 0.5));
        }
        
        .bg-mesh.focused {
            background: radial-gradient(ellipse at 50% 30%, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
        }
        
        .bg-mesh.learning {
            background: radial-gradient(ellipse at 50% 30%, rgba(255, 149, 0, 0.15) 0%, transparent 60%);
        }
        
        /* v14.0: Enhanced Particle Burst */
        @keyframes enhancedParticleBurst {
            0% {
                opacity: 1;
                transform: translate(-50%, -50%) scale(1);
            }
            100% {
                opacity: 0;
                transform: translate(calc(-50% + var(--tx)), calc(-50% + var(--ty))) scale(0) rotate(var(--rot));
            }
        }
        
        .fox-particle {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            pointer-events: none;
            animation: enhancedParticleBurst 0.8s ease-out forwards;
        }
        
        /* v14.0: Focus Mode Enhancement */
        body.focus-mode .fox-container {
            transform: scale(1.05);
            filter: brightness(1.1);
        }
        
        body.focus-mode .fox-glow-idle,
        body.focus-mode .fox-glow-working,
        body.focus-mode .fox-glow-sleeping {
            filter: drop-shadow(0 0 25px rgba(255, 200, 100, 0.6)) drop-shadow(0 0 50px rgba(255, 200, 100, 0.4));
        }
        
        /* v14.0: Quantum Fox States */
        .fox-quantum {
            animation: quantumFox 0.5s ease-in-out;
        }
        
        @keyframes quantumFox {
            0% { filter: blur(0px); transform: scale(1); }
            50% { filter: blur(3px); transform: scale(1.05); }
            100% { filter: blur(0px); transform: scale(1); }
        }
        
        /* v14.0: Sound Wave Visualizer */
        .sound-wave {
            display: flex;
            align-items: center;
            gap: 2px;
            height: 20px;
        }
        
        .sound-wave-bar {
            width: 3px;
            background: var(--accent);
            border-radius: 2px;
            animation: soundWave 0.5s ease-in-out infinite;
        }
        
        .sound-wave-bar:nth-child(1) { animation-delay: 0s; }
        .sound-wave-bar:nth-child(2) { animation-delay: 0.1s; }
        .sound-wave-bar:nth-child(3) { animation-delay: 0.2s; }
        .sound-wave-bar:nth-child(4) { animation-delay: 0.3s; }
        .sound-wave-bar:nth-child(5) { animation-delay: 0.4s; }
        
        @keyframes soundWave {
            0%, 100% { height: 4px; }
            50% { height: 16px; }
        }
        
        .sound-wave.muted .sound-wave-bar {
            animation: none;
            height: 4px;
            opacity: 0.3;
        }
        
        /* v14.0: Energy Wave Effect */
        @keyframes energyWave {
            0% {
                transform: translateX(-100%) scaleY(1);
                opacity: 0.8;
            }
            100% {
                transform: translateX(100%) scaleY(1.5);
                opacity: 0;
            }
        }
        
        .energy-wave {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            animation: energyWave 2s ease-out infinite;
        }
        
        /* v14.0: Ambient Light Effect */
        @keyframes ambientLight {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.6; }
        }
        
        .ambient-light {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at center, var(--accent) 0%, transparent 70%);
            animation: ambientLight 4s ease-in-out infinite;
            pointer-events: none;
            mix-blend-mode: screen;
        }
        
        /* v14.0: 3D Tilt Card Effect */
        .tilt-card {
            transform-style: preserve-3d;
            transition: transform 0.1s ease-out;
        }
        
        /* v14.0: Glassmorphism Enhancement */
        .glass-panel {
            background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 
                0 8px 32px rgba(0,0,0,0.3),
                inset 0 1px 0 rgba(255,255,255,0.1),
                inset 0 -1px 0 rgba(0,0,0,0.1);
        }
        
        /* v14.0: Animated Gradient Border */
        .gradient-border {
            position: relative;
        }
        .gradient-border::before {
            content: '';
            position: absolute;
            inset: -2px;
            background: var(--aurora-gradient);
            border-radius: inherit;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.4s var(--ease-out-expo);
            animation: gradientRotate 3s linear infinite;
        }
        .gradient-border:hover::before,
        .gradient-border.active::before {
            opacity: 1;
        }
        @keyframes gradientRotate {
            0% { background: linear-gradient(0deg, var(--primary), var(--accent), var(--success)); }
            25% { background: linear-gradient(90deg, var(--accent), var(--success), var(--primary)); }
            50% { background: linear-gradient(180deg, var(--success), var(--primary), var(--accent)); }
            75% { background: linear-gradient(270deg, var(--primary), var(--accent), var(--success)); }
            100% { background: linear-gradient(360deg, var(--primary), var(--accent), var(--success)); }
        }
        
        /* v11.8: Morphing Blob Animation */
        @keyframes blobMorph {
            0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
            50% { border-radius: 50% 60% 30% 60% / 30% 60% 70% 40%; }
            75% { border-radius: 60% 40% 60% 30% / 70% 30% 50% 60%; }
        }
        .morph-blob {
            animation: blobMorph 8s ease-in-out infinite;
        }
        
        /* v11.8: Shimmer Effect */
        .shimmer {
            position: relative;
            overflow: hidden;
        }
        .shimmer::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
            transition: left 0.6s var(--ease-out-expo);
        }
        .shimmer:hover::after {
            left: 100%;
        }
        
        /* v11.8: Glow Pulse Animation */
        @keyframes glowPulse {
            0%, 100% { box-shadow: 0 0 20px rgba(255,200,100,0.3), 0 0 40px rgba(255,200,100,0.1); }
            50% { box-shadow: 0 0 30px rgba(255,200,100,0.5), 0 0 60px rgba(255,200,100,0.2); }
        }
        .glow-pulse {
            animation: glowPulse 2s ease-in-out infinite;
        }
        
        /* v11.8: Holographic Effect */
        .holographic {
            background: linear-gradient(135deg, 
                rgba(255,200,100,0.1) 0%, 
                rgba(0,212,255,0.1) 25%, 
                rgba(92,219,149,0.1) 50%, 
                rgba(0,212,255,0.1) 75%, 
                rgba(255,200,100,0.1) 100%);
            background-size: 400% 400%;
            animation: holographicShift 8s ease infinite;
        }
        @keyframes holographicShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        /* v14.0: Ultra-Modern Animation Keyframes */
        @keyframes foxBreathe {
            0%, 100% { transform: scale(1) translateY(0); }
            50% { transform: scale(1.03) translateY(-2px); }
        }
        @keyframes avatarSpringIn {
            0% { transform: scale(0.5) rotate(-10deg); opacity: 0; }
            60% { transform: scale(1.1) rotate(3deg); opacity: 1; }
            80% { transform: scale(0.95) rotate(-1deg); }
            100% { transform: scale(1) rotate(0deg); }
        }
        @keyframes liquidSpread {
            0% { transform: scale(1); filter: brightness(1); }
            50% { transform: scale(1.05); filter: brightness(1.15); }
            100% { transform: scale(1); filter: brightness(1); }
        }
        @keyframes scrollSweep {
            0% { background-position: -100% 0; }
            100% { background-position: 200% 0; }
        }
        @keyframes starTwinkle {
            0%, 100% { opacity: 0.3; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.3); }
        }
        @keyframes statCardEntrance {
            0% { opacity: 0; transform: translateY(20px) scale(0.95); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(10px, -15px) scale(1.05); }
            50% { transform: translate(-5px, -25px) scale(0.95); }
            75% { transform: translate(-15px, -10px) scale(1.02); }
        }
        @keyframes dataStream {
            0% { background-position: 0% 0; }
            100% { background-position: 0% 100%; }
        }
        @keyframes scanLine {
            0% { transform: translateY(-100%); }
            100% { transform: translateY(100vh); }
        }
        @keyframes pulseDot {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.5; }
        }
        @keyframes radarSweep {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        /* v12.2: New CSS Classes */
        .breathing-fox {
            animation: foxBreathe 3s ease-in-out infinite;
        }
        .avatar-spring-in {
            animation: avatarSpringIn 0.8s var(--ease-out-back) forwards;
        }
        .magnetic-btn {
            transition: transform 0.2s var(--ease-out-expo), box-shadow 0.2s ease;
        }
        .liquid-btn:hover {
            animation: liquidSpread 0.6s ease-in-out;
        }
        .scroll-highlight::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,200,100,0.1), transparent);
            background-size: 200% 100%;
            animation: scrollSweep 2s ease-in-out infinite;
            pointer-events: none;
            border-radius: inherit;
        }
        .stat-card {
            opacity: 0;
            animation: statCardEntrance 0.5s var(--ease-out-expo) forwards;
        }
        .stat-card:nth-child(1) { animation-delay: 0.05s; }
        .stat-card:nth-child(2) { animation-delay: 0.1s; }
        .stat-card:nth-child(3) { animation-delay: 0.15s; }
        .stat-card:nth-child(4) { animation-delay: 0.2s; }
        .stat-card:nth-child(5) { animation-delay: 0.25s; }
        .stat-card:nth-child(6) { animation-delay: 0.3s; }
        .ambient-orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.15;
            pointer-events: none;
            z-index: 0;
            animation: orbFloat 20s ease-in-out infinite;
        }
        .ambient-orb-1 {
            width: 400px; height: 400px;
            background: var(--primary);
            top: -100px; left: -100px;
            animation-delay: 0s;
        }
        .ambient-orb-2 {
            width: 300px; height: 300px;
            background: var(--accent);
            bottom: -50px; right: -50px;
            animation-delay: -7s;
        }
        .ambient-orb-3 {
            width: 250px; height: 250px;
            background: var(--success);
            top: 50%; left: 50%;
            animation-delay: -14s;
        }
        .scan-line {
            position: fixed;
            left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(255,200,100,0.1), rgba(0,212,255,0.1), transparent);
            pointer-events: none;
            z-index: 1;
            animation: scanLine 8s linear infinite;
            opacity: 0.5;
        }
        .stat-pulse-dot {
            display: inline-block;
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--success);
            animation: pulseDot 1.5s ease-in-out infinite;
            vertical-align: middle;
            margin-left: 4px;
        }
        .stat-pulse-dot.warning { background: var(--warning); }
        .stat-pulse-dot.danger { background: var(--danger); }
        .fox-particle-system canvas {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 10;
        }
        .aurora-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            opacity: 0.4;
            background: 
                radial-gradient(ellipse 80% 60% at 20% 20%, rgba(255,107,157,0.3) 0%, transparent 50%),
                radial-gradient(ellipse 60% 50% at 80% 30%, rgba(0,212,255,0.25) 0%, transparent 50%),
                radial-gradient(ellipse 70% 55% at 50% 80%, rgba(92,219,149,0.2) 0%, transparent 50%);
            animation: auroraShift 15s ease-in-out infinite;
        }
        @keyframes auroraShift {
            0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.4; }
            33% { transform: scale(1.05) rotate(2deg); opacity: 0.55; }
            66% { transform: scale(0.98) rotate(-1deg); opacity: 0.35; }
        }

        /* ===== v13.0: 2026 Next-Gen Design System ===== */

        /* Liquid Glass Effect - Advanced Glassmorphism 2.0 */
        .liquid-glass {
            background: linear-gradient(135deg,
                rgba(255,255,255,0.1) 0%,
                rgba(255,255,255,0.02) 50%,
                rgba(255,255,255,0.05) 100%);
            backdrop-filter: blur(30px) saturate(200%) brightness(1.1);
            -webkit-backdrop-filter: blur(30px) saturate(200%) brightness(1.1);
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow:
                0 8px 32px rgba(0,0,0,0.3),
                0 2px 8px rgba(0,0,0,0.2),
                inset 0 1px 0 rgba(255,255,255,0.15),
                inset 0 -1px 0 rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden;
        }
        .liquid-glass::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,
                rgba(255,200,100,0.05) 0%,
                transparent 50%,
                rgba(0,212,255,0.05) 100%);
            pointer-events: none;
            animation: liquidShimmer 8s ease-in-out infinite;
        }
        @keyframes liquidShimmer {
            0%, 100% { opacity: 0.3; transform: translateX(-10%); }
            50% { opacity: 0.6; transform: translateX(10%); }
        }

        /* Neumorphic Soft UI */
        .neumorphic {
            background: linear-gradient(145deg, #0c0c14, #0a0a10);
            box-shadow:
                8px 8px 16px #050508,
                -8px -8px 16px #121220;
            border: 1px solid rgba(255,255,255,0.02);
        }
        .neumorphic-pressed {
            background: linear-gradient(145deg, #0a0a10, #0c0c14);
            box-shadow:
                inset 4px 4px 8px #050508,
                inset -4px -4px 8px #121220;
        }

        /* 3D Perspective Card */
        .perspective-3d {
            transform-style: preserve-3d;
            perspective: 1000px;
        }
        .card-3d {
            transition: transform 0.6s var(--ease-out-expo);
            transform-style: preserve-3d;
        }
        .card-3d:hover {
            transform: rotateY(8deg) rotateX(-5deg) translateZ(20px);
        }

        /* Magnetic Button Effect */
        .magnetic-hover {
            transition: transform 0.3s var(--ease-out-expo);
        }

        /* Text Scramble Effect */
        .scramble-text {
            font-family: 'JetBrains Mono', monospace;
        }

        /* Glowing Border Animation */
        .glow-border-animated {
            position: relative;
        }
        .glow-border-animated::before {
            content: '';
            position: absolute;
            inset: -2px;
            background: conic-gradient(from 0deg, var(--primary), var(--accent), var(--success), var(--primary));
            border-radius: inherit;
            z-index: -1;
            animation: rotateGlow 4s linear infinite;
            filter: blur(8px);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .glow-border-animated:hover::before {
            opacity: 0.7;
        }
        @keyframes rotateGlow {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Floating Label Animation */
        .float-label {
            position: relative;
        }
        .float-label input:focus + label,
        .float-label input:not(:placeholder-shown) + label {
            transform: translateY(-24px) scale(0.85);
            color: var(--primary);
        }

        /* Pulse Ring Effect */
        .pulse-ring {
            position: relative;
        }
        .pulse-ring::after {
            content: '';
            position: absolute;
            inset: -4px;
            border: 2px solid var(--primary);
            border-radius: inherit;
            animation: pulseRingAnim 2s ease-out infinite;
            opacity: 0;
        }
        @keyframes pulseRingAnim {
            0% { transform: scale(1); opacity: 0.5; }
            100% { transform: scale(1.2); opacity: 0; }
        }

        /* Typewriter Cursor */
        .typewriter::after {
            content: '|';
            animation: blink 1s step-end infinite;
            color: var(--primary);
        }
        @keyframes blink { 50% { opacity: 0; } }

        /* Smooth Reveal Animation */
        .reveal-up {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s var(--ease-out-expo);
        }
        .reveal-up.revealed {
            opacity: 1;
            transform: translateY(0);
        }

        /* Stagger Children Animation */
        .stagger-children > * {
            opacity: 0;
            transform: translateY(20px);
        }
        .stagger-children.revealed > *:nth-child(1) { animation: staggerIn 0.5s var(--ease-out-expo) 0.05s forwards; }
        .stagger-children.revealed > *:nth-child(2) { animation: staggerIn 0.5s var(--ease-out-expo) 0.1s forwards; }
        .stagger-children.revealed > *:nth-child(3) { animation: staggerIn 0.5s var(--ease-out-expo) 0.15s forwards; }
        .stagger-children.revealed > *:nth-child(4) { animation: staggerIn 0.5s var(--ease-out-expo) 0.2s forwards; }
        .stagger-children.revealed > *:nth-child(5) { animation: staggerIn 0.5s var(--ease-out-expo) 0.25s forwards; }
        .stagger-children.revealed > *:nth-child(6) { animation: staggerIn 0.5s var(--ease-out-expo) 0.3s forwards; }
        @keyframes staggerIn {
            to { opacity: 1; transform: translateY(0); }
        }

        /* Particle Network Background */
        .particle-network {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
        }

        /* Gradient Text Animation */
        .gradient-text-animated {
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--success), var(--primary));
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientTextMove 5s ease infinite;
        }
        @keyframes gradientTextMove {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        /* Morphing Shape */
        .morph-shape {
            animation: morphShape 10s ease-in-out infinite;
        }
        @keyframes morphShape {
            0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
            50% { border-radius: 50% 60% 30% 60% / 30% 60% 70% 40%; }
            75% { border-radius: 60% 40% 60% 30% / 70% 30% 50% 60%; }
        }

        /* Interactive Spotlight */
        .spotlight-container {
            position: relative;
            overflow: hidden;
        }
        .spotlight {
            position: absolute;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(255,200,100,0.15) 0%, transparent 70%);
            pointer-events: none;
            transform: translate(-50%, -50%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .spotlight-container:hover .spotlight {
            opacity: 1;
        }

        /* v13.0: Enhanced Status Indicators */
        .status-dot-pulse {
            position: relative;
        }
        .status-dot-pulse::before {
            content: '';
            position: absolute;
            inset: -4px;
            background: inherit;
            border-radius: 50%;
            opacity: 0.4;
            animation: statusDotPulse 2s ease-out infinite;
        }
        @keyframes statusDotPulse {
            0% { transform: scale(1); opacity: 0.4; }
            100% { transform: scale(2.5); opacity: 0; }
        }

        /* v13.0: Skeleton Loading Shimmer */
        .skeleton-shimmer {
            background: linear-gradient(90deg,
                rgba(255,255,255,0.03) 0%,
                rgba(255,255,255,0.08) 50%,
                rgba(255,255,255,0.03) 100%);
            background-size: 200% 100%;
            animation: skeletonShimmer 1.5s ease-in-out infinite;
        }
        @keyframes skeletonShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* v13.0: Bento Grid Layout */
        .bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }
        .bento-item {
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: transform 0.3s var(--ease-out-expo);
        }
        .bento-item:hover {
            transform: scale(1.02);
        }
        .bento-item.span-2 { grid-column: span 2; }
        .bento-item.span-3 { grid-column: span 3; }

        .progress-ring-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .progress-ring-container svg {
            transform: rotate(-90deg);
        }
        .progress-ring-container .ring-bg {
            fill: none;
            stroke: rgba(255,255,255,0.06);
            stroke-width: 3;
        }
        .progress-ring-container .ring-fill {
            fill: none;
            stroke-width: 3;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.8s var(--ease-out-expo);
        }
        .progress-ring-container .ring-label {
            font-size: 8px;
            font-family: 'JetBrains Mono', monospace;
            fill: var(--text-dim);
        }
        .status-ribbon {
            position: relative;
            display: inline-block;
        }
        .status-ribbon::before {
            content: '';
            position: absolute;
            top: 0; bottom: 0; left: -4px;
            width: 3px;
            background: var(--primary);
            border-radius: 2px;
            animation: ribbonPulse 2s ease-in-out infinite;
        }
        @keyframes ribbonPulse {
            0%, 100% { opacity: 0.5; transform: scaleY(0.8); }
            50% { opacity: 1; transform: scaleY(1); }
        }
        .glass-card-v2 {
            background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.01) 100%);
            backdrop-filter: blur(24px) saturate(200%);
            -webkit-backdrop-filter: blur(24px) saturate(200%);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-lg);
            box-shadow: 
                0 12px 40px rgba(0,0,0,0.4),
                inset 0 1px 0 rgba(255,255,255,0.12),
                inset 0 -1px 0 rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }
        .glass-card-v2::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, transparent 60%);
            pointer-events: none;
        }
        .data-stream-bg {
            position: relative;
            overflow: hidden;
        }
        .data-stream-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0,212,255,0.02) 2px,
                rgba(0,212,255,0.02) 4px
            );
            animation: dataStream 4s linear infinite;
            pointer-events: none;
        }
        .card-flip {
            perspective: 1000px;
        }
        .card-flip-inner {
            transition: transform 0.8s;
            transform-style: preserve-3d;
        }
        .card-flip:hover .card-flip-inner {
            transform: rotateY(10deg) rotateX(5deg);
        }
        .mini-chart {
            height: 20px;
            display: flex;
            align-items: flex-end;
            gap: 1px;
            padding: 0 2px;
        }
        .mini-chart-bar {
            flex: 1;
            border-radius: 1px 1px 0 0;
            transition: height 0.5s var(--ease-out-expo);
            min-height: 2px;
        }
        .tooltip-v2 {
            position: absolute;
            bottom: calc(100% + 8px);
            left: 50%;
            transform: translateX(-50%) translateY(4px);
            background: var(--bg-card);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-sm);
            padding: 6px 10px;
            font-size: 10px;
            color: var(--text);
            white-space: nowrap;
            opacity: 0;
            visibility: hidden;
            transition: all 0.2s var(--ease-out-expo);
            z-index: 100;
            pointer-events: none;
            backdrop-filter: blur(12px);
        }
        .tooltip-v2::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 4px solid transparent;
            border-top-color: var(--glass-border);
        }
        [data-tooltip-v2]:hover .tooltip-v2 {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0);
        }
        .focus-ring:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
        }
        .kbd-v2 {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 2px 6px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 4px;
            font-size: 10px;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-dim);
            box-shadow: 0 2px 0 rgba(0,0,0,0.3);
        }
        /* v12.2: Reduced motion support */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
        /* v12.2: Performance optimizations */
        .stat-card, .glass-panel, .glass-card-v2 {
            content-visibility: auto;
            contain-intrinsic-size: 0 80px;
        }
        
        body {
            font-family: 'Outfit', -apple-system, sans-serif;
            background: var(--bg-dark);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            position: relative;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }
        
        .bg-mesh {
            position: fixed;
            inset: 0;
            z-index: 0;
            background: 
                radial-gradient(ellipse 120% 70% at 0% 0%, rgba(255,180,80,0.15) 0%, transparent 50%),
                radial-gradient(ellipse 90% 55% at 100% 0%, rgba(0,200,255,0.12) 0%, transparent 45%),
                radial-gradient(ellipse 80% 65% at 100% 100%, rgba(100,220,150,0.1) 0%, transparent 50%),
                radial-gradient(ellipse 100% 55% at 0% 100%, rgba(100,100,255,0.08) 0%, transparent 45%),
                var(--bg-dark);
            animation: meshFloat 30s ease-in-out infinite;
            transition: background 2s ease;
        }
        
        /* Dynamic background based on status */
        .bg-mesh.working { background: 
                radial-gradient(ellipse 120% 70% at 0% 0%, rgba(0,200,255,0.2) 0%, transparent 50%),
                radial-gradient(ellipse 90% 55% at 100% 0%, rgba(0,255,200,0.15) 0%, transparent 45%),
                radial-gradient(ellipse 80% 65% at 100% 100%, rgba(0,180,255,0.12) 0%, transparent 50%),
                radial-gradient(ellipse 100% 55% at 0% 100%, rgba(0,100,255,0.1) 0%, transparent 45%),
                var(--bg-dark);
        }
        .bg-mesh.sleeping { background: 
                radial-gradient(ellipse 120% 70% at 0% 0%, rgba(100,120,180,0.12) 0%, transparent 50%),
                radial-gradient(ellipse 90% 55% at 100% 0%, rgba(80,100,160,0.1) 0%, transparent 45%),
                radial-gradient(ellipse 80% 65% at 100% 100%, rgba(120,140,200,0.08) 0%, transparent 50%),
                radial-gradient(ellipse 100% 55% at 0% 100%, rgba(90,110,170,0.06) 0%, transparent 45%),
                var(--bg-dark);
        }
        .bg-mesh.excited { background: 
                radial-gradient(ellipse 120% 70% at 0% 0%, rgba(255,150,200,0.18) 0%, transparent 50%),
                radial-gradient(ellipse 90% 55% at 100% 0%, rgba(255,200,100,0.15) 0%, transparent 45%),
                radial-gradient(ellipse 80% 65% at 100% 100%, rgba(255,100,150,0.12) 0%, transparent 50%),
                radial-gradient(ellipse 100% 55% at 0% 100%, rgba(200,100,255,0.1) 0%, transparent 45%),
                var(--bg-dark);
        }
        .bg-mesh.thinking { background: 
                radial-gradient(ellipse 120% 70% at 0% 0%, rgba(150,130,220,0.15) 0%, transparent 50%),
                radial-gradient(ellipse 90% 55% at 100% 0%, rgba(120,100,200,0.12) 0%, transparent 45%),
                radial-gradient(ellipse 80% 65% at 100% 100%, rgba(180,160,240,0.1) 0%, transparent 50%),
                radial-gradient(ellipse 100% 55% at 0% 100%, rgba(100,80,180,0.08) 0%, transparent 45%),
                var(--bg-dark);
        }
        
        /* New: Laughing state background */
        .bg-mesh.laughing { background: 
                radial-gradient(ellipse 120% 70% at 0% 0%, rgba(255,200,100,0.2) 0%, transparent 50%),
                radial-gradient(ellipse 90% 55% at 100% 0%, rgba(255,150,50,0.15) 0%, transparent 45%),
                radial-gradient(ellipse 80% 65% at 100% 100%, rgba(255,100,150,0.12) 0%, transparent 50%),
                radial-gradient(ellipse 100% 55% at 0% 100%, rgba(255,180,100,0.1) 0%, transparent 45%),
                var(--bg-dark);
        }
        
        /* New: Error state background */
        .bg-mesh.error { background: 
                radial-gradient(ellipse 120% 70% at 0% 0%, rgba(255,100,100,0.15) 0%, transparent 50%),
                radial-gradient(ellipse 90% 55% at 100% 0%, rgba(255,50,50,0.12) 0%, transparent 45%),
                radial-gradient(ellipse 80% 65% at 100% 100%, rgba(200,50,50,0.1) 0%, transparent 50%),
                radial-gradient(ellipse 100% 55% at 0% 100%, rgba(255,80,80,0.08) 0%, transparent 45%),
                var(--bg-dark);
        }
        
        /* New: Noise texture overlay */
        .bg-mesh::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.03;
            pointer-events: none;
            mix-blend-mode: overlay;
        }
        
        /* New: Dynamic glow orbs */
        .glow-orb {
            position: fixed;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            filter: blur(100px);
            z-index: 1;
            pointer-events: none;
            opacity: 0.4;
            animation: glowOrbFloat 20s ease-in-out infinite;
        }
        .glow-orb.primary { background: var(--primary); top: -100px; left: -100px; }
        .glow-orb.accent { background: var(--accent); top: 50%; right: -100px; animation-delay: -7s; }
        .glow-orb.success { background: var(--success); bottom: -100px; left: 30%; animation-delay: -14s; }
        @keyframes glowOrbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
            33% { transform: translate(30px, -30px) scale(1.1); opacity: 0.5; }
            66% { transform: translate(-20px, 20px) scale(0.9); opacity: 0.4; }
        }
        
        /* New: Neon border effect */
        .neon-border {
            position: absolute;
            inset: -1px;
            border-radius: inherit;
            background: linear-gradient(45deg, var(--primary), var(--accent), var(--success), var(--primary));
            background-size: 300% 300%;
            animation: neonGradient 6s ease infinite;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .main-card:hover .neon-border { opacity: 0.5; }
        @keyframes neonGradient {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }
        
        /* New: Holographic card effect */
        .holographic {
            background: linear-gradient(135deg, 
                rgba(255,255,255,0.1) 0%, 
                rgba(255,255,255,0.05) 25%, 
                transparent 50%, 
                rgba(255,255,255,0.05) 75%, 
                rgba(255,255,255,0.1) 100%);
            background-size: 200% 200%;
            animation: holographic 8s ease infinite;
        }
        @keyframes holographic {
            0%, 100% { background-position: 0% 0%; }
            50% { background-position: 100% 100%; }
        }
        
        /* New: Glass card with refraction */
        .glass-card {
            background: linear-gradient(135deg, 
                rgba(255,255,255,0.08) 0%, 
                rgba(255,255,255,0.02) 100%);
            backdrop-filter: blur(32px) saturate(180%);
            -webkit-backdrop-filter: blur(32px) saturate(180%);
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 
                0 8px 32px rgba(0,0,0,0.3),
                inset 0 1px 0 rgba(255,255,255,0.1),
                inset 0 -1px 0 rgba(255,255,255,0.05);
        }
        @keyframes meshFloat {
            0%, 100% { background-position: 0% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%; }
            25% { background-position: 25% 15%, 75% 8%, 85% 85%, 15% 90%, 0% 0%; }
            50% { background-position: 15% 25%, 85% 18%, 75% 75%, 25% 80%, 0% 0%; }
            75% { background-position: 8% 12%, 92% 12%, 90% 92%, 10% 88%, 0% 0%; }
        }
        
        /* v11.7: Stale data warning - data freshness indicator */
        body.loading .main-card > *:not(.quick-actions) {
            opacity: 0.3;
            filter: blur(1px);
            transition: opacity 0.3s ease, filter 0.3s ease;
        }
        body.loading .main-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(8,8,12,0.5);
            border-radius: inherit;
            z-index: 100;
            animation: loadingPulse 1.5s ease-in-out infinite;
        }
        @keyframes loadingPulse {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.6; }
        }
        
        /* Power saving mode */
        body.power-saving .glow-orb,
        body.power-saving .orb,
        body.power-saving .sparkles,
        body.power-saving .morph-shape,
        body.power-saving .wave-bg { animation: none !important; opacity: 0.2 !important; }
        body.power-saving .bg-mesh { animation: none !important; }
        body.power-saving .avatar-ring { animation: none !important; opacity: 0.4 !important; }
        body.power-saving .avatar-glow { animation: none !important; opacity: 0.3 !important; }
        body.power-saving .stat-value.rolling { animation: none !important; }
        body.power-saving .status-dot::after { animation: none !important; }
        .power-indicator { position: fixed; top: 14px; left: 14px; padding: 4px 10px; background: var(--glass); border: 1px solid var(--glass-border); border-radius: 8px; font-size: 7px; color: var(--accent); text-transform: uppercase; z-index: 100; opacity: 0; transition: opacity 0.3s; }
        .power-indicator.visible { opacity: 0.8; }
        
        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            z-index: 1;
            pointer-events: none;
            animation: orbFloat 25s ease-in-out infinite;
        }
        .orb-1 { width: 450px; height: 450px; background: radial-gradient(circle, rgba(255,180,80,0.1) 0%, transparent 70%); top: -120px; left: -120px; }
        .orb-2 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(0,200,255,0.08) 0%, transparent 70%); top: 40%; right: -80px; animation-delay: -8s; }
        .orb-3 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(100,220,150,0.06) 0%, transparent 70%); bottom: -120px; left: 25%; animation-delay: -16s; }
        .orb-4 { width: 200px; height: 200px; background: radial-gradient(circle, rgba(160,100,255,0.05) 0%, transparent 70%); top: 20%; right: 20%; animation-delay: -12s; }
        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(40px, -40px) scale(1.08); }
            50% { transform: translate(-30px, 30px) scale(0.95); }
            75% { transform: translate(20px, -20px) scale(1.02); }
        }
        
        .particles { position: fixed; inset: 0; z-index: 1; overflow: hidden; pointer-events: none; }
        .particle { position: absolute; width: 2px; height: 2px; background: var(--primary); border-radius: 50%; opacity: 0; animation: particleFloat 20s infinite; }
        @keyframes particleFloat { 0% { transform: translateY(100vh) scale(0); opacity: 0; } 5% { opacity: 0.7; } 95% { opacity: 0.7; } 100% { transform: translateY(-150px) scale(1); opacity: 0; } }
        
        .main-card {
            width: 100%;
            max-width: 400px;
            background: var(--bg-card);
            backdrop-filter: blur(32px) saturate(180%);
            -webkit-backdrop-filter: blur(32px) saturate(180%);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl);
            padding: 28px;
            position: relative;
            z-index: 10;
            box-shadow: var(--shadow-soft), 0 0 0 1px rgba(255,255,255,0.02) inset, var(--shadow-glow) rgba(255,200,100,0.12), 0 8px 32px rgba(0,0,0,0.2);
            transform-style: preserve-3d;
            perspective: 1000px;
        }
        .main-card:hover { transform: translateY(-8px); box-shadow: 0 16px 48px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.04) inset, 0 0 120px -20px rgba(255,200,100,0.22), 0 -4px 20px rgba(0,200,255,0.1); background: var(--bg-card-hover); }
        
        /* Enhanced: Touch device optimizations */
        @media (hover: none) and (pointer: coarse) {
            .main-card:active { transform: translateY(-4px) scale(0.98); }
            .stat-card:active { transform: scale(0.96); }
            .action-btn:active { transform: scale(0.92); }
        }
        
        /* Responsive: Mobile optimizations */
        @media (max-width: 480px) {
            .main-card { padding: 20px; border-radius: 24px; }
            .avatar-section { width: 80px; height: 80px; margin-bottom: 14px; }
            .avatar { font-size: 36px; }
            .avatar-ring { inset: -4px; }
            .header { flex-direction: column; gap: 8px; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
            .stat-card { padding: 12px 10px; }
            .stat-value { font-size: 22px; }
            .stat-label { font-size: 9px; }
            .mini-stats { gap: 6px; }
            .mini-stat { padding: 8px; }
            .current-task { font-size: 12px; }
            .action-buttons { gap: 8px; }
            .action-btn { padding: 8px 14px; font-size: 11px; }
            .kbd-hint { font-size: 9px; padding: 3px 6px; }
            .cmd-hint { font-size: 10px; }
            .viz-container { grid-template-columns: 1fr; gap: 12px; }
            .system-status { flex-wrap: wrap; justify-content: center; bottom: 8px; right: 8px; }
            .status-badge { padding: 4px 8px; font-size: 7px; }
            .version-tag { bottom: 8px; left: 8px; font-size: 7px; }
            .power-indicator { top: 8px; left: 8px; }
        }
        
        /* Ultra small screens */
        @media (max-width: 360px) {
            .main-card { padding: 16px; }
            .stats-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
            .stat-card { padding: 10px 8px; }
            .name { font-size: 20px; }
            .status { font-size: 9px; letter-spacing: 2px; }
        }
        
        /* Dark mode enhancement */
        @media (prefers-color-scheme: dark) {
            :root { --bg-dark: #050508; --bg-card: rgba(10,10,18,0.92); }
        }
        
        /* === v10.1 ENHANCEMENTS === */

        /* Live Activity Indicator - iOS Dynamic Island inspired */
        .live-activity {
            position: fixed;
            top: 14px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 200;
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
        }
        .live-activity.visible { opacity: 1; }
        .live-activity-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px 6px 10px;
            background: rgba(10,10,18,0.85);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.03) inset;
        }
        .live-activity-avatar {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            animation: liveAvatarPulse 2s ease-in-out infinite;
        }
        @keyframes liveAvatarPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        .live-activity-content { display: flex; flex-direction: column; gap: 1px; }
        .live-activity-title {
            font-size: 10px;
            font-weight: 600;
            color: var(--text-bright);
            line-height: 1.2;
            max-width: 160px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .live-activity-subtitle {
            font-size: 7.5px;
            color: var(--text-dim);
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .live-activity-subtitle .dot {
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--accent);
            animation: dotBlink 1.5s ease-in-out infinite;
        }
        @keyframes dotBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
        .live-activity-ring {
            position: relative;
            width: 22px;
            height: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .live-activity-ring svg { transform: rotate(-90deg); }
        .live-activity-ring circle {
            fill: none;
            stroke-width: 2.5;
            stroke-linecap: round;
        }
        .live-activity-ring .bg { stroke: rgba(255,255,255,0.1); }
        .live-activity-ring .progress { stroke: var(--accent); stroke-dasharray: 56.5; stroke-dashoffset: 56.5; transition: stroke-dashoffset 0.3s ease; }

        /* Fox Expression Wheel - Interactive mood selector */
        .fox-expression-wheel {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 200px;
            height: 200px;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 50;
            pointer-events: none;
        }
        .fox-expression-wheel.visible {
            opacity: 1;
            visibility: visible;
        }
        .expression-btn {
            position: absolute;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--bg-card);
            border: 1px solid var(--glass-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s;
            backdrop-filter: blur(10px);
            z-index: 51;
        }
        .expression-btn:hover {
            transform: scale(1.2);
            background: rgba(255,200,100,0.2);
            border-color: var(--primary);
            box-shadow: 0 0 15px rgba(255,200,100,0.3);
        }

        /* New: Glassmorphism card with depth */
        .glass-card-v2 {
            background: linear-gradient(135deg, 
                rgba(255,255,255,0.08) 0%, 
                rgba(255,255,255,0.03) 50%,
                rgba(255,255,255,0.01) 100%);
            backdrop-filter: blur(40px) saturate(200%);
            -webkit-backdrop-filter: blur(40px) saturate(200%);
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 
                0 8px 32px rgba(0,0,0,0.3),
                0 2px 8px rgba(0,0,0,0.2) inset,
                0 0 0 1px rgba(255,255,255,0.02) inset;
        }

        /* New: Animated counter with odometer effect */
        .odometer {
            font-variant-numeric: tabular-nums;
            transition: transform 0.15s ease-out;
        }
        .odometer.changing {
            animation: odometerRoll 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        @keyframes odometerRoll {
            0% { transform: translateY(-8px); opacity: 0.4; }
            50% { transform: translateY(4px); }
            100% { transform: translateY(0); opacity: 1; }
        }

        /* New: Status aura - ambient glow around avatar section */
        .avatar-aura {
            position: absolute;
            inset: -40px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.12) 0%, transparent 70%);
            animation: auraRotate 12s linear infinite;
            pointer-events: none;
        }
        @keyframes auraRotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .avatar-aura::before {
            content: '';
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            background: conic-gradient(from 0deg, transparent, rgba(255,200,100,0.1), transparent, rgba(0,212,255,0.1), transparent);
            animation: auraRotate 8s linear infinite reverse;
        }

        /* New: Subtle grid background pattern */
        .grid-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background-image: 
                linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
            background-size: 40px 40px;
            mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 0%, transparent 100%);
        }

        /* New: Toast notification - improved */
        .toast-v2 {
            padding: 12px 18px;
            background: rgba(10,10,18,0.9);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
            font-size: 12px;
            color: var(--text);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.02) inset;
            animation: toastSlide 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            display: flex;
            align-items: center;
            gap: 10px;
            max-width: 300px;
        }
        .toast-v2 .icon { font-size: 16px; }
        .toast-v2.success { border-left: 3px solid var(--success); }
        .toast-v2.warning { border-left: 3px solid var(--warning); }
        .toast-v2.error { border-left: 3px solid var(--danger); }
        .toast-v2.info { border-left: 3px solid var(--accent); }
        @keyframes toastSlide {
            from { transform: translateX(110%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .toast-v2 .close-btn {
            background: none;
            border: none;
            color: var(--text-dim);
            font-size: 16px;
            cursor: pointer;
            padding: 0 0 0 8px;
            margin-left: auto;
            transition: color 0.2s;
        }
        .toast-v2 .close-btn:hover { color: var(--text); }

        /* New: Interactive ripple on any clickable element */
        .ripple-container { position: relative; overflow: hidden; }
        .ripple-el {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.25) 0%, transparent 70%);
            transform: scale(0);
            animation: rippleEl 0.6s ease-out;
            pointer-events: none;
        }
        @keyframes rippleEl {
            to { transform: scale(4); opacity: 0; }
        }

        /* New: Animated gradient text */
        .gradient-text {
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--primary));
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 4s linear infinite;
        }
        @keyframes gradientShift {
            0% { background-position: 0% center; }
            100% { background-position: 200% center; }
        }

        /* New: Cursor follower */
        .cursor-follower {
            position: fixed;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(255,200,100,0.3);
            pointer-events: none;
            z-index: 9999;
            transition: transform 0.1s ease, width 0.2s, height 0.2s;
            mix-blend-mode: screen;
        }
        .cursor-follower.hover {
            width: 24px;
            height: 24px;
            background: rgba(0,212,255,0.3);
        }

        /* New: Blob animation for organic background */
        .blob {
            position: fixed;
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            filter: blur(80px);
            z-index: 0;
            pointer-events: none;
            animation: blobFloat 15s ease-in-out infinite;
        }
        .blob-1 { width: 500px; height: 500px; background: rgba(255,180,80,0.08); top: -150px; left: -150px; }
        .blob-2 { width: 400px; height: 400px; background: rgba(0,200,255,0.07); top: 30%; right: -100px; animation-delay: -5s; }
        .blob-3 { width: 350px; height: 350px; background: rgba(92,219,149,0.06); bottom: -100px; left: 20%; animation-delay: -10s; }
        @keyframes blobFloat {
            0%, 100% { border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; transform: translate(0, 0) scale(1); }
            25% { border-radius: 60% 40% 55% 45% / 55% 45% 60% 40%; transform: translate(20px, -20px) scale(1.05); }
            50% { border-radius: 45% 55% 45% 55% / 50% 50% 50% 50%; transform: translate(-15px, 15px) scale(0.95); }
            75% { border-radius: 55% 45% 60% 40% / 45% 55% 45% 55%; transform: translate(10px, 10px) scale(1.02); }
        }

        /* New: Notification badge pop */
        .notif-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            min-width: 16px;
            height: 16px;
            background: var(--danger);
            border-radius: 8px;
            font-size: 9px;
            font-weight: 700;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            animation: badgePop 0.3s ease;
            box-shadow: 0 2px 8px rgba(255,107,107,0.4);
        }
        @keyframes badgePop {
            0% { transform: scale(0); }
            60% { transform: scale(1.3); }
            100% { transform: scale(1); }
        }

        /* New: Vignette overlay */
        .vignette {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 2;
            background: radial-gradient(ellipse 80% 70% at 50% 50%, transparent 40%, rgba(0,0,0,0.3) 100%);
        }

        /* Status timeline v2 */
        .status-timeline-v2 {
            display: flex;
            align-items: center;
            gap: 0;
            margin: 12px 0;
        }
        .timeline-step {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            position: relative;
        }
        .timeline-step::before {
            content: '';
            position: absolute;
            top: 10px;
            left: 50%;
            right: -50%;
            height: 2px;
            background: var(--glass-border);
            z-index: 0;
        }
        .timeline-step:last-child::before { display: none; }
        .timeline-step.completed::before { background: var(--success); }
        .timeline-step.active .step-dot {
            background: var(--accent);
            box-shadow: 0 0 12px var(--accent);
            animation: stepPulse 1.5s ease-in-out infinite;
        }
        .step-dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--glass);
            border: 2px solid var(--glass-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            z-index: 1;
            transition: all 0.3s;
        }
        .timeline-step.completed .step-dot {
            background: var(--success);
            border-color: var(--success);
        }
        .step-label { font-size: 7px; color: var(--text-dim); text-align: center; }
        .timeline-step.active .step-label { color: var(--accent); }
        @keyframes stepPulse {
            0%, 100% { box-shadow: 0 0 8px var(--accent); }
            50% { box-shadow: 0 0 20px var(--accent); }
        }

        /* New: Shimmer loading effect */
        .shimmer {
            position: relative;
            overflow: hidden;
        }
        .shimmer::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
            animation: shimmerMove 1.5s ease-in-out infinite;
        }
        @keyframes shimmerMove {
            0% { transform: translateX(-150%); }
            100% { transform: translateX(150%); }
        }

        /* Confetti celebration effect */
        .confetti {
            position: fixed;
            width: 8px;
            height: 8px;
            pointer-events: none;
            z-index: 9999;
            animation: confettiFall 3s ease-in forwards;
        }
        @keyframes confettiFall {
            0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }

        /* Focus ring animation */
        .focus-ring {
            position: absolute;
            inset: -3px;
            border-radius: inherit;
            border: 2px solid var(--accent);
            opacity: 0;
            animation: focusRingPulse 2s ease-in-out infinite;
        }
        @keyframes focusRingPulse {
            0%, 100% { opacity: 0; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.05); }
        }

        /* Radar pulse animation for "scanning" status */
        .radar-pulse {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 1px solid var(--accent);
            opacity: 0;
            animation: radarSweep 2s ease-out infinite;
        }
        @keyframes radarSweep {
            0% { transform: scale(0.5); opacity: 0.8; }
            100% { transform: scale(2); opacity: 0; }
        }

        /* Magnetic hover effect on buttons */
        .magnetic-btn {
            transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
        }
        .magnetic-btn:hover {
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 8px 24px rgba(0,0,0,0.25);
        }

        /* Glass toggle button */
        .glass-toggle {
            position: relative;
            width: 44px;
            height: 24px;
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            overflow: hidden;
        }
        .glass-toggle::after {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            width: 18px;
            height: 18px;
            background: var(--accent);
            border-radius: 50%;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 2px 8px rgba(0,212,255,0.4);
        }
        .glass-toggle.active { background: rgba(0,212,255,0.15); border-color: rgba(0,212,255,0.3); }
        .glass-toggle.active::after { transform: translateX(20px); }

        /* Pulse dot */
        .pulse-dot {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .pulse-dot::after {
            content: '';
            position: absolute;
            inset: -3px;
            border-radius: 50%;
            border: 2px solid currentColor;
            animation: pulseDotAnim 1.5s ease-out infinite;
            opacity: 0;
        }
        @keyframes pulseDotAnim {
            0% { transform: scale(0.8); opacity: 0.8; }
            100% { transform: scale(1.8); opacity: 0; }
        }

        /* Responsive: Mobile optimizations */
        @media (max-width: 480px) {
            .main-card { padding: 20px; border-radius: 24px; }
            .avatar-section { width: 80px; height: 80px; margin-bottom: 14px; }
            .avatar { font-size: 36px; }
            .avatar-ring { inset: -4px; }
            .header { flex-direction: column; gap: 8px; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
            .stat-card { padding: 12px 10px; }
            .stat-value { font-size: 22px; }
            .stat-label { font-size: 9px; }
            .mini-stats { gap: 6px; }
            .mini-stat { padding: 8px; }
            .current-task { font-size: 12px; }
            .action-buttons { gap: 8px; }
            .action-btn { padding: 8px 14px; font-size: 11px; }
            .kbd-hint { font-size: 9px; padding: 3px 6px; }
            .cmd-hint { font-size: 10px; }
            .viz-container { grid-template-columns: 1fr; gap: 12px; }
            .system-status { flex-wrap: wrap; justify-content: center; bottom: 8px; right: 8px; }
            .status-badge { padding: 4px 8px; font-size: 7px; }
            .version-tag { bottom: 8px; left: 8px; font-size: 7px; }
            .power-indicator { top: 8px; left: 8px; }
            .live-activity { top: 8px; }
            .live-activity-pill { padding: 4px 10px 4px 8px; }
            .live-activity-title { font-size: 9px; max-width: 120px; }
            .live-activity-subtitle { font-size: 6.5px; }
        }

        @media (max-width: 380px) {
            .main-card { padding: 18px; border-radius: 24px; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .stat-card { padding: 12px 8px; }
            .stat-value { font-size: 13px; }
            .mini-stats { gap: 6px; }
            .quick-actions { gap: 6px; }
            .action-btn { padding: 6px 12px; font-size: 8px; }
            .avatar-section { width: 80px; height: 80px; }
            .avatar { font-size: 36px; }
            .name { font-size: 20px; }
        }

        /* Touch device optimizations */
        @media (hover: none) and (pointer: coarse) {
            .main-card:active { transform: translateY(-4px) scale(0.98); }
            .stat-card:active { transform: scale(0.96); }
            .action-btn:active { transform: scale(0.92); }
        }

        /* Ultra small screens */
        @media (max-width: 360px) {
            .main-card { padding: 16px; }
            .stats-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
            .stat-card { padding: 10px 8px; }
            .name { font-size: 20px; }
            .status { font-size: 9px; letter-spacing: 2px; }
        }

        /* Dark mode enhancement */
        @media (prefers-color-scheme: dark) {
            :root { --bg-dark: #050508; --bg-card: rgba(10,10,18,0.92); }
        }

        /* High contrast mode support */
        @media (prefers-contrast: high) {
            :root {
                --text: #ffffff;
                --text-dim: #aaaaaa;
                --glass-border: rgba(255,255,255,0.2);
            }
        }

        /* Reduced motion support */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }

        /* Gaming mode */
        .gaming { 
            --primary: #ff3366;
            --primary-glow: #ff6699;
            --accent: #00ffcc;
        }
        .gaming .avatar { filter: drop-shadow(0 0 15px rgba(255,51,102,0.6)); }
        .gaming .main-card { border-color: rgba(255,51,102,0.3); }

        /* Focus mode */
        .focus-mode .particles,
        .focus-mode .wave-bg,
        .focus-mode .morph-shape,
        .focus-mode .glow-orb,
        .focus-mode .orb { opacity: 0.2; }

        /* Celebration effect */
        @keyframes celebrate {
            0%, 100% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.1) rotate(-5deg); }
            50% { transform: scale(1.15) rotate(0deg); }
            75% { transform: scale(1.1) rotate(5deg); }
        }
        .avatar.celebrating { animation: celebrate 0.6s ease-in-out infinite; filter: drop-shadow(0 0 20px rgba(255,215,0,0.8)); }
        
        /* === v10.1: Notification Center Styles === */
        .notif-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 10px;
            margin-bottom: 8px;
            animation: fadeInNotif 0.3s ease;
        }
        @keyframes fadeInNotif {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }
        .notif-icon { font-size: 16px; flex-shrink: 0; }
        .notif-text { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .notif-time { font-size: 11px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; flex-shrink: 0; }
        .notif-empty { text-align: center; color: var(--text-dim); font-size: 14px; padding: 40px 0; }
        .notif-item.success { border-left: 3px solid var(--success); }
        .notif-item.error { border-left: 3px solid var(--danger); }
        .notif-item.warning { border-left: 3px solid var(--warning); }
        .notif-item.info { border-left: 3px solid var(--accent); }
        #notifPanel.open { right: 0; }
        #notifPanel::-webkit-scrollbar { width: 4px; }
        #notifPanel::-webkit-scrollbar-track { background: transparent; }
        #notifPanel::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 2px; }
    </style><style>
        
        .ripple { position: absolute; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%); transform: scale(0); animation: rippleAnim 0.7s ease-out; pointer-events: none; }
        @keyframes rippleAnim { to { transform: scale(4); opacity: 0; } }
        
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
