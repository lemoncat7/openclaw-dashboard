        .logo-pill:hover { background: rgba(255,200,100,0.1); border-color: var(--primary-dim); }
        
        .avatar-section { width: 100px; height: 100px; margin: 0 auto 18px; position: relative; }
        .avatar-section canvas { position: absolute; inset: 0; width: 100%; height: 100%; border-radius: 50%; }
        .avatar-ring { position: absolute; inset: -6px; border-radius: 50%; background: conic-gradient(from 0deg, var(--primary), var(--accent), var(--success), var(--primary-glow), var(--primary)); animation: ringRotate 10s linear infinite; opacity: 0.75; }
        .avatar-ring::before { content: ''; position: absolute; inset: -12px; border-radius: 50%; background: conic-gradient(from 0deg, transparent, rgba(255,200,100,0.12), transparent); animation: ringGlow 5s ease-in-out infinite; }
        @keyframes ringRotate { to { transform: rotate(360deg); } }
        @keyframes ringGlow { 0%, 100% { opacity: 0.5; transform: scale(1); } 50% { opacity: 1; transform: scale(1.18); } }
        .avatar-glow { position: absolute; inset: -25px; border-radius: 50%; background: radial-gradient(circle, rgba(255,200,100,0.18) 0%, transparent 65%); animation: glowPulse 4.5s ease-in-out infinite; }
        @keyframes glowPulse { 0%, 100% { transform: scale(1); opacity: 0.5; } 50% { transform: scale(1.2); opacity: 0.8; } }
        .avatar-inner { position: absolute; inset: 6px; background: linear-gradient(145deg, #1a1a24, #0d0d14); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 16px rgba(0,0,0,0.5) inset; }
        
        .avatar { font-size: 44px; animation: avatarBounce 4.5s ease-in-out infinite; filter: drop-shadow(0 0 8px rgba(255,200,100,0.45)); transition: transform 0.3s, filter 0.3s, scale 0.2s; cursor: pointer; position: relative; user-select: none; -webkit-tap-highlight-color: transparent; }
        .avatar:active { transform: scale(0.92); }
        .avatar::before { content: ''; position: absolute; inset: -5px; border-radius: 50%; background: radial-gradient(circle, rgba(255,200,100,0.3) 0%, transparent 70%); opacity: 0; transition: opacity 0.3s; }
        .avatar:hover::before { opacity: 1; animation: avatarHoverPulse 1s ease-in-out infinite; }
        @keyframes avatarHoverPulse { 0%, 100% { transform: scale(1); opacity: 0.5; } 50% { transform: scale(1.3); opacity: 0.8; } }
        @keyframes avatarBounce { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-4px) scale(1.02); } }
        .avatar.working { animation: avatarWorking 1s ease-in-out infinite; filter: drop-shadow(0 0 12px rgba(0,212,255,0.6)); }
        @keyframes avatarWorking { 0%, 100% { transform: translateY(0) rotate(0deg) scale(1); } 25% { transform: translateY(-6px) rotate(-5deg) scale(1.04); } 75% { transform: translateY(-6px) rotate(5deg) scale(1.04); } }
        .avatar.excited { animation: avatarExcited 0.5s ease-in-out infinite; }
        @keyframes avatarExcited { 0%, 100% { transform: scale(1) rotate(0deg); } 25% { transform: scale(1.15) rotate(-10deg); } 75% { transform: scale(1.15) rotate(10deg); } }
        .avatar.sleeping { animation: avatarSleep 3.5s ease-in-out infinite; filter: drop-shadow(0 0 5px rgba(100,150,255,0.35)); }
        @keyframes avatarSleep { 0%, 100% { transform: translateY(0) scale(1); opacity: 1; } 50% { transform: translateY(2px) scale(0.97); opacity: 0.75; } }
        .avatar.thinking { animation: avatarThinking 2s ease-in-out infinite; }
        @keyframes avatarThinking { 0%, 100% { transform: translateY(0) rotate(0deg); } 25% { transform: translateY(-3px) rotate(-3deg); } 75% { transform: translateY(-3px) rotate(3deg); } }
        
        /* New: Laughing state */
        .avatar.laughing { animation: avatarLaughing 0.4s ease-in-out infinite; }
        @keyframes avatarLaughing { 0%, 100% { transform: scale(1) rotate(0deg); } 25% { transform: scale(1.1) rotate(-8deg); } 50% { transform: scale(1.15) rotate(0deg); } 75% { transform: scale(1.1) rotate(8deg); } }
        
        /* Enhanced status glow transitions */
        .avatar-glow {
            position: absolute;
            inset: -25px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,200,100,0.18) 0%, transparent 65%);
            animation: glowPulse 4.5s ease-in-out infinite;
            transition: background 0.5s ease, opacity 0.3s ease;
        }
        
        /* Status-aware glow colors */
        .avatar-glow.idle { background: radial-gradient(circle, rgba(255,200,100,0.18) 0%, transparent 65%); }
        .avatar-glow.working { background: radial-gradient(circle, rgba(0,212,255,0.25) 0%, transparent 65%); animation: glowPulseWorking 2s ease-in-out infinite; }
        .avatar-glow.sleeping { background: radial-gradient(circle, rgba(136,146,176,0.15) 0%, transparent 65%); animation: glowPulseSleep 6s ease-in-out infinite; }
        .avatar-glow.excited { background: radial-gradient(circle, rgba(255,159,243,0.25) 0%, transparent 65%); animation: glowPulseExcited 1s ease-in-out infinite; }
        .avatar-glow.thinking { background: radial-gradient(circle, rgba(162,155,254,0.2) 0%, transparent 65%); animation: glowPulseThinking 3s ease-in-out infinite; }
        .avatar-glow.laughing { background: radial-gradient(circle, rgba(255,200,100,0.22) 0%, transparent 65%); animation: glowPulseLaughing 0.8s ease-in-out infinite; }
        .avatar-glow.error { background: radial-gradient(circle, rgba(255,107,107,0.25) 0%, transparent 65%); animation: glowPulseError 1s ease-in-out infinite; }
        
        @keyframes glowPulseWorking { 0%, 100% { transform: scale(1); opacity: 0.5; } 50% { transform: scale(1.25); opacity: 0.8; } }
        @keyframes glowPulseSleep { 0%, 100% { transform: scale(1); opacity: 0.3; } 50% { transform: scale(1.1); opacity: 0.5; } }
        @keyframes glowPulseExcited { 0%, 100% { transform: scale(1); opacity: 0.6; } 50% { transform: scale(1.4); opacity: 1; } }
        @keyframes glowPulseThinking { 0%, 100% { transform: scale(1); opacity: 0.4; } 50% { transform: scale(1.15); opacity: 0.7; } }
        @keyframes glowPulseLaughing { 0%, 100% { transform: scale(1); opacity: 0.5; } 50% { transform: scale(1.3); opacity: 0.9; } }
        @keyframes glowPulseError { 0%, 100% { transform: scale(1); opacity: 0.5; } 25% { transform: scale(1.2); opacity: 0.8; } 75% { transform: scale(1.2); opacity: 0.8; } }
        
        /* New: New message notification pulse */
        .avatar.has-message { animation: avatarNewMessage 1.5s ease-in-out infinite; }
        @keyframes avatarNewMessage { 0%, 100% { filter: drop-shadow(0 0 8px rgba(255,200,100,0.45)); } 50% { filter: drop-shadow(0 0 20px rgba(0,212,255,0.8)); } }
        
        /* New: Error state */
        .avatar.error { animation: avatarError 0.6s ease-in-out; filter: drop-shadow(0 0 15px rgba(255,107,107,0.8)); }
        @keyframes avatarError { 0%, 100% { transform: translateX(0); } 20% { transform: translateX(-8px); } 40% { transform: translateX(8px); } 60% { transform: translateX(-5px); } 80% { transform: translateX(5px); } }
        
        .mood-bar { height: 4px; background: var(--glass); border-radius: 2px; margin: 6px 22px 16px; overflow: hidden; position: relative; }
        .mood-bar::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent); animation: shimmer 2s linear infinite; }
        @keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        .mood-bar-fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--accent), var(--success), var(--primary), var(--accent)); background-size: 200% 100%; transition: width 1s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 0 14px rgba(0,212,255,0.5); position: relative; animation: gradientFlow 3s ease infinite; }
        @keyframes gradientFlow { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
        .mood-bar-fill::after { content: ''; position: absolute; right: 3px; top: 50%; transform: translateY(-50%); width: 7px; height: 7px; background: #fff; border-radius: 50%; box-shadow: 0 0 12px rgba(255,255,255,0.95), 0 0 20px var(--accent); }
        
        .mood-indicator { display: flex; justify-content: center; gap: 10px; margin-bottom: 16px; }
        .mood-pill { padding: 5px 13px; border-radius: 14px; font-size: 8px; text-transform: uppercase; letter-spacing: 0.8px; background: var(--glass); border: 1px solid var(--glass-border); color: var(--text-dim); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
        .mood-pill:hover { transform: scale(1.05); background: rgba(255,200,100,0.08); }
