            2: '#ff9f43',  // Orange body
            3: '#ffffff',  // White details
            // v14.2: New depth colors
            4: '#ffcc66',  // Orange highlight (fur shine)
            5: '#e08820',  // Orange shadow (fur depth)
            6: '#ffb347',  // Orange mid-tone
            7: '#ffd493',  // Light orange (cheek highlight)
            8: '#c07020',  // Dark orange (shadow)
        };
        
        // Status-specific accent colors (v14.0 enhanced)
        const foxAccentColors = {
            idle: '#ff9f43',
            working: '#00d4ff',
            sleeping: '#5f6caf',
            excited: '#ff6b9d',
            thinking: '#a55eea',
            laughing: '#ffc864',
            error: '#ff6b6b',
            // v14.0: New states
            focused: '#00ff88',
            learning: '#ff9500'
        };
        
        let currentFoxStatus = 'idle';
        let foxAnimationFrame = 0;
        let foxAnimating = true;
        
        function drawFox(status = 'idle', frame = 0) {
            const ctx = foxCtx;
            const canvas = foxCanvas;
            const pixelSize = canvas.width / 16;
            
            // Clear canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Get design for current status
            const design = foxDesign[status] || foxDesign.idle;
            const accentColor = foxAccentColors[status] || foxAccentColors.idle;
            
            // v15.5: Enable anti-aliasing for smoother pixel rendering
            ctx.imageSmoothingEnabled = true;
            ctx.imageSmoothingQuality = 'high';
            
            // v15.5: Draw soft shadow under fox
            ctx.save();
            ctx.globalAlpha = 0.2 + Math.sin(frame * 0.05) * 0.05;
            const shadowOffset = 3 + Math.sin(frame * 0.08) * 1;
            const shadowGradient = ctx.createRadialGradient(
                canvas.width / 2, canvas.height / 2 + shadowOffset,
                0,
                canvas.width / 2, canvas.height / 2 + shadowOffset,
                canvas.width * 0.45
            );
            shadowGradient.addColorStop(0, 'rgba(0,0,0,0.4)');
            shadowGradient.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = shadowGradient;
            ctx.beginPath();
            ctx.ellipse(canvas.width / 2, canvas.height / 2 + shadowOffset, canvas.width * 0.4, canvas.height * 0.15, 0, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
            
            // Draw fox pixels
            for (let y = 0; y < 16; y++) {
                for (let x = 0; x < 16; x++) {
                    const colorCode = design[y][x];
                    if (colorCode !== 0) {
                        // Add slight animation offset for working state
                        let drawX = x * pixelSize;
                        let drawY = y * pixelSize;
                        
                        if (status === 'working') {
                            drawY += Math.sin(frame * 0.2 + x * 0.3) * 0.5;
                        } else if (status === 'excited') {
                            drawY += Math.sin(frame * 0.3 + x * 0.5) * 1;
                        } else if (status === 'laughing') {
                            drawX += Math.sin(frame * 0.4 + y * 0.4) * 0.8;
                        } else if (status === 'idle') {
                            // v12.2: Subtle idle breathing bob
                            drawY += Math.sin(frame * 0.08 + x * 0.2) * 0.6;
                            drawX += Math.cos(frame * 0.06 + y * 0.15) * 0.3;
                        }
                        
                        // v15.5: Draw with subtle rounded corners for softer look
                        ctx.fillStyle = foxColors[colorCode];
                        ctx.beginPath();
                        const radius = pixelSize * 0.15;
                        const r = Math.min(pixelSize / 2, radius);
                        ctx.roundRect(drawX, drawY, pixelSize, pixelSize, r);
                        ctx.fill();
                    }
                }
            }
            
            // v15.5: Enhanced glow effect with color gradient
            ctx.save();
            const glowAlpha = 0.12 + Math.sin(frame * 0.1) * 0.05;
            const glowGradient = ctx.createRadialGradient(
                canvas.width / 2, canvas.height / 2, 0,
                canvas.width / 2, canvas.height / 2, canvas.width * 0.5
            );
            glowGradient.addColorStop(0, accentColor.replace(')', `, ${glowAlpha})`).replace('#', 'rgba(').replace(/([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})/i, (m, r, g, b) => `rgba(${parseInt(r,16)},${parseInt(g,16)},${parseInt(b,16)},${glowAlpha})`));
            glowGradient.addColorStop(0.5, accentColor.replace(')', `, ${glowAlpha * 0.5})`).replace('#', 'rgba(').replace(/([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})/i, (m, r, g, b) => `rgba(${parseInt(r,16)},${parseInt(g,16)},${parseInt(b,16)},${glowAlpha * 0.5})`));
            glowGradient.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = glowGradient;
            ctx.beginPath();
            ctx.arc(canvas.width / 2, canvas.height / 2, canvas.width * 0.5, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
            
            // Draw status-specific glow effect
            if (status !== 'idle') {
                ctx.save();
                ctx.globalAlpha = 0.15 + Math.sin(frame * 0.1) * 0.05;
                ctx.fillStyle = accentColor;
                ctx.beginPath();
                ctx.arc(canvas.width / 2, canvas.height / 2, canvas.width * 0.4, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
            
            // Draw sparkle effects for excited state
            if (status === 'excited' && frame % 20 < 10) {
                ctx.fillStyle = '#fff';
                const sparklePositions = [[3, 2], [12, 3], [2, 8], [13, 7]];
                sparklePositions.forEach(([sx, sy], i) => {
                    if ((frame + i * 5) % 30 < 15) {
                        ctx.beginPath();
                        ctx.arc(sx * pixelSize + pixelSize/2, sy * pixelSize + pixelSize/2, 1.5, 0, Math.PI * 2);
                        ctx.fill();
                    }
                });
            }
            
            // v14.0: Draw laser focus effect for focused state
            if (status === 'focused' && frame % 15 < 8) {
                ctx.fillStyle = '#00ff88';
                const focusPos = [[7, 1], [8, 1], [7, 2], [8, 2]];
                focusPos.forEach(([sx, sy]) => {
                    ctx.beginPath();
                    ctx.arc(sx * pixelSize + pixelSize/2, sy * pixelSize + pixelSize/2, 1, 0, Math.PI * 2);
                    ctx.fill();
                });
                // Draw target rings
                ctx.strokeStyle = '#00ff88';
                ctx.globalAlpha = 0.3;
                ctx.lineWidth = 0.5;
                ctx.beginPath();
                ctx.arc(8 * pixelSize, 4 * pixelSize, 6 * pixelSize * (frame % 15) / 15, 0, Math.PI * 2);
                ctx.stroke();
                ctx.globalAlpha = 1;
            }
            
            // v14.0: Draw book/study effect for learning state
            if (status === 'learning') {
                ctx.fillStyle = '#ff9500';
                ctx.fillRect(12 * pixelSize, 2 * pixelSize, 3 * pixelSize, 2 * pixelSize);
                ctx.fillStyle = '#fff';
                ctx.fillRect(12.3 * pixelSize, 2.3 * pixelSize, 2.4 * pixelSize, 0.2 * pixelSize);
                ctx.fillRect(12.3 * pixelSize, 2.7 * pixelSize, 2.4 * pixelSize, 0.2 * pixelSize);
            }
            
            // Draw Zzz for sleeping
            if (status === 'sleeping') {
                ctx.fillStyle = '#5f6caf';
                ctx.font = '8px JetBrains Mono';
                ctx.fillText('z', 10 * pixelSize, 3 * pixelSize);
                if (frame % 40 > 20) {
                    ctx.fillText('z', 11 * pixelSize, 2.5 * pixelSize);
                }
                if (frame % 60 > 40) {
                    ctx.fillText('z', 12 * pixelSize, 2 * pixelSize);
                }
            }
        }
        
        // Animation loop for fox
        function animateFox() {
            if (foxAnimating) {
                foxAnimationFrame++;
                drawFox(currentFoxStatus, foxAnimationFrame);
            }
            requestAnimationFrame(animateFox);
        }
        
        // Start fox animation
        animateFox();
        
        // v14.0: Enhanced Fox Status Change with Quantum Effects
        window.setFoxStatus = function(status) {
            const prevStatus = currentFoxStatus;
            currentFoxStatus = status;
            
            // Update avatar emoji as fallback
            const moodMap = { 
                idle: '🦊', working: '⚡', sleeping: '😴', excited: '🤩', 
                thinking: '🤔', laughing: '😂', error: '😵',
                focused: '🎯', learning: '📚' // v14.0 new states
            };
            document.getElementById('avatar').textContent = moodMap[status] || '🦊';
            document.getElementById('moodEmoji').textContent = moodMap[status] || '🦊';
            
            // Update status-specific accent colors for glow (v14.0)
            foxAccentColors.idle = '#ff9f43';
            foxAccentColors.working = '#00d4ff';
            foxAccentColors.sleeping = '#5f6caf';
            foxAccentColors.excited = '#ff6b9d';
            foxAccentColors.thinking = '#a55eea';
            foxAccentColors.laughing = '#ffc864';
            foxAccentColors.error = '#ff6b6b';
            foxAccentColors.focused = '#00ff88'; // v14.0
            foxAccentColors.learning = '#ff9500'; // v14.0
            
            // v14.0: Apply Fox Glow Class based on status
            const foxCanvasEl = document.getElementById('foxCanvas');
            if (foxCanvasEl) {
                foxCanvasEl.classList.remove('fox-glow-working', 'fox-glow-sleeping', 'fox-glow-excited', 'fox-glow-thinking', 'fox-glow-laughing', 'fox-glow-error', 'fox-glow-focused', 'fox-glow-learning', 'breathing-fox');
                foxCanvasEl.classList.add(`fox-glow-${status}`);
                if (status === 'idle') foxCanvasEl.classList.add('breathing-fox');
                // v14.0: Add quantum effect for new states
                if (status === 'focused' || status === 'learning') {
                    foxCanvasEl.classList.add('fox-quantum');
                    setTimeout(() => foxCanvasEl.classList.remove('fox-quantum'), 500);
                }
            }
            
            // v11.8: Trigger particle burst on status change
            if (prevStatus !== status) {
                triggerFoxParticleBurst(status);
                addTimelineEvent(`状态切换: ${prevStatus} → ${status}`, 'info');
            }
        };
        
        // v14.0: Fox Particle Burst Effect with Enhanced Colors
        function triggerFoxParticleBurst(status) {
            const foxContainer = document.querySelector('.fox-container');
            if (!foxContainer) return;
            
            const colors = {
                working: ['#00d4ff', '#00ffff', '#00bfff'],
                sleeping: ['#5f6caf', '#7986cb', '#9fa8da'],
                excited: ['#ff6b9d', '#ffc864', '#ffeb3b'],
                thinking: ['#a55eea', '#9c27b0', '#e91e63'],
                laughing: ['#ffc864', '#ffeb3b', '#5cdb95'],
                error: ['#ff6b6b', '#ef4444', '#dc2626'],
                idle: ['#ffc864', '#ffaa33', '#ffe0a0'],
                focused: ['#00ff88', '#00ffaa', '#88ffcc'], // v14.0
                learning: ['#ff9500', '#ffb347', '#ffd700']  // v14.0
            };
            
            const particleColors = colors[status] || colors.idle;
            const particleCount = 12;
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'fox-particle';
                particle.style.background = particleColors[i % particleColors.length];
                particle.style.left = '50%';
                particle.style.top = '50%';
                particle.style.animationDelay = `${i * 30}ms`;
                
                const angle = (i / particleCount) * Math.PI * 2;
                const distance = 30 + Math.random() * 20;
                const tx = Math.cos(angle) * distance;
                const ty = Math.sin(angle) * distance;
                
                particle.style.setProperty('--tx', `${tx}px`);
                particle.style.setProperty('--ty', `${ty}px`);
                particle.style.animation = `foxParticleBurst 0.8s ease-out forwards`;
                
                foxContainer.appendChild(particle);
                setTimeout(() => particle.remove(), 1000);
            }
        }
        
        // v11.8: Add particle burst animation
        const foxParticleBurstStyle = document.createElement('style');
        foxParticleBurstStyle.textContent = `
            @keyframes foxParticleBurst {
                0% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
                100% { opacity: 0; transform: translate(calc(-50% + var(--tx)), calc(-50% + var(--ty))) scale(0); }
            }
        `;
        document.head.appendChild(foxParticleBurstStyle);
        
        // v11.8: Fox Click Interaction Enhancement
        if (foxCanvas) {
            foxCanvas.style.cursor = 'pointer';
            foxCanvas.addEventListener('click', (e) => {
                // Add XP for clicking fox
                updateXP(1);
                showToast('🦊 +1 XP!', 'success', 1500);
                
                // Create ripple effect at click position
                const rect = foxCanvas.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                createFoxClickRipple(x, y);
            });
        }
        
        function createFoxClickRipple(x, y) {
            const foxContainer = document.querySelector('.fox-container');
            if (!foxContainer) return;
            
            const ripple = document.createElement('div');
            ripple.style.cssText = `
                position: absolute;
                width: 60px;
                height: 60px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(255,200,100,0.4) 0%, transparent 70%);
                left: ${x - 30}px;
                top: ${y - 30}px;
                pointer-events: none;
                animation: foxRippleExpand 0.6s ease-out forwards;
                z-index: 100;
            `;
            foxContainer.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);
            
            // Add ripple animation style if not exists
            if (!document.getElementById('foxRippleAnim')) {
                const style = document.createElement('style');
                style.id = 'foxRippleAnim';
                style.textContent = `
                    @keyframes foxRippleExpand {
                        0% { transform: scale(0); opacity: 1; }
                        100% { transform: scale(2); opacity: 0; }
                    }
                `;
                document.head.appendChild(style);
            }
        }
        
        // ===== Mouse Tracking for Fox Eyes (v14.0 Enhanced) =====
        let mouseX = 50, mouseY = 50;
        let pupilOffsetX = 0, pupilOffsetY = 0; // v14.0: Smooth eye tracking
        document.addEventListener('mousemove', (e) => {
            const rect = foxCanvas.getBoundingClientRect();
            mouseX = ((e.clientX - rect.left) / rect.width) * 100;
            mouseY = ((e.clientY - rect.top) / rect.height) * 100;
        });
        
        // Enhanced fox drawing with eye tracking
        const originalDrawFox = drawFox;
        drawFox = function(status = 'idle', frame = 0) {
            const ctx = foxCtx;
            const canvas = foxCanvas;
            const pixelSize = canvas.width / 16;
            
            // Clear canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Get design for current status
            const design = foxDesign[status] || foxDesign.idle;
            const accentColor = foxAccentColors[status] || foxAccentColors.idle;
            
            // Draw fox pixels
            for (let y = 0; y < 16; y++) {
                for (let x = 0; x < 16; x++) {
                    const colorCode = design[y][x];
                    if (colorCode !== 0) {
                        // Add slight animation offset for working state
                        let drawX = x * pixelSize;
                        let drawY = y * pixelSize;
                        
                        if (status === 'working') {
                            drawY += Math.sin(frame * 0.2 + x * 0.3) * 0.5;
                        } else if (status === 'excited') {
                            drawY += Math.sin(frame * 0.3 + x * 0.5) * 1;
                        } else if (status === 'laughing') {
                            drawX += Math.sin(frame * 0.4 + y * 0.4) * 0.8;
                        } else if (status === 'thinking') {
                            // Thinking: subtle head wobble
                            drawY += Math.sin(frame * 0.15) * 1.5;
                            drawX += Math.cos(frame * 0.1) * 0.5;
                        } else if (status === 'idle') {
                            // v12.2: Subtle idle breathing bob
                            drawY += Math.sin(frame * 0.08 + x * 0.2) * 0.6;
                            drawX += Math.cos(frame * 0.06 + y * 0.15) * 0.3;
                        } else if (status === 'focused') {
                            // v14.0: Focused state - laser precision wobble
                            drawY += Math.sin(frame * 0.05) * 0.3;
                            drawX += Math.cos(frame * 0.03) * 0.2;
                        } else if (status === 'learning') {
                            // v14.0: Learning state - curious tilt
                            drawY += Math.sin(frame * 0.12 + x * 0.4) * 0.8;
                            drawX += Math.cos(frame * 0.08 + y * 0.3) * 0.5;
                        }
                        
                        ctx.fillStyle = foxColors[colorCode];
                        ctx.fillRect(drawX, drawY, pixelSize, pixelSize);
                    }
                }
            }
            
            // Draw enhanced status-specific glow effect with pulse
            if (status !== 'idle') {
                ctx.save();
                const glowIntensity = 0.15 + Math.sin(frame * 0.1) * 0.05;
                ctx.globalAlpha = glowIntensity;
                ctx.fillStyle = accentColor;
                ctx.beginPath();
                ctx.arc(canvas.width / 2, canvas.height / 2, canvas.width * 0.4, 0, Math.PI * 2);
                ctx.fill();
                
                // Inner glow ring
                ctx.globalAlpha = glowIntensity * 0.5;
                ctx.beginPath();
                ctx.arc(canvas.width / 2, canvas.height / 2, canvas.width * 0.3, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
            
            // Draw sparkle effects for excited state
            if (status === 'excited' && frame % 20 < 10) {
                ctx.fillStyle = '#fff';
                const sparklePositions = [[3, 2], [12, 3], [2, 8], [13, 7]];
                sparklePositions.forEach(([sx, sy], i) => {
                    if ((frame + i * 5) % 30 < 15) {
                        ctx.beginPath();
                        ctx.arc(sx * pixelSize + pixelSize/2, sy * pixelSize + pixelSize/2, 1.5, 0, Math.PI * 2);
                        ctx.fill();
                    }
                });
            }
            
            // Draw Zzz for sleeping
            if (status === 'sleeping') {
                ctx.fillStyle = '#5f6caf';
                ctx.font = '8px JetBrains Mono';
                ctx.fillText('z', 10 * pixelSize, 3 * pixelSize);
                if (frame % 40 > 20) {
                    ctx.fillText('z', 11 * pixelSize, 2.5 * pixelSize);
                }
                if (frame % 60 > 40) {
                    ctx.fillText('z', 12 * pixelSize, 2 * pixelSize);
                }
            }
            
            // Draw eyes with mouse tracking (v14.2: Enhanced with natural blinking)
            if (status === 'idle' || status === 'working' || status === 'thinking' || status === 'focused' || status === 'learning') {
                const eyeY = 5;
                const leftEyeX = 5;
                const rightEyeX = 10;
                const eyeSize = 1.2;
                
                // v14.2: Natural blinking - every 3-5 seconds
                const blinkCycle = frame % 180; // 3 seconds at 60fps
                const isBlinking = blinkCycle > 175; // Brief blink
                const blinkSquish = isBlinking ? 0.1 : 1;
                
                // v14.0: Smoother eye tracking with momentum
                const targetPupilOffsetX = (mouseX - 50) / 50 * 0.3;
                const targetPupilOffsetY = (mouseY - 50) / 50 * 0.3;
                
                // Apply smoother interpolation for focused/learning states
                const smoothingFactor = (status === 'focused' || status === 'learning') ? 0.15 : 0.25;
                pupilOffsetX = pupilOffsetX + (targetPupilOffsetX - pupilOffsetX) * smoothingFactor;
                pupilOffsetY = pupilOffsetY + (targetPupilOffsetY - pupilOffsetY) * smoothingFactor;
                
                // Draw white of eyes (squished during blink)
                ctx.fillStyle = '#ffffff';
                ctx.beginPath();
                ctx.ellipse(
                    (leftEyeX + eyeSize/2) * pixelSize, 
                    (eyeY + eyeSize/2) * pixelSize, 
                    eyeSize * pixelSize * 0.5, 
                    eyeSize * pixelSize * 0.5 * blinkSquish, 
                    0, 0, Math.PI * 2
                );
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(
                    (rightEyeX + eyeSize/2) * pixelSize, 
                    (eyeY + eyeSize/2) * pixelSize, 
                    eyeSize * pixelSize * 0.5, 
                    eyeSize * pixelSize * 0.5 * blinkSquish, 
                    0, 0, Math.PI * 2
                );
                ctx.fill();
                
                // Only draw pupils if not blinking
                if (!isBlinking) {
                    // Draw pupils with tracking
                    ctx.fillStyle = '#1a1a2e';
                    const pupilSize = eyeSize * pixelSize * 0.3;
                    ctx.beginPath();
                    ctx.arc(
                        (leftEyeX + eyeSize/2 + pupilOffsetX) * pixelSize, 
                        (eyeY + eyeSize/2 + pupilOffsetY) * pixelSize, 
                        pupilSize, 0, Math.PI * 2
                    );
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(
                        (rightEyeX + eyeSize/2 + pupilOffsetX) * pixelSize, 
                        (eyeY + eyeSize/2 + pupilOffsetY) * pixelSize, 
                        pupilSize, 0, Math.PI * 2
                    );
                    ctx.fill();
                    
                    // Draw eye shine
                    ctx.fillStyle = '#ffffff';
                    ctx.beginPath();
                    ctx.arc(
                        (leftEyeX + eyeSize/2 + pupilOffsetX * 0.5 - 0.2) * pixelSize, 
                        (eyeY + eyeSize/2 + pupilOffsetY * 0.5 - 0.2) * pixelSize, 
                        pupilSize * 0.4, 0, Math.PI * 2
                    );
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(
                        (rightEyeX + eyeSize/2 + pupilOffsetX * 0.5 - 0.2) * pixelSize, 
                        (eyeY + eyeSize/2 + pupilOffsetY * 0.5 - 0.2) * pixelSize, 
                        pupilSize * 0.4, 0, Math.PI * 2
                    );
                    ctx.fill();
                }
                
                // v14.2: Draw eyelid line during blink
                if (isBlinking) {
                    ctx.strokeStyle = '#1a1a2e';
                    ctx.lineWidth = 0.8;
                    ctx.beginPath();
                    ctx.moveTo((leftEyeX + 0.1) * pixelSize, (eyeY + eyeSize/2) * pixelSize);
                    ctx.lineTo((leftEyeX + eyeSize + 0.1) * pixelSize, (eyeY + eyeSize/2) * pixelSize);
                    ctx.stroke();
                    ctx.beginPath();
                    ctx.moveTo((rightEyeX + 0.1) * pixelSize, (eyeY + eyeSize/2) * pixelSize);
                    ctx.lineTo((rightEyeX + eyeSize + 0.1) * pixelSize, (eyeY + eyeSize/2) * pixelSize);
                    ctx.stroke();
                }
            }
            
            // v14.2: Ear twitching for idle/working states
            if ((status === 'idle' || status === 'working') && frame % 90 > 80) {
                // Subtle ear twitch - left ear
                const twitchOffset = Math.sin((frame % 10) * 0.8) * 0.15;
                // Draw twitch effect on left ear pixels (row 1-2, cols 5-6)
                ctx.fillStyle = '#ffcc66'; // Highlight color
                ctx.fillRect((5 + twitchOffset) * pixelSize, 1 * pixelSize, pixelSize, pixelSize);
                ctx.fillRect((6 + twitchOffset) * pixelSize, 1 * pixelSize, pixelSize, pixelSize);
            }
        };
        
        // ===== End Pixel Fox =====

        const particlesContainer = document.getElementById('particles');
        for (let i = 0; i < 15; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 20 + 's';
            particle.style.animationDuration = (15 + Math.random() * 10) + 's';
            particle.style.background = ['', 'var(--accent)', 'var(--success)', 'var(--primary)'][Math.floor(Math.random() * 4)];
            particlesContainer.appendChild(particle);
        }
        
        const sparklesContainer = document.getElementById('sparkles');
        for (let i = 0; i < 10; i++) {
            const sparkle = document.createElement('div');
            sparkle.className = 'sparkle';
            sparkle.style.left = Math.random() * 100 + '%';
            sparkle.style.top = Math.random() * 100 + '%';
            sparkle.style.animationDelay = Math.random() * 2.5 + 's';
            sparkle.style.background = Math.random() > 0.5 ? 'var(--accent)' : 'var(--primary)';
            sparklesContainer.appendChild(sparkle);
        }
        
        // v14.0: Initialize floating particles
        function initFloatingParticles() {
            const container = document.getElementById('floatingParticles');
            if (!container) return;
            
            const colors = ['var(--primary)', 'var(--accent)', 'var(--success)'];
            for (let i = 0; i < 15; i++) {
                const particle = document.createElement('div');
                particle.className = 'floating-particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.background = colors[Math.floor(Math.random() * colors.length)];
                particle.style.animationDelay = Math.random() * 10 + 's';
                particle.style.animationDuration = (10 + Math.random() * 10) + 's';
                particle.style.width = (2 + Math.random() * 4) + 'px';
                particle.style.height = particle.style.width;
                container.appendChild(particle);
            }
        }
        initFloatingParticles();
        
        function updateGreeting() {
            const hour = new Date().getHours();
            let greeting = '';
            if (hour >= 5 && hour < 12) greeting = '早上好呀哥哥～ ☀️';
            else if (hour >= 12 && hour < 14) greeting = '中午好！🍱';
            else if (hour >= 14 && hour < 18) greeting = '下午好～ 🌤️';
            else if (hour >= 18 && hour < 22) greeting = '晚上好哥哥！🌙';
            else greeting = '夜深了，要休息啦～ 🌙';
            document.getElementById('greeting').textContent = greeting;
        }
        updateGreeting();
        
        const kbdHint = document.getElementById('kbdHint');
        const cmdHint = document.getElementById('cmdHint');
        document.addEventListener('keydown', (e) => {
            if (e.key === 'r' || e.key === 'R') {
                kbdHint.classList.add('visible');
                cmdHint.classList.add('visible');
                fetchData();
                setTimeout(() => {
                    kbdHint.classList.remove('visible');
                    cmdHint.classList.remove('visible');
                }, 2000);
            }
            // Toggle power saving mode
            if (e.key === 'e' || e.key === 'E') {
                togglePowerSaving();
                cmdHint.classList.add('visible');
                setTimeout(() => cmdHint.classList.remove('visible'), 2000);
            }
            // Show keyboard hints on ?
            if (e.key === '?' || (e.shiftKey && e.key === '/')) {
                cmdHint.classList.add('visible');
                setTimeout(() => cmdHint.classList.remove('visible'), 3000);
            }
            // Number keys 1-7 to preview different statuses
            const statusMap = { '1': 'idle', '2': 'working', '3': 'sleeping', '4': 'excited', '5': 'thinking', '6': 'laughing', '7': 'error' };
            if (statusMap[e.key] && !e.ctrlKey && !e.metaKey && !e.altKey) {
                const status = statusMap[e.key];
                const avatar = document.getElementById('avatar');
                const statusDot = document.getElementById('statusDot');
                const statusText = document.getElementById('statusText');
                const moodEmoji = document.getElementById('moodEmoji');
                const bgMesh = document.querySelector('.bg-mesh');
                // Reset
                avatar.className = 'avatar';
                statusDot.className = 'status-dot';
                statusText.className = 'status';
                // Set new status
                avatar.classList.add(status);
                statusDot.classList.add(status);
                statusText.classList.add(status);
                bgMesh.className = 'bg-mesh ' + status;
                const moodMap = { idle: '🦊', working: '⚡', sleeping: '😴', excited: '🤩', thinking: '🤔', laughing: '😂', error: '😵' };
                moodEmoji.textContent = moodMap[status];
                const statusNames = { idle: 'Idle', working: 'Working', sleeping: 'Sleeping', excited: 'Excited!', thinking: 'Thinking', laughing: 'Happy!', error: 'Error' };
                statusText.textContent = statusNames[status];
                // Auto reset after 3 seconds
                setTimeout(() => {
                    avatar.className = 'avatar';
                    statusDot.className = 'status-dot';
                    statusText.className = 'status';
                    bgMesh.className = 'bg-mesh';
                    moodEmoji.textContent = '🦊';
                    statusText.textContent = 'Online';
                }, 3000);
            }
        });
        
        // Show cmd hints after inactivity
        let inactivityTimer;
        function showCmdHint() {
            cmdHint.classList.add('visible');
            setTimeout(() => cmdHint.classList.remove('visible'), 3000);
        }
        document.addEventListener('mousemove', () => {
            clearTimeout(inactivityTimer);
            inactivityTimer = setTimeout(showCmdHint, 15000);
        });
        
        const mainCard = document.getElementById('mainCard');
        mainCard.addEventListener('click', function(e) {
            const ripple = document.createElement('span');
            ripple.className = 'ripple';
            const rect = this.getBoundingClientRect();
            ripple.style.left = (e.clientX - rect.left) + 'px';
            ripple.style.top = (e.clientY - rect.top) + 'px';
            this.appendChild(ripple);
            setTimeout(() => ripple.remove(), 700);
            document.querySelectorAll('.viz-bar-fill').forEach(bar => {
                bar.style.transition = 'none';
                bar.style.height = '0%';
                setTimeout(() => bar.style.transition = 'height 1s cubic-bezier(0.4, 0, 0.2, 1)', 50);
            });
            fetchData();
        });
        
        let prevData = {};
        let retryCount = 0;
        let consecutiveSuccesses = 0;
        let lastBackoffMs = 0;
        const MAX_RETRIES = 3;
        const BASE_BACKOFF_MS = 2000;
        let lastFetchTime = null;
        let isFetching = false;
        let refreshInterval = 8; // seconds - optimized for real-time feel
        let countdownTimer = null;
        
        // Store previous values for change detection
        const prevValues = {};
        
        // Heartbeat waveform data
        const heartbeatData = { values: [], maxPoints: 20 };
        
        // Activity Sparkline Data
        const activityData = { values: [], maxPoints: 60 };
        
        // Initialize activity sparkline
        function initActivitySparkline() {
            for (let i = 0; i < activityData.maxPoints; i++) {
                activityData.values.push(Math.random() * 30 + 10);
            }
        }
        
        // Update activity sparkline
        function updateActivitySparkline(activityLevel) {
            const canvas = document.getElementById('activitySparkline');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const width = canvas.width;
            const height = canvas.height;
            
            activityData.values.push(activityLevel || 10);
            if (activityData.values.length > activityData.maxPoints) activityData.values.shift();
            
            ctx.clearRect(0, 0, width, height);
            
            const gradient = ctx.createLinearGradient(0, 0, 0, height);
            gradient.addColorStop(0, 'rgba(0, 212, 255, 0.3)');
            gradient.addColorStop(1, 'rgba(0, 212, 255, 0)');
            
            ctx.beginPath();
            ctx.moveTo(0, height);
            
            const step = width / (activityData.maxPoints - 1);
            activityData.values.forEach((val, i) => {
                const x = i * step;
                const y = height - (val / 100) * height;
                ctx.lineTo(x, y);
            });
            
            ctx.lineTo(width, height);
            ctx.closePath();
            ctx.fillStyle = gradient;
            ctx.fill();
            
            ctx.beginPath();
            activityData.values.forEach((val, i) => {
                const x = i * step;
                const y = height - (val / 100) * height;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.strokeStyle = '#00d4ff';
            ctx.lineWidth = 1.5;
            ctx.stroke();
            
            const currentVal = activityData.values[activityData.values.length - 1];
            document.getElementById('activityLevel').textContent = Math.round(currentVal) + '%';
            
            // Dynamic glow based on activity level
            if (currentVal > 70) {
                ctx.shadowColor = '#ff6b6b';
                ctx.shadowBlur = 8;
            } else if (currentVal > 40) {
                ctx.shadowColor = '#00d4ff';
                ctx.shadowBlur = 6;
            } else {
                ctx.shadowColor = '#10b981';
                ctx.shadowBlur = 4;
            }
            ctx.strokeStyle = currentVal > 70 ? '#ff6b6b' : currentVal > 40 ? '#00d4ff' : '#10b981';
            ctx.lineWidth = 1.5;
            ctx.stroke();
            ctx.shadowBlur = 0;
        }
        
        initActivitySparkline();
        
        // Energy level
        
        // Initialize heartbeat waveform
        function initHeartbeatWaveform() {
            const container = document.getElementById('heartbeatWaveform');
            if (!container) return;
            container.innerHTML = '';
            for (let i = 0; i < heartbeatData.maxPoints; i++) {
                const bar = document.createElement('div');
                bar.className = 'heartbeat-bar low';
                bar.style.height = '4px';
                container.appendChild(bar);
            }
        }
        initHeartbeatWaveform();
        
        // Update heartbeat waveform
        function updateHeartbeatWaveform(interval) {
            // Simulate heartbeat pattern based on interval
            const normalized = Math.max(0, Math.min(100, (10 / interval) * 100));
            
            // Add some realistic heartbeat pattern
            let pattern = 0;
            const frame = foxAnimationFrame;
            if (frame % 60 < 5) {
                pattern = normalized * (1 - (frame % 60) / 5); // Spike
            } else if (frame % 60 < 15) {
                pattern = normalized * 0.3;
            } else {
                pattern = normalized * 0.1;
            }
            
            heartbeatData.values.push(pattern);
            if (heartbeatData.values.length > heartbeatData.maxPoints) heartbeatData.values.shift();
            
            const container = document.getElementById('heartbeatWaveform');
            if (!container) return;
            container.innerHTML = '';
            
            heartbeatData.values.forEach((val, i) => {
                const bar = document.createElement('div');
                bar.className = 'heartbeat-bar ';
                const height = 4 + (val / 100) * 24;
                bar.style.height = height + 'px';
                
                if (val > 60) bar.classList.add('high');
                else if (val > 30) bar.classList.add('medium');
                else bar.classList.add('low');
                
                container.appendChild(bar);
            });
        }
        
        // Update energy level
        function updateEnergy(status, heartbeat) {
            // Calculate energy based on status and heartbeat
            let targetEnergy = 75;
            if (status === 'working') targetEnergy = 60 + Math.random() * 20;
            else if (status === 'sleeping') targetEnergy = 85 + Math.random() * 15;
            else if (status === 'excited') targetEnergy = 90 + Math.random() * 10;
            else if (status === 'thinking') targetEnergy = 50 + Math.random() * 30;
            else targetEnergy = 70 + Math.random() * 20;
            
            // Adjust based on heartbeat (faster heartbeat = more energy)
            if (heartbeat && heartbeat < 5) targetEnergy = Math.min(100, targetEnergy + 15);
            
            // Smooth transition
            energyLevel = energyLevel + (targetEnergy - energyLevel) * 0.1;
            
            const energyBar = document.getElementById('energyBar');
            const energyValue = document.getElementById('energyValue');
            if (energyBar) energyBar.style.width = energyLevel + '%';
            if (energyValue) energyValue.textContent = Math.round(energyLevel) + '%';
            
            // Color based on energy level
            if (energyBar) {
                if (energyLevel > 70) energyBar.style.background = 'linear-gradient(90deg, #5cdb95, #34d399)';
                else if (energyLevel > 40) energyBar.style.background = 'linear-gradient(90deg, #feca57, #fbbf24)';
                else energyBar.style.background = 'linear-gradient(90deg, #ff6b6b, #ee5a5a)';
            }
        }
        
        // Update stats ticker
        function updateStatsTicker(d) {
            const container = document.getElementById('statsTicker');
            if (!container) return;
            
            const items = [
                { label: 'API', value: 'OK', status: 'ok' },
                { label: 'Mem', value: (d.system?.memoryPercent || 0) + '%', status: (d.system?.memoryPercent || 0) > 85 ? 'warning' : 'ok' },
                { label: 'CPU', value: (d.system?.cpuPercent || 0) + '%', status: (d.system?.cpuPercent || 0) > 85 ? 'warning' : 'ok' },
                { label: 'Disk', value: (d.system?.diskPercent || 0) + '%', status: (d.system?.diskPercent || 0) > 90 ? 'error' : (d.system?.diskPercent || 0) > 75 ? 'warning' : 'ok' }
            ];
            
            container.innerHTML = items.map(item => `
                <div class="ticker-item ${item.status === 'warning' ? 'warning' : ''} ${item.status === 'error' ? 'error' : ''}">
                    <span class="dot"></span>
                    <span>${item.label}: ${item.value}</span>
                </div>
            `).join('');
        }
        
        // Trend data storage
        const trendData = { memory: [], cpu: [], maxPoints: 12 };
        
        // Latency history storage
        const latencyHistory = { data: [], maxPoints: 15 };
        
        // Smart refresh countdown
        function startRefreshCountdown() {
            const countdownEl = document.getElementById('refreshCountdown');
            const countdownText = document.getElementById('countdownText');
            const countdownFill = document.getElementById('countdownFill');
            if (!countdownEl) return;
            
            let remaining = refreshInterval;
            countdownEl.classList.add('visible');
            countdownFill.style.width = '100%';
            
            if (countdownTimer) clearInterval(countdownTimer);
            
            countdownTimer = setInterval(() => {
                remaining--;
                countdownText.textContent = remaining + 's';
                countdownFill.style.width = (remaining / refreshInterval * 100) + '%';
                
                if (remaining <= 0) {
                    remaining = refreshInterval;
                }
            }, 1000);
        }
        
        function updateTrend(key, value) {
            trendData[key].push(value);
            if (trendData[key].length > trendData.maxPoints) trendData[key].shift();
        }
        
        function renderTrendChart(containerId, dataKey) {
            const container = document.getElementById(containerId);
            if (!container) return;
            container.innerHTML = '';
            const data = trendData[dataKey];
            const max = Math.max(...data, 1);
            data.forEach((val, i) => {
                const bar = document.createElement('div');
                bar.className = 'trend-bar';
                bar.style.height = ((val / max) * 100) + '%';
                if (i > 0) bar.classList.add(val >= data[i-1] ? 'up' : 'down');
                container.appendChild(bar);
            });
        }
        
        // Network status
        function updateNetworkStatus() {
            const status = navigator.onLine;
            const el = document.getElementById('networkStatus');
            const icon = document.getElementById('networkIcon');
            const text = document.getElementById('networkText');
            el.classList.add('visible');
            if (status) {
                icon.classList.remove('offline');
                text.textContent = 'Online';
            } else {
                icon.classList.add('offline');
                text.textContent = 'Offline';
            }
        }
        window.addEventListener('online', updateNetworkStatus);
        window.addEventListener('offline', updateNetworkStatus);
        updateNetworkStatus();
        
        // Enhanced fetch with multiple fallback endpoints
        // v15.5: Auto-detect base path for API endpoints (works through nginx proxy at /onboard/)
        function getApiBase() {
            const path = window.location.pathname;
            // If served from /onboard/ subdirectory, prepend it
            if (path.includes('/onboard') || path.startsWith('/onboard/')) {
                return '/onboard';
            }
            return '';
        }
        const API_BASE = getApiBase();
        
        const API_ENDPOINTS = [
            API_BASE + '/api/dashboard',
            API_BASE + '/api/status', 
            API_BASE + '/health',
            API_BASE + '/api/system'
        ];
        let currentEndpointIndex = 0;
        
        // v15.5: Source health tracking
        const sourceLatencies = {
            'gateway': null,
            'api': null,
            'health': null,
            'system': null
        };
        const sourceEndpoints = {
            'gateway': API_BASE + '/api/dashboard',
            'api': API_BASE + '/api/status',
            'health': API_BASE + '/health',
            'system': API_BASE + '/api/system'
        };
        let activeSource = null;
        
        // v15.2: Update health panel UI
        function updateHealthPanel() {
            const panel = document.getElementById('healthPanel');
            if (!panel) return;
            
            // Update each source indicator
            Object.keys(sourceLatencies).forEach(src => {
                const indicator = document.getElementById('src-' + src);
                const latencyEl = document.getElementById('latency-' + src);
                if (!indicator) return;
                
                // Update latency display
                if (latencyEl && sourceLatencies[src] !== null) {
                    latencyEl.textContent = Math.round(sourceLatencies[src]) + 'ms';
                }
                
                // Update status class
                indicator.classList.remove('active', 'offline', 'slow', 'checking', 'excellent', 'good', 'fair', 'poor');
                
                if (src === activeSource) {
                    indicator.classList.add('active');
                } else if (sourceLatencies[src] === null) {
                    indicator.classList.add('offline');
                } else if (sourceLatencies[src] > 1000) {
                    indicator.classList.add('slow', 'poor');
                } else if (sourceLatencies[src] > 500) {
                    indicator.classList.add('slow', 'fair');
                } else if (sourceLatencies[src] > 200) {
                    indicator.classList.add('good');
                } else {
                    indicator.classList.add('excellent');
                }
            });
            
            // Update active source name
            const activeNameEl = document.getElementById('activeSourceName');
            if (activeNameEl) {
                activeNameEl.textContent = activeSource ? activeSource.toUpperCase() : '--';
            }
        }
        
        // v15.2: Update refresh rate badge
        function updateRefreshRateBadge() {
            const badge = document.getElementById('refreshRateBadge');
            const text = document.getElementById('refreshRateText');
            if (!badge) return;
            
            badge.classList.remove('fast', 'slow');
            if (refreshInterval <= 10) {
                badge.classList.add('fast');
                if (text) text.textContent = 'Fast ' + refreshInterval + 's';
            } else if (refreshInterval >= 20) {
                badge.classList.add('slow');
                if (text) text.textContent = 'Slow ' + refreshInterval + 's';
            } else {
                if (text) text.textContent = 'Adaptive ' + refreshInterval + 's';
            }
            badge.classList.add('visible');
        }
        
        // Real-time data streaming simulation
        let dataStreamActive = false;
        let streamingData = null;
        
        // Simulated real-time data for demo (v14.1: time-aware & enhanced)
        function simulateRealtimeData() {
            const now = new Date();
            const hour = now.getHours();
            
            // Time-aware base values
            const isWorkingHours = hour >= 9 && hour <= 22;
            const memBase = isWorkingHours ? 45 + Math.random() * 20 : 30 + Math.random() * 15;
            const cpuBase = isWorkingHours ? 25 + Math.random() * 30 : 10 + Math.random() * 20;
            
            // Time-aware tasks
            const timeTasks = {
                morning: ['检查日程安排...', '处理清晨消息...', '生成日报...', '监控系统状态...'],
                afternoon: ['处理工作请求...', '优化技能表现...', '响应用户需求...', '更新知识库...'],
                evening: ['整理今日工作...', '生成晚报告...', '准备明日计划...', '清理临时数据...'],
                night: ['进入低功耗模式', '监控异常事件', '执行定时任务', '维护系统健康']
            };
            
            let taskList;
            if (hour >= 5 && hour < 12) taskList = timeTasks.morning;
            else if (hour >= 12 && hour < 18) taskList = timeTasks.afternoon;
            else if (hour >= 18 && hour < 23) taskList = timeTasks.evening;
            else taskList = timeTasks.night;
            
            // Time-aware status
            const statusPool = isWorkingHours 
                ? ['working', 'thinking', 'idle', 'excited', 'focused']
                : ['idle', 'sleeping', 'thinking'];
            const status = statusPool[Math.floor(Math.random() * statusPool.length)];
            
            return {
                heartbeat: 6 + Math.random() * 5,
                msgCount: Math.floor(Math.random() * 150),
                taskDone: Math.floor(Math.random() * 30),
                uptime: Math.floor(Math.random() * 24) + 'h',
                status: status,
                sessions: Math.floor(Math.random() * 10) + 1,
                evomap: { reputation: 100 + Math.random() * 50 },
                system: {
                    memoryPercent: Math.floor(memBase),
                    cpuPercent: Math.floor(cpuBase),
                    diskPercent: 45 + Math.floor(Math.random() * 20)
                },
                skillsActive: Math.floor(Math.random() * 20) + 10,
                skillsTotal: Math.floor(Math.random() * 10) + 25,
                mood: 60 + Math.floor(Math.random() * 35),
                currentTask: taskList[Math.floor(Math.random() * taskList.length)],
                _source: 'demo',
                _demoTs: now.toISOString()
            };
        }
        
        // Demo mode toggle
        let demoMode = false;
        window.toggleDemoMode = function() {
            demoMode = !demoMode;
            showToast(demoMode ? '🎮 Demo模式已开启' : '🔄 Demo模式已关闭', demoMode ? 'info' : 'success');
            
            if (demoMode) {
                // Start simulating data
                if (!dataStreamActive) {
                    dataStreamActive = true;
                    streamingData = setInterval(() => {
                        if (demoMode) {
                            const data = simulateRealtimeData();
                            updateDashboard(data, true);
                        }
                    }, 2000);
                }
            } else {
                if (streamingData) {
                    clearInterval(streamingData);
                    dataStreamActive = false;
                }
                fetchData();
            }
        };
        
        // Local storage cache for offline support
        const CACHE_KEY = 'dashboard_cache';
        const CACHE_TTL = 300000; // 5 minutes
        
        function getCachedData() {
            try {
                const cached = localStorage.getItem(CACHE_KEY);
                if (cached) {
                    const { data, timestamp } = JSON.parse(cached);
                    if (Date.now() - timestamp < CACHE_TTL) {
                        return data;
                    }
                }
            } catch(e) {}
            return null;
        }
        
        function setCachedData(data) {
            try {
                localStorage.setItem(CACHE_KEY, JSON.stringify({
                    data: data,
                    timestamp: Date.now()
                }));
            } catch(e) {}
        }
        
        async function tryFetchEndpoint(endpoint) {
            const controller = new AbortController();
            const timeout = setTimeout(() => controller.abort(), 3000);
            const startTime = performance.now();
            try {
                const response = await fetch(endpoint, {
                    cache: 'no-cache',
                    signal: controller.signal
                });
                clearTimeout(timeout);
                const latency = performance.now() - startTime;
                // v15.2: Track latency per source
                const src = Object.keys(sourceEndpoints).find(k => sourceEndpoints[k] === endpoint);
                if (src) sourceLatencies[src] = latency;
                if (!response.ok) throw new Error('API Error');
                return await response.json();
            } catch (e) {
                clearTimeout(timeout);
                // v15.2: Mark source as offline on error
                const src = Object.keys(sourceEndpoints).find(k => sourceEndpoints[k] === endpoint);
                if (src) sourceLatencies[src] = null;
                throw e;
            }
        }

        async function fetchWithFallback() {
            // v15.2: Check all sources in parallel for health display
            Object.keys(sourceEndpoints).forEach(src => {
                const ep = sourceEndpoints[src];
                const indicator = document.getElementById('src-' + src);
                if (indicator) indicator.classList.add('checking');
            });
            
            // Try each endpoint in sequence
            for (let i = 0; i < API_ENDPOINTS.length; i++) {
                const endpoint = API_ENDPOINTS[(currentEndpointIndex + i) % API_ENDPOINTS.length];
                try {
                    const data = await tryFetchEndpoint(endpoint);
                    currentEndpointIndex = (currentEndpointIndex + i) % API_ENDPOINTS.length;
                    // v15.2: Determine source name from endpoint
                    const src = Object.keys(sourceEndpoints).find(k => sourceEndpoints[k] === endpoint) || 'gateway';
                    activeSource = src;
                    updateHealthPanel();
                    return { data, source: src, endpoint };
                } catch (e) {
                    continue;
                }
            }
            throw new Error('All endpoints failed');
        }
        
        function fetchData() {
            if (isFetching) return;
            isFetching = true;
            const startTime = performance.now();
            
            // Show refresh indicator
            const smartRefresh = document.getElementById('smartRefresh');
            if (smartRefresh) smartRefresh.classList.add('visible');
            
            document.querySelectorAll('.stat-card').forEach(card => {
                const indicator = card.querySelector('.refresh-indicator');
                if (indicator) indicator.classList.add('active');
            });
            
            // Try endpoints with fallback
            return fetchWithFallback()
                .then(({ data, endpoint }) => {
                    retryCount = 0;
                    consecutiveSuccesses++;
                    lastBackoffMs = 0;
                    const latency = Math.round(performance.now() - startTime);
                    updateLatency(latency);
                    // v15.2: Update refresh rate indicator
                    updateRefreshRateBadge();
                    // Cache successful response
                    setCachedData(data);
                    document.getElementById('apiStatus').classList.remove('error');
                    document.getElementById('lastUpdate').classList.remove('error');
                    lastFetchTime = new Date();
                    updateLastUpdate();
                    if (data._source) document.getElementById('dataSrc').textContent = data._source;
                    else if (endpoint) document.getElementById('dataSrc').textContent = endpoint.replace('/', '');
                    // Validate data consistency
                    validateDataConsistency(data);
                    updateDashboard(data);
                    updateHealthScore(data);
                    // v15.5: Update live indicator
                    updateLiveIndicator(src, true);
                })
                .catch((err) => {
                    consecutiveSuccesses = 0;
                    // Calculate exponential backoff
                    lastBackoffMs = Math.min(BASE_BACKOFF_MS * Math.pow(2, retryCount), 30000);
                    // Try cached data first
                    const cached = getCachedData();
                    if (cached) {
                        updateDashboard({ ...cached, _source: 'cache' }, true);
                        document.getElementById('dataSrc').textContent = 'cache';
                    }
                    retryCount++;
                    document.getElementById('lastUpdate').classList.add('error');
                    updateLatency(-1);
                    if (retryCount >= MAX_RETRIES) {
                        document.getElementById('apiStatus').classList.add('error');
                        const relDot = document.getElementById('reliabilityDot');
                        if (relDot) relDot.className = 'reliability-dot low';
                        updateLiveIndicator(null, false);
                    }
                    if (Object.keys(prevData).length > 0 && !cached) updateDashboard(prevData, true);
                }).finally(() => {
                isFetching = false;
                // Hide refresh indicators
                const smartRefresh = document.getElementById('smartRefresh');
                if (smartRefresh) smartRefresh.classList.remove('visible');
                
                document.querySelectorAll('.stat-card').forEach(card => {
                    const indicator = card.querySelector('.refresh-indicator');
                    if (indicator) indicator.classList.remove('active');
                });
                
                // Update reliability based on data freshness
                if (retryCount === 0 && lastFetchTime) {
                    const age = (Date.now() - lastFetchTime.getTime()) / 1000;
                    const relDot = document.getElementById('reliabilityDot');
                    if (relDot) {
                        if (age < 10) relDot.className = 'reliability-dot high';
                        else if (age < 30) relDot.className = 'reliability-dot medium';
                        else relDot.className = 'reliability-dot low';
                    }
                }
                
                // Start countdown for next refresh
                startRefreshCountdown();
            });
        }
        
        function updateLatency(ms) {
            window._lastLatency = ms;
            const indicator = document.getElementById('latencyIndicator');
            const text = document.getElementById('latencyText');
            const bar = document.getElementById('latencyBar');
            const connQuality = document.getElementById('connectionQuality');
            if (ms < 0) { indicator.classList.remove('visible'); connQuality.classList.remove('visible'); return; }
            indicator.classList.add('visible');
            connQuality.classList.add('visible');
            text.textContent = ms + 'ms';
            const percent = Math.min((ms / 2000) * 100, 100);
            bar.style.width = percent + '%';
            bar.classList.remove('slow', 'very-slow');
            connQuality.classList.remove('excellent', 'good', 'fair', 'poor');
            if (ms > 1000) { 
                bar.classList.add('very-slow'); 
                connQuality.classList.add('poor');
                refreshInterval = 30; // Slow network: reduce refresh frequency
            }
            else if (ms > 500) { 
                bar.classList.add('slow'); 
                connQuality.classList.add('fair');
                refreshInterval = 20;
            }
            else if (ms > 200) { 
                connQuality.classList.add('good');
                refreshInterval = 15;
            }
            else { 
                connQuality.classList.add('excellent');
                refreshInterval = 10; // Fast network: normal refresh
            }
            
            // Update latency history
            latencyHistory.data.push(ms);
            if (latencyHistory.data.length > latencyHistory.maxPoints) latencyHistory.data.shift();
            renderLatencyHistory();
            renderLatencySparkline();
        }
        
        function renderLatencyHistory() {
            const container = document.getElementById('latencyHistory');
            if (!container) return;
            container.innerHTML = '';
            const max = Math.max(...latencyHistory.data, 1);
            latencyHistory.data.forEach(val => {
                const bar = document.createElement('div');
                bar.className = 'latency-bar';
                const heightPercent = (val / max) * 100;
                bar.style.height = Math.max(heightPercent, 10) + '%';
                if (val > 1000) bar.classList.add('very-slow');
                else if (val > 500) bar.classList.add('slow');
                container.appendChild(bar);
            });
        }
        
        // v15.5: Render latency sparkline in HUD
        function renderLatencySparkline() {
            const canvas = document.getElementById('latencySparkline');
            if (!canvas || latencyHistory.data.length < 2) return;
            const ctx = canvas.getContext('2d');
            const w = canvas.width, h = canvas.height;
            ctx.clearRect(0, 0, w, h);
            const data = latencyHistory.data.slice(-30);
            const max = Math.max(...data, 1);
            const step = w / (data.length - 1);
            ctx.beginPath();
            ctx.strokeStyle = 'rgba(0, 212, 255, 0.8)';
            ctx.lineWidth = 1.5;
            ctx.shadowColor = 'rgba(0, 212, 255, 0.5)';
            ctx.shadowBlur = 3;
            data.forEach((val, i) => {
                const x = i * step;
                const y = h - (val / max) * (h - 2) - 1;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.stroke();
            // Draw fill gradient
            ctx.lineTo((data.length - 1) * step, h);
            ctx.lineTo(0, h);
            ctx.closePath();
            const grad = ctx.createLinearGradient(0, 0, 0, h);
            grad.addColorStop(0, 'rgba(0, 212, 255, 0.3)');
            grad.addColorStop(1, 'rgba(0, 212, 255, 0)');
            ctx.fillStyle = grad;
            ctx.fill();
        }
        
        // v15.5: Update live data indicator
        function updateLiveIndicator(source, isLive) {
            const indicator = document.getElementById('liveIndicator');
            const dot = document.getElementById('liveDot');
            const text = document.getElementById('liveText');
            if (!indicator) return;
            indicator.classList.remove('live', 'simulated', 'error');
            if (isLive && source && source !== 'demo') {
                indicator.classList.add('live');
                dot.style.background = 'var(--success)';
                text.textContent = 'LIVE';
            } else if (source === 'demo' || source === 'cache') {
                indicator.classList.add('simulated');
                dot.style.background = 'var(--warning)';
                text.textContent = source === 'cache' ? 'CACHE' : 'DEMO';
            } else {
                indicator.classList.add('error');
                dot.style.background = 'var(--danger)';
                text.textContent = 'ERR';
            }
        }
        
        function updateLastUpdate() {
            if (!lastFetchTime) return;
            const now = new Date();
            const diff = Math.floor((now - lastFetchTime) / 1000);
            let text = diff < 5 ? 'just now' : diff < 60 ? diff + 's ago' : Math.floor(diff / 60) + 'm ago';
            document.getElementById('lastUpdateText').textContent = text;
            
            // Update data age indicator
            const dataAgeEl = document.getElementById('dataAge');
            const lastUpdateEl = document.getElementById('lastUpdate');
            if (dataAgeEl && lastUpdateEl) {
                const ageSeconds = diff;
                if (ageSeconds > 30) {
                    dataAgeEl.textContent = '(' + (ageSeconds < 60 ? ageSeconds + 's' : Math.floor(ageSeconds/60) + 'm') + ')';
                    lastUpdateEl.classList.add('stale');
                } else {
                    dataAgeEl.textContent = '';
                    lastUpdateEl.classList.remove('stale');
                }
            }
        }
        setInterval(updateLastUpdate, 5000);
        
        function updateTime() {
            const now = new Date();
            const options = { hour12: false, hour: '2-digit', minute: '2-digit', weekday: 'short' };
            document.getElementById('timeDisplay').textContent = now.toLocaleTimeString('en-US', options);
            
            // Update seconds display
            const seconds = now.getSeconds().toString().padStart(2, '0');
            const secondsEl = document.getElementById('secondsDisplay');
            if (secondsEl && secondsEl.textContent !== seconds) {
                secondsEl.textContent = seconds;
            }
            
            // Update date display
            const dateOptions = { month: 'short', day: 'numeric', weekday: 'short' };
            const dateStr = now.toLocaleDateString('en-US', dateOptions);
            const dateEl = document.getElementById('dateDisplay');
            if (dateEl) {
                const hours = now.getHours();
                let timeStr = '';
                if (hours >= 5 && hours < 8) timeStr = '🌅 清晨';
                else if (hours >= 8 && hours < 12) timeStr = '☀️ 上午';
                else if (hours >= 12 && hours < 14) timeStr = '🌤️ 中午';
                else if (hours >= 14 && hours < 18) timeStr = '☀️ 下午';
                else if (hours >= 18 && hours < 22) timeStr = '🌆 傍晚';
                else timeStr = '🌙 夜晚';
                dateEl.innerHTML = `<span class="date">${dateStr}</span><span class="time-sep">•</span>${timeStr}`;
            }
            
            // Update date widget
            const dayNumber = document.getElementById('dayNumber');
            const monthName = document.getElementById('monthName');
            const yearNum = document.getElementById('yearNum');
            if (dayNumber) dayNumber.textContent = now.getDate();
            if (monthName) monthName.textContent = now.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
            if (yearNum) yearNum.textContent = now.getFullYear();
        }
        // ===== Real-time Clock with Milliseconds =====
        function updateRealtimeClock() {
            const now = new Date();
            const hours = now.getHours().toString().padStart(2, '0');
            const minutes = now.getMinutes().toString().padStart(2, '0');
            const seconds = now.getSeconds().toString().padStart(2, '0');
            const ms = Math.floor(now.getMilliseconds() / 10).toString().padStart(2, '0');
            
            const timeDisplay = document.getElementById('timeDisplay');
            const secondsDisplay = document.getElementById('secondsDisplay');
            
            if (timeDisplay) {
                timeDisplay.textContent = `${hours}:${minutes}`;
            }
            if (secondsDisplay) {
                // Show seconds with ms on hover
                secondsDisplay.textContent = seconds;
                secondsDisplay.title = `${ms}ms`;
            }
        }
        
        // Add millisecond display capability
        const secondsDisplay = document.getElementById('secondsDisplay');
        if (secondsDisplay) {
            secondsDisplay.addEventListener('mouseenter', () => {
                const now = new Date();
                const ms = Math.floor(now.getMilliseconds() / 10).toString().padStart(2, '0');
                secondsDisplay.textContent = '.' + ms;
                secondsDisplay.style.fontSize = '10px';
            });
            secondsDisplay.addEventListener('mouseleave', () => {
                const now = new Date();
                secondsDisplay.textContent = now.getSeconds().toString().padStart(2, '0');
                secondsDisplay.style.fontSize = '';
            });
        }
        
        updateTime();
        setInterval(updateTime, 1000);
        setInterval(updateRealtimeClock, 50);
        
        function updateDashboard(d, isCached = false) {
            // v11.7: Remove loading state after first data arrives
            document.body.classList.remove('loading');
            if (!isCached) prevData = {...d};
            
            // v11.7: Stale data warning - show banner when data is old (>2 min)
            const staleBanner = document.getElementById('staleDataBanner');
            // v2.9: Also check for low reliability even if not technically stale
            const isLowReliability = d._reliability === 'low' || d._isStale;
            if (isLowReliability && staleBanner) {
                const age = d._dataAge;
                // If heartbeat is very old (>24h) but system shows activity, show "system active"
                if (age && age > 86400 && d.status !== 'sleeping') {
                    staleBanner.querySelector('.stale-text').textContent = '🟢 系统运行中 (心跳数据历史遗留)';
                    staleBanner.classList.add('visible');
                    staleBanner.style.background = 'linear-gradient(135deg, rgba(16, 185, 129, 0.2), rgba(16, 185, 129, 0.1))';
                } else if (age !== undefined) {
                    const ageStr = age > 60 ? `${Math.floor(age/60)}m ${Math.floor(age%60)}s` : `${Math.floor(age)}s`;
                    staleBanner.querySelector('.stale-text').textContent = `数据已老化 (${ageStr}未更新)`;
                    staleBanner.classList.add('visible');
                    staleBanner.style.background = '';
                }
            } else if (staleBanner) {
                staleBanner.classList.remove('visible');
                staleBanner.style.background = '';
            }
            
            // Helper to update value with change detection and roll animation
            const updateValue = (id, newVal, key) => {
                const el = document.getElementById(id);
                if (!el) return;
                const val = newVal !== undefined ? newVal : '--';
                const displayVal = typeof val === 'number' ? val : val;
                if (el.textContent !== String(displayVal)) {
                    if (prevValues[key] !== undefined && prevValues[key] !== val) {
                        // Add roll animation
                        el.classList.add('rolling');
                        setTimeout(() => el.classList.remove('rolling'), 500);
                    }
                    el.textContent = displayVal;
                    prevValues[key] = val;
                }
            };
            
            updateValue('hb', d.heartbeat || '--', 'heartbeat');
            updateValue('msgs', d.msgCount || 0, 'messages');
            updateValue('tasks', d.taskDone || 0, 'tasks');
            updateValue('uptime', d.uptime || '0h', 'uptime');
            if (d.sessions !== undefined) updateValue('sessions', d.sessions, 'sessions');
            if (d.evomap && d.evomap.reputation) updateValue('rep', d.evomap.reputation.toFixed(1), 'rep');
            
            // Update activity sparkline
            if (d.activityLevel !== undefined) {
                updateActivitySparkline(d.activityLevel);
                // v15.3: Dispatch neural network activity update
                window.dispatchEvent(new CustomEvent('neuralActivityUpdate', { detail: d.activityLevel }));
            }
            
            // Version info with gradient
            if (d.version) {
                const verEl = document.getElementById('versionBadge');
                if (verEl) verEl.textContent = 'v' + d.version;
            }
            
            // Model badge - show AI model name
            if (d.model) {
                const modelEl = document.getElementById('modelBadge');
                if (modelEl) modelEl.textContent = d.model;
            }
            if (d.channel) {
                const chEl = document.getElementById('channelBadge');
                if (chEl) chEl.textContent = d.channel.toUpperCase();
            }
            
            // API health indicator
            const apiStatus = document.getElementById('apiStatus');
            if (d._source === 'gateway') {
                if (apiStatus) {
                    apiStatus.classList.remove('error');
                    apiStatus.querySelector('.dot').style.background = 'var(--success)';
                    apiStatus.querySelector('.dot').style.boxShadow = '0 0 8px var(--success)';
                }
            } else if (d._source === 'fallback' || d._source === 'cache') {
                if (apiStatus) {
                    apiStatus.querySelector('.dot').style.background = 'var(--warning)';
                    apiStatus.querySelector('.dot').style.boxShadow = '0 0 8px var(--warning)';
                }
            }
            
            // Update health indicator (new feature v2.4)
            if (d._health) {
                const healthEl = document.getElementById('systemHealth');
                if (healthEl) {
                    const { memory, cpu, disk } = d._health;
                    const memBar = healthEl.querySelector('.health-mem .health-bar');
                    const cpuBar = healthEl.querySelector('.health-cpu .health-bar');
                    const diskBar = healthEl.querySelector('.health-disk .health-bar');
                    if (memBar) memBar.style.background = memory === 'ok' ? 'var(--success)' : 'var(--warning)';
                    if (cpuBar) cpuBar.style.background = cpu === 'ok' ? 'var(--success)' : 'var(--warning)';
                    if (diskBar) diskBar.style.background = disk === 'ok' ? 'var(--success)' : 'var(--warning)';
                }
            }
            
            // Update data source indicator
            const dataSourceEl = document.getElementById('dataSource');
            if (dataSourceEl) {
                const dot = dataSourceEl.querySelector('.dot');
                const label = dataSourceEl.querySelector('.label');
                if (d._source === 'gateway') {
                    dot.className = 'dot stable';
                    label.textContent = 'Gateway';
                } else if (d._source === 'cache') {
                    dot.className = 'dot cache';
                    label.textContent = 'Cached';
                } else if (d._source === 'fallback') {
                    dot.className = 'dot fallback';
                    label.textContent = 'Fallback';
                }
            }
            
            // Disk with warning states
            const diskEl = document.getElementById('disk');
            if (diskEl && d.system && d.system.diskPercent !== undefined) {
                const diskPct = d.system.diskPercent;
                diskEl.textContent = diskPct + '%';
                const card = diskEl.closest('.mini-stat');
                card.classList.remove('warning', 'danger');
                if (diskPct > 90) card.classList.add('danger');
                else if (diskPct > 75) card.classList.add('warning');
            }
            
            // Skills statistics - Enhanced with categories
            if (d.skillsTotal !== undefined) {
                const skillsEl = document.getElementById('skillsTotal');
                if (skillsEl) {
                    const active = d.skillsActive || 0;
                    const total = d.skillsTotal || 0;
                    skillsEl.textContent = active + '/' + total;
                    // Color based on active ratio
                    const ratio = total > 0 ? active / total : 0;
                    if (ratio > 0.7) skillsEl.style.color = 'var(--success)';
                    else if (ratio > 0.3) skillsEl.style.color = 'var(--accent)';
                    else skillsEl.style.color = 'var(--warning)';
                }
                // Store skills list and categories for popup
                window.currentSkillsList = d.skillsList || [];
                window.currentSkillsCategories = d.skillsCategories || {};
            }
            
            if (d.system) {
                const memPct = d.system.memoryPercent || 0;
                const cpuPct = d.system.cpuPercent || 0;
                document.getElementById('memBar').style.height = Math.min(memPct, 100) + '%';
                document.getElementById('memPercent').textContent = memPct + '%';
                document.getElementById('cpuBar').style.height = Math.min(cpuPct, 100) + '%';
                document.getElementById('cpuPercent').textContent = cpuPct + '%';
                
                // Color changes based on load
                const memBar = document.getElementById('memBar');
                const cpuBar = document.getElementById('cpuBar');
                memBar.style.background = memPct > 90 ? 'linear-gradient(to top, #dc2626, #ef4444)' : memPct > 75 ? 'linear-gradient(to top, #d97706, #fbbf24)' : 'linear-gradient(to top, #0891b2, #22d3ee)';
                cpuBar.style.background = cpuPct > 90 ? 'linear-gradient(to top, #dc2626, #ef4444)' : cpuPct > 75 ? 'linear-gradient(to top, #d97706, #fbbf24)' : 'linear-gradient(to top, #10b981, #34d399)';
                
                // Update trends
                updateTrend('memory', memPct);
                updateTrend('cpu', cpuPct);
                renderTrendChart('memTrend', 'memory');
                renderTrendChart('cpuTrend', 'cpu');
            }
            
            const status = d.status || 'idle';
            const statusDot = document.getElementById('statusDot');
            const statusText = document.getElementById('statusText');
            const avatar = document.getElementById('avatar');
            
            // Notify status change
            notifyStatusChange(status);
            
            statusDot.className = 'status-dot';
            statusText.className = 'status';
            avatar.className = 'avatar';
            
            if (status === 'working') {
                statusDot.classList.add('working');
                statusText.classList.add('working');
                avatar.classList.add('working');
                statusText.textContent = 'Working';
                document.getElementById('moodEmoji').textContent = '⚡';
                window.setFoxStatus('working');
            } else if (status === 'idle') {
                statusDot.classList.add('idle');
                statusText.classList.add('idle');
                statusText.textContent = 'Idle';
                document.getElementById('moodEmoji').textContent = '🦊';
                window.setFoxStatus('idle');
            } else if (status === 'sleeping') {
                statusDot.classList.add('sleeping');
                statusText.classList.add('sleeping');
                avatar.classList.add('sleeping');
                statusText.textContent = 'Sleeping';
                document.getElementById('moodEmoji').textContent = '😴';
                window.setFoxStatus('sleeping');
            } else if (status === 'excited') {
                statusDot.classList.add('excited');
                statusText.classList.add('excited');
                avatar.classList.add('excited');
                statusText.textContent = 'Excited!';
                document.getElementById('moodEmoji').textContent = '🤩';
                window.setFoxStatus('excited');
            } else if (status === 'thinking') {
                statusDot.classList.add('thinking');
                statusText.classList.add('thinking');
                statusText.textContent = 'Thinking';
                document.getElementById('moodEmoji').textContent = '🤔';
                window.setFoxStatus('thinking');
            } else if (status === 'laughing') {
                statusDot.classList.add('laughing');
                statusText.classList.add('laughing');
                avatar.classList.add('laughing');
                statusText.textContent = 'Happy!';
                document.getElementById('moodEmoji').textContent = '😂';
                window.setFoxStatus('laughing');
            } else if (status === 'error') {
                statusDot.classList.add('error');
                statusText.classList.add('error');
                avatar.classList.add('error');
                statusText.textContent = 'Error';
                document.getElementById('moodEmoji').textContent = '😵';
                window.setFoxStatus('error');
            } else if (status === 'focused') { // v14.0: Focused state
                statusDot.classList.add('focused');
                statusText.classList.add('focused');
                avatar.classList.add('focused');
                statusText.textContent = 'Focused';
                document.getElementById('moodEmoji').textContent = '🎯';
                window.setFoxStatus('focused');
            } else if (status === 'learning') { // v14.0: Learning state
                statusDot.classList.add('learning');
                statusText.classList.add('learning');
                avatar.classList.add('learning');
                statusText.textContent = 'Learning';
                document.getElementById('moodEmoji').textContent = '📚';
                window.setFoxStatus('learning');
            } else {
                statusText.textContent = 'Online';
                document.getElementById('moodEmoji').textContent = '🦊';
                window.setFoxStatus('idle');
            }
            
            document.getElementById('moodIdle').classList.remove('active');
            document.getElementById('moodActive').classList.remove('active');
            document.getElementById('moodWorking').classList.remove('active');
            
            const moodPct = d.mood || 75;
            document.getElementById('moodBar').style.width = moodPct + '%';
            
            if (status === 'working') document.getElementById('moodWorking').classList.add('active');
            else if (status === 'idle') document.getElementById('moodIdle').classList.add('active');
            else document.getElementById('moodActive').classList.add('active');
            
            document.getElementById('currentTask').textContent = d.currentTask || 'Waiting for tasks...';
            if (!d.currentTask) document.getElementById('currentTask').classList.add('current-task-empty');
            else document.getElementById('currentTask').classList.remove('current-task-empty');
            
            // Update new visualizations
            const hbInterval = d.heartbeat || 10;
            updateHeartbeatWaveform(hbInterval);
            updateEnergy(status, hbInterval);
            updateStatsTicker(d);
            
            // v11.4: Update heartbeat pulse ring
            updateHeartbeatPulseRing(hbInterval);
            
            // v11.4: Update activity heatmap
            updateActivityHeatmap(d);
            
            // v11.4: Update smart mood
            updateSmartMood(d, status);
            
            // v11.4: Update persona quote
            updatePersonaQuote(status, d);
        }
        
        // v11.4: Heartbeat Pulse Ring
        let heartbeatRingInterval = null;
        function updateHeartbeatPulseRing(hbInterval) {
            const outerRing = document.getElementById('heartbeatRingOuter');
            const innerRing = document.getElementById('heartbeatRingInner');
            if (!outerRing || !innerRing) return;
            
            // Clear existing animation
            if (heartbeatRingInterval) clearInterval(heartbeatRingInterval);
            
            // Parse heartbeat value
            let intervalMs = 3000; // default
            if (typeof hbInterval === 'string') {
                if (hbInterval.endsWith('s')) intervalMs = parseInt(hbInterval) * 1000;
                else if (hbInterval.endsWith('m')) intervalMs = parseInt(hbInterval) * 60000;
                else if (hbInterval.endsWith('h')) intervalMs = parseInt(hbInterval) * 3600000;
            } else if (typeof hbInterval === 'number') {
                intervalMs = hbInterval * 1000;
            }
            
            // Cap interval
            intervalMs = Math.min(Math.max(intervalMs, 1000), 60000);
            
            // Set animation duration
            const duration = intervalMs / 1000;
            outerRing.style.animationDuration = duration + 's';
            innerRing.style.animationDuration = duration + 's';
            
            // Start pulsing
            outerRing.classList.add('pulse');
            innerRing.classList.add('pulse');
        }
        
        // v11.4: Activity Heatmap
        const activityHistory = [];
        const MAX_HISTORY = 7; // 7 days
        function updateActivityHeatmap(d) {
            // Add current activity level to history
            const activityLevel = d.activityLevel || 50;
            const msgCount = d.msgCount || 0;
            const taskDone = d.taskDone || 0;
            
            // Calculate activity score
            const score = Math.min((activityLevel / 100) * 0.4 + (msgCount > 0 ? 0.3 : 0) + (taskDone > 0 ? 0.3 : 0), 1);
            activityHistory.push({ score, timestamp: Date.now() });
            
            // Keep only last 7 days of data
            const now = Date.now();
            while (activityHistory.length > 0 && now - activityHistory[0].timestamp > 7 * 24 * 60 * 60 * 1000) {
                activityHistory.shift();
            }
            
            // Calculate level for each day
            const heatmap = document.getElementById('activityHeatmap');
            if (!heatmap) return;
            
            const cells = heatmap.querySelectorAll('.heatmap-cell');
            const dayCount = Math.min(activityHistory.length, 7);
            
            // Show activity levels in reverse order (most recent first)
            for (let i = 0; i < 7; i++) {
                const dayIndex = 6 - i; // Reverse order
                const dataIndex = activityHistory.length - 1 - i;
                
                if (dataIndex >= 0 && i < dayCount) {
                    const entry = activityHistory[dataIndex];
                    const level = entry.score > 0.75 ? 4 : entry.score > 0.5 ? 3 : entry.score > 0.25 ? 2 : entry.score > 0 ? 1 : 0;
                    cells[dayIndex].className = 'heatmap-cell level-' + level;
                } else {
                    cells[dayIndex].className = 'heatmap-cell level-0';
                }
            }
            
            // Update activity total
            const totalEl = document.getElementById('activityTotal');
            if (totalEl) {
                const totalEvents = activityHistory.reduce((sum, e) => sum + Math.round(e.score * 10), 0);
                totalEl.textContent = totalEvents + ' events';
            }
        }
        
        // v11.4: Smart Mood System
        function updateSmartMood(d, status) {
            const iconEl = document.getElementById('smartMoodIcon');
            const factorEl = document.getElementById('smartMoodFactor');
            if (!iconEl || !factorEl) return;
            
            const hour = new Date().getHours();
            const activityLevel = d.activityLevel || 50;
            const msgCount = d.msgCount || 0;
            
            // Determine mood based on time of day and activity
            let mood = 'idle';
            let factor = '';
            
            if (status === 'working') {
                mood = 'working';
                factor = '处理任务中';
            } else if (status === 'thinking') {
                mood = 'thinking';
                factor = '深度思考中';
            } else if (hour >= 22 || hour < 6) {
                mood = 'sleeping';
                factor = '夜深了，该休息';
            } else if (hour >= 6 && hour < 9) {
                mood = 'excited';
                factor = '早上好！';
            } else if (hour >= 9 && hour < 12) {
                mood = 'working';
                factor = '上午工作时间';
            } else if (hour >= 12 && hour < 14) {
                mood = 'idle';
                factor = '午休时间';
            } else if (hour >= 14 && hour < 18) {
                mood = 'working';
                factor = '下午工作时间';
            } else if (hour >= 18 && hour < 22) {
                mood = 'idle';
                factor = '晚间休息';
            }
            
            if (msgCount > 50) factor = '活跃聊天中';
            if (activityLevel > 80) factor = '高度活跃';
            
            const moodMap = {
                'idle': '🦊',
                'working': '⚡',
                'thinking': '🤔',
                'sleeping': '😴',
                'excited': '🤩',
                'laughing': '😂'
            };
            
            iconEl.textContent = moodMap[mood] || '🦊';
            factorEl.textContent = factor;
        }
        
        // v11.4: Agent Persona Quote
        const personaQuotes = {
            'working': ['"让哥哥的工作更轻松～"', '"正在努力思考中..."', '"处理任务我是专业的！"'],
            'thinking': ['"让我想想这个问题..."', '"思考中...🤔"', '"这有个好主意！"'],
            'sleeping': ['"Zzz...让我充充电先"', '"休息中...勿扰"', '"明天继续加油！"'],
            'idle': ['"哥哥需要帮忙吗～"', '"有什么我可以做的吗？"', '"随时待命中！"'],
            'excited': ['"太棒了！！！"', '"这个好有趣！"', '"哇～哥哥好厉害！"'],
            'laughing': ['"哈哈哈好好玩～"', '"笑死我了😂"', '"哥哥真幽默！"']
        };
        
        function updatePersonaQuote(status, d) {
            const quoteEl = document.getElementById('personaQuote');
            if (!quoteEl) return;
            
            const quotes = personaQuotes[status] || personaQuotes.idle;
            const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
            quoteEl.textContent = randomQuote;
        }
        
        // v14.0: Sound state visual update with wave visualizer
        let soundEnabled = true;
        function updateSoundVisual() {
            const soundBtn = document.getElementById('soundBtn');
            const soundLabel = document.getElementById('soundLabel');
            const soundWave = document.getElementById('soundWaveVisualizer');
            if (!soundBtn || !soundLabel) return;
            
            if (soundEnabled) {
                soundBtn.classList.remove('muted');
                soundLabel.textContent = '🔊';
                if (soundWave) soundWave.classList.remove('muted');
            } else {
                soundBtn.classList.add('muted');
                soundLabel.textContent = '🔇';
                if (soundWave) soundWave.classList.add('muted');
            }
        }

        // v16.0: Show keyboard shortcuts panel
        function showShortcuts() {
            const panel = document.getElementById('shortcutsPanel');
            panel.classList.add('visible');
        }

        // v16.0: Hide shortcuts panel
        function hideShortcuts() {
            const panel = document.getElementById('shortcutsPanel');
            panel.classList.remove('visible');
        }

        // v16.0: Show XP float notification
        function showXPFloat(amount) {
            const existing = document.querySelector('.xp-float');
            if (existing) existing.remove();
            const el = document.createElement('div');
            el.className = 'xp-float';
            el.textContent = '+' + amount + ' XP';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 1300);
        }

        // v16.0: AI Thinking indicator - show when data is being fetched
        let thinkingTimeout = null;
        function showThinkingIndicator() {
            const el = document.getElementById('aiThinking');
            if (el) {
                el.classList.add('visible');
                if (thinkingTimeout) clearTimeout(thinkingTimeout);
                thinkingTimeout = setTimeout(() => {
                    el.classList.remove('visible');
                }, 3000);
            }
        }

        function toggleSound() {
            soundEnabled = !soundEnabled;
            updateSoundVisual();
            if (soundEnabled) playNotificationSound();
        }

        fetchData();
        setInterval(fetchData, 10000);
        
        // Keyboard shortcut: Press 'R' to manually refresh
        document.addEventListener('keydown', (e) => {
            // Skip if user is typing in an input
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

            if (e.key === 'r' || e.key === 'R') {
                if (!isFetching) {
                    fetchData();
                    // Visual feedback
                    const avatar = document.querySelector('.avatar');
                    if (avatar) {
                        avatar.style.transform = 'scale(1.1)';
                        setTimeout(() => avatar.style.transform = '', 200);
                    }
                }
            }
            // Press 'S' to toggle sleep mode
            if (e.key === 's' || e.key === 'S') {
                const cards = document.querySelectorAll('.main-card, .stat-card');
                cards.forEach(card => {
                    card.style.filter = card.style.filter ? '' : 'grayscale(80%)';
                });
            }
            // v16.0: Press '?' to show shortcuts
            if (e.key === '?') {
                showShortcuts();
            }
            // v16.0: Press Escape to close panels
            if (e.key === 'Escape') {
                hideShortcuts();
                hideSkillsPopup();
                hideNotificationPanel();
            }
        });
        
        // Skills popup functions
        window.currentSkillsList = [];
        
        function showSkillsPopup() {
            const popup = document.getElementById('skillsPopup');
            const overlay = document.getElementById('popupOverlay');
            const content = document.getElementById('skillsPopupContent');
            
            if (!window.currentSkillsList || window.currentSkillsList.length === 0) {
                content.innerHTML = '<div style="color: var(--text-dim); text-align: center; padding: 20px;">暂无技能数据</div>';
            } else {
                // 获取分类信息
                const categories = window.currentSkillsCategories || {};
                const categoryNames = {
                    'system': '系统',
                    'memory': '记忆',
                    'agent': '代理',
                    'utility': '工具',
                    'integration': '集成',
                    'news': '资讯',
                    'security': '安全',
                    'development': '开发',
                    'search': '搜索',
                    'other': '其他'
                };
                
                // v15.1: 构建分类统计 + 雷达图
                let categoryHTML = '';
                if (Object.keys(categories).length > 0) {
                    const radarColors = ['#FF6B6B','#4ECDC4','#45B7D1','#96CEB4','#FFEAA7','#DDA0DD','#98D8C8','#F7DC6F','#BB8FCE','#85C1E9'];
                    const catEntries = Object.entries(categories);
                    const maxCount = Math.max(...catEntries.map(([,c]) => c));
                    const radarId = 'skillsRadarCanvas';
                    const legendHTML = catEntries.map(([cat, count], i) => {
                        const pct = maxCount > 0 ? (count / maxCount * 100).toFixed(0) : 0;
                        return `<div class="skills-radar-legend-item"><span class="skills-radar-legend-dot" style="background:${radarColors[i % radarColors.length]}"></span>${categoryNames[cat] || cat} <span style="color:var(--text-bright)">${count}</span></div>`;
                    }).join('');
                    categoryHTML = `<div class="skills-radar-wrap">
                        <canvas id="${radarId}" width="120" height="120"></canvas>
                        <div class="skills-radar-legend">${legendHTML}</div>
                    </div>`;
                    // Draw radar chart after DOM insertion
                    setTimeout(() => {
                        const canvas = document.getElementById(radarId);
                        if (!canvas) return;
                        const ctx = canvas.getContext('2d');
                        const cx = 60, cy = 60, r = 50;
                        const n = catEntries.length;
                        const keys = catEntries.map(([k]) => k);
                        const vals = catEntries.map(([,c]) => c);
                        // Draw grid (5 rings)
                        for (let ring = 1; ring <= 5; ring++) {
                            const rr = r * ring / 5;
                            ctx.beginPath();
                            for (let i = 0; i < n; i++) {
                                const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
                                const px = cx + Math.cos(angle) * rr;
                                const py = cy + Math.sin(angle) * rr;
                                i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
                            }
                            ctx.closePath();
                            ctx.strokeStyle = 'rgba(255,255,255,0.08)';
                            ctx.lineWidth = 0.5;
                            ctx.stroke();
                        }
                        // Draw axes & data
                        for (let i = 0; i < n; i++) {
                            const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
                            const px = cx + Math.cos(angle) * r;
                            const py = cy + Math.sin(angle) * r;
                            ctx.beginPath();
                            ctx.moveTo(cx, cy);
                            ctx.lineTo(px, py);
                            ctx.strokeStyle = 'rgba(255,255,255,0.1)';
                            ctx.lineWidth = 0.5;
                            ctx.stroke();
                            // Label
                            const lx = cx + Math.cos(angle) * (r + 14);
                            const ly = cy + Math.sin(angle) * (r + 14);
                            ctx.fillStyle = 'rgba(255,255,255,0.4)';
                            ctx.font = '7px JetBrains Mono, monospace';
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'middle';
                            ctx.fillText(categoryNames[keys[i]] || keys[i], lx, ly);
                        }
                        // Fill data area with gradient
                        ctx.beginPath();
                        for (let i = 0; i < n; i++) {
                            const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
                            const rr = maxCount > 0 ? r * vals[i] / maxCount : 0;
                            const px = cx + Math.cos(angle) * rr;
                            const py = cy + Math.sin(angle) * rr;
                            i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
                        }
                        ctx.closePath();
                        const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
                        grad.addColorStop(0, 'rgba(78,205,196,0.4)');
                        grad.addColorStop(1, 'rgba(255,107,107,0.15)');
                        ctx.fillStyle = grad;
                        ctx.fill();
                        // Draw data points
                        for (let i = 0; i < n; i++) {
                            const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
                            const rr = maxCount > 0 ? r * vals[i] / maxCount : 0;
                            const px = cx + Math.cos(angle) * rr;
                            const py = cy + Math.sin(angle) * rr;
                            ctx.beginPath();
                            ctx.arc(px, py, 3, 0, Math.PI * 2);
                            ctx.fillStyle = radarColors[i % radarColors.length];
                            ctx.fill();
                        }
                    }, 50);
                }
                
                // 构建技能列表
                const skillsHTML = window.currentSkillsList.map(skill => `
                    <div class="skill-item">
                        <div class="skill-info">
                            <span class="skill-name">${skill.name}</span>
                            ${skill.category ? `<span class="skill-category">${categoryNames[skill.category] || skill.category}</span>` : ''}
                        </div>
                        <span class="skill-badge ${skill.active ? 'active' : 'inactive'}">${skill.active ? '活跃' : skill.updated}</span>
                    </div>
                `).join('');
                
                content.innerHTML = categoryHTML + '<div class="skills-list">' + skillsHTML + '</div>';
            }
            
            popup.classList.add('visible');
            overlay.classList.add('visible');
        }
        
        function hideSkillsPopup() {
            document.getElementById('skillsPopup').classList.remove('visible');
            document.getElementById('popupOverlay').classList.remove('visible');
        }
        
        function refreshData() {
            // v14.1: Enhanced sync animation
            const mainCard = document.getElementById('mainCard');
            const syncIndicator = document.getElementById('smartRefresh');
            
            // Show sync indicator
            if (syncIndicator) {
                syncIndicator.classList.add('active');
                syncIndicator.style.opacity = '1';
            }
            
            // Card ripple effect
            document.querySelectorAll('.stat-card').forEach((card, i) => {
                setTimeout(() => {
                    card.classList.add('updated');
                    card.style.transform = 'scale(0.95)';
                    setTimeout(() => {
                        card.classList.remove('updated');
                        card.style.transform = '';
                    }, 400);
                }, i * 50); // Stagger effect
            });
            
            // Add sync pulse to main card
            mainCard.classList.add('sync-pulse');
            
            fetchData();
            
            // Remove sync indicator after delay
            setTimeout(() => {
                if (syncIndicator) {
                    syncIndicator.classList.remove('active');
                    syncIndicator.style.opacity = '';
                }
                mainCard.classList.remove('sync-pulse');
            }, 800);
        }
        
        let powerSaving = false;
        let lastStatus = 'idle';
        
        function togglePowerSaving() {
            powerSaving = !powerSaving;
            document.body.classList.toggle('power-saving', powerSaving);
            const indicator = document.getElementById('powerIndicator');
            indicator.classList.toggle('visible', powerSaving);
        }
        
        function playNotificationSound() {
            if (!soundEnabled) return;
            try {
                const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioContext.createOscillator();
                const gainNode = audioContext.createGain();
                oscillator.connect(gainNode);
                gainNode.connect(audioContext.destination);
                oscillator.frequency.value = 800;
                oscillator.type = 'sine';
                gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.2);
                oscillator.start(audioContext.currentTime);
                oscillator.stop(audioContext.currentTime + 0.2);
            } catch(e) {}
        }
        
        // Enhanced status change feedback
        function notifyStatusChange(newStatus) {
            if (lastStatus !== newStatus) {
                const mainCard = document.getElementById('mainCard');
                mainCard.classList.add('enhanced');
                mainCard.classList.add('status-change');
                setTimeout(() => {
                    mainCard.classList.remove('enhanced');
                    mainCard.classList.remove('status-change');
                }, 2000);
                
                // Update avatar glow based on status
                const avatarGlow = document.querySelector('.avatar-glow');
                avatarGlow.className = 'avatar-glow ' + newStatus;
                
                // Update background mesh
                const bgMesh = document.querySelector('.bg-mesh');
                bgMesh.className = 'bg-mesh ' + newStatus;
                
                // Create sparkle burst effect
                createStatusChangeBurst(newStatus);
                
                lastStatus = newStatus;
            }
        }
        
        // Create sparkle burst on status change (v14.0 enhanced)
        function createStatusChangeBurst(status) {
            const colors = {
                'working': ['#00d4ff', '#22d3ee'],
                'idle': ['#ffc864', '#ffaa33'],
                'sleeping': ['#8892b0', '#a8b2d1'],
                'excited': ['#ff9ff3', '#feca57'],
                'thinking': ['#a29bfe', '#6c5ce7'],
                'focused': ['#00ff88', '#00ffaa'],    // v14.0
                'learning': ['#ff9500', '#ffb347']    // v14.0
            };
            const burstColors = colors[status] || ['#00d4ff', '#ffc864'];
            
            for (let i = 0; i < 12; i++) {
                const sparkle = document.createElement('div');
                sparkle.style.cssText = `
                    position: fixed;
                    width: 6px;
                    height: 6px;
                    border-radius: 50%;
                    background: ${burstColors[i % 2]};
                    pointer-events: none;
                    z-index: 1000;
                    left: 50%;
                    top: 50%;
                    transform: translate(-50%, -50%);
                    animation: burst ${0.8 + Math.random() * 0.4}s ease-out forwards;
                `;
                document.body.appendChild(sparkle);
                
                // Random direction
                const angle = (i / 12) * Math.PI * 2;
                const distance = 80 + Math.random() * 60;
                sparkle.animate([
                    { transform: 'translate(-50%, -50%) scale(1)', opacity: 1 },
                    { transform: `translate(calc(-50% + ${Math.cos(angle) * distance}px), calc(-50% + ${Math.sin(angle) * distance}px)) scale(0)`, opacity: 0 }
                ], {
                    duration: 800 + Math.random() * 400,
                    easing: 'ease-out'
                });
                
                setTimeout(() => sparkle.remove(), 1200);
            }
        }
        
        document.addEventListener('keydown', (e) => { if (e.key === 'r' || e.key === 'R') refreshData(); });
        
        // Spotlight effect following mouse
        const mainCard = document.getElementById('mainCard');
        const spotlight = document.getElementById('spotlight');
        
        mainCard.addEventListener('mousemove', (e) => {
            const rect = mainCard.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            if (spotlight) {
                spotlight.style.setProperty('--x', x + '%');
                spotlight.style.setProperty('--y', y + '%');
            }
        });
        
        // Add touch gestures
        let touchStartY = 0;
        document.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; });
        document.addEventListener('touchend', (e) => {
            const touchEndY = e.changedTouches[0].clientY;
            if (touchStartY - touchEndY > 50) refreshData(); // Swipe up to refresh
        });
        
        // New: Double-tap to toggle fullscreen
        let lastTap = 0;
        document.addEventListener('touchend', (e) => {
            const currentTime = new Date().getTime();
            const tapLength = currentTime - lastTap;
            if (tapLength < 300 && tapLength > 0) {
                if (!document.fullscreenElement) {
                    document.documentElement.requestFullscreen().catch(() => {});
                } else {
                    document.exitFullscreen().catch(() => {});
                }
            }
            lastTap = currentTime;
        });
        
        // New: Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            // F for focus mode toggle
            if (e.key === 'f' || e.key === 'F') {
                mainCard.classList.toggle('focus-mode');
            }
            // G for gaming mode
            if (e.key === 'g' || e.key === 'G') {
                mainCard.classList.toggle('gaming');
            }
            // C for celebration effect
            if (e.key === 'c' || e.key === 'C') {
                const avatar = document.getElementById('avatar');
                avatar.classList.add('celebrating');
                setTimeout(() => avatar.classList.remove('celebrating'), 3000);
            }
        });
        
        // New: Add detail popups to stats
        function addStatDetails() {
            const statCards = document.querySelectorAll('.stat-card');
            const details = {
                'hb': '心跳间隔',
                'msgs': '今日消息总数',
                'tasks': '完成任务数',
                'uptime': '运行时长'
            };
            statCards.forEach(card => {
                const icon = card.querySelector('.stat-icon');
                if (icon) {
                    const tooltip = document.createElement('div');
                    tooltip.className = 'detail-popup';
                    const statId = icon.nextElementSibling?.nextElementSibling?.id || '';
                    tooltip.textContent = details[statId] || '';
                    if (tooltip.textContent) {
                        card.appendChild(tooltip);
                    }
                }
            });
        }
        addStatDetails();
        
        // New: Screen visibility API - pause updates when hidden
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                // Pause auto-refresh when tab is hidden
                if (countdownTimer) clearInterval(countdownTimer);
            } else {
                // Resume and refresh immediately when visible
                fetchData();
                startRefreshCountdown();
            }
        });

        // Enhanced Data Stream Effect =====
        class DataStreamEffect {
            constructor() {
                this.container = document.createElement('div');
                this.container.className = 'data-stream';
                this.container.style.cssText = 'position:fixed;top:0;right:0;width:120px;height:100%;pointer-events:none;overflow:hidden;opacity:0.12;z-index:4;';
                document.body.appendChild(this.container);
                this.active = false;
                this.interval = null;
            }
            
            start() {
                if (this.active) return;
                this.active = true;
                
                // Create random data bits falling
                this.interval = setInterval(() => {
                    if (!this.active || Math.random() > 0.3) return;
                    
                    const bit = document.createElement('div');
                    bit.className = 'stream-bit';
                    const chars = '01✦⚡☾●◉◇◆□■△▽◎※♦♢♠♣♥♡';
                    bit.textContent = chars[Math.floor(Math.random() * chars.length)];
                    bit.style.cssText = `
                        position: absolute;
                        font-family: 'JetBrains Mono', monospace;
                        font-size: ${8 + Math.random() * 8}px;
                        color: var(--accent);
                        left: ${Math.random() * 80}px;
                        top: -20px;
                        text-shadow: 0 0 5px var(--accent);
                    `;
                    this.container.appendChild(bit);
                    
                    // Animate falling
                    let posY = -20;
                    const speed = 1 + Math.random() * 2;
                    const animate = () => {
                        posY += speed;
                        if (posY > window.innerHeight) {
                            bit.remove();
                            return;
                        }
                        bit.style.top = posY + 'px';
                        bit.style.opacity = Math.max(0, 1 - posY / window.innerHeight);
                        requestAnimationFrame(animate);
                    };
                    requestAnimationFrame(animate);
                }, 100);
            }
            
            stop() {
                this.active = false;
                if (this.interval) clearInterval(this.interval);
            }
        }
        
        const dataStream = new DataStreamEffect();
        dataStream.start();

        // ===== New: Voice TTS Button =====
        function addVoiceButton() {
            const btn = document.createElement('button');
            btn.id = 'voiceBtn';
            btn.innerHTML = '🎤';
            btn.title = '语音交互';
            btn.style.cssText = 'position:fixed;bottom:14px;left:50%;transform:translateX(-50%);padding:10px 16px;background:var(--glass);border:1px solid var(--glass-border);border-radius:20px;font-size:16px;cursor:pointer;z-index:100;backdrop-filter:blur(10px);transition:all 0.3s;';
            btn.onmouseenter = () => { btn.style.background = 'rgba(255,200,100,0.15)'; btn.style.transform = 'translateX(-50%) scale(1.05)'; };
            btn.onmouseleave = () => { btn.style.background = 'var(--glass)'; btn.style.transform = 'translateX(-50%) scale(1)'; };
            btn.onclick = () => {
                // Check if Web Speech API is available
                if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
                    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                    const recognition = new SpeechRecognition();
                    recognition.lang = 'zh-CN';
                    recognition.interimResults = false;
                    recognition.maxAlternatives = 1;
                    
                    btn.innerHTML = '👂';
                    btn.style.background = 'rgba(0,212,255,0.2)';
                    
                    recognition.onresult = (event) => {
                        const transcript = event.results[0][0].transcript;
                        btn.innerHTML = '🎤';
                        btn.style.background = 'var(--glass)';
                        // Show recognized text
                        showVoiceFeedback(transcript);
                    };
                    
                    recognition.onerror = () => {
                        btn.innerHTML = '🎤';
                        btn.style.background = 'var(--glass)';
                    };
                    
                    recognition.onend = () => {
                        btn.innerHTML = '🎤';
                        btn.style.background = 'var(--glass)';
                    };
                    
                    recognition.start();
                } else {
                    alert('语音识别暂不支持此浏览器');
                }
            };
            document.body.appendChild(btn);
        }

        function showVoiceFeedback(text) {
            const feedback = document.createElement('div');
            feedback.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--bg-card);border:1px solid var(--glass-border);border-radius:12px;padding:16px 24px;font-size:14px;color:var(--text);z-index:1001;backdrop-filter:blur(20px);box-shadow:0 10px 40px rgba(0,0,0,0.5);';
            feedback.textContent = '🎯 识别到: ' + text;
            document.body.appendChild(feedback);
            setTimeout(() => feedback.remove(), 3000);
        }

        addVoiceButton();

        // ===== Settings Panel =====
        function showSettingsPanel() {
            const overlay = document.createElement('div');
            overlay.id = 'settingsOverlay';
            overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:999;opacity:0;visibility:hidden;transition:all 0.3s;';
            
            const panel = document.createElement('div');
            panel.id = 'settingsPanel';
            panel.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.9);background:var(--bg-card);border:1px solid var(--glass-border);border-radius:16px;padding:24px;z-index:1000;backdrop-filter:blur(32px);box-shadow:0 20px 60px rgba(0,0,0,0.6);min-width:320px;opacity:0;visibility:hidden;transition:all 0.3s cubic-bezier(0.4,0,0.2,1);';
            
            panel.innerHTML = `
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                    <span style="font-size:16px;font-weight:600;color:var(--text-bright);">⚙️ 设置</span>
                    <button onclick="hideSettingsPanel()" style="background:none;border:none;color:var(--text-dim);font-size:20px;cursor:pointer;">×</button>
                </div>
                <div style="display:flex;flex-direction:column;gap:14px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="font-size:13px;color:var(--text);">自动刷新</span>
                        <label style="position:relative;width:44px;height:24px;">
                            <input type="checkbox" id="autoRefreshToggle" checked style="opacity:0;width:0;height:0;">
                            <span style="position:absolute;cursor:pointer;inset:0;background:var(--glass);border-radius:24px;transition:0.3s;"></span>
                        </label>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="font-size:13px;color:var(--text);">动画效果</span>
                        <label style="position:relative;width:44px;height:24px;">
                            <input type="checkbox" id="animationsToggle" checked style="opacity:0;width:0;height:0;">
                            <span style="position:absolute;cursor:pointer;inset:0;background:var(--glass);border-radius:24px;transition:0.3s;"></span>
                        </label>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="font-size:13px;color:var(--text);">音效反馈</span>
                        <label style="position:relative;width:44px;height:24px;">
                            <input type="checkbox" id="soundToggle" checked style="opacity:0;width:0;height:0;">
                            <span style="position:absolute;cursor:pointer;inset:0;background:var(--glass);border-radius:24px;transition:0.3s;"></span>
                        </label>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="font-size:13px;color:var(--text);">刷新间隔</span>
                        <select id="refreshIntervalSelect" style="background:var(--glass);border:1px solid var(--glass-border);border-radius:8px;padding:6px 12px;color:var(--text);font-size:12px;">
                            <option value="5">5秒</option>
                            <option value="10" selected>10秒</option>
                            <option value="20">20秒</option>
                            <option value="30">30秒</option>
                        </select>
                    </div>
                </div>
                <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--glass-border);">
                    <button onclick="hideSettingsPanel()" style="width:100%;padding:12px;background:linear-gradient(135deg,var(--primary),var(--accent));border:none;border-radius:10px;color:var(--bg-dark);font-size:13px;font-weight:600;cursor:pointer;">保存设置</button>
                </div>
            `;
            
            document.body.appendChild(overlay);
            document.body.appendChild(panel);
            
            // Style the toggles
            setTimeout(() => {
                const toggles = panel.querySelectorAll('input[type="checkbox"]');
                toggles.forEach((toggle, i) => {
                    const span = toggle.nextElementSibling;
                    toggle.checked = i === 0 || i === 1 || i === 2;
                    if (toggle.checked) span.style.background = 'linear-gradient(135deg, var(--primary), var(--accent))';
                    toggle.addEventListener('change', () => {
                        span.style.background = toggle.checked ? 'linear-gradient(135deg, var(--primary), var(--accent))' : 'var(--glass)';
                    });
                });
            }, 0);
            
            // Show with animation
            requestAnimationFrame(() => {
                overlay.style.opacity = '1';
                overlay.style.visibility = 'visible';
                panel.style.opacity = '1';
                panel.style.visibility = 'visible';
                panel.style.transform = 'translate(-50%,-50%) scale(1)';
            });
            
            overlay.onclick = hideSettingsPanel;
        }

        function hideSettingsPanel() {
            const overlay = document.getElementById('settingsOverlay');
            const panel = document.getElementById('settingsPanel');
            if (overlay) {
                overlay.style.opacity = '0';
                overlay.style.visibility = 'hidden';
            }
            if (panel) {
                panel.style.opacity = '0';
                panel.style.visibility = 'hidden';
                panel.style.transform = 'translate(-50%,-50%) scale(0.9)';
            }
            setTimeout(() => {
                overlay?.remove();
                panel?.remove();
            }, 300);
        }

        // Add settings button to quick actions
        function addSettingsButton() {
            const actions = document.querySelector('.quick-actions');
            if (actions) {
                const settingsBtn = document.createElement('button');
                settingsBtn.className = 'action-btn';
                settingsBtn.textContent = '⚙️ 设置';
                settingsBtn.onclick = showSettingsPanel;
                actions.appendChild(settingsBtn);
                
                // Add about button
                const aboutBtn = document.createElement('button');
                aboutBtn.className = 'action-btn';
                aboutBtn.textContent = 'ℹ️ 关于';
                aboutBtn.onclick = showAboutPanel;
                actions.appendChild(aboutBtn);
            }
        }
        addSettingsButton();
        
        // About Panel
        function showAboutPanel() {
            const overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:999;backdrop-filter:blur(8px);';
            
            const panel = document.createElement('div');
            panel.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--bg-card);border:1px solid var(--glass-border);border-radius:20px;padding:28px;z-index:1000;backdrop-filter:blur(32px);box-shadow:0 25px 80px rgba(0,0,0,0.6);text-align:center;min-width:280px;';
            
            panel.innerHTML = `
                <div style="font-size:48px;margin-bottom:12px;">🦊</div>
                <div style="font-size:22px;font-weight:700;background:linear-gradient(135deg,var(--primary),var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:8px;">MoShang</div>
                <div style="font-size:12px;color:var(--text-dim);margin-bottom:16px;">OpenClaw Status Dashboard</div>
                <div style="display:flex;justify-content:center;gap:20px;margin:20px 0;">
                    <div style="text-align:center;"><div style="font-size:18px;font-weight:600;color:var(--accent);">7</div><div style="font-size:10px;color:var(--text-dim);">状态</div></div>
                    <div style="text-align:center;"><div style="font-size:18px;font-weight:600;color:var(--primary);">6</div><div style="font-size:10px;color:var(--text-dim);">快捷键</div></div>
                    <div style="text-align:center;"><div style="font-size:18px;font-weight:600;color:var(--success);">∞</div><div style="font-size:10px;color:var(--text-dim);">可能</div></div>
                </div>
                <div style="font-size:11px;color:var(--text-dim);line-height:1.6;">
                    <div>⚡ 你的数字弟弟 - 永远在线</div>
                    <div style="margin-top:8px;">Built with ❤️ using Canvas + CSS</div>
                </div>
                <button onclick="this.closest('[style*=\"z-index:1000\"]').previousSibling?.remove();this.closest('[style*=\"z-index:1000\"]').remove()" style="margin-top:20px;padding:10px 32px;background:var(--glass);border:1px solid var(--glass-border);border-radius:20px;color:var(--text);cursor:pointer;">关闭</button>
            `;
            
            document.body.appendChild(overlay);
            document.body.appendChild(panel);
            
            overlay.onclick = () => { overlay.remove(); panel.remove(); };
        }

        // ===== New: Keyboard Shortcuts Guide =====
        function showKeyboardGuide() {
            const guide = document.createElement('div');
            guide.id = 'kbdGuide';
            guide.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--bg-card);border:1px solid var(--glass-border);border-radius:16px;padding:24px;z-index:1001;backdrop-filter:blur(32px);box-shadow:0 20px 60px rgba(0,0,0,0.6);min-width:340px;max-width:90vw;';
            guide.innerHTML = `
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                    <span style="font-size:16px;font-weight:600;color:var(--text-bright);">⚡ MoShang 快捷键</span>
                    <button onclick="this.parentElement.parentElement.remove()" style="background:none;border:none;color:var(--text-dim);font-size:20px;cursor:pointer;">×</button>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:12px;color:var(--text-dim);margin-bottom:16px;">
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">R</kbd>刷新数据</div>
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">E</kbd>节能模式</div>
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">1-7</kbd>预览状态</div>
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">C</kbd>庆祝特效</div>
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">F</kbd>专注模式</div>
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">G</kbd>游戏模式</div>
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">?</kbd>显示帮助</div>
                    <div><kbd style="background:var(--glass);padding:3px 8px;border-radius:4px;margin-right:8px;">Esc</kbd>关闭弹窗</div>
                </div>
                <div style="border-top:1px solid var(--glass-border);padding-top:12px;margin-top:4px;">
                    <div style="font-size:11px;color:var(--text-dim);margin-bottom:8px;">📱 触屏操作</div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:11px;color:var(--text-dim);">
                        <div>👆 上滑刷新</div>
                        <div>👆👆 双击全屏</div>
                        <div>👆 长按头像</div>
                        <div>🖱️ 悬停卡片</div>
                    </div>
                </div>
                <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--glass-border);font-size:10px;color:var(--text-dim);text-align:center;">
                    OpenClaw Status Dashboard v15.5
                </div>
            `;
            document.body.appendChild(guide);
            
            // Close on Escape
            const escHandler = (e) => {
                if (e.key === 'Escape') {
                    guide.remove();
                    document.removeEventListener('keydown', escHandler);
                }
            };
            document.addEventListener('keydown', escHandler);
        }

        // Update keyboard handler to include ?
        document.addEventListener('keydown', (e) => {
            if (e.key === '?' || (e.shiftKey && e.key === '/')) {
                e.preventDefault();
                showKeyboardGuide();
            }
            // V for voice
            if (e.key === 'v' || e.key === 'V') {
                document.getElementById('voiceBtn')?.click();
            }
            // M for mini game
            if (e.key === 'm' || e.key === 'M') {
                startMiniGame();
            }
            // / for shortcuts panel
            if (e.key === '/') {
                e.preventDefault();
                showKeyboardGuide();
            }
            // Existing handlers...
            if (e.key === 'r' || e.key === 'R') {
                if (!e.ctrlKey && !e.metaKey) {
                    e.preventDefault();
                    fetchData();
                }
            }
            if (e.key === 'e' || e.key === 'E') {
                togglePowerSaving();
            }
            // Status keys 1-7
            const statusKeys = {'1':'idle','2':'working','3':'sleeping','4':'excited','5':'thinking','6':'laughing','7':'error'};
            if (statusKeys[e.key]) {
                setFoxStatus(statusKeys[e.key]);
            }
            // C for celebration
            if (e.key === 'c' || e.key === 'C') {
                const avatar = document.getElementById('avatar');
                avatar.classList.add('celebrating');
                setTimeout(() => avatar.classList.remove('celebrating'), 3000);
            }
            // Escape to close panels
            if (e.key === 'Escape') {
                const guide = document.getElementById('keyboardGuide');
                if (guide) guide.remove();
            }
        });

        // ===== Mini Game: Click the Fox =====
        let gameActive = false;
        let gameScore = 0;
        let gameTimeLeft = 30;
        
        function startMiniGame() {
            gameActive = true;
            gameScore = 0;
            gameTimeLeft = 30;
            
            // Create game overlay
            const overlay = document.createElement('div');
            overlay.id = 'gameOverlay';
            overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:2000;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;';
            overlay.innerHTML = `
                <div style="font-size:14px;color:var(--text-dim);">点击小狐狸得分</div>
                <div id="gameScore" style="font-size:48px;font-weight:700;color:var(--primary);">0</div>
                <div id="gameTarget" class="avatar" style="font-size:50px;cursor:pointer;animation:celebrate 0.3s ease infinite;">🦊</div>
                <div id="gameTimer" style="font-size:24px;color:var(--text);font-family:'JetBrains Mono',monospace;">30</div>
                <div style="font-size:12px;color:var(--text-dim);">按 Esc 退出</div>
            `;
            document.body.appendChild(overlay);
            
            const target = document.getElementById('gameTarget');
            const scoreEl = document.getElementById('gameScore');
            const timerEl = document.getElementById('gameTimer');
            
            target.onclick = (e) => {
                if (!gameActive) return;
                gameScore += 10;
                scoreEl.textContent = gameScore;
                // Random position
                const container = overlay;
                const maxX = container.clientWidth - 80;
                const maxY = container.clientHeight - 150;
                target.style.position = 'absolute';
                target.style.left = (50 + Math.random() * 30 - 15) + '%';
                target.style.top = (30 + Math.random() * 30 - 15) + '%';
            };
            
            // Game timer
            const gameTimer = setInterval(() => {
                if (!gameActive) {
                    clearInterval(gameTimer);
                    return;
                }
                gameTimeLeft--;
                timerEl.textContent = gameTimeLeft;
                if (gameTimeLeft <= 0) {
                    clearInterval(gameTimer);
                    gameActive = false;
                    overlay.remove();
                    showToast(`游戏结束！得分: ${gameScore}`, 'success');
                }
            }, 1000);
            
            // Close on Escape
            const escHandler = (e) => {
                if (e.key === 'Escape' && gameActive) {
                    gameActive = false;
                    clearInterval(gameTimer);
                    overlay.remove();
                    document.removeEventListener('keydown', escHandler);
                }
            };
            document.addEventListener('keydown', escHandler);
        }

        // ===== Toast Notification System =====
        window.showToast = function(message, type = 'info', duration = 3000) {
            let container = document.getElementById('toastContainer');
            if (!container) {
                container = document.createElement('div');
                container.id = 'toastContainer';
                container.style.cssText = 'position:fixed;top:60px;right:14px;z-index:1000;display:flex;flex-direction:column;gap:8px;';
                document.body.appendChild(container);
            }
            
            const toast = document.createElement('div');
            const colors = { success: 'var(--success)', warning: 'var(--warning)', error: 'var(--danger)', info: 'var(--accent)' };
            toast.style.cssText = `padding:10px 16px;background:var(--bg-card);border:1px solid var(--glass-border);border-left:3px solid ${colors[type]};border-radius:8px;font-size:12px;color:var(--text);backdrop-filter:blur(20px);animation:toastIn 0.3s ease-out;min-width:180px;`;
            toast.innerHTML = message;
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.animation = 'toastIn 0.3s ease-out reverse';
                setTimeout(() => toast.remove(), 300);
            }, duration);
        };

        // ===== Status-based ambient sounds (visual indicator) =====
        function updateAmbientIndicator() {
            let indicator = document.getElementById('ambientIndicator');
            if (!indicator) {
                indicator = document.createElement('div');
                indicator.id = 'ambientIndicator';
                indicator.style.cssText = 'position:fixed;top:14px;right:14px;width:8px;height:8px;border-radius:50%;background:var(--success);box-shadow:0 0 10px var(--success);z-index:100;transition:all 0.5s;';
                document.body.appendChild(indicator);
            }
            
            const status = currentFoxStatus;
            const colors = {
                idle: 'var(--warning)',
                working: 'var(--accent)',
                sleeping: '#5f6caf',
                excited: '#ff6b9d',
                thinking: '#a55eea',
                laughing: 'var(--primary)',
                error: 'var(--danger)'
            };
            
            indicator.style.background = colors[status] || colors.idle;
            indicator.style.boxShadow = `0 0 10px ${colors[status] || colors.idle}`;
        }
        
        // Call on status change
        const originalSetFoxStatus = setFoxStatus;
        setFoxStatus = function(status) {
            originalSetFoxStatus(status);
            updateAmbientIndicator();
            
            // Create status-specific particle burst
            createStatusParticles(status);
        };
        updateAmbientIndicator();
        
        // ===== Status-specific particle effects =====
        function createStatusParticles(status) {
            const particleCount = 15;
            const colors = {
                idle: ['#ffc864', '#ffaa33'],
                working: ['#00d4ff', '#22d3ee'],
                sleeping: ['#5f6caf', '#8892b0'],
                excited: ['#ff9ff3', '#feca57'],
                thinking: ['#a29bfe', '#6c5ce7'],
                laughing: ['#ffc864', '#ffaa33'],
                error: ['#ff6b6b', '#ee5a5a']
            };
            const statusColors = colors[status] || colors.idle;
            
            const avatarSection = document.querySelector('.avatar-section');
            const rect = avatarSection.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.style.cssText = `
                    position: fixed;
                    width: ${3 + Math.random() * 4}px;
                    height: ${3 + Math.random() * 4}px;
                    border-radius: 50%;
                    background: ${statusColors[i % 2]};
                    pointer-events: none;
                    z-index: 1000;
                    left: ${centerX}px;
                    top: ${centerY}px;
                `;
                document.body.appendChild(particle);
                
                const angle = (i / particleCount) * Math.PI * 2;
                const velocity = 50 + Math.random() * 80;
                const vx = Math.cos(angle) * velocity;
                const vy = Math.sin(angle) * velocity;
                
                let posX = centerX;
                let posY = centerY;
                let opacity = 1;
                let scale = 1;
                
                const animate = () => {
                    posX += vx * 0.02;
                    posY += vy * 0.02 + 0.5; // gravity
                    opacity -= 0.02;
                    scale -= 0.01;
                    
                    if (opacity <= 0) {
                        particle.remove();
                        return;
                    }
                    
                    particle.style.left = posX + 'px';
                    particle.style.top = posY + 'px';
                    particle.style.opacity = opacity;
                    particle.style.transform = `scale(${scale})`;
                    
                    requestAnimationFrame(animate);
                };
                
                requestAnimationFrame(animate);
            }
        }

        // ===== v10.0 NEW FEATURES =====

        // Live Activity - iOS Dynamic Island style
        let liveActivityTimer = null;
        function showLiveActivity(title, subtitle, duration = 5000) {
            const el = document.getElementById('liveActivity');
            const titleEl = document.getElementById('liveActivityTitle');
            const subtitleEl = document.getElementById('liveActivitySubtitle');
            const avatarEl = document.getElementById('liveActivityAvatar');
            const progressEl = document.getElementById('liveActivityProgress');

            titleEl.textContent = title;
            subtitleEl.textContent = subtitle;
            avatarEl.textContent = document.getElementById('moodEmoji')?.textContent || '🦊';
            el.classList.add('visible');

            // Animate progress ring
            const startTime = Date.now();
            const animateProgress = () => {
                const elapsed = Date.now() - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const offset = 56.5 * (1 - progress);
                progressEl.style.strokeDashoffset = offset;
                if (progress < 1) {
                    requestAnimationFrame(animateProgress);
                }
            };
            animateProgress();

            clearTimeout(liveActivityTimer);
            liveActivityTimer = setTimeout(() => {
                el.classList.remove('visible');
                progressEl.style.strokeDashoffset = 56.5;
            }, duration);
        }

        // Fox Expression Wheel
        let expressionWheelVisible = false;
        document.getElementById('avatar')?.addEventListener('dblclick', () => {
            const wheel = document.getElementById('foxExpressionWheel');
            expressionWheelVisible = !expressionWheelVisible;
            wheel.classList.toggle('visible', expressionWheelVisible);
        });

        function setFoxExpression(status) {
            const avatar = document.getElementById('avatar');
            const statusDot = document.getElementById('statusDot');
            const statusText = document.getElementById('statusText');
            const moodEmoji = document.getElementById('moodEmoji');
            const bgMesh = document.querySelector('.bg-mesh');

            // Reset classes
            avatar.className = 'avatar';
            statusDot.className = 'status-dot';
            statusText.className = 'status';

            // Set new status
            avatar.classList.add(status);
            statusDot.classList.add(status);
            statusText.classList.add(status);
            bgMesh.className = 'bg-mesh ' + status;

            const moodMap = { idle: '🦊', working: '⚡', sleeping: '😴', excited: '🤩', thinking: '🤔', laughing: '😂', error: '😵', focused: '🎯', learning: '📚' };
            const statusNames = { idle: 'Idle', working: 'Working', sleeping: 'Sleeping', excited: 'Excited!', thinking: 'Thinking', laughing: 'Happy!', error: 'Error', focused: 'Focused', learning: 'Learning' };

            moodEmoji.textContent = moodMap[status];
            statusText.textContent = statusNames[status];
            window.setFoxStatus(status);

            // Hide wheel
            document.getElementById('foxExpressionWheel').classList.remove('visible');
            expressionWheelVisible = false;

            // Show live activity
            showLiveActivity(statusNames[status], moodMap[status] + ' ' + statusNames[status]);

            // Auto reset after 5s unless same status
            clearTimeout(window._foxExpressionTimeout);
            window._foxExpressionTimeout = setTimeout(() => {
                avatar.className = 'avatar';
                statusDot.className = 'status-dot';
                statusText.className = 'status';
                bgMesh.className = 'bg-mesh';
                moodEmoji.textContent = '🦊';
                statusText.textContent = 'Online';
                window.setFoxStatus('idle');
            }, 5000);
        }

        // Toast Notification System v2
        function showToast(message, type = 'info', duration = 3000) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast-v2 ${type}`;

            const icons = { success: '✅', warning: '⚠️', error: '❌', info: 'ℹ️' };
            toast.innerHTML = `
                <span class="icon">${icons[type] || icons.info}</span>
                <span>${message}</span>
                <button class="close-btn" onclick="this.parentElement.remove()">×</button>
            `;

            container.appendChild(toast);
            setTimeout(() => toast.remove(), duration);
        }

        // Cursor Follower
        const cursorFollower = document.getElementById('cursorFollower');
        let cursorThrottle = false;
        document.addEventListener('mousemove', (e) => {
            if (cursorThrottle) return;
            cursorThrottle = true;
            cursorFollower.style.transform = `translate(${e.clientX - 6}px, ${e.clientY - 6}px)`;
            setTimeout(() => cursorThrottle = false, 50);
        });

        document.addEventListener('mouseover', (e) => {
            if (e.target.closest('button, a, .action-btn, .stat-card, .quick-action-item')) {
                cursorFollower.classList.add('hover');
            }
        });
        document.addEventListener('mouseout', (e) => {
            if (e.target.closest('button, a, .action-btn, .stat-card, .quick-action-item')) {
                cursorFollower.classList.remove('hover');
            }
        });

        // Confetti Celebration
        function triggerConfetti() {
            const colors = ['#ffc864', '#00d4ff', '#5cdb95', '#ff6b6b', '#a29bfe', '#ff9ff3'];
            for (let i = 0; i < 50; i++) {
                const confetti = document.createElement('div');
                confetti.className = 'confetti';
                confetti.style.cssText = `
                    left: ${Math.random() * 100}%;
                    background: ${colors[Math.floor(Math.random() * colors.length)]};
                    animation-delay: ${Math.random() * 2}s;
                    animation-duration: ${2 + Math.random() * 2}s;
                    border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
                    width: ${4 + Math.random() * 8}px;
                    height: ${4 + Math.random() * 8}px;
                `;
                document.body.appendChild(confetti);
                setTimeout(() => confetti.remove(), 5000);
            }
        }

        // Status Timeline v2
        function updateStatusTimeline(currentStatus) {
            const steps = ['idle', 'thinking', 'working', 'done'];
            const currentIndex = steps.indexOf(currentStatus);
            // Timeline would be rendered in the HTML, this just updates state
        }

        // Enhanced keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            // Press L to toggle Live Activity demo
            if (e.key === 'l' || e.key === 'L') {
                showLiveActivity('Live Activity Demo', 'This is a test notification', 4000);
            }
            // Press X to close live activity
            if (e.key === 'x' || e.key === 'X') {
                document.getElementById('liveActivity').classList.remove('visible');
