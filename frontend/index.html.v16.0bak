        };

        // ===== v12.0: Boot Events =====
        addTimelineEvent('仪表盘已加载 v12.1', 'ok');
        setTimeout(() => addTimelineEvent('AI助手已就绪', 'ok'), 1500);
        setTimeout(() => addTimelineEvent('天气服务已加载', 'ok'), 2500);
        setTimeout(() => addTimelineEvent('表情交互系统就绪', 'ok'), 3500);
        
        // ===== v12.1: Data Stream Animation =====
        function createDataStream() {
            const stream = document.createElement('div');
            stream.className = 'data-stream-line';
            stream.style.left = Math.random() * 100 + 'vw';
            stream.style.animationDuration = (3 + Math.random() * 4) + 's';
            stream.style.animationDelay = Math.random() * 2 + 's';
            stream.style.opacity = 0.3 + Math.random() * 0.4;
            document.body.appendChild(stream);
            stream.addEventListener('animationend', () => stream.remove());
        }
        // Create initial data streams
        for (let i = 0; i < 3; i++) {
            setTimeout(createDataStream, i * 1000);
        }
        // Continuously create data streams
        setInterval(createDataStream, 3000);
        
        // ===== v12.1: Enhanced Tooltip with Position Detection =====
        const originalShowTooltip = window.showTooltip;
        window.showTooltip = function(el, text) {
            if (originalShowTooltip) originalShowTooltip(el, text);
            // Add position-aware styling
            const rect = el.getBoundingClientRect();
            if (rect.top < 200) {
                el.classList.add('tooltip-below');
            }
        };
        
        // ===== v12.1: Mini Memory Widget =====
        window.showMiniMemory = function() {
            const memWidget = document.getElementById('miniMemoryWidget');
            if (memWidget) {
                memWidget.classList.toggle('visible');
                if (memWidget.classList.contains('visible')) {
                    // Fetch recent memories
                    try {
                        fetch(API_BASE + '/api/memories?recent=5')
                            .then(r => r.json())
                            .then(data => {
                                const list = memWidget.querySelector('.memory-list');
                                if (list && data.memories) {
                                    list.innerHTML = data.memories.slice(0, 5).map(m => 
                                        `<div class="memory-item">${m.content || m.text || '...'} <small>${m.time || ''}</small></div>`
                                    ).join('');
                                }
                            })
                            .catch(() => {
                                const list = memWidget.querySelector('.memory-list');
                                if (list) list.innerHTML = '<div class="memory-item">暂无记忆数据</div>';
                            });
                    } catch(e) {
                        const list = memWidget.querySelector('.memory-list');
                        if (list) list.innerHTML = '<div class="memory-item">记忆服务不可用</div>';
                    }
                }
            }
        };
        
        // ===== v12.1: Sparkline Generator =====
        window.generateSparkline = function(values, color = 'var(--accent)') {
            if (!values || values.length < 2) return '';
            const min = Math.min(...values);
            const max = Math.max(...values);
            const range = max - min || 1;
            const points = values.map((v, i) => {
                const x = (i / (values.length - 1)) * 60;
                const y = 14 - ((v - min) / range) * 12;
                return `${x},${y}`;
            }).join(' ');
            return `<svg viewBox="0 0 60 16"><polyline points="${points}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        };
        
        // ===== v12.1: Status-aware Ambient Sound Visualization =====
        const soundVizColors = {
            idle: 'var(--text-dim)',
            working: 'var(--accent)',
            sleeping: '#5f6caf',
            excited: 'var(--primary)',
            thinking: '#a55eea',
            laughing: 'var(--success)',
            error: 'var(--danger)'
        };
        
        window.updateSoundVisualization = function(status) {
            const waveform = document.getElementById('voiceWaveform');
            if (waveform) {
                waveform.style.setProperty('--viz-color', soundVizColors[status] || soundVizColors.idle);
                waveform.querySelectorAll('.voice-bar').forEach(bar => {
                    bar.style.background = soundVizColors[status] || soundVizColors.idle;
                });
            }
        };
        
        // ===== v12.1: Performance Monitor =====
        window.perfMetrics = {
            fps: 60,
            frameCount: 0,
            lastTime: performance.now(),
            samples: []
        };
        
        window.updatePerfMetrics = function() {
            perfMetrics.frameCount++;
            const now = performance.now();
            const delta = now - perfMetrics.lastTime;
            
            if (delta >= 1000) {
                perfMetrics.fps = Math.round((perfMetrics.frameCount * 1000) / delta);
                perfMetrics.frameCount = 0;
                perfMetrics.lastTime = now;
                perfMetrics.samples.push(perfMetrics.fps);
                if (perfMetrics.samples.length > 30) perfMetrics.samples.shift();
                
                // Update FPS display if available
                const fpsEl = document.getElementById('perfFPS');
                if (fpsEl) {
                    fpsEl.textContent = perfMetrics.fps + ' FPS';
                    fpsEl.style.color = perfMetrics.fps >= 50 ? 'var(--success)' : 
                                         perfMetrics.fps >= 30 ? 'var(--warning)' : 'var(--danger)';
                }
            }
            requestAnimationFrame(updatePerfMetrics);
        };
        requestAnimationFrame(updatePerfMetrics);
        
        // ===== v12.1: Keyboard shortcut for mini memory =====
        document.addEventListener('keydown', (e) => {
            if (e.key === 'm' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                const active = document.activeElement;
                if (active.tagName !== 'INPUT' && active.tagName !== 'TEXTAREA') {
                    e.preventDefault();
                    showMiniMemory();
                }
            }
        });
        
        // ===== v12.1: Enhanced Activity Sparkline =====
        window.updateActivitySparkline = function(data) {
            const canvas = document.getElementById('activitySparkline');
            if (!canvas) return;
            
            const ctx = canvas.getContext('2d');
            const width = canvas.width;
            const height = canvas.height;
            
            // Clear canvas
            ctx.clearRect(0, 0, width, height);
            
            // Generate mock activity data if not available
            const values = data?.activity?.slice(-20) || Array.from({length: 20}, () => Math.random() * height);
            
            if (values.length < 2) return;
            
            const max = Math.max(...values);
            const min = Math.min(...values);
            const range = max - min || 1;
            
            ctx.beginPath();
            ctx.strokeStyle = 'var(--accent)';
            ctx.lineWidth = 1.5;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            values.forEach((v, i) => {
                const x = (i / (values.length - 1)) * width;
                const y = height - ((v - min) / range) * (height - 4) - 2;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            
            ctx.stroke();
            
            // Add gradient fill
            ctx.lineTo(width, height);
            ctx.lineTo(0, height);
            ctx.closePath();
            const gradient = ctx.createLinearGradient(0, 0, 0, height);
            gradient.addColorStop(0, 'rgba(0, 212, 255, 0.3)');
            gradient.addColorStop(1, 'rgba(0, 212, 255, 0)');
            ctx.fillStyle = gradient;
            ctx.fill();
        };
        
        // ===== v13.0: Init =====
        console.log('%c🦊 MoShang Dashboard v13.0', 'color: var(--primary); font-size: 14px; font-weight: bold;');
        console.log('%c✨ 2026 Next-Gen: Liquid Glass, Magnetic UI, Particle Networks, Text Scramble', 'color: var(--accent);');

        // ===== v13.0: 2026 Next-Gen Interactive Features =====

        // Magnetic Button Effect
        document.querySelectorAll('.magnetic-hover').forEach(btn => {
            btn.addEventListener('mousemove', (e) => {
                const rect = btn.getBoundingClientRect();
                const x = e.clientX - rect.left - rect.width / 2;
                const y = e.clientY - rect.top - rect.height / 2;
                btn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
            });
            btn.addEventListener('mouseleave', () => {
                btn.style.transform = 'translate(0, 0)';
            });
        });

        // Scroll Reveal Animation
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal-up, .stagger-children').forEach(el => {
            revealObserver.observe(el);
        });

        // Spotlight Effect
        document.querySelectorAll('.spotlight-container').forEach(container => {
            const spotlight = document.createElement('div');
            spotlight.className = 'spotlight';
            container.appendChild(spotlight);

            container.addEventListener('mousemove', (e) => {
                const rect = container.getBoundingClientRect();
                spotlight.style.left = (e.clientX - rect.left) + 'px';
                spotlight.style.top = (e.clientY - rect.top) + 'px';
            });
        });

        // Text Scramble Effect
        class TextScramble {
            constructor(el) {
                this.el = el;
                this.chars = '!<>-_\\/[]{}—=+*^?#________';
                this.update = this.update.bind(this);
            }
            setText(newText) {
                const oldText = this.el.innerText;
                const length = Math.max(oldText.length, newText.length);
                const promise = new Promise((resolve) => this.resolve = resolve);
                this.queue = [];
                for (let i = 0; i < length; i++) {
                    const from = oldText[i] || '';
                    const to = newText[i] || '';
                    const start = Math.floor(Math.random() * 40);
                    const end = start + Math.floor(Math.random() * 40);
                    this.queue.push({ from, to, start, end });
                }
                cancelAnimationFrame(this.frameRequest);
                this.frame = 0;
                this.update();
                return promise;
            }
            update() {
                let output = '';
                let complete = 0;
                for (let i = 0, n = this.queue.length; i < n; i++) {
                    let { from, to, start, end, char } = this.queue[i];
                    if (this.frame >= end) {
                        complete++;
                        output += to;
                    } else if (this.frame >= start) {
                        if (!char || Math.random() < 0.28) {
                            char = this.randomChar();
                            this.queue[i].char = char;
                        }
                        output += `<span class="scramble-char">${char}</span>`;
                    } else {
                        output += from;
                    }
                }
                this.el.innerHTML = output;
                if (complete === this.queue.length) {
                    this.resolve();
                } else {
                    this.frameRequest = requestAnimationFrame(this.update);
                    this.frame++;
                }
            }
            randomChar() {
                return this.chars[Math.floor(Math.random() * this.chars.length)];
            }
        }

        // Apply scramble effect to status text
        const statusEl = document.querySelector('.status-text');
        if (statusEl) {
            const scrambler = new TextScramble(statusEl);
            let counter = 0;
            const phrases = ['Online', 'Active', 'Ready', 'Listening'];
            const next = () => {
                scrambler.setText(phrases[counter]).then(() => {
                    setTimeout(next, 3000);
                });
                counter = (counter + 1) % phrases.length;
            };
            // next(); // Uncomment to enable auto-scramble
        }

        // Particle Network Canvas
        function initParticleNetwork() {
            const canvas = document.getElementById('particleNetwork');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            let particles = [];
            let animationId;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', resize);

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.vx = (Math.random() - 0.5) * 0.5;
                    this.vy = (Math.random() - 0.5) * 0.5;
                    this.size = Math.random() * 2 + 1;
                }
                update() {
                    this.x += this.vx;
                    this.y += this.vy;
                    if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                    if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
                }
                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(255, 200, 100, 0.3)';
                    ctx.fill();
                }
            }

            for (let i = 0; i < 50; i++) {
                particles.push(new Particle());
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                particles.forEach((p, i) => {
                    p.update();
                    p.draw();

                    // Draw connections
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = p.x - particles[j].x;
                        const dy = p.y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);

                        if (dist < 150) {
                            ctx.beginPath();
                            ctx.moveTo(p.x, p.y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.strokeStyle = `rgba(255, 200, 100, ${0.2 * (1 - dist / 150)})`;
                            ctx.stroke();
                        }
                    }
                });

                animationId = requestAnimationFrame(animate);
            }
            animate();

            // Cleanup on visibility change
            document.addEventListener('visibilitychange', () => {
                if (document.hidden) {
                    cancelAnimationFrame(animationId);
                } else {
                    animate();
                }
            });
        }

        // Initialize particle network
        initParticleNetwork();

        // ===== v15.3: Neural Network Background Canvas =====
        (function initNeuralNetwork() {
            const canvas = document.getElementById('neuralNetworkCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let width, height;
            let nodes = [];
            let connections = [];
            let animFrame;
            let activityLevel = 50;
            
            const NODE_COUNT = 40;
            const CONNECTION_DISTANCE = 180;
            const NODE_COLORS = ['#ffc864', '#00d4ff', '#5cdb95', '#ff9f43', '#a55eea'];
            
            function resize() {
                width = canvas.width = window.innerWidth;
                height = canvas.height = window.innerHeight;
            }
            
            function createNodes() {
                nodes = [];
                for (let i = 0; i < NODE_COUNT; i++) {
                    nodes.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        vx: (Math.random() - 0.5) * 0.4,
                        vy: (Math.random() - 0.5) * 0.4,
                        radius: 2 + Math.random() * 3,
                        color: NODE_COLORS[Math.floor(Math.random() * NODE_COLORS.length)],
                        pulse: Math.random() * Math.PI * 2,
                        pulseSpeed: 0.02 + Math.random() * 0.03
                    });
                }
            }
            
            function draw() {
                ctx.clearRect(0, 0, width, height);
                
                // Update nodes
                nodes.forEach(node => {
                    node.x += node.vx * (activityLevel / 50);
                    node.y += node.vy * (activityLevel / 50);
                    node.pulse += node.pulseSpeed;
                    
                    // Wrap around screen
                    if (node.x < 0) node.x = width;
                    if (node.x > width) node.x = 0;
                    if (node.y < 0) node.y = height;
                    if (node.y > height) node.y = 0;
                    
                    // Draw node
                    const pulseRadius = node.radius + Math.sin(node.pulse) * 1.5;
                    const alpha = 0.4 + Math.sin(node.pulse) * 0.2;
                    
                    // Glow
                    const gradient = ctx.createRadialGradient(node.x, node.y, 0, node.x, node.y, pulseRadius * 4);
                    gradient.addColorStop(0, node.color.replace(')', `, ${alpha})`).replace('rgb', 'rgba').replace('#', 'rgba('));
                    gradient.addColorStop(1, 'transparent');
                    ctx.fillStyle = gradient;
                    ctx.beginPath();
                    ctx.arc(node.x, node.y, pulseRadius * 4, 0, Math.PI * 2);
                    ctx.fill();
                    
                    // Core
                    ctx.fillStyle = node.color;
                    ctx.globalAlpha = alpha;
                    ctx.beginPath();
                    ctx.arc(node.x, node.y, pulseRadius, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.globalAlpha = 1;
                });
                
                // Draw connections
                for (let i = 0; i < nodes.length; i++) {
                    for (let j = i + 1; j < nodes.length; j++) {
                        const dx = nodes[i].x - nodes[j].x;
                        const dy = nodes[i].y - nodes[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        
                        if (dist < CONNECTION_DISTANCE) {
                            const alpha = (1 - dist / CONNECTION_DISTANCE) * 0.25 * (activityLevel / 100);
                            ctx.strokeStyle = `rgba(255, 200, 100, ${alpha})`;
                            ctx.lineWidth = 0.5;
                            ctx.beginPath();
                            ctx.moveTo(nodes[i].x, nodes[i].y);
                            ctx.lineTo(nodes[j].x, nodes[j].y);
                            ctx.stroke();
                        }
                    }
                }
                
                // Activity-reactive pulse
                if (activityLevel > 70) {
                    const pulseX = width * 0.5 + Math.sin(Date.now() * 0.001) * width * 0.2;
                    const pulseY = height * 0.4 + Math.cos(Date.now() * 0.0008) * height * 0.15;
                    const pulseAlpha = (activityLevel - 70) / 100;
                    const pulseGradient = ctx.createRadialGradient(pulseX, pulseY, 0, pulseX, pulseY, 200);
                    pulseGradient.addColorStop(0, `rgba(0, 212, 255, ${pulseAlpha * 0.15})`);
                    pulseGradient.addColorStop(1, 'transparent');
                    ctx.fillStyle = pulseGradient;
                    ctx.beginPath();
                    ctx.arc(pulseX, pulseY, 200, 0, Math.PI * 2);
                    ctx.fill();
                }
                
                animFrame = requestAnimationFrame(draw);
            }
            
            // Listen for activity updates
            window.addEventListener('neuralActivityUpdate', (e) => {
                activityLevel = Math.min(100, Math.max(10, e.detail || 50));
            });
            
            resize();
            createNodes();
            draw();

            window.addEventListener('resize', () => {
                resize();
                createNodes();
            });
        })();

        // v16.0: Ambient Particle Canvas - floating dust particles
        (function initAmbientCanvas() {
            const canvas = document.getElementById('ambientCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let width, height;
            let particles = [];
            const PARTICLE_COUNT = 30;

            function resize() {
                width = canvas.width = window.innerWidth;
                height = canvas.height = window.innerHeight;
            }

            function createParticles() {
                particles = [];
                for (let i = 0; i < PARTICLE_COUNT; i++) {
                    particles.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        vx: (Math.random() - 0.5) * 0.2,
                        vy: (Math.random() - 0.5) * 0.2 - 0.1,
                        radius: 1 + Math.random() * 2,
                        alpha: 0.1 + Math.random() * 0.3,
                        color: ['#ffc864', '#00d4ff', '#5cdb95'][Math.floor(Math.random() * 3)]
                    });
                }
            }

            function draw() {
                ctx.clearRect(0, 0, width, height);
                particles.forEach(p => {
                    p.x += p.vx;
                    p.y += p.vy;
                    if (p.x < 0) p.x = width;
                    if (p.x > width) p.x = 0;
                    if (p.y < 0) p.y = height;
                    if (p.y > height) p.y = 0;

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    ctx.fillStyle = p.color;
                    ctx.globalAlpha = p.alpha;
                    ctx.fill();
                });
                ctx.globalAlpha = 1;
                requestAnimationFrame(draw);
            }

            resize();
            createParticles();
            draw();
            window.addEventListener('resize', () => { resize(); createParticles(); });
        })();

        // ===== v15.0: Ultra-Modern JavaScript Enhancements =====

        // v15.0: Mouse-Tracking Spotlight on Avatar
        const avatarSection = document.querySelector('.avatar-section');
        const avatarSpotlight = document.getElementById('avatarSpotlight');
        if (avatarSection && avatarSpotlight) {
            avatarSection.addEventListener('mousemove', (e) => {
                const rect = avatarSection.getBoundingClientRect();
                const x = ((e.clientX - rect.left) / rect.width) * 100;
                const y = ((e.clientY - rect.top) / rect.height) * 100;
                avatarSpotlight.style.setProperty('--mx', x + '%');
                avatarSpotlight.style.setProperty('--my', y + '%');
            });
        }

        // v15.0: Fox Ambient Glow State Controller
        function updateFoxAmbientGlow(state) {
            const glow = document.getElementById('foxAmbientGlow');
            if (!glow) return;
            glow.className = 'fox-ambient-glow ' + (state || 'idle');
        }

        // v15.0: Sync Ring Animation Controller
        function showSyncRing() {
            const ring = document.getElementById('syncRing');
            if (!ring) return;
            ring.classList.add('active');
            setTimeout(() => ring.classList.remove('active'), 1500);
        }

        // v15.0: Fox Particle Burst on Click
        function createFoxParticleBurst(x, y, color) {
            const container = document.querySelector('.avatar-section');
            if (!container) return;
            const rect = container.getBoundingClientRect();
            const colors = ['#ffc864', '#ff9f43', '#00d4ff', '#5cdb95', '#ff6b9d', '#a55eea'];
            for (let i = 0; i < 12; i++) {
                const particle = document.createElement('div');
                particle.className = 'fox-particle-burst';
                const angle = (i / 12) * Math.PI * 2;
                const distance = 40 + Math.random() * 30;
                const bx = Math.cos(angle) * distance;
                const by = Math.sin(angle) * distance;
                particle.style.cssText = `
                    left: ${x - rect.left}px;
                    top: ${y - rect.top}px;
                    background: ${colors[i % colors.length]};
                    --bx: ${bx}px;
                    --by: ${by}px;
                    box-shadow: 0 0 8px ${colors[i % colors.length]};
                `;
                container.appendChild(particle);
                setTimeout(() => particle.remove(), 700);
            }
        }

        // Attach fox click burst
        const avatarEl = document.getElementById('avatar');
        if (avatarEl) {
            avatarEl.addEventListener('click', (e) => {
                createFoxParticleBurst(e.clientX, e.clientY);
                // Glitch effect on avatar
                avatarEl.classList.add('glitch-text');
                setTimeout(() => avatarEl.classList.remove('glitch-text'), 500);
            });
        }

        // v15.0: Card Ripple Effect on Click
        document.querySelectorAll('.stat-card, .main-card').forEach(card => {
            card.addEventListener('click', (e) => {
                const ripple = document.createElement('div');
                ripple.className = 'card-ripple';
                const rect = card.getBoundingClientRect();
                ripple.style.cssText = `
                    left: ${e.clientX - rect.left}px;
                    top: ${e.clientY - rect.top}px;
                    width: 40px;
                    height: 40px;
                `;
                card.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            });
        });

        // v15.0: Floating Emoji Reaction
        function floatEmoji(emoji) {
            const avatar = document.getElementById('avatar');
            if (!avatar) return;
            const rect = avatar.getBoundingClientRect();
            const floater = document.createElement('div');
            floater.className = 'emoji-react-float';
            floater.textContent = emoji;
            floater.style.cssText = `left: ${rect.left + rect.width / 2 - 10}px; top: ${rect.top}px;`;
            document.body.appendChild(floater);
            setTimeout(() => floater.remove(), 1000);
        }

        // v15.0: Glitch Text Effect for XP Popup
        function showXPWithGlitch(title, sub) {
            const popup = document.getElementById('xpPopup');
            const popupTitle = document.getElementById('xpPopupTitle');
            const popupSub = document.getElementById('xpPopupSub');
            if (!popup) return;
            popupTitle.textContent = title;
            popupSub.textContent = sub;
            popup.classList.add('visible');
            popupTitle.classList.add('glitch-text');
            setTimeout(() => {
                popupTitle.classList.remove('glitch-text');
            }, 500);
            setTimeout(() => {
                popup.classList.remove('visible');
            }, 3000);
        }

        // v15.0: Time-Based Ambient Shift
        function updateTimeAmbient() {
            const el = document.getElementById('timeAmbient');
            if (!el) return;
            const hour = new Date().getHours();
            let shiftDuration = '60s';
            if (hour >= 6 && hour < 12) {
                shiftDuration = '40s'; // Morning - faster shifts
            } else if (hour >= 12 && hour < 18) {
                shiftDuration = '50s'; // Afternoon
            } else if (hour >= 18 && hour < 22) {
                shiftDuration = '45s'; // Evening
            } else {
                shiftDuration = '70s'; // Night - slower, calmer
            }
            el.style.animationDuration = shiftDuration;
        }
        updateTimeAmbient();

        // v15.0: Enhanced Typing Indicator (replace old one)
        function showTypingIndicatorV15(show) {
            const el = document.getElementById('typingIndicator');
            if (!el) return;
            if (show) {
                el.innerHTML = '<span style="font-size:9px;color:var(--text-dim)">同步中</span><div class="typing-bounce"><span></span><span></span><span></span></div>';
                el.classList.add('visible');
            } else {
                el.classList.remove('visible');
            }
        }

        // v15.0: Live Pulse Dot (status indicator)
        function createLivePulseDot() {
            const statusDot = document.getElementById('statusDot');
            if (statusDot) {
                const dot = document.createElement('div');
                dot.className = 'live-dot';
                dot.style.cssText = 'position:absolute;top:50%;left:8px;transform:translateY(-50%);width:8px;height:8px;';
                statusDot.style.position = 'relative';
                statusDot.appendChild(dot);
            }
        }
        createLivePulseDot();

        // v15.0: Fox State Glow Updater - Hook into existing setFoxExpression
        const originalSetFoxExpression = window.setFoxExpression;
        if (typeof originalSetFoxExpression === 'function') {
            const _setFoxExpression = (state) => {
                originalSetFoxExpression(state);
                updateFoxAmbientGlow(state);
            };
            window.setFoxExpression = _setFoxExpression;
        }

        // Hook sync ring to data refresh
        const originalRefreshData = window.refreshData;
        if (typeof originalRefreshData === 'function') {
            const _refreshData = (...args) => {
                showSyncRing();
                setTimeout(() => originalRefreshData(...args), 200);
            };
            window.refreshData = _refreshData;
        }

        // v15.0: Progress Arc for Stat Cards
        function addProgressArcsToStatCards() {
            document.querySelectorAll('.stat-card').forEach(card => {
                const arc = document.createElement('div');
                arc.className = 'progress-arc-container';
                const circumference = 2 * Math.PI * 10; // radius 10
                arc.innerHTML = `
                    <svg width="28" height="28" viewBox="0 0 28 28">
                        <circle class="arc-bg" cx="14" cy="14" r="10"/>
                        <circle class="arc-fill" cx="14" cy="14" r="10"
                            stroke-dasharray="${circumference}"
                            stroke-dashoffset="${circumference}"/>
                    </svg>
                `;
                card.style.position = 'relative';
                card.appendChild(arc);
            });
        }
        addProgressArcsToStatCards();

        // v15.0: Update Progress Arcs when stats change
        function updateProgressArc(cardId, value, max) {
            const card = document.querySelector(`#${cardId}`)?.closest('.stat-card');
            if (!card) return;
            const arc = card.querySelector('.arc-fill');
            if (!arc) return;
            const circumference = 2 * Math.PI * 10;
            const offset = circumference * (1 - Math.min(value / max, 1));
            arc.style.strokeDashoffset = offset;
        }

        // v15.0: Enhanced Emoji Reaction Floater
        const originalSendFoxEmojiReact = window.sendFoxEmojiReact;
        window.sendFoxEmojiReact = function(emoji) {
            if (typeof originalSendFoxEmojiReact === 'function') {
                originalSendFoxEmojiReact(emoji);
            }
            floatEmoji(emoji);
        };

        // v15.0: Stagger Reveal on Load
        document.querySelectorAll('.mini-stat').forEach((el, i) => {
            el.style.animationDelay = (0.15 + i * 0.07) + 's';
        });

        // v15.0: Console Art
        console.log('%c🚀 v15.0 Ultra-Modern Dashboard Loaded', 'color: var(--success); font-size: 12px;');
        console.log('%c   • Time Ambient Colors', 'color: var(--text-dim);');
        console.log('%c   • Fox Particle Burst', 'color: var(--text-dim);');
        console.log('%c   • Mouse Spotlight', 'color: var(--text-dim);');
        console.log('%c   • Card Ripple Effects', 'color: var(--text-dim);');
        console.log('%c   • Ambient Glow States', 'color: var(--text-dim);');
        console.log('%c   • Progress Arcs', 'color: var(--text-dim);');

        // Smooth Scroll Behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        // ===== v15.1: Data Streaming & Reliability Enhancements =====

        // v15.1: Streaming Data Effect on Fetch
        function addStreamingEffect(element) {
            if (!element) return;
            element.classList.add('streaming-data');
            setTimeout(() => element.classList.remove('streaming-data'), 2000);
        }

        // v15.1: Data Pulse Ring Effect
        function showDataPulseRing(element) {
            if (!element) return;
            const ring = document.createElement('div');
            ring.className = 'data-pulse-ring active';
            element.style.position = 'relative';
            element.appendChild(ring);
            setTimeout(() => ring.remove(), 1000);
        }

        // v15.1: Enhanced Stat Card with 3D Hover
        document.querySelectorAll('.stat-card').forEach(card => {
            card.classList.add('enhanced-hover');
            
            // Add ripple effect on click
            card.addEventListener('click', (e) => {
                const ripple = document.createElement('div');
                ripple.className = 'ripple-effect';
                const rect = card.getBoundingClientRect();
                ripple.style.cssText = `
                    left: ${e.clientX - rect.left}px;
                    top: ${e.clientY - rect.top}px;
                    width: 40px;
                    height: 40px;
                `;
                card.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            });
        });

        // v15.1: Number Counter Animation on Value Change
        window.animateValueChange = function(elementId, newValue, oldValue) {
            const el = document.getElementById(elementId);
            if (!el) return;
            
            el.classList.add('num-counter');
            el.classList.remove('bump');
            
            if (newValue > oldValue) {
                el.classList.add('up');
            } else if (newValue < oldValue) {
                el.classList.add('down');
            }
            
            void el.offsetWidth; // Trigger reflow
            
            el.classList.add('bump');
            
            setTimeout(() => {
                el.classList.remove('up', 'down', 'bump', 'num-counter');
            }, 500);
        };

        // v15.1: Enhanced Error Shake Effect
        window.showErrorShake = function(elementId) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.classList.add('error-shake');
            setTimeout(() => el.classList.remove('error-shake'), 500);
        };

        // v15.1: Success Pop Animation
        window.showSuccessPop = function(elementId) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.classList.add('success-pop');
            setTimeout(() => el.classList.remove('success-pop'), 500);
        };

        // v15.2: Sync Status Indicator
        window.updateSyncStatus = function(syncing) {
            const syncDot = document.getElementById('syncStatusDot');
            const avatarSection = document.querySelector('.avatar-section');
            if (!syncDot) {
                // Create sync dot if it doesn't exist
                const statusArea = document.querySelector('.status-area');
                if (statusArea) {
                    const dot = document.createElement('div');
                    dot.id = 'syncStatusDot';
                    dot.className = 'sync-dot';
                    dot.title = '数据同步状态';
                    statusArea.appendChild(dot);
                }
            } else {
                if (syncing) {
                    syncDot.classList.add('syncing');
                } else {
                    syncDot.classList.remove('syncing');
                }
            }
            // v15.2: Toggle avatar sync shimmer
            if (avatarSection) {
                avatarSection.classList.toggle('syncing', syncing);
            }
        };

        // v15.1: Hook into refreshData to add effects
        const originalFetchData = window.fetchData;
        window.fetchData = function() {
            // Add streaming effect to main card
            const mainCard = document.getElementById('mainCard');
            if (mainCard) {
                addStreamingEffect(mainCard);
                showDataPulseRing(mainCard);
            }
            
            // Update sync status
            updateSyncStatus(true);
            
            if (typeof originalFetchData === 'function') {
                const result = originalFetchData();
                // If it returns a promise, hook into completion
                if (result && typeof result.then === 'function') {
                    result.finally(() => updateSyncStatus(false));
                } else {
                    updateSyncStatus(false);
                }
                return result;
            }
            
            updateSyncStatus(false);
            return null;
        };

        // v15.1: Breathing Effect for Idle State
        function updateBreathingEffect() {
            const avatar = document.getElementById('avatar');
            const foxContainer = document.querySelector('.fox-container');
            const currentStatus = window.currentFoxState || 'idle';
            
            if (currentStatus === 'idle' || currentStatus === 'sleeping') {
                if (avatar) avatar.classList.add('breathing');
                if (foxContainer) foxContainer.classList.add('breathing');
            } else {
                if (avatar) avatar.classList.remove('breathing');
                if (foxContainer) foxContainer.classList.remove('breathing');
            }
        }

        // v15.1: Enhanced Data Freshness Check
        window.checkDataFreshness = function() {
            const lastUpdateEl = document.getElementById('lastUpdate');
            if (!lastUpdateEl || !window.lastFetchTime) return;
            
            const age = (Date.now() - window.lastFetchTime.getTime()) / 1000;
            const reliabilityDot = document.getElementById('reliabilityDot');
            
            if (age > 60) {
                lastUpdateEl.classList.add('stale');
                if (reliabilityDot) reliabilityDot.className = 'reliability-dot critical';
            } else if (age > 30) {
                lastUpdateEl.classList.add('stale');
                if (reliabilityDot) reliabilityDot.className = 'reliability-dot low';
            }
        };

        // v15.1: Auto-refresh data freshness check
        setInterval(checkDataFreshness, 10000);

        // v15.1: Enhanced Status Transition
        window.transitionStatus = function(newStatus, oldStatus) {
            const mainCard = document.getElementById('mainCard');
            if (mainCard) {
                mainCard.classList.add('status-transition', 'changing');
                setTimeout(() => {
                    mainCard.classList.remove('changing');
                }, 500);
            }
            
            // Update breathing effect based on status
            setTimeout(updateBreathingEffect, 100);
        };

        // v15.1: Add glow border to main stats on special events
        window.showGlowBorder = function(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                el.classList.add('glow-border');
                setTimeout(() => el.classList.remove('glow-border'), 3000);
            }
        };

        // v15.1: Enhanced Shimmer for Loading States
        window.showLoadingShimmer = function(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                el.classList.add('shimmer-wave');
            }
        };
        window.hideLoadingShimmer = function(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                el.classList.remove('shimmer-wave');
            }
        };

        // v15.5: Console Art
        console.log('%c🚀 v15.5 Live Data Dashboard', 'color: var(--success); font-size: 12px;');
        console.log('%c   • API Auto-Base-Path (nginx /onboard proxy support)', 'color: var(--text-dim);');
        console.log('%c   • Live Data Indicator + Latency Sparkline', 'color: var(--text-dim);');
        console.log('%c   • Source Health Panel (4 endpoints)', 'color: var(--text-dim);');
        console.log('%c   • Heartbeat Sync Pulse Effect', 'color: var(--text-dim);');
        console.log('%c   • Achievement Toast System', 'color: var(--text-dim);');
        console.log('%c   • Floating Emoji Reactions 2.0', 'color: var(--text-dim);');
        console.log('%c   • Fox Color Theme Selector', 'color: var(--text-dim);');
        console.log('%c   • Status Transition Flash', 'color: var(--text-dim);');

        // v15.1: Console Art
        console.log('%c🚀 v15.1 Ultra-Modern Dashboard Enhanced', 'color: var(--success); font-size: 12px;');
        console.log('%c   • Streaming Data Effects', 'color: var(--text-dim);');
        console.log('%c   • 3D Hover Cards', 'color: var(--text-dim);');
        console.log('%c   • Number Counter Animations', 'color: var(--text-dim);');
        console.log('%c   • Enhanced Data Reliability', 'color: var(--text-dim);');
        console.log('%c   • Breathing Effects', 'color: var(--text-dim);');
        console.log('%c   • Sync Status Indicators', 'color: var(--text-dim);');

        // v13.0: Console Art
        console.log('%c🚀 v13.0 Next-Gen Features Loaded', 'color: var(--success); font-size: 12px;');
        console.log('%c   • Magnetic Buttons', 'color: var(--text-dim);');
        console.log('%c   • Scroll Reveal Animations', 'color: var(--text-dim);');
        console.log('%c   • Spotlight Effects', 'color: var(--text-dim);');
        console.log('%c   • Text Scramble', 'color: var(--text-dim);');
        console.log('%c   • Particle Network', 'color: var(--text-dim);');

        // ===== v12.0: Command Palette Enhancement - Add AI commands =====
        if (window.cmdPalette) {
            window.cmdPalette.commands.push(
                {title:'AI 助手', icon:'🦊', desc:'与莫殇对话', kbd:'A', action:() => toggleAIChat()},
                {title:'紧凑模式', icon:'📐', desc:'切换紧凑布局', kbd:'C', action:() => toggleCompactMode()},
                {title:'天气信息', icon:'🌤️', desc:'查看当前天气', action:() => { refreshWeather(); showToast('🌤️ 正在刷新天气...', 'info', 2000); }},
                {title:'成就查看', icon:'🏆', desc:'查看已解锁成就', action:() => showToast('🏆 成就: ' + checkAchievements().join(' | '), 'info', 4000)},
                {title:'表情反应', icon:'😀', desc:'向莫殇发送表情', action:() => document.getElementById('emojiReactBar')?.classList.toggle('visible')}
            );
        }

        // ===== v15.4: Ambient Pulse Sync Functions =====
        let pulseInterval = null;
        let lastHeartbeatBPM = 60;

        function startAmbientPulse(bpm = 60) {
            lastHeartbeatBPM = bpm;
            const intervalMs = Math.max(500, 60000 / bpm / 2);

            if (pulseInterval) clearInterval(pulseInterval);

            const rings = ['pulseRing1', 'pulseRing2', 'pulseRing3'];
            let ringIndex = 0;

            function firePulse() {
                const ring = document.getElementById(rings[ringIndex]);
                if (ring) {
                    ring.classList.remove('active');
                    void ring.offsetWidth;
                    ring.classList.add('active');
                }
                ringIndex = (ringIndex + 1) % rings.length;
            }

            firePulse();
            pulseInterval = setInterval(firePulse, intervalMs);

            const glowCenter = document.getElementById('pulseGlowCenter');
            if (glowCenter) {
                glowCenter.style.opacity = Math.min(0.8, 30 / bpm);
            }
        }

        function updateAmbientPulseFromData(data) {
            if (data.heartbeat && data.heartbeat.bpm) {
                lastHeartbeatBPM = data.heartbeat.bpm;
                startAmbientPulse(data.heartbeat.bpm);
            }
        }

        // ===== v15.4: Achievement Toast System =====
        function showAchievementToast(icon, title, description) {
            const toast = document.getElementById('achievementToast');
            const iconEl = document.getElementById('achievementIcon');
            const titleEl = document.getElementById('achievementTitle');
            const descEl = document.getElementById('achievementDesc');
            if (!toast) return;
            iconEl.textContent = icon;
            titleEl.textContent = title;
            descEl.textContent = description;
            toast.classList.add('visible');
            setTimeout(() => toast.classList.remove('visible'), 4000);
        }

        // ===== v15.4: Floating Emoji Reactions 2.0 =====
        function triggerFloatingEmoji(emoji) {
            const container = document.getElementById('emojiReactionContainer');
            if (!container) return;
            const rect = container.getBoundingClientRect();
            const floater = document.createElement('div');
            floater.className = 'floating-emoji';
            floater.textContent = emoji;
            floater.style.right = (window.innerWidth - rect.left) + 'px';
            floater.style.bottom = (window.innerHeight - rect.top) + 'px';
            document.body.appendChild(floater);
            setTimeout(() => floater.remove(), 2000);
        }

        // ===== v15.4: Status Transition Flash =====
        function triggerStatusFlash() {
            const flash = document.getElementById('statusTransitionFlash');
            if (flash) {
                flash.classList.remove('active');
                void flash.offsetWidth;
                flash.classList.add('active');
            }
        }

        // ===== v15.4: Fox Theme Selector Handler =====
        let currentFoxTheme = 'orange';
        const foxThemes = {
            orange: { primary: '#ffc864', glow: '#ffaa33' },
            blue: { primary: '#00d4ff', glow: '#00ffff' },
            purple: { primary: '#a855f7', glow: '#c084fc' },
            green: { primary: '#5cdb95', glow: '#7fff7f' },
            pink: { primary: '#ff6b9d', glow: '#ff8fb3' }
        };

        function applyFoxTheme(theme) {
            currentFoxTheme = theme;
            const colors = foxThemes[theme];
            if (colors && foxCanvas) {
                foxCanvas.style.filter = `drop-shadow(0 0 20px ${colors.glow})`;
            }
            localStorage.setItem('foxTheme', theme);
        }

        function loadFoxTheme() {
            const saved = localStorage.getItem('foxTheme');
            if (saved && foxThemes[saved]) {
                applyFoxTheme(saved);
            }
        }

        // ===== v15.4: Initialize Ambient Pulse on Load =====
        setTimeout(() => {
            startAmbientPulse(60);
            loadFoxTheme();
        }, 1000);

        // ===== v15.4: Hook into heartbeat updates =====
        const originalUpdateDashboard = window.updateDashboardData || function(){};
        window.updateDashboardData = function(data) {
            originalUpdateDashboard(data);
            if (data.heartbeat) {
                updateAmbientPulseFromData(data);
            }
        };

        // ===== v15.4: Intercept state changes for flash effect =====
        const originalSetFoxState = window.setFoxState || function(){};
        window.setFoxState = function(state) {
            triggerStatusFlash();
            originalSetFoxState(state);
        };

    </script>
    
    <!-- v11.5: Command Palette Overlay -->
    <div class="cmd-palette-overlay" id="cmdPaletteOverlay">
        <div class="cmd-palette" id="cmdPalette">
            <div class="cmd-palette-input-wrap">
                <span class="cmd-icon">⌘</span>
                <input type="text" class="cmd-palette-input" id="cmdInput" placeholder="输入命令或搜索..." autocomplete="off">
                <span class="cmd-palette-hint">ESC 关闭</span>
            </div>
            <div class="cmd-palette-results" id="cmdResults"></div>
        </div>
    </div>
    
    <!-- v11.5: Timeline Panel -->
    <div class="timeline-panel" id="timelinePanel">
        <div class="timeline-header">
            <span>📋 活动时间线</span>
            <button class="timeline-close" onclick="toggleTimeline()">✕</button>
        </div>
        <div class="timeline-events" id="timelineEvents"></div>
    </div>
    
    <!-- v11.5: Keyboard Hint -->
    <div class="kbd-nav-hint">⌘K 命令面板 · T 时间线 · N 通知</div>

    <!-- v12.0: Scroll Progress Bar -->
    <div class="scroll-progress" id="scrollProgress"><div class="scroll-progress-fill" id="scrollProgressFill"></div></div>

    <!-- v12.0: Glass HUD -->
    <div class="glass-hud" id="glassHud">
        <!-- v15.5: Live Data Indicator -->
        <div class="hud-pill live-indicator" id="liveIndicator" title="数据源状态">
            <span class="live-dot" id="liveDot"></span>
            <span id="liveText">--</span>
        </div>
        <div class="hud-pill" id="hudMode"><span class="dot"></span><span id="hudModeText">正常</span></div>
        <div class="hud-pill" id="hudNet"><span class="dot"></span><span id="hudNetText">--ms</span></div>
        <!-- v12.1: Performance FPS Indicator -->
        <div class="hud-pill" id="hudPerf" title="Frames Per Second"><span class="dot" style="background:var(--success)"></span><span id="perfFPS" style="font-size:9px;color:var(--success)">-- FPS</span></div>
        <!-- v15.5: Latency Sparkline -->
        <div class="hud-pill" id="hudSparkline" title="延迟趋势"><canvas id="latencySparkline" width="60" height="16"></canvas></div>
    </div>

    <!-- v12.0: AI Chat Widget -->
    <div class="ai-chat-widget" id="aiChatWidget">
        <div class="ai-chat-header" onclick="toggleAIChat()">
            <div class="ai-chat-avatar">🦊</div>
            <div class="ai-chat-info">
                <div class="ai-chat-name">MoShang AI</div>
                <div class="ai-chat-status">在线</div>
            </div>
            <button style="background:none;border:none;color:var(--text-dim);font-size:18px;cursor:pointer;" onclick="event.stopPropagation();toggleAIChat()">×</button>
        </div>
        <div class="ai-chat-messages" id="aiChatMessages">
            <div class="ai-msg ai">👋 你好！我是莫殇，你的数字弟弟。有什么我可以帮你的吗？试试问我问题或触发技能！</div>
        </div>
        <div class="ai-chat-input-area">
            <textarea class="ai-chat-input" id="aiChatInput" placeholder="问我任何问题..." rows="1" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendAIMessage()}"></textarea>
            <button class="ai-chat-send" onclick="sendAIMessage()" aria-label="发送">➤</button>
        </div>
    </div>

    <!-- v12.0: Emoji React Bar (shown on fox hover) -->
    <div class="emoji-react-bar" id="emojiReactBar">
        <button class="emoji-react-btn" onclick="sendFoxEmojiReact('❤️')" title="喜欢">❤️</button>
        <button class="emoji-react-btn" onclick="sendFoxEmojiReact('🔥')" title="火焰">🔥</button>
        <button class="emoji-react-btn" onclick="sendFoxEmojiReact('⚡')" title="电力">⚡</button>
        <button class="emoji-react-btn" onclick="sendFoxEmojiReact('😂')" title="笑">😂</button>
        <button class="emoji-react-btn" onclick="sendFoxEmojiReact('😮')" title="惊讶">😮</button>
    </div>

    <!-- v12.0: Weather Widget -->
    <div class="weather-widget" id="weatherWidget">
        <span class="weather-icon" id="weatherIcon">🌤️</span>
        <div class="weather-info">
            <div class="weather-location" id="weatherLocation">获取中...</div>
            <div class="weather-temp" id="weatherTemp">--°</div>
            <div class="weather-desc" id="weatherDesc">正在加载天气</div>
        </div>
        <button style="background:none;border:none;color:var(--text-dim);font-size:14px;cursor:pointer;padding:4px;" onclick="refreshWeather()" title="刷新天气">🔄</button>
    </div>

    <!-- v12.1: Mini Memory Widget -->
    <div class="mini-memory-widget" id="miniMemoryWidget">
        <div class="mini-memory-header" onclick="showMiniMemory()">
            <span>🧠 近期记忆</span>
            <button class="mini-memory-close" onclick="event.stopPropagation();showMiniMemory()" style="background:none;border:none;color:var(--text-dim);font-size:12px;cursor:pointer;">✕</button>
        </div>
        <div class="memory-list">
            <div class="memory-item skeleton" style="height:24px;margin:4px 0;"></div>
            <div class="memory-item skeleton" style="height:24px;margin:4px 0;"></div>
            <div class="memory-item skeleton" style="height:24px;margin:4px 0;"></div>
        </div>
        <div class="mini-memory-footer">
            <small>按 M 键打开</small>
        </div>
    </div>

    <!-- v12.0: Voice Waveform Visualizer -->
    <div class="voice-waveform" id="voiceWaveform">
        <div class="voice-bar" style="height:8px"></div>
        <div class="voice-bar" style="height:12px"></div>
        <div class="voice-bar" style="height:6px"></div>
        <div class="voice-bar" style="height:16px"></div>
        <div class="voice-bar" style="height:10px"></div>
        <div class="voice-bar" style="height:14px"></div>
        <div class="voice-bar" style="height:8px"></div>
        <div class="voice-bar" style="height:12px"></div>
        <div class="voice-bar" style="height:6px"></div>
        <div class="voice-bar" style="height:16px"></div>
        <div class="voice-bar" style="height:10px"></div>
        <div class="voice-bar" style="height:14px"></div>
    </div>

    <!-- v12.0: Float Notification -->
    <div class="float-notif" id="floatNotif">
        <div class="float-notif-icon" id="floatNotifIcon">🎉</div>
        <div class="float-notif-text" id="floatNotifText"></div>
    </div>

    <!-- v12.0: Toast Stack Container -->
    <div class="toast-stack" id="toastStack"></div>

    <!-- v12.0: FAB Chat Button -->
    <div style="position:fixed;bottom:140px;right:24px;z-index:500;opacity:0;transition:opacity 0.3s;" id="aiChatFab">
        <button onclick="toggleAIChat()" style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--accent));border:none;cursor:pointer;font-size:20px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(255,200,100,0.35);transition:all 0.3s;" aria-label="打开AI助手">🦊</button>
    </div>

    <!-- v15.3: Neural Network Background Canvas -->
    <canvas id="neuralNetworkCanvas"></canvas>

    <!-- v16.0: Ambient Particle Canvas -->
    <canvas id="ambientCanvas"></canvas>

    <!-- v16.0: Keyboard Shortcuts Panel -->
    <div id="shortcutsPanel" role="dialog" aria-label="键盘快捷键">
        <div class="shortcuts-title">⌨️ Keyboard Shortcuts</div>
        <div class="shortcut-row">
            <span class="shortcut-desc">刷新数据</span>
            <div class="shortcut-keys"><span class="shortcut-key">R</span></div>
        </div>
        <div class="shortcut-row">
            <span class="shortcut-desc">切换Demo模式</span>
            <div class="shortcut-keys"><span class="shortcut-key">D</span></div>
        </div>
        <div class="shortcut-row">
            <span class="shortcut-desc">节能模式</span>
            <div class="shortcut-keys"><span class="shortcut-key">E</span></div>
        </div>
        <div class="shortcut-row">
            <span class="shortcut-desc">专注模式</span>
            <div class="shortcut-keys"><span class="shortcut-key">F</span></div>
        </div>
        <div class="shortcut-row">
            <span class="shortcut-desc">通知中心</span>
            <div class="shortcut-keys"><span class="shortcut-key">N</span></div>
        </div>
        <div class="shortcut-row">
            <span class="shortcut-desc">记忆面板</span>
            <div class="shortcut-keys"><span class="shortcut-key">M</span></div>
        </div>
        <div class="shortcut-row">
            <span class="shortcut-desc">关闭弹窗</span>
            <div class="shortcut-keys"><span class="shortcut-key">Esc</span></div>
        </div>
    </div>
</body>
</html>
