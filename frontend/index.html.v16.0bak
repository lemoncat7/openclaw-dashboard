        // ===== v12.0: Achievement System =====
        const achievements = [
            {id:'first_visit', icon:'🌟', title:'初次到访', desc:'首次打开仪表盘', xp:10, condition: () => true},
            {id:'speed_demon', icon:'⚡', title:'速度恶魔', desc:'3次心跳间隔<5秒', xp:20, condition: () => false},
            {id:'chatter_box', icon:'💬', title:'话痨', desc:'今日消息数>50', xp:15, condition: () => false},
            {id:'early_bird', icon:'🌅', title:'早起鸟', desc:'8点前刷新', xp:10, condition: () => false},
            {id:'night_owl', icon:'🦉', title:'夜猫子', desc:'23点后活跃', xp:10, condition: () => false},
            {id:'fox_friend', icon:'🦊', title:'狐狸之友', desc:'给莫殇发送10次表情', xp:25, condition: () => false},
            {id:'task_master', icon:'📋', title:'任务大师', desc:'完成10个任务', xp:30, condition: () => false},
            {id:'streak_week', icon:'🔥', title:'一周连续', desc:'连续在线7天', xp:50, condition: () => false},
        ];
        const earnedAchievements = new Set();

        window.checkAchievements = function() {
            const now = new Date();
            const hour = now.getHours();
            const msgs = parseInt(document.getElementById('msgs')?.textContent || '0');
            const tasks = parseInt(document.getElementById('tasks')?.textContent || '0');
            const streak = parseInt(document.getElementById('streakCount')?.textContent || '0');
            const emojiReacts = 0; // tracked via addTimelineEvent

            const newlyEarned = [];
            if (hour < 8 && !earnedAchievements.has('early_bird')) { newlyEarned.push('early_bird'); }
            if (hour >= 23 && !earnedAchievements.has('night_owl')) { newlyEarned.push('night_owl'); }
            if (msgs > 50 && !earnedAchievements.has('chatter_box')) { newlyEarned.push('chatter_box'); }
            if (tasks >= 10 && !earnedAchievements.has('task_master')) { newlyEarned.push('task_master'); }
            if (streak >= 7 && !earnedAchievements.has('streak_week')) { newlyEarned.push('streak_week'); }

            newlyEarned.forEach(id => {
                const ach = achievements.find(a => a.id === id);
                if (ach) {
                    earnedAchievements.add(id);
                    updateXP(ach.xp);
                    showFloatNotif(ach.icon, ach.title + ' +' + ach.xp + 'XP');
                    addTimelineEvent('🏆 成就解锁: ' + ach.title, 'ok');
                }
            });

            return achievements.filter(a => earnedAchievements.has(a.id)).map(a => a.icon + ' ' + a.title);
        };

        // Check achievements on load
        setTimeout(() => checkAchievements(), 3000);

        // ===== v12.0: Keyboard Shortcuts Enhancement =====
        document.addEventListener('keydown', (e) => {
            if (e.key === '?' && !e.ctrlKey && !e.metaKey) {
                const active = document.activeElement;
                if (active.tagName !== 'INPUT' && active.tagName !== 'TEXTAREA') {
                    e.preventDefault();
                    showShortcuts();
                }
            }
            if (e.key === 'c' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                const active = document.activeElement;
                if (active.tagName !== 'INPUT' && active.tagName !== 'TEXTAREA') {
                    e.preventDefault();
                    toggleCompactMode();
                }
            }
            if (e.key === 'a' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                const active = document.activeElement;
                if (active.tagName !== 'INPUT' && active.tagName !== 'TEXTAREA') {
                    e.preventDefault();
                    toggleAIChat();
                }
            }
        });

        // ===== v12.0: Compact Mode Toggle =====
        window.toggleCompactMode = function() {
            document.body.classList.toggle('compact-mode');
            const isCompact = document.body.classList.contains('compact-mode');
            showToast(isCompact ? '📐 紧凑模式已启用' : '📐 紧凑模式已关闭', 'info', 2000);
            addTimelineEvent(isCompact ? '切换到紧凑模式' : '退出紧凑模式', 'info');
        };

        // ===== v12.0: Status-aware Fox Animation =====
        const foxExpressions = {
            idle: { eyeScale: 1, mouthOpen: 0, earWiggle: 0 },
            working: { eyeScale: 1.3, mouthOpen: 0.3, earWiggle: 0.5 },
            sleeping: { eyeScale: 0, mouthOpen: 0, earWiggle: 0 },
            excited: { eyeScale: 1.5, mouthOpen: 0.8, earWiggle: 1 },
            thinking: { eyeScale: 0.8, mouthOpen: 0.2, earWiggle: 0.3 },
            laughing: { eyeScale: 1.2, mouthOpen: 0.9, earWiggle: 0.7 },
            error: { eyeScale: 0.5, mouthOpen: 0, earWiggle: 0 }
        };

        // ===== v12.0: Context-aware Tooltips =====
        const tooltipData = {
            'hb': '💓 两次心跳之间的平均间隔，数值越低表示系统越活跃',
            'msgs': '💬 今日通过 OpenClaw 处理的对话消息总数',
            'tasks': '✅ 今日已完成的各项任务数量',
            'uptime': '⏱️ OpenClaw 连续运行的时间长度',
            'sessions': '🔗 当前会话数量和累计会话数',
            'rep': '⭐ EvoMap 声誉值，反映在协作网络中的贡献度',
