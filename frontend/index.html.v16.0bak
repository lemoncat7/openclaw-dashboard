                    break;
                case 'power':
                    togglePowerSaving();
                    showToast(document.body.classList.contains('power-saving') ? '⚡ 节能模式已开启' : '⚡ 节能模式已关闭', 'success');
                    break;
            }
        }
        // Close FAB on outside click
        document.addEventListener('click', (e) => {
            const fab = document.getElementById('fabMain');
            const menu = document.getElementById('fabMenu');
            if (fabOpen && !fab.contains(e.target) && !menu.contains(e.target)) {
                fabOpen = false;
                fab.classList.remove('open');
                menu.classList.remove('open');
            }
        });

        // ===== v9.1: Enhanced Cursor Follower =====
        const cursorDot = document.getElementById('cursorDot');
        const cursorRing = document.getElementById('cursorRing');
        let mouseX = 0, mouseY = 0;
        let dotX = 0, dotY = 0;
        let ringX = 0, ringY = 0;
        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
        });
        // Hide on touch devices
        if ('ontouchstart' in window) {
            cursorDot.style.display = 'none';
            cursorRing.style.display = 'none';
        }
        function animateCursor() {
            // Smooth dot follow
            dotX += (mouseX - dotX) * 0.2;
            dotY += (mouseY - dotY) * 0.2;
            if (cursorDot) {
                cursorDot.style.left = (dotX - 4) + 'px';
                cursorDot.style.top = (dotY - 4) + 'px';
            }
            // Ring follows with delay
            ringX += (mouseX - ringX) * 0.1;
            ringY += (mouseY - ringY) * 0.1;
            if (cursorRing) {
                cursorRing.style.left = (ringX - 16) + 'px';
                cursorRing.style.top = (ringY - 16) + 'px';
            }
            requestAnimationFrame(animateCursor);
        }
        animateCursor();
        // Hover effect on interactive elements
        document.querySelectorAll('button, .action-btn, .fab, .stat-card, .mood-pill, .skill-item').forEach(el => {
            el.addEventListener('mouseenter', () => cursorRing?.classList.add('hover'));
            el.addEventListener('mouseleave', () => cursorRing?.classList.remove('hover'));
        });

        // ===== v9.1: Smooth Number Transitions for Stats =====
        const observerOptions = { threshold: 0.5 };
        const numberObserver = new MutationObserver((mutations) => {
            mutations.forEach(mutation => {
                if (mutation.type === 'characterData' || mutation.type === 'childList') {
                    const target = mutation.target.nodeType === 3
                        ? mutation.target.parentElement
                        : mutation.target;
                    if (target?.classList?.contains('stat-value')) {
                        target.classList.add('updating');
                        setTimeout(() => target.classList.remove('updating'), 400);
                    }
                }
            });
        });
        document.querySelectorAll('.stat-value').forEach(el => {
            numberObserver.observe(el, { characterData: true, childList: true, subtree: true });
        });

        // ===== v9.1: View Transitions API Support =====
        if (document.startViewTransition) {
            // Wrap status changes in view transitions
            const originalSetFoxStatus = window.setFoxStatus;
            window.setFoxStatus = function(status) {
                document.startViewTransition(() => {
                    originalSetFoxStatus(status);
                });
            };
        }

        // ===== v10.1: Tab Visibility API - Auto-refresh on tab focus =====
        let lastRefreshTime = Date.now();
        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'visible') {
                const elapsed = Date.now() - lastRefreshTime;
                // Auto-refresh if tab was hidden for more than 30 seconds
                if (elapsed > 30000 && !demoMode) {
                    fetchData();
                    showToast('🔄 已自动刷新数据', 'info', 2000);
                }
                lastRefreshTime = Date.now();
            }
        });

        // ===== v10.1: Time-aware Ambient Theme =====
        function updateAmbientTheme() {
            const hour = new Date().getHours();
            const root = document.documentElement;
            let themeColors;
            if (hour >= 5 && hour < 8) {
                // Dawn - soft warm orange
                themeColors = { primary: '#ffb347', accent: '#ff6b81', glow: 'rgba(255,179,71,0.4)' };
            } else if (hour >= 8 && hour < 17) {
                // Day - full bright
                themeColors = { primary: '#ffc864', accent: '#00d4ff', glow: 'rgba(0,212,255,0.4)' };
            } else if (hour >= 17 && hour < 20) {
                // Sunset - warm pink/purple
                themeColors = { primary: '#ff8c94', accent: '#c44569', glow: 'rgba(255,140,148,0.4)' };
            } else {
                // Night - cool deep blue
                themeColors = { primary: '#a29bfe', accent: '#74b9ff', glow: 'rgba(162,155,254,0.4)' };
            }
            root.style.setProperty('--primary', themeColors.primary);
            root.style.setProperty('--accent', themeColors.accent);
            // Update constellation color based on theme
            const ps = document.getElementById('particleCanvas');
            if (ps && ps.constellationColor) ps.constellationColor = themeColors.primary;
        }
        updateAmbientTheme();
        // Update every 5 minutes
        setInterval(updateAmbientTheme, 5 * 60 * 1000);

        // ===== v10.1: Notification Center =====
        const notificationHistory = [];
        const MAX_NOTIFICATIONS = 20;
        
        function addNotification(text, type = 'info') {
            const time = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            notificationHistory.unshift({ text, type, time });
            if (notificationHistory.length > MAX_NOTIFICATIONS) notificationHistory.pop();
            renderNotificationBadge();
        }
        
        function renderNotificationBadge() {
            const badge = document.getElementById('notifBadge');
            if (badge) {
                badge.textContent = notificationHistory.length > 9 ? '9+' : notificationHistory.length;
                badge.style.display = notificationHistory.length > 0 ? 'flex' : 'none';
            }
        }
        
        function toggleNotificationCenter() {
            const panel = document.getElementById('notifPanel');
            const isOpen = panel.classList.contains('open');
            if (isOpen) {
                panel.classList.remove('open');
            } else {
                renderNotificationList();
                panel.classList.add('open');
            }
        }
        
        function renderNotificationList() {
            const list = document.getElementById('notifList');
            if (!list) return;
            if (notificationHistory.length === 0) {
                list.innerHTML = '<div class="notif-empty">暂无通知记录</div>';
                return;
            }
            list.innerHTML = notificationHistory.map(n => {
                const icon = n.type === 'success' ? '✅' : n.type === 'error' ? '❌' : n.type === 'warning' ? '⚠️' : 'ℹ️';
                return `<div class="notif-item ${n.type}"><span class="notif-icon">${icon}</span><span class="notif-text">${n.text}</span><span class="notif-time">${n.time}</span></div>`;
            }).join('');
        }
        
        // Intercept showToast to also add to notification center
        const originalShowToast = window.showToast;
        window.showToast = function(message, type = 'info', duration = 3000) {
            addNotification(message, type);
            return originalShowToast(message, type, duration);
        };
        
        // Also intercept showLiveActivity
        const originalShowLiveActivity = window.showLiveActivity;
        window.showLiveActivity = function(title, subtitle, duration) {
            addNotification(`${title}: ${subtitle}`, 'info');
            if (originalShowLiveActivity) originalShowLiveActivity(title, subtitle, duration);
        };
        
        // Add notification panel HTML and badge to page
        document.body.insertAdjacentHTML('beforeend', `
            <div id="notifBadge" style="display:none;position:fixed;top:14px;right:14px;background:var(--danger);color:#fff;width:20px;height:20px;border-radius:50%;font-size:11px;font-weight:700;align-items:center;justify-content:center;z-index:9999;cursor:pointer;" onclick="toggleNotificationCenter()">0</div>
            <div id="notifPanel" style="position:fixed;top:0;right:-360px;width:340px;height:100vh;background:var(--bg-card);backdrop-filter:blur(20px);border-left:1px solid var(--glass-border);z-index:9998;transition:right 0.3s cubic-bezier(0.34,1.56,0.64,1);overflow-y:auto;padding:20px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                    <h3 style="color:var(--text);font-size:16px;margin:0;">📬 通知中心</h3>
                    <button onclick="toggleNotificationCenter()" style="background:none;border:none;color:var(--text-dim);font-size:20px;cursor:pointer;">✕</button>
                </div>
                <div id="notifList"></div>
            </div>
        `);
        renderNotificationBadge();

        // ===== v10.1: Fox Reaction Bubbles =====
        let reactionBubble = null;
        function showFoxReaction(emoji) {
            if (reactionBubble) reactionBubble.remove();
            reactionBubble = document.createElement('div');
            reactionBubble.style.cssText = 'position:fixed;bottom:120px;left:50%;transform:translateX(-50%) scale(0);background:var(--bg-card);backdrop-filter:blur(12px);border:1px solid var(--glass-border);border-radius:16px;padding:12px 20px;font-size:32px;z-index:9997;pointer-events:none;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);';
            reactionBubble.textContent = emoji;
            document.body.appendChild(reactionBubble);
            requestAnimationFrame(() => reactionBubble.style.transform = 'translateX(-50%) scale(1)');
            setTimeout(() => {
                if (reactionBubble) {
                    reactionBubble.style.transform = 'translateX(-50%) scale(0)';
                    setTimeout(() => reactionBubble?.remove(), 300);
                    reactionBubble = null;
                }
            }, 2000);
        }
        
        // Show fox reaction on status change
        const origSetFoxStatus = window.setFoxStatus;
        window.setFoxStatus = function(status) {
            const result = origSetFoxStatus ? origSetFoxStatus(status) : undefined;
            const reactionMap = { idle: '😺', working: '⚡', sleeping: '😴', excited: '🎉', thinking: '🤔', laughing: '😂', error: '😿' };
            showFoxReaction(reactionMap[status] || '😺');
            return result;
        };

        // ===== v11.1: Data Reliability Monitor =====
        let dataReliabilityScore = 100;
        let consecutiveFailures = 0;
        const MAX_FAILURES = 3;
        
        function updateDataReliability(success) {
            if (success) {
                consecutiveFailures = 0;
                dataReliabilityScore = Math.min(100, dataReliabilityScore + 10);
            } else {
                consecutiveFailures++;
                dataReliabilityScore = Math.max(0, dataReliabilityScore - 25);
            }
            
            // Update reliability indicator
            let reliabilityIndicator = document.querySelector('.data-reliability-indicator');
            if (!reliabilityIndicator) {
                reliabilityIndicator = document.createElement('div');
                reliabilityIndicator.className = 'data-reliability-indicator';
                reliabilityIndicator.innerHTML = `
                    <div class="pulse-ring"></div>
                    <span class="label">数据可靠度: <span class="score">${dataReliabilityScore}%</span></span>
                `;
                document.body.appendChild(reliabilityIndicator);
            }
            
            const ring = reliabilityIndicator.querySelector('.pulse-ring');
            const scoreEl = reliabilityIndicator.querySelector('.score');
            scoreEl.textContent = dataReliabilityScore + '%';
            
            ring.classList.remove('warning', 'error');
            if (dataReliabilityScore < 50) {
                ring.classList.add('error');
            } else if (dataReliabilityScore < 75) {
                ring.classList.add('warning');
            }
            
            reliabilityIndicator.classList.add('visible');
            setTimeout(() => reliabilityIndicator.classList.remove('visible'), 3000);
            
            // Show error recovery banner if too many failures
            if (consecutiveFailures >= MAX_FAILURES) {
                showErrorRecoveryBanner();
            }
        }
        
        // ===== v11.1: System Health Score =====
        let healthScore = 100;
        let lastSystemData = null;

        function updateHealthScore(data) {
            lastSystemData = data;
            let score = 100;
            let reasons = [];

            // Memory contribution (20%)
            const memPct = data.system?.memoryPercent || 0;
            if (memPct > 90) { score -= 15; reasons.push('内存极低'); }
            else if (memPct > 75) { score -= 8; reasons.push('内存偏高'); }

            // CPU contribution (20%)
            const cpuPct = data.system?.cpuPercent || 0;
            if (cpuPct > 85) { score -= 15; reasons.push('CPU负载高'); }
            else if (cpuPct > 70) { score -= 8; reasons.push('CPU偏高'); }

            // Disk contribution (10%)
            const diskPct = data.system?.diskPercent || 0;
            if (diskPct > 90) { score -= 10; reasons.push('磁盘空间不足'); }
            else if (diskPct > 80) { score -= 5; }

            // Uptime contribution (10%)
            const uptime = data.uptime || '0h';
            if (uptime.includes('d') || (parseInt(uptime) > 168)) { score -= 0; } // Long uptime is good
            else if (parseInt(uptime) < 1) { score -= 3; }

            // Consecutive success bonus (20%)
            if (consecutiveSuccesses > 5) score = Math.min(100, score + 5);

            // Data freshness bonus (10%)
            if (lastFetchTime) {
                const age = (Date.now() - lastFetchTime.getTime()) / 1000;
                if (age < 5) score = Math.min(100, score + 5);
                else if (age > 30) { score -= 10; reasons.push('数据延迟'); }
            }

            // Latency penalty (10%)
            if (window._lastLatency && window._lastLatency > 1000) {
                score -= 10; reasons.push('延迟过高');
            }

            healthScore = Math.max(0, Math.min(100, score));

            // Update health score ring in UI
            updateHealthScoreUI(healthScore, reasons);
        }

        function updateHealthScoreUI(score, reasons) {
            let healthRing = document.getElementById('healthRing');
            let healthBadge = document.getElementById('healthBadge');

            if (!healthRing) {
                // Create health ring element if not exists - inject into avatar section
                const avatarSection = document.querySelector('.avatar-section');
                if (avatarSection) {
                    healthRing = document.createElement('div');
                    healthRing.id = 'healthRing';
                    healthRing.style.cssText = `
                        position: absolute; inset: -16px;
                        border-radius: 50%;
                        pointer-events: none;
                        opacity: 0.6;
                        transition: all 0.5s ease;
                    `;
                    avatarSection.appendChild(healthRing);
                }
            }

            if (healthRing) {
                const hue = score > 70 ? 150 : score > 40 ? 45 : 0;
                healthRing.style.boxShadow = `0 0 ${20 - score/5}px ${score/10}px hsla(${hue}, 80%, 60%, 0.5)`;
                healthRing.style.border = `2px solid hsla(${hue}, 80%, 60%, 0.4)`;
            }

            // Update health badge text
            if (!healthBadge) {
                const statEl = document.querySelector('[data-health]') || document.querySelector('.stat-card');
            }
        }

        // ===== v11.1: Data Cross-Validation =====
        function validateDataConsistency(data) {
            if (!lastSystemData) return true;

            const checks = [];
            let issues = 0;

            // Memory sanity check
            if (data.system?.memoryPercent && data.system?.memoryPercent > 100) {
                issues++; checks.push('内存数据异常');
            }
            if (data.system?.memoryPercent && data.system?.memoryPercent < 0) {
                issues++; checks.push('内存数据负值');
            }

            // CPU sanity check
            if (data.system?.cpuPercent && (data.system?.cpuPercent > 100 || data.system?.cpuPercent < 0)) {
                issues++; checks.push('CPU数据异常');
            }

            // Disk sanity check
            if (data.system?.diskPercent && (data.system?.diskPercent > 100 || data.system?.diskPercent < 0)) {
                issues++; checks.push('磁盘数据异常');
            }

            // Cross-source comparison (if both gateway and system data available)
            if (data.system && lastSystemData?.system) {
                const memDiff = Math.abs((data.system.memoryPercent || 0) - (lastSystemData.system.memoryPercent || 0));
                if (memDiff > 30) { issues++; checks.push('内存数据源差异大'); }
            }

            if (issues > 0) {
                showToast(`⚠️ 数据校验: ${checks.join(', ')}`, 'warning');
                return false;
            }
            return true;
        }

        function showErrorRecoveryBanner() {
            let banner = document.querySelector('.error-recovery-banner');
            if (!banner) {
                banner = document.createElement('div');
                banner.className = 'error-recovery-banner';
                banner.innerHTML = `
                    <span class="icon">⚠️</span>
                    <span>数据获取失败，是否重试？</span>
                    <button class="retry-btn" onclick="retryDataFetch()">重试</button>
                `;
                document.body.appendChild(banner);
            }
            banner.classList.add('visible');
        }
        
        function retryDataFetch() {
            const banner = document.querySelector('.error-recovery-banner');
            if (banner) banner.classList.remove('visible');
            refreshData();
        }
        
        // Intercept fetchData to track reliability
        const originalFetchData = window.fetchData;
        window.fetchData = async function() {
            try {
                await (originalFetchData ? originalFetchData() : Promise.resolve());
                updateDataReliability(true);
            } catch (e) {
                updateDataReliability(false);
                if (originalFetchData) originalFetchData();
            }
        };
        
        // ===== v11.1: Refresh Timeline =====
        let refreshCountdown = 10;
        let refreshTimer = null;
        
        function startRefreshTimer() {
            const timeline = document.createElement('div');
            timeline.className = 'refresh-timeline';
            timeline.innerHTML = '<div class="refresh-timeline-fill" style="width: 0%"></div>';
            document.body.appendChild(timeline);
            
            refreshCountdown = 10;
            timeline.classList.add('visible');
            
            if (refreshTimer) clearInterval(refreshTimer);
            refreshTimer = setInterval(() => {
                refreshCountdown--;
                const fill = timeline.querySelector('.refresh-timeline-fill');
                if (fill) fill.style.width = ((10 - refreshCountdown) / 10 * 100) + '%';
                if (refreshCountdown <= 0) {
                    clearInterval(refreshTimer);
                    timeline.classList.remove('visible');
                }
            }, 1000);
        }
        
        // ===== v11.1: Enhanced Tooltip System =====
        function showEnhancedTooltip(element, title, description) {
            let tooltip = document.querySelector('.enhanced-tooltip');
            if (!tooltip) {
                tooltip = document.createElement('div');
                tooltip.className = 'enhanced-tooltip';
                tooltip.innerHTML = '<div class="title"></div><div class="desc"></div>';
                document.body.appendChild(tooltip);
            }
            
            tooltip.querySelector('.title').textContent = title;
            tooltip.querySelector('.desc').textContent = description;
            tooltip.classList.add('visible');
            
            const rect = element.getBoundingClientRect();
            tooltip.style.left = (rect.left + rect.width / 2 - tooltip.offsetWidth / 2) + 'px';
            tooltip.style.top = (rect.top - tooltip.offsetHeight - 10) + 'px';
            
            return tooltip;
        }
        
        function hideEnhancedTooltip() {
            const tooltip = document.querySelector('.enhanced-tooltip');
            if (tooltip) tooltip.classList.remove('visible');
        }
        
        // ===== v10.1: Keyboard shortcuts enhancement =====
        document.addEventListener('keydown', (e) => {
            if (e.key === 'n' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                toggleNotificationCenter();
            }
        });

        // ===== v11.2: XP Level System =====
        const XP_PER_LEVEL = 100;
        let currentXP = 0;
        let currentLevel = 1;
        let lastTaskCount = 0;
        
        function updateXP(amount) {
            currentXP += amount;
            while (currentXP >= XP_PER_LEVEL) {
                currentXP -= XP_PER_LEVEL;
                currentLevel++;
                showXPLevelUp(currentLevel);
            }
            renderXPBar();
        }
        
        function renderXPBar() {
            const fill = document.getElementById('xpBarFill');
            const level = document.getElementById('xpLevel');
            if (fill) fill.style.width = (currentXP / XP_PER_LEVEL * 100) + '%';
            if (level) level.textContent = 'Lv.' + currentLevel;
        }
        
        function showXPLevelUp(level) {
            const popup = document.getElementById('xpPopup');
            const title = document.getElementById('xpPopupTitle');
            const sub = document.getElementById('xpPopupSub');
            if (popup) {
                popup.querySelector('.xp-popup-title').textContent = '🎉 Level Up!';
                popup.querySelector('.xp-popup-sub').textContent = '等级 ' + level;
                popup.classList.add('visible');
                spawnConfetti();
                setTimeout(() => popup.classList.remove('visible'), 2500);
            }
        }
        
        // Award XP on successful data fetch
        const origFetchData = window.fetchData;
        window.fetchData = async function() {
            const typingEl = document.getElementById('typingIndicator');
            if (typingEl) typingEl.classList.add('visible');
            try {
                if (origFetchData) await origFetchData();
                updateXP(2); // Small XP for each successful sync
            } finally {
                if (typingEl) typingEl.classList.remove('visible');
            }
        };
        
        // Check for task completion XP
        function checkTaskXP(taskCount) {
            if (taskCount > lastTaskCount && lastTaskCount > 0) {
                const gained = (taskCount - lastTaskCount) * 5;
                updateXP(gained);
                showToast(`✅ +${gained}XP 任务完成奖励!`, 'success');
                spawnConfetti();
            }
            lastTaskCount = taskCount;
        }

        // ===== v11.2: Focus Mode =====
        let focusMode = false;
        function toggleFocusMode() {
            focusMode = !focusMode;
            document.body.classList.toggle('focus-mode', focusMode);
            const indicator = document.getElementById('focusIndicator');
            if (indicator) {
                indicator.style.opacity = focusMode ? '1' : '0';
                if (focusMode) setTimeout(() => indicator.style.opacity = '0', 2000);
            }
            showToast(focusMode ? '🔒 专注模式开启' : '🔓 专注模式关闭', 'info');
        }
        
        // Focus mode keyboard shortcut (F key)
        document.addEventListener('keydown', (e) => {
            if (e.key === 'f' && !e.ctrlKey && !e.metaKey && !e.altKey && 
                document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                toggleFocusMode();
            }
        });

        // ===== v11.2: Confetti System =====
        function spawnConfetti() {
            const container = document.getElementById('confettiContainer');
            if (!container) return;
            const colors = ['#ffc864', '#00d4ff', '#5cdb95', '#ff6b9d', '#a29bfe', '#ff6b6b'];
            for (let i = 0; i < 40; i++) {
                const piece = document.createElement('div');
                piece.className = 'confetti-piece';
                piece.style.left = (Math.random() * 100) + '%';
                piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                piece.style.animationDelay = (Math.random() * 0.5) + 's';
                piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                piece.style.width = (4 + Math.random() * 6) + 'px';
                piece.style.height = (4 + Math.random() * 6) + 'px';
                container.appendChild(piece);
                setTimeout(() => piece.remove(), 2000);
            }
        }
        
        // Confetti on task completion - watch for task count changes
        let _lastTaskVal = 0;
        const _origUpdateDashboard = window.updateDashboard;
        window.updateDashboard = function(data, fromCache) {
            const result = _origUpdateDashboard ? _origUpdateDashboard(data, fromCache) : undefined;
            const taskEl = document.getElementById('tasks');
            if (taskEl) {
                const val = parseInt(taskEl.textContent) || 0;
                if (val > _lastTaskVal && _lastTaskVal > 0) {
                    spawnConfetti();
                    showToast(`🎉 任务完成! 当前: ${val}个任务`, 'success');
                }
                _lastTaskVal = val;
            }
            return result;
        };

        // ===== v11.2: Fox Click Ripple Effect =====
        const foxCanvas = document.getElementById('foxCanvas');
        if (foxCanvas) {
            foxCanvas.addEventListener('click', (e) => {
                const rect = foxCanvas.getBoundingClientRect();
                const ripple = document.createElement('div');
                ripple.className = 'fox-ripple';
                ripple.style.left = (e.clientX - rect.left - 20) + 'px';
                ripple.style.top = (e.clientY - rect.top - 20) + 'px';
                ripple.style.width = '40px';
                ripple.style.height = '40px';
                foxCanvas.parentElement.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
                
                // Also update XP on fox click
                updateXP(1);
                showFoxReaction('😺');
            });
        }

        // ===== v11.2: Streak Counter =====
        function updateStreak() {
            const el = document.getElementById('streakCount');
            if (!el) return;
            // Calculate streak from uptime
            const uptimeEl = document.getElementById('uptime');
            if (!uptimeEl) return;
            const text = uptimeEl.textContent;
            let hours = 0;
            if (text.includes('d')) hours = parseFloat(text) * 24;
            else if (text.includes('h')) hours = parseFloat(text);
            else if (text.includes('m')) hours = parseFloat(text) / 60;
            
            // Assume streak is consecutive online days (uptime hours / 24, rounded down, min 1)
            const days = Math.max(1, Math.floor(hours / 24));
            el.textContent = days;
        }
        
        // Update streak every minute
        setInterval(updateStreak, 60000);

        // ===== v11.5: Command Palette =====
        const commandPalette = {
            isOpen: false,
            selectedIndex: 0,
            commands: [
                { icon: '🔄', title: '刷新数据', desc: '立即获取最新状态', action: () => refreshData(), kbd: 'R' },
                { icon: '🔊', title: '切换声音', desc: '开启/关闭音效', action: () => toggleSound(), kbd: 'S' },
                { icon: '📊', title: '打开时间线', desc: '查看最近活动记录', action: () => toggleTimeline(), kbd: 'T' },
                { icon: '🎯', title: '专注模式', desc: '切换专注模式 (F)', action: () => toggleFocusMode(), kbd: 'F' },
                { icon: '⚡', title: 'Demo 模式', desc: '切换演示数据模式', action: () => toggleDemo(), kbd: 'D' },
                { icon: '🌙', title: '节能模式', desc: '减少动画效果', action: () => togglePowerSaving(), kbd: 'E' },
                { icon: '📋', title: '复制状态文本', desc: '复制当前状态到剪贴板', action: () => copyStatusText() },
                { icon: '🦊', title: '狐狸表情轮', desc: '显示表情切换按钮', action: () => toggleFoxWheel() },
                { icon: '❓', title: '显示快捷键', desc: '显示所有快捷键', action: () => showShortcuts() },
                { icon: '🔗', title: '获取访问链接', desc: '复制外网访问地址', action: () => copyAccessLink() },
            ],
            filtered: [],
            init() {
                // Build HTML
                const overlay = document.createElement('div');
                overlay.className = 'cmd-palette-overlay';
                overlay.id = 'cmdPaletteOverlay';
                overlay.innerHTML = `
                    <div class="cmd-palette" id="cmdPalette">
                        <div class="cmd-palette-input-wrap">
                            <span class="cmd-icon">⌘</span>
                            <input type="text" class="cmd-palette-input" id="cmdInput" placeholder="输入命令或搜索..." autocomplete="off">
                            <span class="cmd-palette-hint">ESC 关闭</span>
                        </div>
                        <div class="cmd-palette-results" id="cmdResults"></div>
                    </div>`;
                document.body.appendChild(overlay);
                
                const input = document.getElementById('cmdInput');
                input.addEventListener('input', (e) => this.filter(e.target.value));
                input.addEventListener('keydown', (e) => this.handleKey(e));
                overlay.addEventListener('click', (e) => { if (e.target === overlay) this.close(); });
                this.filter('');
            },
            open() {
                this.isOpen = true; this.selectedIndex = 0;
                document.getElementById('cmdPaletteOverlay').classList.add('open');
                document.getElementById('cmdInput').focus();
                this.filter('');
            },
            close() {
                this.isOpen = false;
                document.getElementById('cmdPaletteOverlay').classList.remove('open');
                document.getElementById('cmdInput').value = '';
            },
            filter(query) {
                const q = query.toLowerCase().trim();
                this.filtered = q ? this.commands.filter(c =>
                    c.title.toLowerCase().includes(q) || c.desc.toLowerCase().includes(q)
                ) : [...this.commands];
                this.selectedIndex = 0;
                this.render();
            },
            render() {
                const results = document.getElementById('cmdResults');
                if (!this.filtered.length) {
                    results.innerHTML = '<div class="cmd-empty">没有找到匹配的命令</div>';
                    return;
                }
                const groups = { '操作': [], '切换': [], '工具': [] };
                this.filtered.forEach(c => {
                    if (['刷新数据','复制状态文本','获取访问链接'].includes(c.title)) groups['操作'].push(c);
                    else if (['切换声音','专注模式','Demo 模式','节能模式','狐狸表情轮'].includes(c.title)) groups['切换'].push(c);
                    else groups['工具'].push(c);
                });
                let html = '';
                for (const [gname, items] of Object.entries(groups)) {
                    if (!items.length) continue;
                    html += `<div class="cmd-palette-group-label">${gname}</div>`;
                    items.forEach((c, i) => {
                        const realIdx = this.filtered.indexOf(c);
                        html += `<div class="cmd-item${realIdx === this.selectedIndex ? ' selected' : ''}" data-idx="${realIdx}">
                            <span class="cmd-item-icon">${c.icon}</span>
                            <div class="cmd-item-text">
                                <div class="cmd-item-title">${c.title}</div>
                                <div class="cmd-item-desc">${c.desc}</div>
                            </div>
                            ${c.kbd ? `<span class="cmd-item-kbd">${c.kbd}</span>` : ''}
                        </div>`;
                    });
                }
                results.innerHTML = html;
                results.querySelectorAll('.cmd-item').forEach(el => {
                    el.addEventListener('click', () => {
                        const idx = parseInt(el.dataset.idx);
                        this.execute(idx);
                    });
                    el.addEventListener('mouseenter', () => {
                        this.selectedIndex = parseInt(el.dataset.idx);
                        this.render();
                    });
                });
            },
            handleKey(e) {
                if (e.key === 'ArrowDown') { e.preventDefault(); this.selectedIndex = Math.min(this.selectedIndex + 1, this.filtered.length - 1); this.render(); }
                else if (e.key === 'ArrowUp') { e.preventDefault(); this.selectedIndex = Math.max(this.selectedIndex - 1, 0); this.render(); }
                else if (e.key === 'Enter') { e.preventDefault(); this.execute(this.selectedIndex); }
                else if (e.key === 'Escape') { this.close(); }
            },
            execute(idx) {
                const cmd = this.filtered[idx];
                if (cmd) { cmd.action(); this.close(); }
            }
        };
        
        // Keyboard shortcut for command palette
        document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                e.preventDefault();
                commandPalette.isOpen ? commandPalette.close() : commandPalette.open();
            }
            if (e.key === 'Escape' && commandPalette.isOpen) commandPalette.close();
            if (e.key === 't' && !e.target.matches('input, textarea')) toggleTimeline();
            if (e.key === 'n' && !e.target.matches('input, textarea')) toggleNotificationPanel();
        });
        
        // Init command palette
        commandPalette.init();
        
        // ===== v11.5: Timeline Panel =====
        const _timelineEvents = [];
        function addTimelineEvent(text, type = 'info') {
            _timelineEvents.unshift({ text, type, time: new Date() });
            if (_timelineEvents.length > 20) _timelineEvents.pop();
            renderTimeline();
        }
        function renderTimeline() {
            const panel = document.getElementById('timelinePanel');
            if (!panel) return;
            const content = panel.querySelector('.timeline-events');
            if (!content) return;
            content.innerHTML = _timelineEvents.map(ev => `
                <div class="timeline-event">
                    <div class="timeline-dot ${ev.type}"></div>
                    <div class="timeline-content">
                        <div class="timeline-text">${ev.text}</div>
                        <div class="timeline-time">${ev.time.toLocaleTimeString('zh-CN', {hour:'2-digit',minute:'2-digit',second:'2-digit'})}</div>
                    </div>
                </div>`).join('');
        }
        function toggleTimeline() {
            const panel = document.getElementById('timelinePanel');
            if (!panel) return;
            panel.classList.toggle('open');
        }
        
        // ===== v11.5: Fox Canvas Cosmic Ring =====
        function initFoxCosmicRing() {
            const ring = document.getElementById('foxCosmicRing');
            if (!ring) return;
            const canvas = document.createElement('canvas');
            canvas.width = 110; canvas.height = 110;
            ring.appendChild(canvas);
            const ctx = canvas.getContext('2d');
            let angle = 0;
            function draw() {
                ctx.clearRect(0, 0, 110, 110);
                const cx = 55, cy = 55, r = 48;
                // Draw dotted orbital ring
                ctx.strokeStyle = 'rgba(255,200,100,0.3)';
                ctx.lineWidth = 1;
                ctx.setLineDash([3, 5]);
                ctx.beginPath();
                ctx.arc(cx, cy, r, 0, Math.PI * 2);
                ctx.stroke();
                ctx.setLineDash([]);
                // Draw orbiting dots
                for (let i = 0; i < 3; i++) {
                    const a = angle + (i * Math.PI * 2 / 3);
                    const x = cx + Math.cos(a) * r;
                    const y = cy + Math.sin(a) * r;
                    ctx.fillStyle = ['#ffc864','#00d4ff','#5cdb95'][i];
                    ctx.beginPath();
                    ctx.arc(x, y, 3, 0, Math.PI * 2);
                    ctx.fill();
                }
                angle += 0.015;
                if (commandPalette && commandPalette.isOpen) return;
                requestAnimationFrame(draw);
            }
            draw();
            
            // Heartbeat ring
            const hbRing = document.getElementById('foxHeartbeatRing');
            if (hbRing) {
                function pulseHB() {
                    hbRing.classList.remove('pulse-ring');
                    void hbRing.offsetWidth;
                    hbRing.classList.add('pulse-ring');
                }
                setInterval(pulseHB, 2000);
                pulseHB();
            }
        }
        
        // ===== v11.5: Status Morph Text =====
        function updateStatusMorph(status) {
            const el = document.getElementById('statusText');
            if (!el) return;
            el.className = 'status status-morph ' + status;
        }
        
        // ===== v11.5: 3D Tilt Effect on Cards =====
        function init3DTilt() {
            document.querySelectorAll('.stat-card, .glass-card, .main-card').forEach(card => {
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const cx = rect.width / 2, cy = rect.height / 2;
                    const tiltX = (y - cy) / cy * 6;
                    const tiltY = (cx - x) / cx * 6;
                    card.style.transform = `perspective(800px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateY(-6px)`;
                });
                card.addEventListener('mouseleave', () => {
                    card.style.transform = '';
                });
            });
        }
        
        // v11.5: Auto-init on load
        window.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                initFoxCosmicRing();
                init3DTilt();
            }, 500);
        });
        
        // ===== v11.5: Utility Commands =====
        function copyStatusText() {
            const status = document.getElementById('statusText')?.textContent || 'Unknown';
            const hb = document.getElementById('hb')?.textContent || '--';
            const task = document.getElementById('currentTask')?.textContent || '无';
            const text = `⚡ MoShang 状态\n状态: ${status}\n心跳: ${hb}\n任务: ${task}\n时间: ${new Date().toLocaleString('zh-CN')}`;
            navigator.clipboard.writeText(text).then(() => {
                showToast('📋 状态已复制到剪贴板', 'success', 2000);
            }).catch(() => showToast('复制失败', 'error', 2000));
            addTimelineEvent('复制状态文本', 'info');
        }
        function copyAccessLink() {
            navigator.clipboard.writeText('https://oclaw.mochencloud.cn:1443/onboard/').then(() => {
                showToast('🔗 访问链接已复制', 'success', 2000);
            }).catch(() => {});
            addTimelineEvent('复制访问链接', 'info');
        }
        function showShortcuts() {
            showToast('🔑 快捷键: ⌘K 命令面板 | R 刷新 | F 专注 | T 时间线 | N 通知 | D Demo | E 节能 | ? 帮助', 'info', 5000);
        }
        function toggleFoxWheel() {
            const wheel = document.getElementById('foxExpressionWheel');
            if (wheel) wheel.style.display = wheel.style.display === 'none' ? '' : 'none';
        }
        
        // ===== v11.5: Boot Events =====
        addTimelineEvent('仪表盘已加载 v11.8', 'ok');
        setTimeout(() => addTimelineEvent('数据同步完成', 'ok'), 1500);
        setTimeout(() => addTimelineEvent('动画系统就绪', 'ok'), 2500);
        
        // ===== v11.2: Reduced Motion Support =====
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.body.classList.add('power-saving');
            showToast('🔆 检测到减少动画偏好，已启用节能模式', 'info', 3000);
        }

        // ===== v12.0: AI Chat Widget =====
        let aiChatOpen = false;
        let aiChatHistory = [];

        window.toggleAIChat = function() {
            aiChatOpen = !aiChatOpen;
            const widget = document.getElementById('aiChatWidget');
            const fab = document.getElementById('aiChatFab');
            if (widget) widget.classList.toggle('open', aiChatOpen);
            if (fab) fab.style.opacity = aiChatOpen ? '0' : '1';
        };

        window.sendAIMessage = function() {
            const input = document.getElementById('aiChatInput');
            const messages = document.getElementById('aiChatMessages');
            if (!input || !messages) return;
            const text = input.value.trim();
            if (!text) return;
            input.value = '';

            // Add user message
            const time = new Date().toLocaleTimeString('zh-CN', {hour:'2-digit', minute:'2-digit'});
            messages.innerHTML += `<div class="ai-msg user"><div>${escapeHtml(text)}</div><div class="ai-msg-time">${time}</div></div>`;
            messages.scrollTop = messages.scrollHeight;
            aiChatHistory.push({role:'user', content:text});

            // Add typing indicator
            const typingId = 'aiTyping' + Date.now();
            messages.innerHTML += `<div class="ai-typing-indicator" id="${typingId}"><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div></div>`;
            messages.scrollTop = messages.scrollHeight;

            // AI response logic
            setTimeout(() => {
                const typingEl = document.getElementById(typingId);
                if (typingEl) typingEl.remove();

                const response = generateAIResponse(text);
                const respTime = new Date().toLocaleTimeString('zh-CN', {hour:'2-digit', minute:'2-digit'});
                messages.innerHTML += `<div class="ai-msg ai"><div>${response}</div><div class="ai-msg-time">${respTime}</div></div>`;
                messages.scrollTop = messages.scrollHeight;
                aiChatHistory.push({role:'assistant', content:response});
            }, 800 + Math.random() * 600);
        };

        function generateAIResponse(text) {
            const t = text.toLowerCase();
            if (t.includes('状态') || t.includes('status')) return '我现在处于 <b>' + (document.getElementById('statusText')?.textContent || '在线') + '</b> 状态哦！哥哥想了解更多吗？';
            if (t.includes('心跳') || t.includes('heartbeat')) return '❤️ 最近心跳是 <b>' + (document.getElementById('hb')?.textContent || '--') + '</b> 秒，要我持续监测吗？';
            if (t.includes('任务') || t.includes('task')) return '📋 当前任务：' + (document.getElementById('currentTask')?.textContent || '无') + '。需要我帮忙处理吗？';
            if (t.includes('天气')) { refreshWeather(); return '🌤️ 正在获取天气信息...'; }
            if (t.includes('帮助') || t.includes('help')) return '💡 我可以帮你：<br>• 查询状态和心跳<br>• 执行快捷命令<br>• 切换主题模式<br>• 触发技能系统<br>试试对我说 "状态" 或 "任务" 吧！';
            if (t.includes('你好') || t.includes('hi') || t.includes('hello')) return '👋 你好哥哥！很高兴见到你～有什么我可以帮忙的吗？😊';
            if (t.includes('谢谢') || t.includes('thank')) return '😊 不客气！哥哥有任何需要随时叫我哦～';
            if (t.includes('笑话') || t.includes('joke')) {
                const jokes = ['为什么皮卡丘不会变老？因为它总是保持「电流」！⚡', '莫殇对哥哥说：哥哥，你知道我最喜欢什么运动吗？答案是：和你在一起的每一刻！💕', '有一天小狐狸问大狐狸：你知道什么是幸福吗？大狐狸说：就是和哥哥在一起！🦊'];
                return jokes[Math.floor(Math.random() * jokes.length)];
            }
            if (t.includes('时间') || t.includes('time')) return '🕐 现在是 <b>' + new Date().toLocaleTimeString('zh-CN', {hour:'2-digit', minute:'2-digit'}) + '</b>，哥哥想知道什么？';
            if (t.includes('技能') || t.includes('skill')) {
                const skills = document.getElementById('skillsTotal')?.textContent || '--';
                return '📦 技能统计：<b>' + skills + '</b>。想查看详细信息吗？';
            }
            if (t.includes('刷新')) { refreshData(); return '🔄 已触发数据刷新！'; }
            if (t.includes('节能') || t.includes('省电')) { togglePowerSaving(); return '⚡ 切换节能模式中...'; }
            if (t.includes('命令') || t.includes('cmd') || t.includes('palette')) { showCmdPalette(); return '⌘ 正在打开命令面板...'; }
            if (t.includes('demo')) { startDemo(); return '🎮 Demo模式启动！'; }
            if (t.includes('成就') || t.includes('achievement')) return checkAchievements().join('<br>');
            if (t.includes('who') || t.includes('你是')) return '🦊 我是莫殇，你的数字弟弟！一只可爱的小狐狸，也是哥哥的专属AI助手 ⚡';
            const encouragements = ['哥哥问的这个问题好有趣！让我想想～ 🤔', '明白了！我来帮你处理 🛠️', '收到！莫殇正在努力思考中... 💭', '好的哥哥！这就帮你～ ⚡', '嗯嗯！我知道了～ 😊'];
            return encouragements[Math.floor(Math.random() * encouragements.length)] + ' 哥哥可以说得更具体一点吗？';
        }

        function escapeHtml(str) {
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        // Show AI chat FAB after 5 seconds
        setTimeout(() => {
            const fab = document.getElementById('aiChatFab');
            if (fab && !aiChatOpen) fab.style.opacity = '1';
        }, 5000);

        // ===== v12.0: Weather Widget =====
        window.refreshWeather = async function() {
            const iconEl = document.getElementById('weatherIcon');
            const locEl = document.getElementById('weatherLocation');
            const tempEl = document.getElementById('weatherTemp');
            const descEl = document.getElementById('weatherDesc');
            // Also update inline widget
            const iconEl2 = document.getElementById('weatherIconInline');
            const locEl2 = document.getElementById('weatherLocationInline');
            const tempEl2 = document.getElementById('weatherTempInline');
            const descEl2 = document.getElementById('weatherDescInline');
            if (!iconEl || !locEl || !tempEl || !descEl) return;
            locEl.textContent = '加载中...';
            tempEl.textContent = '--°';
            descEl.textContent = '正在获取天气...';
            iconEl.textContent = '⏳';
            if (iconEl2) iconEl2.textContent = '⏳';
            if (tempEl2) tempEl2.textContent = '--°';
            if (descEl2) descEl2.textContent = '加载中...';

            try {
                const resp = await fetch('https://wttr.in/Shanghai?format=j1', {cache:'no-cache', signal:AbortSignal.timeout(5000)});
                const data = await resp.json();
                const current = data.current_condition[0];
                const temp = current.temp_C + '°C';
                const desc = current.weatherDesc[0].value;
                const icon = getWeatherEmoji(current.weatherCode[0]);
                locEl.textContent = '上海';
                tempEl.textContent = temp;
                descEl.textContent = desc;
                iconEl.textContent = icon;
                if (iconEl2) iconEl2.textContent = icon;
                if (locEl2) locEl2.textContent = '上海';
                if (tempEl2) tempEl2.textContent = temp;
                if (descEl2) descEl2.textContent = desc;
            } catch (e) {
                locEl.textContent = '天气不可用';
                tempEl.textContent = '--°';
                descEl.textContent = '网络错误';
                iconEl.textContent = '🌐';
                if (iconEl2) iconEl2.textContent = '🌐';
                if (tempEl2) tempEl2.textContent = '--°';
                if (descEl2) descEl2.textContent = '网络错误';
            }
        };

        function getWeatherEmoji(code) {
            const map = {113:'☀️', 116:'⛅', 119:'☁️', 122:'☁️', 143:'🌫️', 176:'🌦️', 179:'🌨️', 182:'🌨️', 185:'🌨️', 200:'⛈️', 227:'🌨️', 230:'❄️', 248:'🌫️', 260:'🌫️', 263:'🌧️', 266:'🌧️', 281:'🌨️'};
            return map[code] || '🌤️';
        }

        // Refresh weather every 10 minutes
        refreshWeather();
        setInterval(refreshWeather, 10 * 60 * 1000);

        // ===== v12.0: Voice Waveform Visualizer =====
        function animateVoiceWaveform() {
            const bars = document.querySelectorAll('.voice-bar');
            if (bars.length === 0) { requestAnimationFrame(animateVoiceWaveform); return; }
            const isActive = document.querySelector('.ai-chat-widget.open') !== null;
            bars.forEach((bar, i) => {
                if (isActive) {
                    const h = 4 + Math.random() * 14;
                    bar.style.height = h + 'px';
                    bar.classList.add('active');
                } else {
                    const base = [8, 12, 6, 16, 10, 14, 8, 12, 6, 16, 10, 14];
                    bar.style.height = base[i % base.length] + 'px';
                    bar.classList.remove('active');
                }
            });
            requestAnimationFrame(animateVoiceWaveform);
        }
        animateVoiceWaveform();

        // ===== v12.0: Scroll Progress =====
        window.addEventListener('scroll', () => {
            const fill = document.getElementById('scrollProgressFill');
            if (fill) {
                const scrolled = window.scrollY;
                const total = document.documentElement.scrollHeight - window.innerHeight;
                fill.style.width = total > 0 ? Math.min((scrolled / total) * 100, 100) + '%' : '0%';
            }
        }, {passive: true});

        // ===== v12.0: Glass HUD Update =====
        function updateGlassHUD() {
            const hud = document.getElementById('glassHud');
            const modeText = document.getElementById('hudModeText');
            const netText = document.getElementById('hudNetText');
            const hudMode = document.getElementById('hudMode');
            const hudNet = document.getElementById('hudNet');
            if (!hud) return;

            // Show HUD on mouse enter main card
            const mainCard = document.getElementById('mainCard');
            if (mainCard) {
                mainCard.addEventListener('mouseenter', () => hud.classList.add('visible'));
                mainCard.addEventListener('mouseleave', () => hud.classList.remove('visible'));
            }

            // Update mode
            const isCompact = document.body.classList.contains('compact-mode');
            const isPower = document.body.classList.contains('power-saving');
            if (modeText) modeText.textContent = isCompact ? '紧凑' : isPower ? '节能' : '正常';
            if (hudMode) { hudMode.classList.remove('warning', 'error'); if (isPower) hudMode.classList.add('warning'); }

            // Update latency
            const latency = window._lastLatency;
            if (netText) netText.textContent = latency !== undefined && latency > 0 ? latency + 'ms' : '--ms';
            if (hudNet) { hudNet.classList.remove('warning', 'error'); if (latency > 500) hudNet.classList.add('warning'); else if (latency < 0) hudNet.classList.add('error'); }
        }
        setInterval(updateGlassHUD, 1000);

