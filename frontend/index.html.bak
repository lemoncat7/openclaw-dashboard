                        </div>
                        <svg class="mini-trend" id="activitySparkline" viewBox="0 0 48 20" preserveAspectRatio="none"></svg>
                    </div>

                    <div class="stat-card spring-hover v38-entrance v38-entrance-3" onclick="copyStat('memory')">
