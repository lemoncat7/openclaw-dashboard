            <!-- Footer -->
            <div class="dashboard-footer">
                <div class="data-route-map" id="dataRouteMap">
                    <div class="route-node" id="routeSrc">
                        <div class="route-dot"></div>
                        <span>Source</span>
                    </div>
                    <div class="route-line"></div>
                    <div class="route-node" id="routeGW">
                        <div class="route-dot"></div>
                        <span>Gateway</span>
                    </div>
